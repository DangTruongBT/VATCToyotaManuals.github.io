<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="35">
<name>SUSPENSION &amp; AXLE</name>
<section id="1000J_S000X" variety="S000X">
<name>TIRE AND WHEEL</name>
<ttl id="1000J_S000X_738JZ_T00GU" variety="T00GU">
<name>TIRE PRESSURE WARNING SYSTEM</name>
<para id="RM000000XNA009X" category="C" type-id="304OF" name-id="TW0JB-01" from="200601">
<dtccode>C2191/91</dtccode>
<dtcname>Vehicle Speed Signal Error (Test Mode DTC)</dtcname>
<subpara id="RM000000XNA009X_02" type-id="60" category="03" proc-id="RM0250U___00005I800001">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>The tire pressure warning ECU receives a speed signal from the combination meter. This DTC is stored upon entering test mode, and cleared when a vehicle speed signal of 12 mph (20 km/h) is detected for 3 seconds or more. This DTC is output only in test mode.</ptxt>
<table pgwide="1">
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.27in"/>
<colspec colname="COL2" colwidth="2.90in"/>
<colspec colname="COL3" colwidth="2.91in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>DTC No.</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>DTC Detecting Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Trouble Area</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>C2191/91</ptxt>
</entry>
<entry valign="middle">
<ptxt>Speed sensor circuit malfunction</ptxt>
</entry>
<entry valign="middle">
<list1 type="unordered">
<item>
<ptxt>Vehicle speed sensor</ptxt>
</item>
<item>
<ptxt>Tire pressure warning ECU</ptxt>
</item>
<item>
<ptxt>Combination meter</ptxt>
</item>
<item>
<ptxt>Wire harness or connector</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</content5>
</subpara>
<subpara id="RM000000XNA009X_03" type-id="32" category="03" proc-id="RM0250U___00005I900001">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="E115290E29" width="7.106578999in" height="3.779676365in"/>
</figure>
</content5>
</subpara>
<subpara id="RM000000XNA009X_04" type-id="51" category="05" proc-id="RM0250U___00005IA00001">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten3>
<list1 type="unordered">
<item>
<ptxt>When replacing the tire pressure warning ECU, read the IDs stored in the ECU using the intelligent tester and write them down before removal.</ptxt>
</item>
<item>
<ptxt>It is necessary to perform initialization (See page <xref label="Seep01" href="RM000000XMZ008X"/>) after registration (See page <xref label="Seep02" href="RM000000XN1008X"/>) of the transmitter IDs into the tire pressure warning ECU after the ECU have been replaced.</ptxt>
</item>
</list1>
</atten3>
</content5>
</subpara>
<subpara id="RM000000XNA009X_01" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000000XNA009X_01_0013" proc-id="RM0250U___0000B0000001">
<testtitle>READ VALUE ON INTELLIGENT TESTER</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Connect the intelligent tester to DLC3.</ptxt>
</test1>
<test1>
<ptxt>Turn the ignition switch on (IG), and turn the intelligent tester on.</ptxt>
</test1>
<test1>
<ptxt>Select the item below in the Data List, and read the value displayed on the intelligent tester.</ptxt>
<atten4>
<ptxt>Enter the following menus: DIAGNOSIS / OBD/MOBD / METER / DATA LIST.</ptxt>
</atten4>
</test1>
<spec>
<title>METER</title>
<table pgwide="1">
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="3.55in"/>
<colspec colname="COL2" colwidth="3.53in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Item</ptxt>
</entry>
<entry valign="middle">
<ptxt>Normal Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>VEHICLE SPD</ptxt>
</entry>
<entry valign="middle">
<ptxt>Almost same as actual vehicle speed</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<test1>
<ptxt>Check that the values indicated on the tester and on the combination meter are the same.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Vehicle speed indicated on the intelligent tester indicates the actual speed.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000XNA009X_01_0006" fin="false">OK</down>
<right ref="RM000000XNA009X_01_0009" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000XNA009X_01_0006" proc-id="RM0250U___00005I600001">
<testtitle>CHECK HARNESS AND CONNECTOR (ECU - COMBINATION METER)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the E60 ECU connector.</ptxt>
<figure>
<graphic graphicname="E129462E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</test1>
<test1>
<ptxt>Disconnect the F2 meter connector.</ptxt>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>E60-2 (SPD) - F2-12 (+S)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>E60-2 (SPD) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000XNA009X_01_0003" fin="true">OK</down>
<right ref="RM000000XNA009X_01_0004" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000XNA009X_01_0003">
<testtitle>REPLACE TIRE PRESSURE WARNING ECU</testtitle>
</testgrp>
<testgrp id="RM000000XNA009X_01_0004">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
<testgrp id="RM000000XNA009X_01_0009">
<testtitle>GO TO METER / GAUGE SYSTEM</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>