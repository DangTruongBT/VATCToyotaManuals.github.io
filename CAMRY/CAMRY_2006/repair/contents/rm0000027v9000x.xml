<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="38">
<name>HEATER &amp; AIR CONDITIONING SYSTEM</name>
<section id="1002K_S0015" variety="S0015">
<name>AIR CONDITIONING</name>
<ttl id="1002K_S0015_72YHP_T009Y" variety="T009Y">
<name>ROOM TEMPERATURE SENSOR</name>
<para id="RM0000027V9000X" category="A" type-id="80001" name-id="AC23H-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000027V9000X_01" type-id="01" category="01">
<s-1 id="RM0000027V9000X_01_0005" proc-id="RM0250U___000044M00000">
<ptxt>REMOVE FRONT DOOR SCUFF PLATE LH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 5 claws and 2 clips, and remove the rear door scuff plate LH.</ptxt>
<figure>
<graphic graphicname="B132068" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000027V9000X_01_0006" proc-id="RM0250U___000044L00000">
<ptxt>REMOVE COWL SIDE TRIM SUB-ASSEMBLY LH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the cowl side trim clip.</ptxt>
<figure>
<graphic graphicname="B132116E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disengage the 2 clips and remove the cowl side trim sub-assembly LH.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000027V9000X_01_0007" proc-id="RM0250U___000056300000">
<ptxt>REMOVE LOWER INSTRUMENT PANEL FINISH PANEL LH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt &lt;A&gt; and the screw &lt;B&gt;.</ptxt>
<figure>
<graphic graphicname="B133980E05" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the hood lock control cable assembly.</ptxt>
</s2>
<s2>
<ptxt>Disengage the claw and the 9 clips.</ptxt>
</s2>
<s2>
<ptxt>Remove the air hose, disconnect the connector, and then remove the lower instrument panel finish panel LH.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000027V9000X_01_0001" proc-id="RM0250U___00009E000000">
<ptxt>REMOVE ROOM TEMPERATURE SENSOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the connector and air hose.</ptxt>
<figure>
<graphic graphicname="E129986" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Release the claw and remove the sensor.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>