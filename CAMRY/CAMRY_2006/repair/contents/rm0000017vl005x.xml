<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10025_S001V" variety="S001V">
<name>2AZ-FE CHARGING</name>
<ttl id="10025_S001V_72ZCO_T00BW" variety="T00BW">
<name>GENERATOR</name>
<para id="RM0000017VL005X" category="A" type-id="8000E" name-id="CH0D0-01" from="200601">
<name>REASSEMBLY</name>
<subpara id="RM0000017VL005X_01" type-id="01" category="01">
<s-1 id="RM0000017VL005X_01_0004" proc-id="RM0250U___00006LN00000">
<ptxt>INSTALL GENERATOR DRIVE END FRAME BEARING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST and a press, press in a new generator drive end frame bearing.</ptxt>
<figure>
<graphic graphicname="A128619E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-60010</s-number>
<s-subnumber>09951-00250</s-subnumber>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07100</s-subnumber>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Fit the tabs on the retainer plate into the cutouts on the drive end frame to install the retainer plate.</ptxt>
<figure>
<graphic graphicname="A128620E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 4 screws.</ptxt>
<torque>
<torqueitem>
<t-value1>2.3</t-value1>
<t-value2>23</t-value2>
<t-value3>20</t-value3>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM0000017VL005X_01_0001" proc-id="RM0250U___00006KA00000">
<ptxt>INSTALL GENERATOR ROTOR ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Place the drive end frame on the clutch pulley.</ptxt>
</s2>
<s2>
<ptxt>Install the generator rotor onto the generator rectifier end frame.</ptxt>
<figure>
<graphic graphicname="A128615" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Place a new generator washer on the generator rotor.</ptxt>
<figure>
<graphic graphicname="A118365E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000017VL005X_01_0005" proc-id="RM0250U___00006NE00000">
<ptxt>INSTALL GENERATOR COIL ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST and a press, press in the generator coil assembly to the drive end frame.</ptxt>
<figure>
<graphic graphicname="A128621E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09612-70100</s-number>
<s-subnumber>09612-07240</s-subnumber>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Tighten the 4 bolts.</ptxt>
<figure>
<graphic graphicname="A128612" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.8</t-value1>
<t-value2>59</t-value2>
<t-value3>51</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Install the cord clip with the bolt.</ptxt>
<figure>
<graphic graphicname="A128613" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>4.6</t-value1>
<t-value2>47</t-value2>
<t-value3>41</t-value3>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM0000017VL005X_01_0002" proc-id="RM0250U___00006KB00000">
<ptxt>INSTALL GENERATOR BRUSH HOLDER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>While pushing the 2 brushes into the generator brush holder, insert a 1.0 mm (0.039 in.) pin into the generator brush holder.</ptxt>
<figure>
<graphic graphicname="A079315E04" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the generator brush holder with the 2 screws.</ptxt>
<figure>
<graphic graphicname="A128622" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>1.8 </t-value1>
<t-value2>18 </t-value2>
<t-value3>16 </t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Pull the pin out of the generator brush holder.</ptxt>
<figure>
<graphic graphicname="A130537E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000017VL005X_01_0006" proc-id="RM0250U___00006NF00000">
<ptxt>INSTALL GENERATOR TERMINAL INSULATOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the terminal insulator onto the generator rectifier end frame.</ptxt>
<figure>
<graphic graphicname="A128623" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000017VL005X_01_0007" proc-id="RM0250U___00006NG00000">
<ptxt>INSTALL GENERATOR REAR END COVER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the generator rear end cover with the 3 nuts.</ptxt>
<figure>
<graphic graphicname="A128610" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>4.6</t-value1>
<t-value2>47</t-value2>
<t-value3>41</t-value3>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM0000017VL005X_01_0003" proc-id="RM0250U___00006KC00000">
<ptxt>INSTALL GENERATOR CLUTCH PULLEY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Temporarily install the clutch pulley onto the rotor shaft.</ptxt>
</s2>
<s2>
<ptxt>Set SST (A) and (B).</ptxt>
<figure>
<graphic graphicname="A128084E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09820-63020</s-number>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Clamp SST (A) in a vise.</ptxt>
</s2>
<s2>
<ptxt>Place the rotor shaft end into SST (A).</ptxt>
<figure>
<graphic graphicname="A128605E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Fit SST (B) to the clutch pulley.</ptxt>
<figure>
<graphic graphicname="A128606E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Tighten the pulley by turning SST (B) in the direction shown in the illustration.</ptxt>
<figure>
<graphic graphicname="A135051E01" width="2.775699831in" height="2.775699831in"/>
</figure>
<torque>
<torqueitem>
<t-value1>111</t-value1>
<t-value2>1,125</t-value2>
<t-value4>81</t-value4>
</torqueitem>
</torque>
<atten3>
<ptxt>The torque shown above should be used for tightening without using the SST. When the SST is used for tightening, the torque should be calculated based on the length of the SST (See page <xref label="Seep01" href="RM000000UYX01KX"/>).</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Remove the generator assembly from the SST.</ptxt>
</s2>
<s2>
<ptxt>Check that the clutch pulley rotates smoothly.</ptxt>
</s2>
<s2>
<ptxt>Install a new clutch pulley cap to the clutch pulley.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>