<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="38">
<name>HEATER &amp; AIR CONDITIONING SYSTEM</name>
<section id="1002K_S0015" variety="S0015">
<name>AIR CONDITIONING</name>
<ttl id="1002K_S0015_72YHS_T00A1" variety="T00A1">
<name>AIR CONDITIONING AMPLIFIER</name>
<para id="RM0000026PU000X" category="A" type-id="80001" name-id="AC1ZG-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000026PU000X_01" type-id="01" category="01">
<s-1 id="RM0000026PU000X_01_0006" proc-id="RM0250U___000044R00000">
<ptxt>REMOVE FRONT DOOR SCUFF PLATE RH
</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedure for the RH side and the LH side.</ptxt>
</atten4>
</content1></s-1>
<s-1 id="RM0000026PU000X_01_0007" proc-id="RM0250U___000044S00000">
<ptxt>REMOVE COWL SIDE TRIM SUB-ASSEMBLY RH
</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedure for the RH side and the LH side.</ptxt>
</atten4>
</content1></s-1>
<s-1 id="RM0000026PU000X_01_0008" proc-id="RM0250U___00005C100000">
<ptxt>REMOVE INSTRUMENT PANEL NO. 2 UNDER COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 4 claws.</ptxt>
<figure>
<graphic graphicname="B133988E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Disengage the 2 guides and remove the No. 2 under cover sub-assembly.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000026PU000X_01_0009" proc-id="RM0250U___00005C200000">
<ptxt>REMOVE LOWER INSTRUMENT PANEL SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt &lt;A&gt;.</ptxt>
<figure>
<graphic graphicname="B133992E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 4 screws &lt;B&gt;.</ptxt>
</s2>
<s2>
<ptxt>Disengage the 3 claws and the 3 clips.</ptxt>
</s2>
<s2>
<ptxt>Disconnect the connector and remove the lower instrument panel sub-assembly.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000026PU000X_01_0001" proc-id="RM0250U___00005JI00000">
<ptxt>REMOVE AIR CONDITIONING AMPLIFIER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the connectors.</ptxt>
<figure>
<graphic graphicname="E128518E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts and air conditioning amplifier assembly.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>