<name>POWER WINDOW CONTROL SYSTEM</name>
<para id="RM0000026QP000X" category="J" type-id="3020Z" name-id="WS0SK-01" from="200601">
<dtccode/>
<dtcname>Power Window Master Switch Circuit</dtcname>
<subpara id="RM0000026QP000X_02" type-id="60" category="03" proc-id="RM0250U___00006ND00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>This circuit transmits signal from the power window regulator master switch assembly to the power window regulator switch.</ptxt>
</content5>
</subpara>
<subpara id="RM0000026QP000X_03" type-id="32" category="03" proc-id="RM0250U___00006JZ00000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="B140723E01" width="7.106578999in" height="7.795582503in"/>
</figure>
</content5>
</subpara>
<subpara id="RM0000026QP000X_04" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM0000026QP000X_01" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM0000026QP000X_01_0008" proc-id="RM0250U___0000BZB00000">
<testtitle>CHECK DTC OUTPUT</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Turn the ignition switch off.</ptxt>
</test1>
<test1>
<ptxt>Wait for at least 10 seconds, and then turn the ignition switch on (IG).</ptxt>
</test1>
<test1>
<ptxt>Check whether the DTC output recurs.</ptxt>
<spec>
<title>Result</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Display (DTC output)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>No output</ptxt>
</entry>
<entry valign="middle">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Output DTCs</ptxt>
</entry>
<entry valign="middle">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000026QP000X_01_0001" fin="false">A</down>
<right ref="RM0000026QP000X_01_0010" fin="true">B</right>
</res>
</testgrp>
<testgrp id="RM0000026QP000X_01_0001" proc-id="RM0250U___00005KZ00000">
