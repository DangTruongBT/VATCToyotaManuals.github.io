<s-1 id="RM000000YXC00FX_01_0003" proc-id="RM0250U___00000SF00000">
<ptxt>REMOVE FRONT OIL PUMP DRIVE GEAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the front oil pump drive gear.</ptxt>
<figure>
<graphic graphicname="D009206E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YXC00FX_01_0004" proc-id="RM0250U___00000SG00000">
<ptxt>REMOVE FRONT OIL PUMP DRIVEN GEAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the front oil pump driven gear.</ptxt>
<figure>
<graphic graphicname="D009206E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YXC00FX_01_0005" proc-id="RM0250U___00000SH00000">
<ptxt>REMOVE FRONT OIL PUMP BODY O-RING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a screwdriver, remove the O-ring.</ptxt>
<figure>
<graphic graphicname="D025586E03" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten4>
<ptxt>Tape the screwdriver tip before use.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YXC00FX_01_0006" proc-id="RM0250U___00000SI00000">
<ptxt>REMOVE FRONT OIL PUMP OIL SEAL</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Mount the oil pump in a soft jaw vise.</ptxt>
<figure>
<graphic graphicname="D003647E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using SST, remove the oil seal from the oil pump body.</ptxt>
<sst>
<sstitem>
<s-number>09308-00010</s-number>
</sstitem>
</sst>
</s2>
</content1>
</s-1>
</subpara>
</para>
