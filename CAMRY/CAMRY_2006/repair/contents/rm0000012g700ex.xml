<entry valign="middle" align="center">
<ptxt>Item</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Test Details</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Diagnostic Note</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>D-BELT REMIND</ptxt>
</entry>
<entry valign="middle">
<ptxt>D-SEAT BELT indicator light (OFF/ON)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Confirm that the vehicle is stopped with the engine idling</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>P-BELT REMIND</ptxt>
</entry>
<entry valign="middle">
