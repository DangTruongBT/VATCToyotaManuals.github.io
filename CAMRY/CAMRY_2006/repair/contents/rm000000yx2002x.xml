<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000S" variety="S000S">
<name>U250E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000S_72XP4_T007G" variety="T007G">
<name>SHIFT LEVER</name>
<para id="RM000000YX2002X" category="G" type-id="3001K" name-id="AX03X-02" from="200601">
<name>INSPECTION</name>
<subpara id="RM000000YX2002X_02" type-id="01" category="01">
<s-1 id="RM000000YX2002X_02_0003" proc-id="RM0250U___0000AGR00000">
<ptxt>INSPECT TRANSMISSION CONTROL SWITCH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Measure the resistance according to the value(s) in the table below when the shift lever is moved to each position.</ptxt>
<figure>
<graphic graphicname="G028380E11" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Shift Position</ptxt>
</entry>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>4 and 3</ptxt>
</entry>
<entry morerows="1" valign="middle">
<ptxt>1 - 2</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Except 4 and 3</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>L</ptxt>
</entry>
<entry morerows="1" valign="middle">
<ptxt>5 - 6</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Except L</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<ptxt>If the resistance value is not as specified, replace the transmission control switch.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
