<para id="RM000000YCC00AX" category="D" type-id="303F4" name-id="WS0GP-04" from="200601">
<name>DTC CHECK / CLEAR</name>
<subpara id="RM000000YCC00AX_z0" proc-id="RM0250U___0000BYE00000">
<content5 releasenbr="1">
<step1>
<ptxt>CHECK DTC</ptxt>
<step2>
<ptxt>Connect the intelligent tester to the DLC3.</ptxt>
</step2>
<step2>
<ptxt>Turn the ignition switch on (IG).</ptxt>
</step2>
<step2>
<ptxt>Check the DTC(s).</ptxt>
</step2>
</step1>
<step1>
<ptxt>CLEAR DTC</ptxt>
<figure>
<graphic graphicname="C131977E01" width="2.775699831in" height="2.775699831in"/>
</figure>
<step2>
<ptxt>Connect the intelligent tester to the DLC3.</ptxt>
</step2>
<step2>
<ptxt>Turn the ignition switch on (IG) .</ptxt>
</step2>
<step2>
<ptxt>Clear the DTCs.</ptxt>
</step2>
<step2>
<ptxt>Check that "DTCs are cleared" is displayed.</ptxt>
<atten3>
<ptxt>If any DTCs are output, troubleshoot those DTCs again.</ptxt>
</atten3>
</step2>
</step1>
</content5>
