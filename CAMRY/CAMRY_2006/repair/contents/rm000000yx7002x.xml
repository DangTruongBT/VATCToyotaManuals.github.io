<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000S" variety="S000S">
<name>U250E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000S_72XP3_T007F" variety="T007F">
<name>TRANSMISSION CONTROL CABLE ASSEMBLY</name>
<para id="RM000000YX7002X" category="A" type-id="80001" name-id="AX03S-02" from="200601">
<name>REMOVAL</name>
<subpara id="RM000000YX7002X_01" type-id="01" category="01">
<s-1 id="RM000000YX7002X_01_0003" proc-id="RM0250U___00001XS00000">
<ptxt>REMOVE AIR CONDITIONING UNIT</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>See page <xref label="Seep01" href="RM000001HLW001X"/>.</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM000000YX7002X_01_0016" proc-id="RM0250U___0000A7W00000">
<ptxt>REMOVE BATTERY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Loosen the bolt and nut, and remove the battery clamp.</ptxt>
<figure>
<graphic graphicname="A134906" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the battery and battery tray.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000YX7002X_01_0017" proc-id="RM0250U___0000A7U00000">
<ptxt>REMOVE AIR CLEANER INLET ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts, clamp and air cleaner inlet.</ptxt>
<figure>
<graphic graphicname="A134903" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000000YX7002X_01_0018" proc-id="RM0250U___0000B9500000">
<ptxt>REMOVE AIR CLEANER CAP SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the mass air flow meter connector (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A135666E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the purge VSV connector (<sup>*</sup>2).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the 2 purge VSV vacuum hoses (<sup>*</sup>3).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the purge line hose from the clamp (<sup>*</sup>4).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the No. 2 ventilation hose from the air cleaner hose.</ptxt>
<figure>
<graphic graphicname="A135667E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Lock the No. 1 air cleaner hose clamp, and then disconnect the No. 1 air cleaner hose from the throttle body.</ptxt>
<figure>
<graphic graphicname="A135668" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts and air cleaner cap.</ptxt>
<figure>
<graphic graphicname="A135669" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the air cleaner filter element from the air cleaner case.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000YX7002X_01_0013" proc-id="RM0250U___0000A7V00000">
<ptxt>REMOVE AIR CLEANER CASE SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the hose clamp.</ptxt>
<figure>
<graphic graphicname="A134905" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 3 bolts and air cleaner case.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000YX7002X_01_0007" proc-id="RM0250U___00001XV00000">
<ptxt>DISCONNECT NO. 2 SHIFT CABLE GROMMET RETAINER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the transmission control cable assembly from the transmission floor shift assembly while pushing the 2 claws of the floor shift cable.</ptxt>
<figure>
<graphic graphicname="C135015" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Turn back the carpet.</ptxt>
</s2>
<s2>
<ptxt>Remove the 2 bolts and disconnect the No. 2 shift cable grommet retainer.</ptxt>
<figure>
<graphic graphicname="C132234" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the No. 2 shift cable grommet retainer.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YX7002X_01_0008" proc-id="RM0250U___00001XW00000">
<ptxt>REMOVE TRANSMISSION CONTROL CABLE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the nut from the control shaft lever.</ptxt>
<figure>
<graphic graphicname="C135109" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the transmission control cable assembly from the control shaft lever.</ptxt>
</s2>
<s2>
<ptxt>Remove the clip and disconnect the transmission control cable assembly from the No. 1 control cable bracket.</ptxt>
<figure>
<graphic graphicname="C135705" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the transmission control cable assembly from the control cable clamp.</ptxt>
<figure>
<graphic graphicname="C090579" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Pull out the transmission control cable assembly from the body.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>