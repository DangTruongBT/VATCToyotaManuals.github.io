<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="36">
<name>BRAKE</name>
<section id="1000N_S0011" variety="S0011">
<name>BRAKE</name>
<ttl id="1000N_S0011_72V8Z_T003W" variety="T003W">
<name>BRAKE BOOSTER</name>
<para id="RM0000022JK000X" category="A" type-id="80001" name-id="BR0XM-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000022JK000X_01" type-id="01" category="01">
<s-1 id="RM0000022JK000X_01_0001" proc-id="RM0250U___000078L00000">
<ptxt>REMOVE BRAKE PEDAL RETURN SPRING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the brake pedal return spring.</ptxt>
<figure>
<graphic graphicname="C133454" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022JK000X_01_0017" proc-id="RM0250U___0000CZH00000">
<ptxt>SEPARATE BRAKE MASTER CYLINDER PUSH ROD CLEVIS</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the clip and the push rod pin, and separate the master cylinder push rod clevis.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022JK000X_01_0005" proc-id="RM0250U___00003WT00000">
<ptxt>DISCONNECT NO. 2 VACUUM HOSE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Slide the clip and disconnect the No. 2 vacuum hose.</ptxt>
<figure>
<graphic graphicname="C132715" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022JK000X_01_0018" proc-id="RM0250U___0000C1C00000">
<ptxt>REMOVE BRAKE MASTER CYLINDER SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Refer to the procedures up to "REMOVE MASTER CYLINDER". (See page <xref label="Seep01" href="RM0000022JG000X"/>)</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000022JK000X_01_0003" proc-id="RM0250U___00003CC00000">
<ptxt>REMOVE BRAKE BOOSTER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 4 nuts and the brake booster assembly.</ptxt>
<figure>
<graphic graphicname="C132719" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Do not damage the brake lines.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022JK000X_01_0009" proc-id="RM0250U___000071400000">
<ptxt>REMOVE BRAKE BOOSTER GASKET</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the brake booster gasket.</ptxt>
<figure>
<graphic graphicname="C132835E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022JK000X_01_0004" proc-id="RM0250U___00003CD00000">
<ptxt>REMOVE BRAKE MASTER CYLINDER PUSH ROD CLEVIS</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Loosen the lock nut and remove the brake master cylinder push rod clevis.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>