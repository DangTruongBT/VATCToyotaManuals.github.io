<graphic graphicname="A076787E11" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>Turn the ignition switch to the ON position.</ptxt>
</test1>
<test1>
<ptxt>Measure the voltage between the terminal of the A/F sensor connector and body ground.</ptxt>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.89in"/>
<colspec colname="COL2" colwidth="1.24in"/>
