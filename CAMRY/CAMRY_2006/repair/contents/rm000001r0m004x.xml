<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="1000D_S000C" variety="S000C">
<name>2AZ-FE LUBRICATION</name>
<ttl id="1000D_S000C_7303O_T00DE" variety="T00DE">
<name>OIL PUMP</name>
<para id="RM000001R0M004X" category="A" type-id="80001" name-id="LU0DZ-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM000001R0M004X_01" type-id="01" category="01">
<s-1 id="RM000001R0M004X_01_0055">
<ptxt>DISCONNECT CABLE FROM NEGATIVE BATTERY TERMINAL</ptxt>
</s-1>
<s-1 id="RM000001R0M004X_01_0056" proc-id="RM0250U___0000A7T00000">
<ptxt>REMOVE NO. 1 ENGINE COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 nuts and cover.</ptxt>
<figure>
<graphic graphicname="A134904" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0057">
<ptxt>REMOVE FRONT WHEEL RH</ptxt>
</s-1>
<s-1 id="RM000001R0M004X_01_0058">
<ptxt>REMOVE ENGINE UNDER COVER LH</ptxt>
</s-1>
<s-1 id="RM000001R0M004X_01_0059">
<ptxt>REMOVE ENGINE UNDER COVER RH</ptxt>
</s-1>
<s-1 id="RM000001R0M004X_01_0060">
<ptxt>REMOVE FRONT FENDER APRON SEAL RH</ptxt>
</s-1>
<s-1 id="RM000001R0M004X_01_0061" proc-id="RM0250U___00008M800000">
<ptxt>DRAIN ENGINE OIL
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the oil filler cap.</ptxt>
</s2>
<s2>
<ptxt>Remove the oil drain plug and drain the oil into a container.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0062" proc-id="RM0250U___0000CVB00000">
<ptxt>REMOVE FRONT EXHAUST PIPE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<ptxt>(See page <xref label="Seep01" href="RM000001XBN003X"/>)</ptxt>
</content1>
</s-1>
<s-1 id="RM000001R0M004X_01_0063" proc-id="RM0250U___0000A7X00000">
<ptxt>REMOVE NO. 2 ENGINE MOUNTING STAY RH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts and No. 2 mounting stay RH.</ptxt>
<figure>
<graphic graphicname="A134912" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0064" proc-id="RM0250U___00006ZV00000">
<ptxt>REMOVE ENGINE MOVING CONTROL ROD SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt and disconnect the ground cable.</ptxt>
<figure>
<graphic graphicname="A134909" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 3 bolts and the engine moving control rod with bracket.</ptxt>
<figure>
<graphic graphicname="A134910" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0065" proc-id="RM0250U___0000A7Y00000">
<ptxt>REMOVE NO. 2 ENGINE MOUNTING BRACKET RH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 3 bolts and No. 2 mounting bracket RH.</ptxt>
<figure>
<graphic graphicname="A134911" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0066" proc-id="RM0250U___00006VG00000">
<ptxt>REMOVE V-RIBBED BELT
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST and 19 mm socket wrench, loosen the V-ribbed belt tensioner arm clockwise, then remove the V-ribbed belt.</ptxt>
<figure>
<graphic graphicname="A114351E03" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09216-42010</s-number>
</sstitem>
</sst>
<atten3>
<list1 type="unordered">
<item>
<ptxt>Be sure to connect SST and the tools so that they are in line during use.</ptxt>
</item>
<item>
<ptxt>When retracting the tensioner, turn it clockwise slowly for 3 seconds or more. Do not apply force rapidly.</ptxt>
</item>
<item>
<ptxt>After the tensioner is fully retracted, do not apply force any more than necessary.</ptxt>
</item>
</list1>
</atten3>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0067" proc-id="RM0250U___000077900000">
<ptxt>REMOVE GENERATOR ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the generator connector.</ptxt>
<figure>
<graphic graphicname="A135170" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the nut and disconnect the wire harness from terminal B.</ptxt>
</s2>
<s2>
<ptxt>Remove the bolt and wire harness clamp bracket.</ptxt>
</s2>
<s2>
<ptxt>Remove the wire harness clamps.</ptxt>
</s2>
<s2>
<ptxt>Remove the 2 bolts and generator assembly.</ptxt>
<figure>
<graphic graphicname="A133567" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0068" proc-id="RM0250U___000070E00000">
<ptxt>REMOVE VANE PUMP ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the oil pressure switch connector.</ptxt>
<figure>
<graphic graphicname="A059879" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Loosen the 2 bolts and remove the vane pump from the engine.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0069" proc-id="RM0250U___0000AHI00000">
<ptxt>REMOVE IGNITION COIL ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 4 bolts and 4 ignition coils.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0070">
<ptxt>DISCONNECT VENTILATION HOSE</ptxt>
</s-1>
<s-1 id="RM000001R0M004X_01_0071">
<ptxt>DISCONNECT NO. 2 VENTILATION HOSE</ptxt>
</s-1>
<s-1 id="RM000001R0M004X_01_0072" proc-id="RM0250U___00006WK00000">
<ptxt>REMOVE CYLINDER HEAD COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts and disconnect the 2 engine wires.</ptxt>
<figure>
<graphic graphicname="A112210E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 8 bolts, 2 nuts, and the cylinder head cover.</ptxt>
<figure>
<graphic graphicname="A127550E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0073" proc-id="RM0250U___0000AMK00000">
<ptxt>SET NO. 1 CYLINDER TO TDC/COMPRESSION
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Turn the crankshaft pulley until its groove and the timing mark "0" of the timing chain cover are aligned.</ptxt>
<figure>
<graphic graphicname="A098345E09" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Check that each timing mark of the camshaft timing gear and sprocket is aligned with each timing mark located on the No. 1 and No. 2 bearing caps as shown in the illustration. If not, turn the crankshaft by 1 revolution (360°) to align the timing marks as above.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0074" proc-id="RM0250U___00006X400000">
<ptxt>REMOVE CRANKSHAFT PULLEY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>TMMK made:</ptxt>
<s3>
<ptxt>Using SST, fix the pulley in place and loosen the pulley bolt.</ptxt>
<figure>
<graphic graphicname="A062057E02" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09960-10010</s-number>
<s-subnumber>09962-01000</s-subnumber>
<s-subnumber>09963-01000</s-subnumber>
</sstitem>
</sst>
</s3>
<s3>
<ptxt>Using SST, remove the pulley bolt and pulley.</ptxt>
<figure>
<graphic graphicname="A062058E03" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-40011</s-number>
<s-subnumber>09951-04010</s-subnumber>
<s-subnumber>09952-04010</s-subnumber>
<s-subnumber>09953-04030</s-subnumber>
<s-subnumber>09955-04041</s-subnumber>
<s-subnumber>09957-04010</s-subnumber>
<s-subnumber>09954-04010</s-subnumber>
<s-subnumber>91111-51014</s-subnumber>
</sstitem>
</sst>
</s3>
</s2>
<s2>
<ptxt>TMC made:</ptxt>
<s3>
<ptxt>Using SST, fix the pulley in place and loosen the pulley bolt.</ptxt>
<figure>
<graphic graphicname="A013697E02" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09213-54015</s-number>
<s-subnumber>91651-60855</s-subnumber>
</sstitem>
<sstitem>
<s-number>09330-00021</s-number>
</sstitem>
</sst>
</s3>
<s3>
<ptxt>Using SST, remove the pulley bolt and pulley.</ptxt>
<figure>
<graphic graphicname="A124860E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-50013</s-number>
<s-subnumber>09951-05010</s-subnumber>
<s-subnumber>09952-05010</s-subnumber>
<s-subnumber>09953-05020</s-subnumber>
<s-subnumber>09954-05021</s-subnumber>
</sstitem>
<sstitem>
<s-number>09950-40011</s-number>
<s-subnumber>09957-04010</s-subnumber>
</sstitem>
</sst>
<atten4>
<ptxt>If necessary, remove the pulley and pulley bolt using SST.</ptxt>
</atten4>
</s3>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0075" proc-id="RM0250U___0000B4O00000">
<ptxt>REMOVE CRANK POSITION SENSOR
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the crankshaft position sensor connector.</ptxt>
<figure>
<graphic graphicname="A097797" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the connector clamp and wire harness clamp.</ptxt>
</s2>
<s2>
<ptxt>Remove the wire harness clamp bracket from the wire harness.</ptxt>
</s2>
<s2>
<ptxt>Remove the bolt, and then remove the crankshaft position sensor.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0076" proc-id="RM0250U___00006WM00000">
<ptxt>REMOVE OIL PAN SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 12 bolts and 2 nuts.</ptxt>
<figure>
<graphic graphicname="A114333" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Insert the blade of SST between the crankcase and oil pan. Cut through the sealer and remove the oil pan.</ptxt>
<figure>
<graphic graphicname="A000019E05" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09032-00100</s-number>
</sstitem>
</sst>
<atten3>
<ptxt>Be careful not to damage the contact surfaces of the crankcase, chain cover and oil pan.</ptxt>
</atten3>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0077" proc-id="RM0250U___00006WN00000">
<ptxt>REMOVE NO. 1 CHAIN TENSIONER ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 nuts, tensioner and gasket.</ptxt>
<figure>
<graphic graphicname="A098348E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Do not turn the crankshaft without the chain tensioner.</ptxt>
</atten3>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0078" proc-id="RM0250U___00006WP00000">
<ptxt>INSTALL ENGINE HANGERS
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the No. 1 engine hanger and No. 2 engine hanger with the bolts as shown in the illustration.</ptxt>
<figure>
<graphic graphicname="A052507E05" width="2.775699831in" height="1.771723296in"/>
</figure>
<ptxt>Parts No.:</ptxt>
<table>
<tgroup cols="2">
<colspec colname="COL1" align="center" colwidth="2.07in"/>
<colspec colname="COL2" align="center" colwidth="2.06in"/>
<tbody>
<row>
<entry>
<ptxt>No. 1 Engine hanger</ptxt>
</entry>
<entry>
<ptxt>12281-28010</ptxt>
</entry>
</row>
<row>
<entry>
<ptxt>No. 2 Engine hanger</ptxt>
</entry>
<entry>
<ptxt>12282-28010</ptxt>
</entry>
</row>
<row>
<entry>
<ptxt>Bolt</ptxt>
</entry>
<entry>
<ptxt>91512-61020</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<torque>
<torqueitem>
<t-value1>38</t-value1>
<t-value2>387</t-value2>
<t-value4>28</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Attach the sling device to the engine hangers and chain block.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0079" proc-id="RM0250U___00006WO00000">
<ptxt>REMOVE V-RIBBED BELT TENSIONER ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Lift the engine upward using the chain block.</ptxt>
<atten3>
<ptxt>Do not lift the engine more than necessary.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Remove the bolt, nut and V-ribbed belt tensioner.</ptxt>
<figure>
<graphic graphicname="A112212" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0080" proc-id="RM0250U___00006WQ00000">
<ptxt>REMOVE ENGINE MOUNTING INSULATOR
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Attach the engine chain hoist to the engine hangers.</ptxt>
<figure>
<graphic graphicname="A059880" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten2>
<ptxt>Do not attempt to hang the engine by hooking the chain to any other part.</ptxt>
</atten2>
</s2>
<s2>
<ptxt>Remove the bolt and disconnect the engine mounting insulator FR.</ptxt>
</s2>
<s2>
<ptxt>M/T:</ptxt>
<figure>
<graphic graphicname="A060825E02" width="2.775699831in" height="1.771723296in"/>
</figure>
<ptxt>Remove the bolt and disconnect the engine lateral control rod.</ptxt>
</s2>
<s2>
<ptxt>Remove the 2 bolts and disconnect the steering gear return tube clamps from the frame.</ptxt>
<figure>
<graphic graphicname="A138332" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 4 nuts from the engine mounting insulator RH.</ptxt>
<figure>
<graphic graphicname="A059900" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Raise the engine and remove the engine mounting insulator RH.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0081" proc-id="RM0250U___00006WR00000">
<ptxt>REMOVE ENGINE MOUNTING BRACKET RH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 3 bolts and engine mounting bracket.</ptxt>
<figure>
<graphic graphicname="A052481" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0023" proc-id="RM0250U___00008MQ00000">
<ptxt>REMOVE TIMING CHAIN COVER SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a E10 "torx" socket, remove the stud bolt for the drive belt tensioner from the cylinder block.</ptxt>
<figure>
<graphic graphicname="A128178" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 12 bolts and 2 nuts.</ptxt>
</s2>
<s2>
<ptxt>Remove the timing chain cover by prying between the timing chain cover and cylinder head or cylinder block with a screwdriver.</ptxt>
<figure>
<graphic graphicname="A128179" width="2.775699831in" height="3.779676365in"/>
</figure>
<atten3>
<ptxt>Be careful not to damage the contact surfaces of the timing chain cover, cylinder block and cylinder head.</ptxt>
</atten3>
<atten4>
<ptxt>Tape the screwdriver tip before use.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM000001R0M004X_01_0054" proc-id="RM0250U___0000BKA00000">
<ptxt>REMOVE TIMING CHAIN CASE OIL SEAL</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a screwdriver and a hammer, tap out the oil seal.</ptxt>
<figure>
<graphic graphicname="A128180" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten4>
<ptxt>Tape the screwdriver tip before use.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM000001R0M004X_01_0082" proc-id="RM0250U___0000AMR00000">
<ptxt>REMOVE NO. 1 CRANKSHAFT POSITION SENSOR PLATE
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the crankshaft position sensor plate.</ptxt>
<figure>
<graphic graphicname="A132571" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0083" proc-id="RM0250U___0000AMS00000">
<ptxt>REMOVE CHAIN TENSIONER SLIPPER
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt and chain tensioner slipper.</ptxt>
<figure>
<graphic graphicname="A125372" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0084" proc-id="RM0250U___0000AMT00000">
<ptxt>REMOVE NO. 1 CHAIN VIBRATION DAMPER
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts and chain vibration damper.</ptxt>
<figure>
<graphic graphicname="A125371" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0085" proc-id="RM0250U___0000AMU00000">
<ptxt>REMOVE TIMING CHAIN GUIDE
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt and timing chain guide.</ptxt>
<figure>
<graphic graphicname="A125373" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0086" proc-id="RM0250U___0000AMV00000">
<ptxt>REMOVE CHAIN SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the chain sub-assembly.</ptxt>
<figure>
<graphic graphicname="A128185" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0087" proc-id="RM0250U___0000AMW00000">
<ptxt>REMOVE CRANKSHAFT TIMING SPROCKET
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the crankshaft timing sprocket.</ptxt>
<figure>
<graphic graphicname="A125374" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0088" proc-id="RM0250U___00006WT00000">
<ptxt>REMOVE NO. 2 CHAIN SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Turn the crankshaft by 90° counterclockwise to align the adjusting hole of the oil pump drive shaft sprocket with the groove of the oil pump.</ptxt>
<figure>
<graphic graphicname="A098351E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Insert a 4 mm diameter bar into the adjusting hole of the oil pump drive shaft sprocket to lock the gear in position, and then remove the nut.</ptxt>
<figure>
<graphic graphicname="A098352E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the bolt, chain tensioner plate and spring.</ptxt>
<figure>
<graphic graphicname="B011415E03" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the chain tensioner, oil pump driven sprocket and chain.</ptxt>
<figure>
<graphic graphicname="A063847" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001R0M004X_01_0028" proc-id="RM0250U___00008MR00000">
<ptxt>REMOVE OIL PUMP ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 3 bolts, oil pump and gasket.</ptxt>
<figure>
