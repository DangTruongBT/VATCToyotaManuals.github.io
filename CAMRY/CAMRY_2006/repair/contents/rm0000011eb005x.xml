<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="35">
<name>SUSPENSION &amp; AXLE</name>
<section id="1002I_S000Z" variety="S000Z">
<name>SUSPENSION</name>
<ttl id="1002I_S000Z_72VBF_T005H" variety="T005H">
<name>REAR STABILIZER BAR</name>
<para id="RM0000011EB005X" category="A" type-id="80001" name-id="SP0ZV-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000011EB005X_02" type-id="11" category="10" proc-id="RM0250U___0000BC800000">
<content3 releasenbr="1">
<atten3>
<ptxt>Check if an old gasket still remains on the pipe. If so, remove it. Also, check if any bolts or nuts are rusted. If so, replace them.</ptxt>
</atten3>
</content3>
</subpara>
<subpara id="RM0000011EB005X_01" type-id="01" category="01">
<s-1 id="RM0000011EB005X_01_0001">
<ptxt>REMOVE REAR WHEELS</ptxt>
</s-1>
<s-1 id="RM0000011EB005X_01_0014" proc-id="RM0250U___0000AX200000">
<ptxt>REMOVE CENTER EXHAUST PIPE ASSEMBLY (for 2AZ-FE)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts, 2 nuts and center exhaust pipe assembly.</ptxt>
<figure>
<graphic graphicname="A135690E01" width="7.106578999in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the gasket from the front exhaust pipe.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000011EB005X_01_0015" proc-id="RM0250U___000095A00000">
<ptxt>REMOVE TAIL EXHAUST PIPE ASSEMBLY (for 2GR-FE)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 4 nuts and 2 exhaust tail pipes.</ptxt>
<figure>
<graphic graphicname="A135718" width="7.106578999in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 gaskets from the exhaust center pipe assembly.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000011EB005X_01_0016" proc-id="RM0250U___000095900000">
<ptxt>REMOVE CENTER EXHAUST PIPE ASSEMBLY (for 2GR-FE)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts, 2 nuts and exhaust center pipe assembly.</ptxt>
<figure>
<graphic graphicname="A135719" width="7.106578999in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the gasket from the exhaust pipe assembly.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000011EB005X_01_0002" proc-id="RM0250U___00000JC00000">
<ptxt>REMOVE REAR STABILIZER LINK ASSEMBLY LH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 nuts and rear stabilizer link assembly LH.</ptxt>
<figure>
<graphic graphicname="C132493" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten4>
<ptxt>If the ball joint turns together with the nut, use a hexagon wrench (5 mm) to hold the stud.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011EB005X_01_0003" proc-id="RM0250U___00000JD00000">
<ptxt>REMOVE REAR STABILIZER LINK ASSEMBLY RH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 nuts and rear stabilizer link assembly RH.</ptxt>
<figure>
<graphic graphicname="C138761" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten4>
<ptxt>If the ball joint turns together with the nut, use a hexagon wrench (5 mm) to hold the stud.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011EB005X_01_0004" proc-id="RM0250U___00000JF00000">
<ptxt>REMOVE REAR STABILIZER BAR NO. 2 BRACKET</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts and rear stabilizer bar No. 2 bracket.</ptxt>
<figure>
<graphic graphicname="C139014" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011EB005X_01_0012" proc-id="RM0250U___0000BE200000">
<ptxt>REMOVE REAR STABILIZER BAR NO. 1 BRACKET</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts and rear stabilizer bar No. 1 bracket.</ptxt>
<figure>
<graphic graphicname="C139015" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011EB005X_01_0006" proc-id="RM0250U___00000JG00000">
<ptxt>REMOVE REAR STABILIZER BUSHING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 rear stabilizer bushings from the rear stabilizer bar.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011EB005X_01_0013">
<ptxt>REMOVE REAR STABILIZER BAR</ptxt>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>