<name>STEERING</name>
<section id="1000U_S0013" variety="S0013">
<name>STEERING COLUMN</name>
<ttl id="1000U_S0013_72VA7_T004F" variety="T004F">
<name>STEERING SYSTEM</name>
<para id="RM000000WB7007X" category="G" type-id="8000T" name-id="SR012-08" from="200601">
<name>ON-VEHICLE INSPECTION</name>
<subpara id="RM000000WB7007X_01" type-id="01" category="01">
<s-1 id="RM000000WB7007X_01_0001" proc-id="RM0250U___00000BP00000">
<ptxt>INSPECT STEERING WHEEL FREE PLAY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Stop the vehicle and align the tires facing straight ahead.</ptxt>
</s2>
<s2>
<ptxt>Gently turn the steering wheel right and left by hand, and check the steering wheel free play.</ptxt>
<figure>
<graphic graphicname="C132537E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Maximum free play</title>
<specitem>
<ptxt>30 mm (1.18 in.)</ptxt>
</specitem>
</spec>
<atten4>
<ptxt>If the free play exceeds the maximum, check the steering column, steering intermediate shaft, steering sliding yoke, or steering gear.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
