<subpara id="RM0000012AF001X_01" type-id="01" category="01">
<s-1 id="RM0000012AF001X_01_0001" proc-id="RM0250U___00000LU00000">
<ptxt>INSPECT SKID CONTROL SENSOR (for BOSCH Made)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Inspect the skid control sensor. If any of the following occurs, replace the skid control sensor with a new one:</ptxt>
<list1 type="unordered">
<item>
<ptxt>The surface of the skid control sensor is cracked, dented, or chipped off.</ptxt>
</item>
<item>
<ptxt>The connector is scratched, cracked, or damaged.</ptxt>
</item>
<item>
<ptxt>The skid control sensor has been dropped.</ptxt>
</item>
</list1>
</s2>
<s2>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<figure>
<graphic graphicname="C113377E14" width="2.775699831in" height="2.775699831in"/>
</figure>
<spec>
<title>Standard resistance</title>
<subtitle>LH</subtitle>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.89in"/>
<colspec colname="COL2" colwidth="1.24in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>1 (RR+) - 2 (RR-)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 2.2 kΩ</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>1 (RR+) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>2 (RR-) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<subtitle>RH</subtitle>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.89in"/>
<colspec colname="COL2" colwidth="1.24in"/>
<thead>
