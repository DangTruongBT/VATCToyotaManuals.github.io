<ptxt>INSPECT AMBIENT TEMPERATURE SENSOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<figure>
<graphic graphicname="E118395E07" width="2.775699831in" height="5.787629434in"/>
</figure>
