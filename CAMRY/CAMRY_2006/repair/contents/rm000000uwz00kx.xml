<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="39">
<name>RESTRAINTS</name>
<section id="1000Y_S0016" variety="S0016">
<name>SUPPLEMENTAL RESTRAINT SYSTEM</name>
<ttl id="1000Y_S0016_72V8X_T003U" variety="T003U">
<name>FRONT AIRBAG SENSOR</name>
<para id="RM000000UWZ00KX" category="A" type-id="80001" name-id="RS1QG-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM000000UWZ00KX_02" type-id="11" category="10" proc-id="RM0250U___000007C00000">
<content3 releasenbr="1">
<atten4>
<list1 type="unordered">
<item>
<ptxt>Use the same procedures for the RH side and LH side.</ptxt>
</item>
<item>
<ptxt>The procedures listed below are for the LH side.</ptxt>
</item>
</list1>
</atten4>
</content3>
</subpara>
<subpara id="RM000000UWZ00KX_01" type-id="01" category="01">
<s-1 id="RM000000UWZ00KX_01_0011" proc-id="RM0250U___000007900000">
<ptxt>PRECAUTION</ptxt>
<content1 releasenbr="1">
<atten2>
<ptxt>Be sure to read "PRECAUTION" thoroughly before servicing (See page <xref label="Seep01" href="RM000000KT1010X"/>).</ptxt>
</atten2>
</content1>
</s-1>
<s-1 id="RM000000UWZ00KX_01_0001" proc-id="RM0250U___000007400000">
<ptxt>DISCONNECT CABLE FROM NEGATIVE BATTERY TERMINAL</ptxt>
<content1 releasenbr="1">
<atten2>
<ptxt>Wait for 90 seconds after disconnecting the cable to prevent airbag deployment.</ptxt>
</atten2>
</content1>
</s-1>
<s-1 id="RM000000UWZ00KX_01_0008">
<ptxt>REMOVE ENGINE UNDER COVER RH</ptxt>
</s-1>
<s-1 id="RM000000UWZ00KX_01_0012">
<ptxt>REMOVE ENGINE UNDER COVER LH</ptxt>
</s-1>
<s-1 id="RM000000UWZ00KX_01_0002" proc-id="RM0250U___000007500000">
<ptxt>REMOVE FRONT AIRBAG SENSOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt and front airbag sensor from the body.</ptxt>
<figure>
<graphic graphicname="C133886" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the connector from the front airbag sensor.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>