<name>MIRROR</name>
<ttl id="1002V_S001O_72XLQ_T0071" variety="T0071">
<name>OUTER REAR VIEW MIRROR</name>
<para id="RM000001PGP002X" category="A" type-id="30014" name-id="MI08Q-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000001PGP002X_01" type-id="01" category="01">
<s-1 id="RM000001PGP002X_01_0001" proc-id="RM0250U___00001PR00000">
<ptxt>INSTALL OUTER REAR VIEW MIRROR ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the claw to install the outer rear view mirror assembly.</ptxt>
<figure>
<graphic graphicname="B136838" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the outer rear view mirror assembly with the 3 nuts.</ptxt>
<torque>
<torqueitem>
<t-value1>5.5</t-value1>
<t-value2>56</t-value2>
<t-value3>49</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the connector.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001PGP002X_01_0023" proc-id="RM0250U___00003XX00000">
<ptxt>INSTALL FRONT DOOR LOWER FRAME BRACKET GARNISH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 2 clips and install the front door lower frame bracket garnish.</ptxt>
<figure>
<graphic graphicname="B132833" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
</subpara>
</para>
