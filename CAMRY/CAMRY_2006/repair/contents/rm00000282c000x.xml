<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000T" variety="S000T">
<name>U660E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000T_72VR9_T005Q" variety="T005Q">
<name>DIFFERENTIAL CASE</name>
<para id="RM00000282C000X" category="A" type-id="80002" name-id="AX13H-01" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM00000282C000X_01" type-id="01" category="01">
<s-1 id="RM00000282C000X_01_0001" proc-id="RM0250U___0000BCA00000">
<ptxt>REMOVE FRONT DIFFERENTIAL RING GEAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Put matchmarks on the front differential ring gear and differential case.</ptxt>
<figure>
<graphic graphicname="C138531E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 12 bolts.</ptxt>
<figure>
<graphic graphicname="C138532" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using a plastic hammer, tap on the front differential ring gear to remove it from the case.</ptxt>
<figure>
<graphic graphicname="C138533" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM00000282C000X_01_0005" proc-id="RM0250U___0000BCJ00000">
<ptxt>REMOVE FRONT DIFFERENTIAL CASE FRONT TAPERED ROLLER BEARING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST, remove the front differential case front tapered roller bearing from the differential case.</ptxt>
<figure>
<graphic graphicname="C138534E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-00020</s-number>
</sstitem>
<sstitem>
<s-number>09950-00030</s-number>
</sstitem>
<sstitem>
<s-number>09950-60010</s-number>
<s-subnumber>09951-00480</s-subnumber>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Using SST, remove the front differential case front tapered roller bearing outer race and shim from the transaxle housing.</ptxt>
<figure>
<graphic graphicname="C138537E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09308-00010</s-number>
</sstitem>
</sst>
</s2>
</content1>
</s-1>
<s-1 id="RM00000282C000X_01_0006" proc-id="RM0250U___0000BCL00000">
<ptxt>REMOVE FRONT DIFFERENTIAL CASE REAR TAPERED ROLLER BEARING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST, remove the front differential case rear tapered roller bearing from the differential case.</ptxt>
<figure>
<graphic graphicname="C138535E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-00020</s-number>
</sstitem>
<sstitem>
<s-number>09950-00030</s-number>
</sstitem>
<sstitem>
<s-number>09950-60010</s-number>
<s-subnumber>09951-00480</s-subnumber>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Using SST, remove the front differential case rear tapered roller bearing outer race from the transaxle case.</ptxt>
<figure>
<graphic graphicname="C138536E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09308-00010</s-number>
</sstitem>
</sst>
</s2>
</content1>
</s-1>
<s-1 id="RM00000282C000X_01_0007" proc-id="RM0250U___0000BCM00000">
<ptxt>REMOVE FRONT DIFFERENTIAL PINION SHAFT STRAIGHT PIN</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a pin punch (3 mm) and hammer, remove the straight pin.</ptxt>
<figure>
<graphic graphicname="C138710" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Before removing the straight pin, unstake it with a pin punch.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM00000282C000X_01_0002" proc-id="RM0250U___0000BCN00000">
<ptxt>REMOVE FRONT NO. 1 DIFFERENTIAL PINION SHAFT</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the front No. 1 differential pinion shaft from the differential case.</ptxt>
<figure>
<graphic graphicname="C138706" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM00000282C000X_01_0008" proc-id="RM0250U___0000BCO00000">
<ptxt>REMOVE DIFFERENTIAL SIDE GEAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 front differential pinions, 2 pinion thrust washers, 2 front differential side gears, and 2 side gear thrust washers from the differential case.</ptxt>
<figure>
<graphic graphicname="C138528" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM00000282C000X_01_0003" proc-id="RM0250U___0000BCP00000">
<ptxt>REMOVE FRONT TRANSAXLE CASE OIL SEAL</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST and a hammer, remove the front transaxle case oil seal from the transaxle housing.</ptxt>
<figure>
<graphic graphicname="C138708E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-60010</s-number>
<s-subnumber>09951-00540</s-subnumber>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07200</s-subnumber>
</sstitem>
</sst>
</s2>
</content1>
</s-1>
<s-1 id="RM00000282C000X_01_0004" proc-id="RM0250U___0000BCQ00000">
<ptxt>REMOVE TRANSAXLE CASE OIL SEAL</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST and a hammer, remove the transaxle case oil seal from transaxle case.</ptxt>
<figure>
<graphic graphicname="C138709E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-60010</s-number>
<s-subnumber>09951-00650</s-subnumber>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07100</s-subnumber>
</sstitem>
</sst>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>