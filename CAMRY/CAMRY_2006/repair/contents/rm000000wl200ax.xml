</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000WL200AX_05_0003" fin="false">OK</down>
<right ref="RM000000WL200AX_05_0004" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000WL200AX_05_0003" proc-id="RM0250U___00009FM00000">
