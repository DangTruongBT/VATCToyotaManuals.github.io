<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000T" variety="S000T">
<name>U660E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000T_72XRM_T007W" variety="T007W">
<name>TRANSMISSION CONTROL CABLE ASSEMBLY</name>
<para id="RM000000YX7003X" category="A" type-id="80001" name-id="AX03S-03" from="200601">
<name>REMOVAL</name>
<subpara id="RM000000YX7003X_01" type-id="01" category="01">
<s-1 id="RM000000YX7003X_01_0011" proc-id="RM0250U___0000CKG00000">
<ptxt>REMOVE AIR CONDITIONING UNIT</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>(See page <xref label="Seep01" href="RM000001HLW001X"/>)</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM000000YX7003X_01_0015" proc-id="RM0250U___000003M00000">
<ptxt>REMOVE CENTER AIRBAG SENSOR ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Turn back the carpet.</ptxt>
</s2>
<s2>
<ptxt>Disconnect the holder (with connectors).</ptxt>
<figure>
<graphic graphicname="C133884" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 3 bolts and center airbag sensor assembly.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000YX7003X_01_0016" proc-id="RM0250U___00009VS00000">
<ptxt>REMOVE COOL AIR INTAKE DUCT SEAL
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 7 clips and intake duct seal.</ptxt>
<figure>
<graphic graphicname="A132967" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000000YX7003X_01_0017" proc-id="RM0250U___00006SM00000">
<ptxt>REMOVE AIR CLEANER INLET ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts, clamp and air cleaner inlet.</ptxt>
<figure>
<graphic graphicname="A132969" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000000YX7003X_01_0018" proc-id="RM0250U___0000BRR00000">
<ptxt>REMOVE AIR CLEANER CAP SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the 3 vacuum hoses.</ptxt>
<figure>
<graphic graphicname="A135704" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the mass air flow meter connector (<sup>*</sup>1). </ptxt>
<figure>
<graphic graphicname="A135705E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the No. 2 ventilation hose (<sup>*</sup>2).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the hose band (<sup>*</sup>3).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the 3 bands, and remove the air cleaner cap sub-assembly.</ptxt>
<figure>
<graphic graphicname="A135706" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000000YX7003X_01_0019" proc-id="RM0250U___00006SN00000">
<ptxt>REMOVE AIR CLEANER CASE SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the vacuum hose and hose clamp.</ptxt>
<figure>
<graphic graphicname="A132971" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 3 bolts and air cleaner case.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000YX7003X_01_0020" proc-id="RM0250U___00006SO00000">
<ptxt>REMOVE NO. 1 AIR CLEANER INLET
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt and No. 1 air cleaner inlet.</ptxt>
<figure>
<graphic graphicname="A132970" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000000YX7003X_01_0007" proc-id="RM0250U___000028100000">
<ptxt>DISCONNECT NO. 2 SHIFT CABLE GROMMET RETAINER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Turn back the carpet.</ptxt>
<figure>
<graphic graphicname="C132234" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts and disconnect the No. 2 shift cable grommet retainer.</ptxt>
</s2>
<s2>
<ptxt>Remove the No. 2 shift cable grommet retainer.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YX7003X_01_0008" proc-id="RM0250U___000028200000">
<ptxt>REMOVE TRANSMISSION CONTROL CABLE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the end of the transmission control cable assembly from the shift lock control unit.  </ptxt>
<figure>
<graphic graphicname="C135015" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the transmission control cable assembly from the transmission floor shift assembly while pushing the 2 claws of the floor shift cable.</ptxt>
</s2>
<s2>
<ptxt>Remove the nut and transmission control cable from the control shaft lever.</ptxt>
<figure>
<graphic graphicname="C132236" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the clip and disconnect the transmission control cable assembly from the No. 1 control cable bracket.</ptxt>
<figure>
<graphic graphicname="C132237" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Pull out the transmission control cable assembly from the body.  </ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>