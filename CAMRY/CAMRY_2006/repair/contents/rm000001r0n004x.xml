<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="1000D_S000C" variety="S000C">
<name>2AZ-FE LUBRICATION</name>
<ttl id="1000D_S000C_7303O_T00DE" variety="T00DE">
<name>OIL PUMP</name>
<para id="RM000001R0N004X" category="A" type-id="80002" name-id="LU0A0-05" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM000001R0N004X_01" type-id="01" category="01">
<s-1 id="RM000001R0N004X_01_0001" proc-id="RM0250U___00008MS00000">
<ptxt>REMOVE OIL PUMP STRAINER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 nuts, oil pump strainer and gasket.</ptxt>
<figure>
<graphic graphicname="B011430E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001R0N004X_01_0002" proc-id="RM0250U___00008MT00000">
<ptxt>REMOVE OIL PUMP RELIEF VALVE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a 27 mm socket wrench, remove the plug.</ptxt>
<figure>
<graphic graphicname="A052074E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the valve spring and relief valve.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001R0N004X_01_0003" proc-id="RM0250U___00008MU00000">
<ptxt>REMOVE OIL PUMP COVER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 5 bolts and oil pump cover.</ptxt>
<figure>
<graphic graphicname="B011431E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the oil pump rotor. </ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>