<section id="1002Q_S001I" variety="S001I">
<name>NAVIGATION</name>
<ttl id="1002Q_S001I_72YIF_T00A4" variety="T00A4">
<name>NAVIGATION SYSTEM</name>
<para id="RM000001YZ0006X" category="C" type-id="801O4" name-id="NS0MB-05" from="200601">
<dtccode>63-78</dtccode>
<dtcname>DSP Error</dtcname>
<subpara id="RM000001YZ0006X_01" type-id="60" category="03" proc-id="RM0250U___000053A00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<table pgwide="1">
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.42in"/>
<colspec colname="COL2" colwidth="2.83in"/>
<colspec colname="COL3" colwidth="2.83in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>DTC No.</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>DTC Detection Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Trouble Area</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>63-78</ptxt>
</entry>
<entry valign="middle">
<ptxt>An error occurs during the decode process (MP3/WMA).</ptxt>
</entry>
<entry valign="middle">
<ptxt>-</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</content5>
</subpara>
<subpara id="RM000001YZ0006X_02" type-id="51" category="05" proc-id="RM0250U___000053B00000">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten4>
<ptxt>After the inspection completed, clear the DTCs.</ptxt>
</atten4>
<atten3>
<list1 type="unordered">
<item>
<ptxt>This code may be output even if there is no malfunction.</ptxt>
</item>
<item>
<ptxt>If this code is output frequently, replace the radio and navigation assembly.</ptxt>
</item>
</list1>
</atten3>
</content5>
</subpara>
<subpara id="RM000001YZ0006X_03" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000001YZ0006X_03_0001" proc-id="RM0250U___000053C00000">
<testtitle>CLEAR DTC</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Clear the DTCs (See page <xref label="Seep01" href="RM0000011BU00FX"/>).</ptxt>
<atten4>
<ptxt>These DTCs do not indicate a malfunction.</ptxt>
</atten4>
</test1>
</content6>
<res>
<down ref="RM000001YZ0006X_03_0002" fin="false">NEXT</down>
</res>
</testgrp>
<testgrp id="RM000001YZ0006X_03_0002" proc-id="RM0250U___000053D00000">
<testtitle>RECHECK DTC</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Recheck for DTCs and check if the same trouble occurs again.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Malfunction disappears.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000001YZ0006X_03_0003" fin="true">OK</down>
<right ref="RM000001YZ0006X_03_0004" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000001YZ0006X_03_0003">
<testtitle>END</testtitle>
</testgrp>
<testgrp id="RM000001YZ0006X_03_0004">
<testtitle>REPLACE RADIO AND NAVIGATION ASSEMBLY</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
