<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10006_S0004" variety="S0004">
<name>2AZ-FE ENGINE CONTROL SYSTEM</name>
<ttl id="10006_S0004_731VR_T00FY" variety="T00FY">
<name>CAMSHAFT POSITION SENSOR</name>
<para id="RM0000017V7005X" category="A" type-id="80001" name-id="ES49G-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000017V7005X_02" type-id="01" category="01">
<s-1 id="RM0000017V7005X_02_0004" proc-id="RM0250U___0000A7T00000">
<ptxt>REMOVE NO. 1 ENGINE COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 nuts and cover.</ptxt>
<figure>
<graphic graphicname="A134904" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000017V7005X_02_0005" proc-id="RM0250U___0000B9500000">
<ptxt>REMOVE AIR CLEANER CAP SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the mass air flow meter connector (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A135666E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the purge VSV connector (<sup>*</sup>2).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the 2 purge VSV vacuum hoses (<sup>*</sup>3).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the purge line hose from the clamp (<sup>*</sup>4).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the No. 2 ventilation hose from the air cleaner hose.</ptxt>
<figure>
<graphic graphicname="A135667E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Lock the No. 1 air cleaner hose clamp, and then disconnect the No. 1 air cleaner hose from the throttle body.</ptxt>
<figure>
<graphic graphicname="A135668" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts and air cleaner cap.</ptxt>
<figure>
<graphic graphicname="A135669" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the air cleaner filter element from the air cleaner case.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000017V7005X_02_0003" proc-id="RM0250U___0000B6I00000">
<ptxt>REMOVE CAMSHAFT POSITION SENSOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the camshaft position sensor connector.</ptxt>
<figure>
<graphic graphicname="A124557" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the bolt and camshaft position sensor.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>