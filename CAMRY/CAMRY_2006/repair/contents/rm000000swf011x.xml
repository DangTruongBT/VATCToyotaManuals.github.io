<ptxt>Frequency of Operation</ptxt>
</entry>
<entry valign="middle">
<ptxt>Once per driving cycle</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Duration</ptxt>
</entry>
<entry valign="middle">
<ptxt>Within 15 minutes</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>MIL Operation</ptxt>
</entry>
<entry valign="middle">
<ptxt>2 driving cycles</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
