</row>
<row>
<entry valign="middle">
<ptxt>Atmospheric pressure difference between sequence 1 and 8</ptxt>
</entry>
<entry valign="middle">
<ptxt>0.3 kPa (2.25 mmHg) or less</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
