<colspec colname="COL1" colwidth="3.54in"/>
<colspec colname="COL2" colwidth="3.54in"/>
<tbody>
<row>
<entry valign="middle">
<ptxt>Required Sensors/Components</ptxt>
</entry>
<entry valign="middle">
<ptxt>EVAP VSV and pump module</ptxt>
</entry>
</row>
