</entry>
<entry valign="middle">
<ptxt>-</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>EVAP pressure when vacuum introduction was complete</ptxt>
</entry>
<entry valign="middle">
<ptxt>Less than second reference pressure</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
