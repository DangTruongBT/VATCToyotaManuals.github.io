<res>
<down ref="RM000000ZRE00LX_04_0009" fin="false">NG</down>
<right ref="RM000000ZRE00LX_04_0005" fin="true">OK</right>
</res>
</testgrp>
<testgrp id="RM000000ZRE00LX_04_0009" proc-id="RM0250U___000080500000">
<testtitle>CHECK HARNESS AND CONNECTOR (STOP LIGHT SWITCH - BATTERY)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the A19 connector from the stop light switch.</ptxt>
<figure>
<graphic graphicname="E114084E08" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the voltage according to the value(s) in the table below.</ptxt>
</test1>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>A19-2 - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 to 14 V</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>A19-3 - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Ignition switch on (IG)</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 to 14 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</content6>
<res>
<down ref="RM000000ZRE00LX_04_0002" fin="false">OK</down>
<right ref="RM000000ZRE00LX_04_0007" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000ZRE00LX_04_0002" proc-id="RM0250U___000080300000">
<testtitle>INSPECT STOP LIGHT SWITCH</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Remove the stop light switch. (See page <xref label="Seep01" href="RM000001OC2001X"/>)</ptxt>
<figure>
<graphic graphicname="E128781E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Switch Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>1 - 2</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Switch pin not pushed</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>3 - 4</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Switch pin not pushed</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>1 - 2</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Switch pin pushed</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>3 - 4</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Switch pin pushed</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
<test1>
<ptxt>Install the stop light switch.</ptxt>
</test1>
</content6>
<res>
<down ref="RM000000ZRE00LX_04_0004" fin="false">OK</down>
<right ref="RM000000ZRE00LX_04_0006" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000ZRE00LX_04_0004" proc-id="RM0250U___000080400000">
