<atten4>
<ptxt>*1: 2GR-FE</ptxt>
<ptxt>*2: 2AZ-FE</ptxt>
</atten4>
</test1>
</content6>
<res>
<down ref="RM000000ZRE00LX_04_0005" fin="true">OK</down>
<right ref="RM000000ZRE00LX_04_0008" fin="true">NG</right>
