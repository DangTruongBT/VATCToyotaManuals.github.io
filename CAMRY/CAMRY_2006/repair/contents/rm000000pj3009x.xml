<subpara id="RM000000PJ3009X_z0" proc-id="RM0250U___000071800000">
<content5 releasenbr="2">
<step1>
<ptxt>EXPRESSIONS OF IGNITION SWITCH</ptxt>
<step2>
<ptxt>The type of ignition switch used on this model differs according to the specifications of the vehicle.</ptxt>
<ptxt>The expressions listed in the table below are used in this section.</ptxt>
<table pgwide="1">
<tgroup cols="4" align="center">
<colspec colname="COL1" colwidth="1.77in"/>
<colspec colname="COL2" colwidth="1.77in"/>
<colspec colname="COL3" colwidth="1.77in"/>
<colspec colname="COL4" colwidth="1.77in"/>
<thead>
<row>
<entry namest="COL1" nameend="COL2" valign="middle">
<ptxt>Switch Type</ptxt>
</entry>
<entry valign="middle">
<ptxt>Ignition Switch (position)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Engine Switch (condition)</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry morerows="3" valign="middle">
