<para id="RM000001T9V002X" category="J" type-id="30173" name-id="LI1RS-01" from="200601">
<dtccode/>
<dtcname>Interior Light Circuit</dtcname>
<subpara id="RM000001T9V002X_01" type-id="60" category="03" proc-id="RM0250U___0000AMI00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>The main body ECU controls the illuminated entry system (interior light and ignition key cylinder light).</ptxt>
</content5>
</subpara>
<subpara id="RM000001T9V002X_02" type-id="32" category="03" proc-id="RM0250U___00007V400000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="E121492E02" width="7.106578999in" height="6.791605969in"/>
</figure>
</content5>
</subpara>
<subpara id="RM000001T9V002X_03" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM000001T9V002X_05" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000001T9V002X_05_0013" proc-id="RM0250U___00007V600000">
<testtitle>PERFORM ACTIVE TEST BY INTELLIGENT TESTER</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Connect the intelligent tester to the DLC3.</ptxt>
</test1>
<test1>
<ptxt>Turn the ignition switch on (IG) and turn intelligent tester main switch on.</ptxt>
</test1>
<test1>
<ptxt>Select the item(s) below in the ACTIVE TEST, and check the operation.</ptxt>
<table pgwide="1">
<title>MAIN BODY (MAIN BODY ECU):</title>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.77in"/>
<colspec colname="COL2" colwidth="3.89in"/>
<colspec colname="COL3" colwidth="1.42in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Item</ptxt>
</entry>
<entry valign="middle">
<ptxt>Test Details</ptxt>
</entry>
<entry valign="middle">
<ptxt>Diagnostic Note</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>INTERIOR LAMP</ptxt>
</entry>
<entry valign="middle" align="left">
<ptxt>Interior light and ignition key cylinder light ON / OFF (Interior light switch in DOOR position and all doors are closed).</ptxt>
</entry>
<entry valign="middle">
<ptxt>-</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</test1>
<spec>
<title>OK</title>
<specitem>
<ptxt>Each light illuminates.</ptxt>
</specitem>
</spec>
</content6>
<res>
<down ref="RM000001T9V002X_05_0015" fin="false">NG</down>
<right ref="RM000001T9V002X_05_0020" fin="true">OK</right>
</res>
</testgrp>
<testgrp id="RM000001T9V002X_05_0015" proc-id="RM0250U___00007V800000">
<testtitle>CHECK VEHICLE CONDITION</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check the vehicle condition.</ptxt>
<spec>
<title>Result</title>
<table pgwide="1">
<tgroup cols="2">
<colspec colname="COL1" colwidth="3.55in"/>
<colspec colname="COL2" colwidth="3.53in"/>
<thead>
<row>
<entry align="center">
<ptxt>Condition</ptxt>
</entry>
<entry align="center">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>without Sliding Roof</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>with Sliding Roof</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000001T9V002X_05_0023" fin="false">A</down>
<right ref="RM000001T9V002X_05_0017" fin="false">B</right>
</res>
</testgrp>
