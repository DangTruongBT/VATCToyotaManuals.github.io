<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10007_S000G" variety="S000G">
<name>2GR-FE FUEL</name>
<ttl id="10007_S000G_7305V_T00DS" variety="T00DS">
<name>FUEL PUMP</name>
<para id="RM000001IRC001X" category="A" type-id="8000E" name-id="FU0SY-02" from="200601">
<name>REASSEMBLY</name>
<subpara id="RM000001IRC001X_01" type-id="01" category="01">
<s-1 id="RM000001IRC001X_01_0001" proc-id="RM0250U___00008U800000">
<ptxt>INSTALL FUEL PRESSURE REGULATOR ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply a light coat of spindle oil or gasoline to a new O-ring, and install it to the fuel pressure regulator.</ptxt>
<figure>
<graphic graphicname="A133534E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Push in the fuel pressure regulator to the fuel filter.</ptxt>
<figure>
<graphic graphicname="A065037" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IRC001X_01_0003" proc-id="RM0250U___00008UA00000">
<ptxt>INSTALL FUEL PUMP</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply a light coat of gasoline or grease to the O-ring of the fuel pump.</ptxt>
<figure>
<graphic graphicname="A079496E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Push in the fuel pump to the fuel filter.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IRC001X_01_0004" proc-id="RM0250U___00008UB00000">
<ptxt>INSTALL FUEL PUMP HARNESS</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Connect the connector (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A079495E05" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the fuel pump harness (<sup>*</sup>2).</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IRC001X_01_0005" proc-id="RM0250U___00008UC00000">
<ptxt>INSTALL FUEL SUCTION PLATE SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Connect the fuel pump connector (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A129485E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the fuel suction plate.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IRC001X_01_0006" proc-id="RM0250U___00008UD00000">
<ptxt>INSTALL FUEL SENDER GAUGE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Slide the fuel sender gauge to engage with the claw (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A136741E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the fuel sender gauge connector (<sup>*</sup>2).</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IRC001X_01_0007" proc-id="RM0250U___00008UE00000">
<ptxt>INSTALL FUEL PUMP CUSHION RUBBER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the fuel pump cushion rubber to the fuel pump.</ptxt>
<figure>
<graphic graphicname="A079492E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IRC001X_01_0008" proc-id="RM0250U___00008UF00000">
<ptxt>INSTALL NO. 2 FUEL SUCTION SUPPORT</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the No. 2 fuel suction support.</ptxt>
<figure>
<graphic graphicname="A129487" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>