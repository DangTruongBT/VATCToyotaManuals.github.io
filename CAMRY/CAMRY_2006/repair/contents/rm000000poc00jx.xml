<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1002Q_S001I" variety="S001I">
<name>NAVIGATION</name>
<ttl id="1002Q_S001I_72YIF_T00A4" variety="T00A4">
<name>NAVIGATION SYSTEM</name>
<para id="RM000000POC00JX" category="J" type-id="8001T" name-id="NS0W9-01" from="200601">
<dtccode/>
<dtcname>Vehicle Position Mark is not Updated</dtcname>
<subpara id="RM000000POC00JX_01" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM000000POC00JX_02" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000000POC00JX_02_0001" proc-id="RM0250U___00004YK00000">
<testtitle>CHECK MAP DISC</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check that the map disc is not deformed or cracked.</ptxt>
<figure>
<graphic graphicname="I100152E12" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>OK</title>
<specitem>
<ptxt>No deformations or cracks on map disc.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000POC00JX_02_0003" fin="false">OK</down>
<right ref="RM000000POC00JX_02_0002" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000POC00JX_02_0002">
<testtitle>REPLACE MAP DISC</testtitle>
</testgrp>
<testgrp id="RM000000POC00JX_02_0003" proc-id="RM0250U___00004YL00000">
<testtitle>CHECK NAVIGATION DISPLAY</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check if a touch scroll can be performed on the map display.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Touch scroll can be performed.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000POC00JX_02_0005" fin="false">OK</down>
<right ref="RM000000POC00JX_02_0004" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000POC00JX_02_0004">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM000000POC00JX_02_0005" proc-id="RM0250U___00004YM00000">
<testtitle>CHECK VEHICLE SENSOR (NAVIGATION CHECK MODE)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Enter the "Navigation Check" mode (Vehicle Sensors) (See page <xref label="Seep01" href="RM0000011BW00EX"/>).</ptxt>
<figure>
<graphic graphicname="E120089" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>While driving the vehicle, compare the "Speed" indicator to the reading on the speedometer. Check if these readings are almost equal.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The readings are almost equal.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000POC00JX_02_0007" fin="true">OK</down>
<right ref="RM000000POC00JX_02_0006" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000POC00JX_02_0006">
<testtitle>GO TO "SPEED SIGNAL DOES NOT CHANGE IN NAVIGATION CHECK MODE" IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM000000POC00JX_02_0007">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>