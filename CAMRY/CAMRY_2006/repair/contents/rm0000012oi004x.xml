<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10008_S0006" variety="S0006">
<name>2AZ-FE EMISSION CONTROL</name>
<ttl id="10008_S0006_731VZ_T00G6" variety="T00G6">
<name>AIR FUEL RATIO SENSOR</name>
<para id="RM0000012OI004X" category="A" type-id="80001" name-id="EC04F-04" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000012OI004X_01" type-id="01" category="01">
<s-1 id="RM0000012OI004X_01_0003" proc-id="RM0250U___0000BSQ00000">
<ptxt>REMOVE NO. 1 EXHAUST MANIFOLD HEAT INSULATOR (except PZEV)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 4 bolts and No. 1 exhaust manifold heat insulator.</ptxt>
<figure>
<graphic graphicname="A135682" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000012OI004X_01_0001" proc-id="RM0250U___0000B7Q00000">
<ptxt>REMOVE AIR FUEL RATIO SENSOR (except PZEV)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the air fuel ratio sensor connector and clamp.</ptxt>
<figure>
<graphic graphicname="A135681E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using SST, remove the air fuel ratio sensor from the exhaust manifold converter sub-assembly No. 2.</ptxt>
<figure>
<graphic graphicname="A135683E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09224-00010</s-number>
</sstitem>
</sst>
<atten3>
<ptxt>Do not damage the air fuel ratio sensor.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM0000012OI004X_01_0002" proc-id="RM0250U___0000B7R00000">
<ptxt>REMOVE AIR FUEL RATIO SENSOR (for PZEV)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the air fuel ratio sensor connector.</ptxt>
<figure>
<graphic graphicname="A135685E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using SST, remove the air fuel ratio sensor.</ptxt>
<figure>
<graphic graphicname="A135686E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09224-00010</s-number>
</sstitem>
</sst>
<atten3>
<ptxt>Do not damage the air fuel ratio sensor.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>