<entry valign="middle">
<ptxt>Driver door lock/unlock switch lock signal (key-linked lock switch)</ptxt>
<ptxt>/ON or OFF</ptxt>
</entry>
<entry valign="middle">
<ptxt>ON: Driver side door key cylinder is turned to LOCK</ptxt>
<ptxt>OFF: Driver side door key cylinder is not turned to LOCK</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>-</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>DOR KEY SW-ULCK</ptxt>
</entry>
<entry valign="middle">
<ptxt>Driver door lock/unlock switch unlock signal (key-linked unlock switch)</ptxt>
<ptxt>/ON or OFF</ptxt>
</entry>
<entry valign="middle">
<ptxt>ON: Driver side door key cylinder is turned to UNLOCK</ptxt>
<ptxt>OFF: Driver side door key cylinder is not turned to UNLOCK</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>-</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<spec>
<title>OK</title>
