<graphic graphicname="B065428E11" width="2.775699831in" height="3.779676365in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>7 - 9</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>ON (Door lock set to LOCK)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>7 - 9</ptxt>
<ptxt>7 - 10</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>OFF (Free)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>7 - 10</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>ON (Door lock set to UNLOCK)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM00000100800AX_04_0002" fin="false">OK</down>
<right ref="RM00000100800AX_04_0005" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM00000100800AX_04_0002" proc-id="RM0250U___00009GR00000">
