</entry>
</row>
<row>
<entry valign="middle">
<ptxt>SW2 - SWG</ptxt>
</entry>
<entry valign="middle">
<ptxt>ON HOOK switch: push (*1)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Approx. 0.3 kΩ</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>SW2 - SWG</ptxt>
