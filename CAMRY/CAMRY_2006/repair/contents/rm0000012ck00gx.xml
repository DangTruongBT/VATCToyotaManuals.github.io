</row>
<row>
<entry valign="middle">
<ptxt>SW1 - SWG</ptxt>
</entry>
<entry valign="middle">
<ptxt>SEEK- switch: push</ptxt>
</entry>
<entry valign="middle">
<ptxt>Approx. 0.3 kΩ</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>SW1 - SWG</ptxt>
</entry>
<entry valign="middle">
<ptxt>VOL+ switch: push</ptxt>
</entry>
<entry valign="middle">
<ptxt>Approx. 1 kΩ</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>SW1 - SWG</ptxt>
</entry>
<entry valign="middle">
<ptxt>VOL- switch: push</ptxt>
</entry>
<entry valign="middle">
<ptxt>Approx. 3.1 kΩ</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>SW2 - SWG</ptxt>
</entry>
<entry valign="middle">
