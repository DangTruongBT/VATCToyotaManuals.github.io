<ptxt>*1: for Premium model</ptxt>
</test1>
</content6>
<res>
<down ref="RM0000012CK00GX_04_0002" fin="true">OK</down>
<right ref="RM0000012CK00GX_04_0003" fin="false">NG</right>
</res>
</testgrp>
