<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="1000C_S000M" variety="S000M">
<name>2GR-FE COOLING</name>
<ttl id="1000C_S000M_72Z7O_T00BC" variety="T00BC">
<name>RADIATOR</name>
<para id="RM000001IQE001X" category="A" type-id="80002" name-id="CO0NC-03" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM000001IQE001X_01" type-id="01" category="01">
<s-1 id="RM000001IQE001X_01_0001" proc-id="RM0250U___000065U00000">
<ptxt>REMOVE DRAIN PLUG</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the drain plug.</ptxt>
</s2>
<s2>
<ptxt>Remove the O-ring.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IQE001X_01_0003" proc-id="RM0250U___000065W00000">
<ptxt>REMOVE RADIATOR TANK UPPER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the claw to the overhaul handle, inserting it in the hole in part A as shown in the illustration.</ptxt>
<figure>
<graphic graphicname="A104619E03" width="2.775699831in" height="3.779676365in"/>
</figure>
<sst>
<sstitem>
<s-number>09230-01010</s-number>
<s-subnumber>09231-01010</s-subnumber>
<s-subnumber>09231-01030</s-subnumber>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>While gripping the handle, adjust the stopper bolt so that dimension B is as shown in the illustration.</ptxt>
<spec>
<title>Dimension B</title>
<specitem>
<ptxt>0.2 to 0.3 mm (0.008 to 0.012 in.)</ptxt>
</specitem>
</spec>
<atten3>
<ptxt>If the stopper bolt is not adjusted, the claw may be damaged.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Using SST to release the caulking, grip the handle until stopped by the stopper bolt.</ptxt>
<figure>
<graphic graphicname="A128137E02" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09230-01010</s-number>
<s-subnumber>09231-01010</s-subnumber>
<s-subnumber>09231-01030</s-subnumber>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Lightly tap the bracket of the radiator (or radiator hose inlet or outlet) with a soft-faced hammer and remove the tank.</ptxt>
<figure>
<graphic graphicname="A128138E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the O-ring.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IQE001X_01_0006" proc-id="RM0250U___000077M00000">
<ptxt>REMOVE RADIATOR TANK LOWER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>with hose:</ptxt>
<figure>
<graphic graphicname="A134968E05" width="2.775699831in" height="1.771723296in"/>
</figure>
<s3>
<ptxt>Remove the bolt, 2 clips and hose from the radiator assembly.</ptxt>
</s3>
</s2>
<s2>
<ptxt>Removal procedure of the radiator tank lower is the same as that of the radiator tank upper. </ptxt>
</s2>
<s2>
<ptxt>without hose:</ptxt>
<figure>
<graphic graphicname="A128140E04" width="2.775699831in" height="1.771723296in"/>
</figure>
<s3>
<ptxt>Remove the screw and cooler pipe (A).</ptxt>
</s3>
<s3>
<ptxt>Remove the nut and plate washer (B).</ptxt>
</s3>
<s3>
<ptxt>Remove the oil cooler (C).</ptxt>
</s3>
<s3>
<ptxt>Remove the 2 O-rings from the oil cooler (D).</ptxt>
</s3>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>