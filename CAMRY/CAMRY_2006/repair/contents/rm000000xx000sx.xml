<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="1000C_S000M" variety="S000M">
<name>2GR-FE COOLING</name>
<ttl id="1000C_S000M_72Z7L_T00B9" variety="T00B9">
<name>COOLING FAN RELAY</name>
<para id="RM000000XX000SX" category="G" type-id="8000T" name-id="CO01B-10" from="200601">
<name>ON-VEHICLE INSPECTION</name>
<subpara id="RM000000XX000SX_01" type-id="01" category="01">
<s-1 id="RM000000XX000SX_01_0001" proc-id="RM0250U___000064C00000">
<ptxt>COOLING FAN RELAY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the relay from engine room relay block No. 1.</ptxt>
<figure>
<graphic graphicname="A035654" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Measure the resistance of the relay.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry>
<ptxt>Tester Connection</ptxt>
</entry>
<entry>
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>3 - 5</ptxt>
</entry>
<entry>
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry>
<ptxt>3 - 5</ptxt>
</entry>
<entry>
<ptxt>Below 1 Ω</ptxt>
<ptxt>(when battery voltage is applied to terminals 1 and 2)</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<ptxt>If the result is not as specified, replace the cooling fan relay.</ptxt>
</s2>
<s2>
<ptxt>Install the relay to engine room relay block No. 1.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>