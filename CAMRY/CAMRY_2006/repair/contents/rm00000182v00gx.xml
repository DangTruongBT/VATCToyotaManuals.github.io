<subpara id="RM00000182V00GX_02" type-id="51" category="05" proc-id="RM0250U___000052D00000">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten4>
<ptxt>After the inspection is completed, clear the DTCs.</ptxt>
</atten4>
</content5>
</subpara>
<subpara id="RM00000182V00GX_03" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM00000182V00GX_03_0001" proc-id="RM0250U___000052E00000">
<testtitle>CHECK VEHICLE SENSOR (NAVIGATION CHECK MODE)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Enter the "Navigation Check" mode (Vehicle Sensors) (See page <xref label="Seep01" href="RM0000011BW00EX"/>).</ptxt>
<figure>
<graphic graphicname="E120089" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>While driving the vehicle, compare the "SPD" indicator to the reading on the speedometer. Check if these readings are almost equal.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The readings are almost equal.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM00000182V00GX_03_0002" fin="false">NG</down>
<right ref="RM00000182V00GX_03_0004" fin="true">OK</right>
</res>
</testgrp>
<testgrp id="RM00000182V00GX_03_0002" proc-id="RM0250U___000052F00000">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
<content6 releasenbr="2">
<ptxt>Refer to "Speed signal does not change in the navigation check mode" in the problem symptoms table (See page <xref label="Seep01" href="RM0000011BR00CX"/>).</ptxt>
</content6>
<res>
<down ref="RM00000182V00GX_03_0003" fin="true">NEXT</down>
</res>
</testgrp>
<testgrp id="RM00000182V00GX_03_0003">
<testtitle>END</testtitle>
</testgrp>
<testgrp id="RM00000182V00GX_03_0004">
<testtitle>REPLACE RADIO AND NAVIGATION ASSEMBLY</testtitle>
</testgrp>
</subpara>
</para>
