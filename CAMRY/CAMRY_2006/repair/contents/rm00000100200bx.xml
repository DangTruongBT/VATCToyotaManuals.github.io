<servcat id="40">
<name>SECURITIES</name>
<section id="1002O_S0019" variety="S0019">
<name>ENGINE IMMOBILISER</name>
<ttl id="1002O_S0019_7301M_T00D1" variety="T00D1">
<name>ENGINE IMMOBILISER SYSTEM (w/ Smart Key System)</name>
<para id="RM00000100200BX" category="C" type-id="304MR" name-id="EI0EA-01" from="200601">
<dtccode>B2785</dtccode>
<dtcname>Communication Malfunction between ECUs Connected by LIN</dtcname>
<subpara id="RM00000100200BX_01" type-id="60" category="03" proc-id="RM0250U___00008DK00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>This DTC is output when LIN communication from the certification ECU stops for a certain amount of time.</ptxt>
<table pgwide="1">
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.42in"/>
<colspec colname="COL2" colwidth="2.83in"/>
<colspec colname="COL3" colwidth="2.83in"/>
<thead>
<row>
<entry align="center">
<ptxt>DTC No.</ptxt>
</entry>
<entry align="center">
<ptxt>DTC Detection Condition</ptxt>
</entry>
<entry align="center">
<ptxt>Trouble Area</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>B2785</ptxt>
</entry>
<entry valign="middle">
<list1 type="nonmark">
<item>
<ptxt>LIN communication from certification ECU stops for a certain amount of time</ptxt>
</item>
</list1>
<list1 type="unordered">
<item>
<ptxt>Open or short in wire harness between ECUs</ptxt>
</item>
</list1>
</entry>
<entry valign="middle">
<list1 type="unordered">
<item>
<ptxt>Wire harness</ptxt>
</item>
<item>
<ptxt>Certification ECU</ptxt>
</item>
<item>
<ptxt>Main body ECU</ptxt>
</item>
<item>
<ptxt>Steering lock ECU</ptxt>
</item>
<item>
<ptxt>ID code box</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</content5>
</subpara>
<subpara id="RM00000100200BX_02" type-id="32" category="03" proc-id="RM0250U___00008DL00000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="B128332E01" width="7.106578999in" height="4.7836529in"/>
</figure>
</content5>
</subpara>
<subpara id="RM00000100200BX_03" type-id="51" category="05" proc-id="RM0250U___00009VD00000">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="2">
<atten3>
<list1 type="unordered">
<item>
<ptxt>If the certification ECU or ID code box is replaced, register the key and ECU communication ID (See page <xref label="Seep01" href="RM000000QYF004X"/>).</ptxt>
</item>
</list1>
<list1 type="unordered">
<item>
<ptxt>If the steering lock ECU or main body ECU is replaced, register the ECU code and ECU communication ID (See page <xref label="Seep02" href="RM000000QYF004X"/>).</ptxt>
</item>
</list1>
</atten3>
</content5>
</subpara>
<subpara id="RM00000100200BX_04" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM00000100200BX_04_0001" proc-id="RM0250U___00008DM00000">
<testtitle>CHECK DTC OUTPUT</testtitle>
<content6 releasenbr="2">
<test1>
<ptxt>Delete the DTCs (See page <xref label="Seep01" href="RM000000QYC00BX"/>).</ptxt>
</test1>
<test1>
<ptxt>Recheck for DTCs (See page <xref label="Seep02" href="RM000000QYC00BX"/>).</ptxt>
<spec>
<title>Result</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Result</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>B2785 output reoccurs</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>B2785 output does not reoccur</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM00000100200BX_04_0002" fin="false">A</down>
<right ref="RM00000100200BX_04_0007" fin="true">B</right>
</res>
</testgrp>
<testgrp id="RM00000100200BX_04_0002" proc-id="RM0250U___00008DN00000">
<testtitle>CHECK HARNESS AND CONNECTOR (LIN COMMUNICATION LINE)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the E58, E51, IR and E50 ECU connectors.</ptxt>
<figure>
<graphic graphicname="B128348E01" width="7.106578999in" height="3.779676365in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>E58-10 (LIN) - E50-3 (LIN1)</ptxt>
</entry>
<entry morerows="2" valign="middle" align="center">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>E58-10 (LIN) - IR-9 (LIN1)</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>E58-10 (LIN) - E51-5 (LIN)</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>E58-10 (LIN) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM00000100200BX_04_0003" fin="false">OK</down>
<right ref="RM00000100200BX_04_0008" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM00000100200BX_04_0003" proc-id="RM0250U___00008DO00000">
<testtitle>CHECK CERTIFICATION ECU</testtitle>
<content6 releasenbr="2">
<test1>
<ptxt>After replacing the certification ECU with a normal one, check for DTCs (See page <xref label="Seep01" href="RM000000QYC00BX"/>).</ptxt>
<spec>
<title>Result</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Result</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>B2785 output reoccurs</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>B2785 output does not reoccur</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM00000100200BX_04_0004" fin="false">A</down>
<right ref="RM00000100200BX_04_0007" fin="true">B</right>
</res>
</testgrp>
<testgrp id="RM00000100200BX_04_0004" proc-id="RM0250U___00008DP00000">
<testtitle>CHECK MAIN BODY ECU</testtitle>
<content6 releasenbr="2">
<test1>
<ptxt>After replacing the main body ECU with a normal one, check for DTCs (See page <xref label="Seep01" href="RM000000QYC00BX"/>).</ptxt>
<spec>
<title>Result</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Result</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>B2785 output reoccurs</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>B2785 output does not reoccur</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM00000100200BX_04_0005" fin="false">A</down>
<right ref="RM00000100200BX_04_0007" fin="true">B</right>
</res>
</testgrp>
<testgrp id="RM00000100200BX_04_0005" proc-id="RM0250U___00008DQ00000">
<testtitle>CHECK STEERING LOCK ECU</testtitle>
<content6 releasenbr="2">
<test1>
<ptxt>After replacing the steering lock ECU with a normal one, check for DTCs (See page <xref label="Seep01" href="RM000000QYC00BX"/>).</ptxt>
<spec>
<title>Result</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Result</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>B2785 output reoccurs</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>B2785 output does not reoccur</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM00000100200BX_04_0006" fin="true">A</down>
<right ref="RM00000100200BX_04_0007" fin="true">B</right>
</res>
</testgrp>
<testgrp id="RM00000100200BX_04_0006">
<testtitle>REPLACE ID CODE BOX</testtitle>
</testgrp>
<testgrp id="RM00000100200BX_04_0007">
<testtitle>END</testtitle>
</testgrp>
<testgrp id="RM00000100200BX_04_0008">
