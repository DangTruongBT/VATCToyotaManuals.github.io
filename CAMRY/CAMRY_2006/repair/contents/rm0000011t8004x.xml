<dtccode/>
<dtcname>Door LOCK Position Circuit</dtcname>
<subpara id="RM0000011T8004X_01" type-id="60" category="03" proc-id="RM0250U___00004NR00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>The main body ECU receives each door lock position switch signal to control the illuminated entry system.</ptxt>
</content5>
</subpara>
<subpara id="RM0000011T8004X_02" type-id="32" category="03" proc-id="RM0250U___00004NS00000">
