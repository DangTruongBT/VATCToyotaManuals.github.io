<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1001A_S001B" variety="S001B">
<name>LIGHTING</name>
<ttl id="1001A_S001B_72Y3P_T008I" variety="T008I">
<name>GLOVE BOX LIGHT</name>
<para id="RM000001WIK002X" category="A" type-id="30014" name-id="LI23U-02" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000001WIK002X_01" type-id="01" category="01">
<s-1 id="RM000001WIK002X_01_0001" proc-id="RM0250U___00003FZ00000">
<ptxt>INSTALL GLOVE BOX LIGHT ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 2 claws and install the glove box light assembly.</ptxt>
<figure>
<graphic graphicname="E128205" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the connector.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001WIK002X_01_0013" proc-id="RM0250U___00007X800000">
<ptxt>INSTALL LOWER INSTRUMENT PANEL SUB-ASSEMBLY (for TMC Made)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Connect the connector.</ptxt>
</s2>
<s2>
<ptxt>Engage the 3 claws and 3 clips.</ptxt>
<figure>
<graphic graphicname="B133992E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 4 screws &lt;B&gt;.</ptxt>
</s2>
<s2>
<ptxt>Install the lower instrument panel sub-assembly with the bolt &lt;A&gt;.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001WIK002X_01_0014" proc-id="RM0250U___00007X900000">
<ptxt>INSTALL LOWER INSTRUMENT PANEL SUB-ASSEMBLY (for TMMK Made)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 3 claws and 3 clips.</ptxt>
<figure>
<graphic graphicname="B133992E02" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Install the screw &lt;O&gt; or &lt;P&gt; and 3 screws &lt;O&gt;.</ptxt>
</s2>
<s2>
<ptxt>Install the lower instrument panel sub-assembly with the bolt &lt;N&gt;.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001WIK002X_01_0015" proc-id="RM0250U___00007XA00000">
<ptxt>INSTALL INSTRUMENT PANEL NO. 2 UNDER COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 4 claws and 2 guides and install the instrument panel No. 2 under cover.</ptxt>
<figure>
<graphic graphicname="B133989E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001WIK002X_01_0016" proc-id="RM0250U___00006N000000">
<ptxt>INSTALL COWL SIDE TRIM SUB-ASSEMBLY RH
</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedure for the RH side and the LH side.</ptxt>
</atten4>
</content1></s-1>
<s-1 id="RM000001WIK002X_01_0017" proc-id="RM0250U___00006N100000">
<ptxt>INSTALL FRONT DOOR SCUFF PLATE RH
</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedure for the RH side and the LH side.</ptxt>
</atten4>
</content1></s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>