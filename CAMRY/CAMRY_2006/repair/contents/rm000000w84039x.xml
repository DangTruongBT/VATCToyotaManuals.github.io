<row>
<entry valign="middle">
<ptxt>R</ptxt>
</entry>
<entry morerows="1" valign="middle">
<ptxt>R (C56-15) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 to 14 V *</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
