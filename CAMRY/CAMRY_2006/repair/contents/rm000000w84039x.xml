<ptxt>Disconnect the park/neutral position switch connector.</ptxt>
<figure>
<graphic graphicname="A137047E06" width="2.775699831in" height="6.791605969in"/>
</figure>
</test1>
<test1>
<ptxt>Remove the ST relay from the engine room relay block.</ptxt>
</test1>
<test1>
<ptxt>Measure the resistance between the terminals.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.89in"/>
<colspec colname="COL2" colwidth="1.24in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>L (C1-9) - ST relay terminal 1</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
<test1>
<ptxt>Install the ST relay.</ptxt>
</test1>
<test1>
<ptxt>Reconnect the park/neutral position switch connector.</ptxt>
</test1>
</content6>
<res>
<down ref="RM000000W84039X_11_0025" fin="false">OK</down>
<right ref="RM000000W84039X_11_0021" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000W84039X_11_0025" proc-id="RM0250U___0000CYY00000">
