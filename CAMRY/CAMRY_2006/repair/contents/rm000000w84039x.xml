<figure>
<graphic graphicname="C117645E20" width="2.775699831in" height="2.775699831in"/>
</figure>
</test1>
<test1>
<ptxt>Turn the ignition switch on (IG).</ptxt>
</test1>
<test1>
<ptxt>Measure voltage according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="2">
<colspec colname="COL2" colwidth="2.89in"/>
<colspec colname="COL3" colwidth="1.24in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>RB (C1-1) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 to 14 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000W84039X_11_0024" fin="false">OK</down>
<right ref="RM000000W84039X_11_0031" fin="true">NG</right>
