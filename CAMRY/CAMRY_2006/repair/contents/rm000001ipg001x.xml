<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="1000C_S000M" variety="S000M">
<name>2GR-FE COOLING</name>
<ttl id="1000C_S000M_72Z7M_T00BA" variety="T00BA">
<name>WATER PUMP</name>
<para id="RM000001IPG001X" category="A" type-id="80001" name-id="CO0N3-02" from="200601">
<name>REMOVAL</name>
<subpara id="RM000001IPG001X_01" type-id="01" category="01">
<s-1 id="RM000001IPG001X_01_0017" proc-id="RM0250U___0000COI00000">
<ptxt>REMOVE ENGINE ASSEMBLY AND TRANSAXLE</ptxt>
<content1 releasenbr="2">
<atten4>
<ptxt>See page <xref label="Seep01" href="RM0000021ZT001X"/>
</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM000001IPG001X_01_0018" proc-id="RM0250U___0000COJ00000">
<ptxt>SECURE ENGINE STAND</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>See page <xref label="Seep01" href="RM0000021ZT001X_01_0055"/>
</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM000001IPG001X_01_0020" proc-id="RM0250U___00006TN00000">
<ptxt>REMOVE NO. 1 ENGINE MOUNTING BRACKET FRONT LH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 6 bolts and No. 1 engine mounting bracket front LH.</ptxt>
<figure>
<graphic graphicname="A129646" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001IPG001X_01_0013" proc-id="RM0250U___000064V00000">
<ptxt>REMOVE NO. 2 IDLER PULLEY SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts, 2 idler pulley cover plates and 2 idler pulley sub-assemblies.</ptxt>
<figure>
<graphic graphicname="A129645E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IPG001X_01_0016" proc-id="RM0250U___00008KW00000">
<ptxt>REMOVE V-RIBBED BELT TENSIONER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 5 bolts and V-ribbed belt tensioner assembly.</ptxt>
<figure>
<graphic graphicname="A135522" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IPG001X_01_0012" proc-id="RM0250U___000064U00000">
<ptxt>REMOVE WATER PUMP PULLEY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST, hold the water pump pulley.</ptxt>
<figure>
<graphic graphicname="A128112E03" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09960-10010</s-number>
<s-subnumber>09962-01000</s-subnumber>
<s-subnumber>09963-00700</s-subnumber>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Remove the 4 bolts and water pump pulley.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IPG001X_01_0010" proc-id="RM0250U___000064S00000">
<ptxt>REMOVE WATER INLET HOUSING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the water hose.</ptxt>
<figure>
<graphic graphicname="A133375E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts, nut and water inlet housing.</ptxt>
</s2>
<s2>
<ptxt>Remove the water inlet housing gasket and water outlet pipe O-ring.</ptxt>
<figure>
<graphic graphicname="A128120" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IPG001X_01_0015" proc-id="RM0250U___000064W00000">
<ptxt>REMOVE WATER PUMP ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 16 bolts, water pump assembly and water pump gasket.</ptxt>
<figure>
<graphic graphicname="A094889" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>