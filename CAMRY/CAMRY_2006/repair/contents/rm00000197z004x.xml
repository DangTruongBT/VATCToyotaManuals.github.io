<name>VANITY LIGHT</name>
<para id="RM00000197Z004X" category="G" type-id="3001K" name-id="LI0IN-05" from="200601">
<name>INSPECTION</name>
<subpara id="RM00000197Z004X_01" type-id="01" category="01">
<s-1 id="RM00000197Z004X_01_0001" proc-id="RM0250U___00004JF00000">
<ptxt>INSPECT VANITY LIGHT ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply battery voltage to the vanity light assembly connector.</ptxt>
<figure>
<graphic graphicname="E121462" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Check that the vanity light comes on.</ptxt>
<spec>
<title>OK</title>
<table>
<tgroup cols="2">
<colspec colname="COLSPEC1" colwidth="2.07in"/>
<colspec colname="COLSPEC0" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Measurement Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>Battery positive (+) → Terminal 1</ptxt>
<ptxt>Battery negative (-) → Terminal 2</ptxt>
</entry>
<entry valign="middle">
<ptxt>Vanity light comes on</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<ptxt>If the result is not as specified, replace the vanity light assembly.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
