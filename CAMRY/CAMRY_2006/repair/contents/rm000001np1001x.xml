<tmc-service-inc>
<pub id="RM0251U">
<servcat id="43">
<name>BODY</name>
<section id="1001H_S001L" variety="S001L">
<name>SEAT</name>
<ttl id="1001H_S001L_72ZF5_T00C4" variety="T00C4">
<name>REAR SEAT ASSEMBLY (for Reclining Seat Type)</name>
<para id="RM000001NP1001X" category="A" type-id="80001" name-id="SE0HJ-02" from="200601">
<name>REMOVAL</name>
<subpara id="RM000001NP1001X_01" type-id="01" category="01">
<s-1 id="RM000001NP1001X_01_0001" proc-id="RM0250U___00006NS00000">
<ptxt>REMOVE REAR SEAT CUSHION ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Detach the 2 front hooks of the seat cushion from the vehicle body.</ptxt>
<figure>
<graphic graphicname="B139074E01" width="2.775699831in" height="2.775699831in"/>
</figure>
<atten3>
<ptxt>Follow the instructions below carefully as the cushion frame can be deformed easily.</ptxt>
</atten3>
<s3>
<ptxt>Choose a hook to detach first. Place your hands near the hook as shown in the illustration. Then lift the seat cushion to detach the hook.</ptxt>
</s3>
<s3>
<ptxt>Repeat the step above for the other hook.</ptxt>
</s3>
</s2>
<s2>
<ptxt>Remove the seat cushion.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001NP1001X_01_0007">
<ptxt>REMOVE REAR SEAT HEADREST ASSEMBLY</ptxt>
</s-1>
<s-1 id="RM000001NP1001X_01_0008">
<ptxt>REMOVE REAR CENTER SEAT HEADREST ASSEMBLY</ptxt>
</s-1>
<s-1 id="RM000001NP1001X_01_0009" proc-id="RM0250U___00006PC00000">
<ptxt>REMOVE REAR SEAT BACK COVER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a screwdriver, detach the claws and remove the 2 rear seat back covers.</ptxt>
<figure>
<graphic graphicname="B139075" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<list1 type="unordered">
<item>
<ptxt>Tape the screwdriver tip before use.</ptxt>
</item>
<item>
<ptxt>Use the same procedures for the RH side and LH side.</ptxt>
</item>
</list1>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM000001NP1001X_01_0002" proc-id="RM0250U___00006NT00000">
<ptxt>REMOVE SEPARATE TYPE REAR SEAT BACK ASSEMBLY LH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Separate the 2 rear seat belts.</ptxt>
<figure>
<graphic graphicname="B139076E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disengage the 3 clamps and then separate the cover.</ptxt>
<figure>
<graphic graphicname="B139081E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts and 2 nuts and separate type rear seat back assembly LH.</ptxt>
<figure>
<graphic graphicname="B139077" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001NP1001X_01_0006" proc-id="RM0250U___00006NU00000">
<ptxt>REMOVE SEPARATE TYPE REAR SEAT BACK ASSEMBLY RH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Separate the rear seat belt.</ptxt>
<figure>
<graphic graphicname="B139078E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disengage the 3 clamps and then separate the cover.</ptxt>
<figure>
<graphic graphicname="B139082E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts and 2 nuts and separate type rear seat back assembly RH.</ptxt>
<figure>
<graphic graphicname="B139079" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001NP1001X_01_0010" proc-id="RM0250U___000070X00000">
<ptxt>REMOVE CENTER SEAT BACK ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts and center seat back assembly.</ptxt>
<figure>
<graphic graphicname="B139080" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
