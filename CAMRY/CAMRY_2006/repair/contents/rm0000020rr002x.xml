<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1002Q_S001I" variety="S001I">
<name>NAVIGATION</name>
<ttl id="1002Q_S001I_72YIF_T00A4" variety="T00A4">
<name>NAVIGATION SYSTEM</name>
<para id="RM0000020RR002X" category="J" type-id="302Y1" name-id="NS0NX-03" from="200601">
<dtccode/>
<dtcname>Black Screen</dtcname>
<subpara id="RM0000020RR002X_01" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM0000020RR002X_02" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM0000020RR002X_02_0001" proc-id="RM0250U___00004WC00000">
<testtitle>CHECK DISPLAY SETTING</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check that the display is not in "Screen OFF" mode.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The display setting is not in "Screen OFF" mode.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000020RR002X_02_0002" fin="false">OK</down>
<right ref="RM0000020RR002X_02_0005" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000020RR002X_02_0002" proc-id="RM0250U___00004WD00000">
<testtitle>CHECK IMAGE QUALITY SETTING</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check that the screen color quality can be set.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Setting is possible.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000020RR002X_02_0006" fin="true">OK</down>
<right ref="RM0000020RR002X_02_0003" fin="false">NG</right>
</res>
</testgrp>
<testgrp id="RM0000020RR002X_02_0003" proc-id="RM0250U___00004WE00000">
<testtitle>CHECK CABIN</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check that condensation is not likely to occur in the cabin, and that the temperature is not high or extremely low in the cabin.</ptxt>
<atten4>
<list1 type="unordered">
<item>
<ptxt>A humid cabin and a rapid change in temperature may lead to condensation. Condensation in the cabin may short circuit the screen.</ptxt>
</item>
<item>
<ptxt>The appropriate cabin temperature is 20 to 30°C (68 to 86°F).</ptxt>
</item>
</list1>
</atten4>
<spec>
<title>OK</title>
<specitem>
<ptxt>Condensation is not likely and temperature is not high or extremely low.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000020RR002X_02_0004" fin="true">OK</down>
<right ref="RM0000020RR002X_02_0007" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000020RR002X_02_0004">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM0000020RR002X_02_0005">
<testtitle>CHANGE SCREEN TO "SCREEN ON" MODE</testtitle>
</testgrp>
<testgrp id="RM0000020RR002X_02_0006">
<testtitle>PRESS PANEL SWITCH "DISPLAY" AND SET SCREEN COLOR QUALITY TO NORMAL</testtitle>
</testgrp>
<testgrp id="RM0000020RR002X_02_0007">
<testtitle>SET CABIN TO APPROPRIATE TEMPERATURE</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>