<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1001B_S001C" variety="S001C">
<name>WIPER AND WASHER</name>
<ttl id="1001B_S001C_72WDP_T0066" variety="T0066">
<name>FRONT WIPER MOTOR</name>
<para id="RM0000023QU000X" category="A" type-id="30014" name-id="WW0O5-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000023QU000X_01" type-id="01" category="01">
<s-1 id="RM0000023QU000X_01_0001" proc-id="RM0250U___000055G00000">
<ptxt>INSTALL WINDSHIELD WIPER MOTOR ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the windshield wiper motor assembly with the 3 bolts.</ptxt>
<figure>
<graphic graphicname="E128816" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.4</t-value1>
<t-value2>55</t-value2>
<t-value3>48</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Move the crank arm in the direction indicated by the arrow.</ptxt>
<figure>
<graphic graphicname="E128817" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Apply MP grease to the crank arm pivot of the windshield wiper motor assembly.</ptxt>
<figure>
<graphic graphicname="E128818E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the No. 2 windshield wiper link rod to the pivot of the windshield wiper motor assembly.</ptxt>
<figure>
<graphic graphicname="E128819E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000023QU000X_01_0002" proc-id="RM0250U___000055H00000">
<ptxt>INSTALL WINDSHIELD WIPER MOTOR AND LINK ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the windshield wiper motor and link assembly with the 4 bolts.</ptxt>
<figure>
<graphic graphicname="E128813E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>7.5</t-value1>
<t-value2>77</t-value2>
<t-value3>66</t-value3>
</torqueitem>
</torque>
<atten3>
<ptxt>Tighten the bolts in the order shown in the illustration.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Connect the connector.</ptxt>
<figure>
<graphic graphicname="E128812" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000023QU000X_01_0003" proc-id="RM0250U___000055I00000">
<ptxt>INSTALL COWL TOP VENTILATOR LOUVER SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 4 claws and install the cowl top ventilator louver sub-assembly.</ptxt>
<figure>
<graphic graphicname="E128811" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 2 clips.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000023QU000X_01_0004" proc-id="RM0250U___000055J00000">
<ptxt>INSTALL FRONT FENDER TO COWL SIDE SEAL RH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the claw and install the front fender to cowl side seal RH.</ptxt>
<figure>
<graphic graphicname="E128810" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000023QU000X_01_0005" proc-id="RM0250U___000055K00000">
<ptxt>INSTALL FRONT FENDER TO COWL SIDE SEAL LH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the claw and install the front fender to cowl side seal LH.</ptxt>
<figure>
<graphic graphicname="E128809" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000023QU000X_01_0006" proc-id="RM0250U___000055L00000">
<ptxt>INSTALL FRONT WIPER ARM AND BLADE ASSEMBLY LH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Operate the wiper and stop the windshield wiper motor at the automatic stop position.</ptxt>
</s2>
<s2>
<ptxt>Clean the wiper arm serrations.</ptxt>
<figure>
<graphic graphicname="E112237E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>When reinstalling:</ptxt>
<s3>
<ptxt>Clean the wiper pivot serrations with a wire brush.</ptxt>
</s3>
</s2>
<s2>
<ptxt>Install the front wiper arm and blade assembly LH with the nut to the position shown in the illustration.</ptxt>
<figure>
<graphic graphicname="E128820E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>20</t-value1>
<t-value2>204</t-value2>
<t-value4>15</t-value4>
</torqueitem>
</torque>
<atten4>
<ptxt>Hold the arm hinge by hand to fasten the nut.</ptxt>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry>
<ptxt>Area</ptxt>
</entry>
<entry>
<ptxt>Measurement</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>A</ptxt>
</entry>
<entry>
<ptxt>37 to 52 mm (1.46 to 2.05 in.)</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM0000023QU000X_01_0007" proc-id="RM0250U___000055M00000">
<ptxt>INSTALL FRONT WIPER ARM AND BLADE ASSEMBLY RH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Operate the wiper and stop the windshield wiper motor at the automatic stop position.</ptxt>
</s2>
<s2>
<ptxt>Clean the wiper arm serrations.</ptxt>
<figure>
<graphic graphicname="E112237E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>When reinstalling:</ptxt>
<s3>
<ptxt>Clean the wiper pivot serrations with a wire brush.</ptxt>
</s3>
</s2>
<s2>
<ptxt>Install the front wiper arm and blade assembly RH with the nut to the position shown in the illustration.</ptxt>
<figure>
<graphic graphicname="E128821E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>20</t-value1>
<t-value2>204</t-value2>
<t-value4>15</t-value4>
</torqueitem>
</torque>
<atten4>
<ptxt>Hold the arm hinge by hand to fasten the nut.</ptxt>
<table frame="all">
<tgroup cols="2" align="center">
<colspec colname="col1" colwidth="2.07in"/>
<colspec colname="col2" colwidth="2.06in"/>
<thead>
<row>
<entry>
<ptxt>Area</ptxt>
</entry>
<entry>
<ptxt>Measurement</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>A</ptxt>
</entry>
<entry>
<ptxt>23 to 38 mm (0.90 to 1.49 in.)</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</atten4>
</s2>
<s2>
<ptxt>Operate the front wipers while spraying washer fluid on the windshield glass. Make sure that the front wipers function properly and the wipers do not come into contact with the vehicle body.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>