<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="43">
<name>BODY</name>
<section id="1001H_S001L" variety="S001L">
<name>SEAT</name>
<ttl id="1001H_S001L_72ZF5_T00C4" variety="T00C4">
<name>REAR SEAT ASSEMBLY (for Reclining Seat Type)</name>
<para id="RM000001NOZ001X" category="A" type-id="30014" name-id="SE0HM-02" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000001NOZ001X_01" type-id="01" category="01">
<s-1 id="RM000001NOZ001X_01_0001" proc-id="RM0250U___00006P500000">
<ptxt>INSTALL CENTER SEAT BACK ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the center seat back assembly with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="B140592" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>18</t-value1>
<t-value2>184</t-value2>
<t-value4>13</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000001NOZ001X_01_0002" proc-id="RM0250U___00006P600000">
<ptxt>INSTALL SEPARATE TYPE REAR SEAT BACK ASSEMBLY RH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the separate type rear seat back assembly RH with the 2 bolts and 2 nuts.</ptxt>
<figure>
<graphic graphicname="B139079" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>18</t-value1>
<t-value2>184</t-value2>
<t-value4>13</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Engage the 3 clamps and install the cover.</ptxt>
<figure>
<graphic graphicname="B139082E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the rear seat belt.</ptxt>
<figure>
<graphic graphicname="B139078E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001NOZ001X_01_0003" proc-id="RM0250U___00006P700000">
<ptxt>INSTALL SEPARATE TYPE REAR SEAT BACK ASSEMBLY LH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the separate type rear seat back assembly LH with the 2bolts and 2 nuts.</ptxt>
<figure>
<graphic graphicname="B139077" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>18</t-value1>
<t-value2>184</t-value2>
<t-value4>13</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Engage the 3 clamps and install the cover.</ptxt>
<figure>
<graphic graphicname="B139081E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 2 rear seat belts.</ptxt>
<figure>
<graphic graphicname="B139076E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001NOZ001X_01_0004">
<ptxt>INSTALL REAR SEAT BACK COVER</ptxt>
</s-1>
<s-1 id="RM000001NOZ001X_01_0005">
<ptxt>INSTALL REAR CENTER SEAT HEADREST ASSEMBLY</ptxt>
</s-1>
<s-1 id="RM000001NOZ001X_01_0006">
<ptxt>INSTALL REAR SEAT HEADREST ASSEMBLY</ptxt>
</s-1>
<s-1 id="RM000001NOZ001X_01_0007" proc-id="RM0250U___0000A3W00000">
<ptxt>INSTALL REAR SEAT CUSHION ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Attach the front hooks of the bench type rear seat cushion assembly to the vehicle body.</ptxt>
<figure>
<graphic graphicname="B140591E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Confirm that the seat cushion is firmly installed.</ptxt>
<atten3>
<ptxt>When installing the bench type rear seat cushion assembly, make sure that the seat belt buckle is not under the bench type rear seat cushion assembly.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>