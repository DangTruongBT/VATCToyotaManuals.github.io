</entry>
</row>
</tbody>
</tgroup>
</table>
<table pgwide="1">
<title>P0456: EVAP small leak</title>
<tgroup cols="2">
<colspec colname="COL1" colwidth="3.54in"/>
<colspec colname="COL2" colwidth="3.54in"/>
<tbody>
<row>
<entry valign="middle">
<ptxt>EVAP pressure when vacuum introduction is complete</ptxt>
</entry>
<entry valign="middle">
<ptxt>Between reference pressure and reference pressure x 0.2</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</content5>
</subpara>
<subpara id="RM000000SWH00TX_06" type-id="68" category="03" proc-id="RM0250U___00002PF00000">
