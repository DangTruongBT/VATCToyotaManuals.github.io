</testgrp>
<testgrp id="RM000001IYS002X_09_0005" proc-id="RM0250U___00009TS00000">
<testtitle>INSPECT SHIFT SOLENOID VALVE SL (RESISTANCE)</testtitle>
<content6 releasenbr="1">
