</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>A26-27 (STP) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Stop light switch ON (Brake pedal depressed)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>8 to 14 V</ptxt>
