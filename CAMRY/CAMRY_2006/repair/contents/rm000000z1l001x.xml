<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002C_S000U" variety="S000U">
<name>E351 MANUAL TRANSAXLE</name>
<ttl id="1002C_S000U_73068_T00E3" variety="T00E3">
<name>FLOOR SHIFT LEVER ASSEMBLY</name>
<para id="RM000000Z1L001X" category="A" type-id="80001" name-id="MX0FQ-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM000000Z1L001X_02" type-id="01" category="01">
<s-1 id="RM000000Z1L001X_02_0013" proc-id="RM0250U___00005C500000">
<ptxt>REMOVE NO. 1 INSTRUMENT CLUSTER FINISH PANEL GARNISH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 2 clips and remove the No. 1 instrument cluster finish panel garnish.</ptxt>
<figure>
<graphic graphicname="B133993" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000000Z1L001X_02_0014" proc-id="RM0250U___00005C600000">
<ptxt>REMOVE NO. 2 INSTRUMENT CLUSTER FINISH PANEL GARNISH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 2 clips and remove the No. 2 instrument cluster finish panel garnish.</ptxt>
<figure>
<graphic graphicname="B133994" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000000Z1L001X_02_0015" proc-id="RM0250U___00005D300000">
<ptxt>REMOVE SHIFT LEVER KNOB SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Turn the shift lever knob counterclockwise and remove the shift lever knob sub-assembly.</ptxt>
<figure>
<graphic graphicname="B137272" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000000Z1L001X_02_0016" proc-id="RM0250U___00005D400000">
<ptxt>REMOVE UPPER CONSOLE PANEL
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Open the lid of the upper console panel.</ptxt>
<figure>
<graphic graphicname="B137274E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Apply protective tape to the area shown in the illustration.</ptxt>
</s2>
<s2>
<ptxt>Using a moulding remover, disengage the 2 claws and the 5 clips, and then remove the upper console panel as shown in the illustration.</ptxt>
<figure>
<graphic graphicname="B137275E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000000Z1L001X_02_0017" proc-id="RM0250U___00005D500000">
<ptxt>REMOVE UPPER CONSOLE REAR PANEL SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 3 claws and the 5 clips.</ptxt>
<figure>
<graphic graphicname="B137277" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the connector and remove the upper console rear panel sub-assembly.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000Z1L001X_02_0010" proc-id="RM0250U___00009SF00000">
<ptxt>DISCONNECT TRANSMISSION CONTROL CABLE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 clips and disconnect the end of the transmission control cable.</ptxt>
<figure>
<graphic graphicname="C132951" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Pull out the control cable assembly locks.</ptxt>
<figure>
<graphic graphicname="C135402E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Turn the adjust nut 180° clockwise. While holding the adjust nut, separate the control cable assembly.</ptxt>
<figure>
<graphic graphicname="C132953" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z1L001X_02_0007" proc-id="RM0250U___000090400000">
<ptxt>REMOVE FLOOR SHIFT LEVER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 4 bolts and shift lever assembly.</ptxt>
<figure>
<graphic graphicname="C132955" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>