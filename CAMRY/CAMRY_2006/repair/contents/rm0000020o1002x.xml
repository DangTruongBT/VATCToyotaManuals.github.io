<entry valign="middle">
<ptxt>Specified condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>C1-1 - C1-2</ptxt>
</entry>
<entry valign="middle">
<ptxt>Shift lever is moved to R.</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>C1-1 - C1-2</ptxt>
</entry>
<entry valign="middle">
<ptxt>Shift lever is moved to any position except R.</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000020O1002X_04_0004" fin="true">OK</down>
<right ref="RM0000020O1002X_04_0007" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000020O1002X_04_0004">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
<testgrp id="RM0000020O1002X_04_0005">
<testtitle>REPLACE RADIO AND NAVIGATION ASSEMBLY</testtitle>
</testgrp>
<testgrp id="RM0000020O1002X_04_0006">
