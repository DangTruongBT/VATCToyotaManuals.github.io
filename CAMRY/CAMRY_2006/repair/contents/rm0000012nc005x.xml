<subpara id="RM0000012NC005X_01" type-id="01" category="01">
<s-1 id="RM0000012NC005X_01_0001" proc-id="RM0250U___0000B4Z00000">
<ptxt>INSPECT THROTTLE BODY ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using an ohmmeter, measure the resistance between the terminals.</ptxt>
<figure>
<graphic graphicname="A090372" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Symbols (terminal No.)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Resistance</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Temperature</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>M+ (2) - M- (1)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>0.3 to 100 Ω</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>20°C (68°F)</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<ptxt>If the result is not as specified, replace the throttle body assembly.</ptxt>
</s2>
