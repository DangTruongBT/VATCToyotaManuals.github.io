<section id="1001I_S001E" variety="S001E">
<name>DOOR LOCK</name>
<ttl id="1001I_S001E_7307E_T00ER" variety="T00ER">
<name>POWER DOOR LOCK CONTROL SYSTEM</name>
<para id="RM000001HV4001X" category="J" type-id="8014U" name-id="DL191-01" from="200601">
<dtccode/>
<dtcname>Door Key Lock / Unlock Switch Circuit</dtcname>
<subpara id="RM000001HV4001X_05" type-id="60" category="03" proc-id="RM0250U___00009OW00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>The door lock and unlock switch is built into the door lock assembly.</ptxt>
<ptxt>This switch is ON when the door key is in the unlock position and OFF when the door key is in the lock position. It is used as one of the operating conditions for the key confinement prevention function.</ptxt>
</content5>
</subpara>
<subpara id="RM000001HV4001X_06" type-id="32" category="03" proc-id="RM0250U___00009OX00000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="B109774E05" width="7.106578999in" height="3.779676365in"/>
</figure>
</content5>
</subpara>
<subpara id="RM000001HV4001X_07" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM000001HV4001X_08" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000001HV4001X_08_0009" proc-id="RM0250U___00009OZ00000">
<testtitle>INSPECT FRONT DOOR LOCK ASSEMBLY RH (DOOR KEY LOCK AND UNLOCK SWITCH)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Remove the front door lock assembly RH.</ptxt>
<figure>
<graphic graphicname="B112613E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.24in"/>
<colspec colname="COL2" colwidth="1.65in"/>
<colspec colname="COL3" colwidth="1.24in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>5 - 8</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>ON</ptxt>
<ptxt>(Door lock set to UNLOCK)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>5 - 8</ptxt>
<ptxt>6 - 8</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>OFF (Free)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>6 - 8</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>ON</ptxt>
<ptxt>(Door lock set to LOCK)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000001HV4001X_08_0010" fin="false">OK</down>
<right ref="RM000001HV4001X_08_0012" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000001HV4001X_08_0010" proc-id="RM0250U___00009P000000">
