<graphic graphicname="C133231E01" width="2.775699831in" height="2.775699831in"/>
</figure>
<atten3>
<list1 type="unordered">
<item>
<ptxt>Before disconnecting the connector, make a note of where it is connected.</ptxt>
</item>
<item>
<ptxt>Reconnect the connector to its original position.</ptxt>
</item>
</list1>
</atten3>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.68in"/>
<colspec colname="COL2" colwidth="1.33in"/>
<colspec colname="COL3" colwidth="1.12in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Value</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>E43-1 (CANH) - E43-2 (CANL)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Ignition switch off</ptxt>
</entry>
<entry valign="middle">
<ptxt>108 to 132 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000WIM00GX_05_0027" fin="false">OK</down>
<right ref="RM000000WIM00GX_05_0009" fin="false">NG</right>
</res>
</testgrp>
