<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000T" variety="S000T">
<name>U660E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000T_7309I_T00EY" variety="T00EY">
<name>SHIFT SOLENOID VALVE</name>
<para id="RM00000282P000X" category="A" type-id="80002" name-id="AX13M-01" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM00000282P000X_01" type-id="01" category="01">
<s-1 id="RM00000282P000X_01_0010" proc-id="RM0250U___0000BPJ00000">
<ptxt>REMOVE TRANSMISSION WIRE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the connector from the transmission wire.</ptxt>
<figure>
<graphic graphicname="C138518" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the bolt and lock plate from the valve body assembly.</ptxt>
</s2>
<s2>
<ptxt>Disconnect the 8 connectors and remove the transmission wire from the valve body assembly.</ptxt>
<figure>
<graphic graphicname="C138519" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM00000282P000X_01_0011" proc-id="RM0250U___0000BPK00000">
<ptxt>REMOVE ATF TEMPERATURE SENSOR ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 4 bolts, ATF temperature sensor assembly and clamp from the valve body assembly.</ptxt>
<figure>
<graphic graphicname="C138522" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the O-ring from the ATF temperature sensor assembly. O-ring</ptxt>
<figure>
<graphic graphicname="C138520E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM00000282P000X_01_0001" proc-id="RM0250U___0000BN900000">
<ptxt>REMOVE SHIFT SOLENOID VALVE SL</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the shift solenoid valve SL from the valve body assembly.</ptxt>
<figure>
<graphic graphicname="C138523E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM00000282P000X_01_0002" proc-id="RM0250U___0000BNA00000">
<ptxt>REMOVE SHIFT SOLENOID VALVE SLT</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the lock plate and shift solenoid valve SLT from the valve body assembly </ptxt>
<figure>
<graphic graphicname="C138524E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM00000282P000X_01_0003" proc-id="RM0250U___0000BNB00000">
<ptxt>REMOVE SHIFT SOLENOID VALVE SLU</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the shift solenoid valve SLU from the valve body assembly.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM00000282P000X_01_0004" proc-id="RM0250U___0000BNC00000">
<ptxt>REMOVE SHIFT SOLENOID VALVE SL2</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt, lock plate and shift solenoid valve SL2 from the valve body assembly.</ptxt>
<figure>
<graphic graphicname="C138525E02" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM00000282P000X_01_0005" proc-id="RM0250U___0000BND00000">
<ptxt>REMOVE SHIFT SOLENOID VALVE SL1</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the shift solenoid valve SL1 from the valve body assembly.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM00000282P000X_01_0006" proc-id="RM0250U___0000BNE00000">
<ptxt>REMOVE SHIFT SOLENOID VALVE SL3</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt, lock plate and shift solenoid valve SL3 from the valve body assembly.</ptxt>
<figure>
<graphic graphicname="C138526E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM00000282P000X_01_0007" proc-id="RM0250U___0000BNF00000">
<ptxt>REMOVE SHIFT SOLENOID VALVE SL4</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt, lock plate and shift solenoid valve SL4 from the valve body assembly.</ptxt>
<figure>
<graphic graphicname="C138527E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
