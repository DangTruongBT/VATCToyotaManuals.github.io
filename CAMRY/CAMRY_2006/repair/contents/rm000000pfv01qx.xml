</entry>
<entry valign="middle">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000PFV01QX_09_0007" fin="true">A</down>
<right ref="RM000000PFV01QX_09_0006" fin="true">B</right>
</res>
