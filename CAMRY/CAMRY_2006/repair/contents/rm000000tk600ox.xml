<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10007_S0005" variety="S0005">
<name>2AZ-FE FUEL</name>
<ttl id="10007_S0005_7305Q_T00DN" variety="T00DN">
<name>FUEL PUMP</name>
<para id="RM000000TK600OX" category="A" type-id="8000E" name-id="FU0V9-01" from="200601">
<name>REASSEMBLY</name>
<subpara id="RM000000TK600OX_01" type-id="01" category="01">
<s-1 id="RM000000TK600OX_01_0010" proc-id="RM0250U___0000B2M00000">
<ptxt>INSTALL FUEL PRESSURE REGULATOR ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply a light coat of gasoline to 2 new O-rings, and install them to the fuel pressure regulator.</ptxt>
<figure>
<graphic graphicname="A096585E03" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the fuel pressure regulator to the fuel filter.</ptxt>
<figure>
<graphic graphicname="A136236E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000TK600OX_01_0008" proc-id="RM0250U___0000AXL00000">
<ptxt>INSTALL FUEL PUMP</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply gasoline to a new O-ring and install it to the fuel filter.</ptxt>
<figure>
<graphic graphicname="A131633E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the fuel pump harness connector.</ptxt>
<figure>
<graphic graphicname="A126130" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Engage the 5 claws on the fuel filter and install the fuel pump with the pump filter.</ptxt>
<figure>
<graphic graphicname="A136240" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000TK600OX_01_0011" proc-id="RM0250U___0000B2N00000">
<ptxt>CONNECT FUEL PUMP HARNESS</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Connect the fuel pump harness connector from the fuel suction plate.</ptxt>
<figure>
<graphic graphicname="A136231" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000TK600OX_01_0007" proc-id="RM0250U___0000AXK00000">
<ptxt>INSTALL FUEL NO. 1 SUCTION SUPPORT</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the fuel No. 1 suction support to the fuel filter.</ptxt>
<figure>
<graphic graphicname="A136233" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000TK600OX_01_0009" proc-id="RM0250U___0000AXM00000">
<ptxt>INSTALL FUEL NO. 1 TANK BAND BRACKET</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the spring to the fuel suction plate shaft and install it to the fuel No. 1 tank band bracket.</ptxt>
</s2>
<s2>
<ptxt>Engage the 4 claws of the fuel No. 1 suction support and install the fuel No. 1 tank band bracket to the fuel suction plate with the fuel filter.</ptxt>
</s2>
<s2>
<ptxt>Install a new E-ring.</ptxt>
<figure>
<graphic graphicname="A136234E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000TK600OX_01_0005" proc-id="RM0250U___0000AXJ00000">
<ptxt>INSTALL FUEL SENDER GAUGE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Slide the fuel sender gauge to fit the claw.</ptxt>
<figure>
<graphic graphicname="A136241" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the fuel sender gauge connector.</ptxt>
<figure>
<graphic graphicname="A136021" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>