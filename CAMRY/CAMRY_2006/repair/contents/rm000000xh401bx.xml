<ptxt>CH1: IGT1, IGT2, IGT3, IGT4 - E1</ptxt>
<ptxt>CH2: IGF1 - E1</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Equipment Settings</ptxt>
</entry>
<entry valign="middle" align="left">
<ptxt>2 V/Division</ptxt>
<ptxt>20 ms./Division</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
