<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1002Q_S001I" variety="S001I">
<name>NAVIGATION</name>
<ttl id="1002Q_S001I_72YIF_T00A4" variety="T00A4">
<name>NAVIGATION SYSTEM</name>
<para id="RM000000POE00JX" category="J" type-id="8001V" name-id="NS0W7-01" from="200601">
<dtccode/>
<dtcname>Vehicle Position Mark Deviates Greatly</dtcname>
<subpara id="RM000000POE00JX_01" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM000000POE00JX_02" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000000POE00JX_02_0001" proc-id="RM0250U___00004YO00000">
<testtitle>CHECK GPS MARK</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check that the GPS mark is displayed.</ptxt>
<figure>
<graphic graphicname="E125110E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>OK</title>
<specitem>
<ptxt>GPS mark is displayed.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000POE00JX_02_0003" fin="false">OK</down>
<right ref="RM000000POE00JX_02_0002" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000POE00JX_02_0002">
<testtitle>GO TO "GPS MARK IS NOT DISPLAYED" IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM000000POE00JX_02_0003" proc-id="RM0250U___00004YP00000">
<testtitle>CHECK VEHICLE SENSOR (NAVIGATION CHECK MODE)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Enter the "Navigation Check" mode (Vehicle Sensors) (See page <xref label="Seep01" href="RM0000011BW00EX"/>).</ptxt>
<figure>
<graphic graphicname="E120089" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>While driving the vehicle, compare the "Speed" indicator to the reading on the speedometer. Check that these readings are almost equal.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The readings are almost equal.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000POE00JX_02_0005" fin="false">OK</down>
<right ref="RM000000POE00JX_02_0004" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000POE00JX_02_0004">
<testtitle>GO TO "SPEED SIGNAL DOES NOT CHANGE IN NAVIGATION CHECK MODE" IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM000000POE00JX_02_0005" proc-id="RM0250U___00004YQ00000">
<testtitle>CHECK VEHICLE SENSOR (NAVIGATION CHECK MODE)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check that the display changes between ON and OFF according to the shift lever operation.</ptxt>
<figure>
<graphic graphicname="E120101E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>OK</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Shift Lever Position</ptxt>
</entry>
<entry align="center">
<ptxt>Display</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>Except Reverse</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>OFF</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>Reverse</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>ON</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<atten4>
<ptxt>The display is updated once per second. It is normal for the display to lag behind the actual switch operation.</ptxt>
</atten4>
</test1>
</content6>
<res>
<down ref="RM000000POE00JX_02_0007" fin="true">OK</down>
<right ref="RM000000POE00JX_02_0006" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000POE00JX_02_0006">
<testtitle>GO TO "REVERSE SIGNAL DOES NOT CHANGE IN NAVIGATION CHECK MODE" IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM000000POE00JX_02_0007">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>