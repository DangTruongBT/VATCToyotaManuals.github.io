<tmc-service-inc>
<pub id="RM0251U">
<servcat id="36">
<name>BRAKE</name>
<section id="1000O_S0012" variety="S0012">
<name>PARKING BRAKE</name>
<ttl id="1000O_S0012_72V96_T0043" variety="T0043">
<name>PARKING BRAKE PEDAL</name>
<para id="RM0000022KJ000X" category="A" type-id="80002" name-id="PB09O-01" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM0000022KJ000X_01" type-id="01" category="01">
<s-1 id="RM0000022KJ000X_01_0003" proc-id="RM0250U___00003PB00000">
<ptxt>REMOVE NO. 1 PARKING BRAKE CABLE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a screwdriver, pull up the parking brake pedal claw.</ptxt>
<figure>
<graphic graphicname="C132698" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the lock nut and the No. 1 wire adjusting nut.</ptxt>
<figure>
<graphic graphicname="C132697" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using needle nose pliers, remove the clip and the No. 1 parking brake cable from the parking brake pedal assembly.</ptxt>
<figure>
<graphic graphicname="C132696" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022KJ000X_01_0001" proc-id="RM0250U___00003C100000">
<ptxt>REMOVE PARKING BRAKE SWITCH ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the screw and the parking brake switch assembly.</ptxt>
<figure>
<graphic graphicname="C132700" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022KJ000X_01_0002" proc-id="RM0250U___00003C200000">
<ptxt>REMOVE PARKING PEDAL PAD</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the parking pedal pad.</ptxt>
<figure>
<graphic graphicname="C132702" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>