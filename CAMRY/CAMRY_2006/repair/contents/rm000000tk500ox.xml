<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10007_S0005" variety="S0005">
<name>2AZ-FE FUEL</name>
<ttl id="10007_S0005_7305Q_T00DN" variety="T00DN">
<name>FUEL PUMP</name>
<para id="RM000000TK500OX" category="A" type-id="80002" name-id="FU0V8-01" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM000000TK500OX_01" type-id="01" category="01">
<s-1 id="RM000000TK500OX_01_0001" proc-id="RM0250U___0000AXF00000">
<ptxt>REMOVE FUEL SENDER GAUGE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the fuel sender gauge connector.</ptxt>
<figure>
<graphic graphicname="A136021" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Unlock the fuel sender gauge, and slide it to remove.</ptxt>
<figure>
<graphic graphicname="A136022" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000TK500OX_01_0006" proc-id="RM0250U___0000AXH00000">
<ptxt>REMOVE FUEL NO. 1 TANK BAND BRACKET</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using needle nozzle pliers, remove the E-ring.</ptxt>
<figure>
<graphic graphicname="A136234E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disengage the 4 claws of the fuel No. 1 suction support and remove the fuel No. 1 tank band bracket from the fuel suction plate with the fuel filter.</ptxt>
<figure>
<graphic graphicname="A136232" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the spring from the fuel suction plate.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000000TK500OX_01_0007" proc-id="RM0250U___0000AXI00000">
<ptxt>REMOVE FUEL NO. 1 SUCTION SUPPORT</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a screwdriver with the tip taped, disengage the claw and remove the fuel No. 1 suction support.</ptxt>
<figure>
<graphic graphicname="A136233" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000TK500OX_01_0009" proc-id="RM0250U___0000B1X00000">
<ptxt>DISCONNECT FUEL PUMP HARNESS</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the fuel pump harness connector from the fuel suction plate. </ptxt>
<figure>
<graphic graphicname="A136231" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000TK500OX_01_0003" proc-id="RM0250U___0000AXG00000">
<ptxt>REMOVE FUEL PUMP</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a screwdriver with its tip wrapped in protective tape, disengage the 5 claws and pull out the fuel pump from the fuel filter assembly.</ptxt>
<figure>
<graphic graphicname="A136239E01" width="2.775699831in" height="2.775699831in"/>
</figure>
<atten3>
<list1 type="unordered">
<item>
<ptxt>Do not damage the fuel pump filter.</ptxt>
</item>
<item>
<ptxt>Do not remove the suction filter.</ptxt>
</item>
</list1>
</atten3>
</s2>
<s2>
<ptxt>Remove the fuel pump harness connector.</ptxt>
<figure>
<graphic graphicname="A136237" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the O-ring from the fuel pump.</ptxt>
<figure>
<graphic graphicname="A136238E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000TK500OX_01_0010" proc-id="RM0250U___0000B1Z00000">
<ptxt>REMOVE FUEL PRESSURE REGULATOR ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a screwdriver with its tip wrapped in protective tape, remove the fuel pressure regulator from the fuel filter.</ptxt>
<figure>
<graphic graphicname="A136235" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 O-rings from the fuel pressure regulator.</ptxt>
<figure>
<graphic graphicname="A096585E03" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>