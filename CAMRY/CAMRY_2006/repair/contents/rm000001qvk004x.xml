<subpara id="RM000001QVK004X_01" type-id="01" category="01">
<s-1 id="RM000001QVK004X_01_0001" proc-id="RM0250U___00008O000000">
<ptxt>INSTALL IGNITION COIL ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the 4 ignition coils with the 4 bolts.</ptxt>
<figure>
<graphic graphicname="A124400" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>9.0</t-value1>
<t-value2>92</t-value2>
<t-value3>80</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the 4 ignition coil connectors.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001QVK004X_01_0006" proc-id="RM0250U___0000AMD00000">
<ptxt>INSTALL NO. 1 ENGINE COVER
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the engine cover with the 2 nuts.</ptxt>
<figure>
<graphic graphicname="A134904" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>9.0</t-value1>
<t-value2>92</t-value2>
<t-value3>80</t-value3>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM000001QVK004X_01_0007" proc-id="RM0250U___0000ALW00000">
<ptxt>CONNECT CABLE TO NEGATIVE BATTERY TERMINAL
</ptxt>
<content1 releasenbr="1">
<torque>
<torqueitem>
<t-value1>6.9</t-value1>
<t-value2>70</t-value2>
<t-value3>61</t-value3>
</torqueitem>
</torque>
</content1></s-1>
