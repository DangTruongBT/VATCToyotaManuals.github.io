<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000T" variety="S000T">
<name>U660E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000T_72XRH_T007R" variety="T007R">
<name>SPEED SENSOR</name>
<para id="RM0000016E400EX" category="A" type-id="80001" name-id="AX08H-02" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000016E400EX_02" type-id="01" category="01">
<s-1 id="RM0000016E400EX_02_0007" proc-id="RM0250U___0000CLI00000">
<ptxt>REMOVE AUTOMATIC TRANSAXLE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>(See page <xref label="Seep01" href="RM0000016DV004X"/>)</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000016E400EX_02_0012" proc-id="RM0250U___0000C8T00000">
<ptxt>REMOVE AUTOMATIC TRANSAXLE OIL PAN SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 18 bolts and oil pan from the transaxle.</ptxt>
<figure>
<graphic graphicname="C134962" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Some fluid will remain in the oil pan. Remove all the pan bolts, and carefully remove the oil pan assembly.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Remove the gasket from the oil pan.</ptxt>
</s2>
<s2>
<ptxt>Remove the 2 magnets from the oil pan.</ptxt>
<figure>
<graphic graphicname="C134963E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Examine particles in the oil pan.</ptxt>
<figure>
<graphic graphicname="AT00103" width="2.775699831in" height="1.771723296in"/>
</figure>
<s3>
<ptxt>Collect any steel chips with the removed magnets. Look carefully at the chips and particles in the oil pan and on the magnets to see the type of wear which might be found in the transaxle.</ptxt>
<spec>
<title>Result</title>
<subtitle>Steel (magnetic)</subtitle>
<specitem>
<ptxt>Bearing, gear and plate wear</ptxt>
</specitem>
<subtitle>Brass (non-magnetic)</subtitle>
<specitem>
<ptxt>Bearing wear</ptxt>
</specitem>
</spec>
</s3>
</s2>
</content1></s-1>
<s-1 id="RM0000016E400EX_02_0013" proc-id="RM0250U___0000C8U00000">
<ptxt>REMOVE VALVE BODY OIL STRAINER ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts and oil strainer from the valve body.</ptxt>
<figure>
<graphic graphicname="C136687" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the O-ring from the oil strainer.</ptxt>
<figure>
<graphic graphicname="C136688E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000016E400EX_02_0014" proc-id="RM0250U___0000C8V00000">
<ptxt>REMOVE TRANSMISSION VALVE BODY ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 11 bolts and valve body from the transaxle.</ptxt>
<figure>
<graphic graphicname="C136689" width="2.775699831in" height="2.775699831in"/>
</figure>
<atten3>
<ptxt>When removing the transmission valve body assembly, be careful not to allow the transmission revolution sensor and the transaxle case to interfere with each other.</ptxt>
</atten3>
</s2>
</content1></s-1>
<s-1 id="RM0000016E400EX_02_0011" proc-id="RM0250U___0000C8P00000">
<ptxt>REMOVE SPEED SENSOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the connector.</ptxt>
</s2>
<s2>
<ptxt>Remove the 2 bolts and speed sensor from the valve body.</ptxt>
<figure>
<graphic graphicname="C138516" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>