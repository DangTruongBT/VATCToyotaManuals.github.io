<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="43">
<name>BODY</name>
<section id="1002X_S001Q" variety="S001Q">
<name>EXTERIOR</name>
<ttl id="1002X_S001Q_72Z6T_T00AP" variety="T00AP">
<name>REAR BUMPER</name>
<para id="RM0000026RV000X" category="A" type-id="8000E" name-id="ET0Y6-01" from="200601">
<name>REASSEMBLY</name>
<subpara id="RM0000026RV000X_01" type-id="01" category="01">
<s-1 id="RM0000026RV000X_01_0001" proc-id="RM0250U___0000AJG00000">
<ptxt>INSTALL REAR BUMPER REINFORCEMENT SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the rear bumper reinforcement sub-assembly with the 6 nuts.</ptxt>
<figure>
<graphic graphicname="B137217" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>68</t-value1>
<t-value2>693</t-value2>
<t-value4>50</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026RV000X_01_0002" proc-id="RM0250U___0000AJH00000">
<ptxt>INSTALL REAR  BUMPER BAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the rear bumper bar on the rear bumper energy absorber.</ptxt>
<figure>
<graphic graphicname="B137218" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026RV000X_01_0003" proc-id="RM0250U___0000AJI00000">
<ptxt>INSTALL REAR BUMPER ENERGY ABSORBER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 4 claws and install the rear bumper energy absorber.</ptxt>
<figure>
<graphic graphicname="B137216" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 4 bolts.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026RV000X_01_0004" proc-id="RM0250U___0000AJJ00000">
<ptxt>INSTALL WHEEL HOUSE REINFORCEMENT LH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the wheel house reinforcement LH with the nut.</ptxt>
<figure>
<graphic graphicname="B137221" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026RV000X_01_0005">
<ptxt>INSTALL WHEEL HOUSE REINFORCEMENT RH</ptxt>
</s-1>
<s-1 id="RM0000026RV000X_01_0006" proc-id="RM0250U___0000AJK00000">
<ptxt>INSTALL REAR BUMPER SIDE RETAINER LH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 3 claws and install the rear bumper side retainer LH.</ptxt>
<figure>
<graphic graphicname="B137220" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 2 screws.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026RV000X_01_0007">
<ptxt>INSTALL REAR BUMPER SIDE RETAINER RH</ptxt>
</s-1>
<s-1 id="RM0000026RV000X_01_0008" proc-id="RM0250U___0000AJL00000">
<ptxt>INSTALL REAR BUMPER SIDE SUPPORT LH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 3 claws and install the rear bumper side support LH.</ptxt>
<figure>
<graphic graphicname="B137219" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 2 screws.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026RV000X_01_0009">
<ptxt>INSTALL REAR BUMPER SIDE SUPPORT RH</ptxt>
</s-1>
<s-1 id="RM0000026RV000X_01_0010" proc-id="RM0250U___0000AJR00000">
<ptxt>INSTALL REAR BUMPER PAD</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply new double-sided tape to the rear bumper pad.</ptxt>
<figure>
<graphic graphicname="B146333" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the release paper from the rear bumper pad.</ptxt>
</s2>
<s2>
<ptxt>Install the rear bumper pad.</ptxt>
<atten4>
<ptxt>Use the same procedures for the RH side and LH side.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026RV000X_01_0011">
<ptxt>INSTALL REAR BUMPER PLATE LH</ptxt>
</s-1>
<s-1 id="RM0000026RV000X_01_0012">
<ptxt>INSTALL REAR BUMPER PLATE RH</ptxt>
</s-1>
<s-1 id="RM0000026RV000X_01_0013" proc-id="RM0250U___0000AJM00000">
<ptxt>INSTALL REAR BUMPER EXTENSION LH (w/ Rear Lower Spoiler)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the rear bumper extension LH with the 2 nuts.</ptxt>
<figure>
<graphic graphicname="B137222" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026RV000X_01_0014">
<ptxt>INSTALL REAR BUMPER EXTENSION RH (w/ Rear Lower Spoiler)</ptxt>
</s-1>
<s-1 id="RM0000026RV000X_01_0015" proc-id="RM0250U___0000AJN00000">
<ptxt>INSTALL REAR LOWER SPOILER (w/ Rear Lower Spoiler)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 16 claws and install the rear lower spoiler.</ptxt>
<figure>
<graphic graphicname="B137223" width="7.106578999in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 16 clips, 4 nuts and 2 screws.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>