<subpara id="RM00000182T00GX_02" type-id="51" category="05" proc-id="RM0250U___000052300000">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten4>
<ptxt>After the inspection is completed, clear the DTCs.</ptxt>
</atten4>
</content5>
</subpara>
<subpara id="RM00000182T00GX_03" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM00000182T00GX_03_0001" proc-id="RM0250U___000052400000">
<testtitle>CHECK HARNESS AND CONNECTOR (GPS ANTENNA - RADIO AND NAVIGATION ASSEMBLY)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check that the GPS antenna cord is securely connected to the radio and navigation assembly connector.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The cord is securely connected.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM00000182T00GX_03_0002" fin="false">OK</down>
<right ref="RM00000182T00GX_03_0004" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM00000182T00GX_03_0002" proc-id="RM0250U___000052500000">
<testtitle>REPLACE GPS ANTENNA</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Replace the GPS antenna with a normal one and check if the same problem occurs again.</ptxt>
<test2>
<ptxt>Clear the DTCs (See page <xref label="Seep01" href="RM0000011BU00FX"/>).</ptxt>
</test2>
<test2>
<ptxt>Recheck for DTCs and check if the same trouble occurs again.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Same problem does not occur.</ptxt>
</specitem>
</spec>
</test2>
</test1>
</content6>
<res>
<down ref="RM00000182T00GX_03_0003" fin="true">OK</down>
<right ref="RM00000182T00GX_03_0005" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM00000182T00GX_03_0003">
<testtitle>END</testtitle>
</testgrp>
<testgrp id="RM00000182T00GX_03_0004">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
<testgrp id="RM00000182T00GX_03_0005">
<testtitle>REPLACE RADIO AND NAVIGATION ASSEMBLY</testtitle>
</testgrp>
</subpara>
</para>
