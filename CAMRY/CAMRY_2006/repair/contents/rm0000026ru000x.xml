<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="43">
<name>BODY</name>
<section id="1002X_S001Q" variety="S001Q">
<name>EXTERIOR</name>
<ttl id="1002X_S001Q_72Z6T_T00AP" variety="T00AP">
<name>REAR BUMPER</name>
<para id="RM0000026RU000X" category="A" type-id="80002" name-id="ET0Y5-01" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM0000026RU000X_01" type-id="01" category="01">
<s-1 id="RM0000026RU000X_01_0005" proc-id="RM0250U___0000AHX00000">
<ptxt>REMOVE REAR LOWER SPOILER (w/ Rear Lower Spoiler)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 screws, 4 nuts and 16 clips.</ptxt>
<figure>
<graphic graphicname="B137223" width="7.106578999in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Disengage the 16 claws and remove the rear lower spoiler.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026RU000X_01_0003" proc-id="RM0250U___0000AHY00000">
<ptxt>REMOVE REAR BUMPER EXTENSION LH (w/ Rear Lower Spoiler)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 nuts and rear bumper extension LH.</ptxt>
<figure>
<graphic graphicname="B137222" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026RU000X_01_0004">
<ptxt>REMOVE REAR BUMPER EXTENSION RH (w/ Rear Lower Spoiler)</ptxt>
</s-1>
<s-1 id="RM0000026RU000X_01_0006">
<ptxt>REMOVE REAR BUMPER PLATE LH</ptxt>
</s-1>
<s-1 id="RM0000026RU000X_01_0007">
<ptxt>REMOVE REAR BUMPER PLATE RH</ptxt>
</s-1>
<s-1 id="RM0000026RU000X_01_0008" proc-id="RM0250U___0000CLK00000">
<ptxt>REMOVE REAR BUMPER PAD</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the rear bumper pad.</ptxt>
<figure>
<graphic graphicname="B146333" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten4>
<ptxt>Use the same procedures for the RH side and LH side.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026RU000X_01_0009" proc-id="RM0250U___0000AHZ00000">
<ptxt>REMOVE REAR BUMPER SIDE SUPPORT LH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 screws.</ptxt>
<figure>
<graphic graphicname="B137219" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disengage the 3 claws and remove the rear bumper side support LH.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026RU000X_01_0010">
<ptxt>REMOVE REAR BUMPER SIDE SUPPORT RH</ptxt>
</s-1>
<s-1 id="RM0000026RU000X_01_0011" proc-id="RM0250U___0000AI000000">
<ptxt>REMOVE REAR BUMPER SIDE RETAINER LH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 screws.</ptxt>
<figure>
<graphic graphicname="B137220" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disengage the 3 claws and remove the rear bumper side retainer LH.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026RU000X_01_0012">
<ptxt>REMOVE REAR BUMPER SIDE RETAINER RH</ptxt>
</s-1>
<s-1 id="RM0000026RU000X_01_0013" proc-id="RM0250U___0000AI100000">
<ptxt>REMOVE WHEEL HOUSE REINFORCEMENT LH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the nut and wheel house reinforcement LH.</ptxt>
<figure>
<graphic graphicname="B137221" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026RU000X_01_0014">
<ptxt>REMOVE WHEEL HOUSE REINFORCEMENT RH</ptxt>
</s-1>
<s-1 id="RM0000026RU000X_01_0002" proc-id="RM0250U___0000A9100000">
<ptxt>REMOVE REAR BUMPER ENERGY ABSORBER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 4 bolts.</ptxt>
<figure>
<graphic graphicname="B137216" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disengage the 4 claws and remove the rear bumper energy absorber.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026RU000X_01_0001" proc-id="RM0250U___0000A9200000">
<ptxt>REMOVE REAR  BUMPER BAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the rear bumper bar from the rear bumper energy absorber.</ptxt>
<figure>
<graphic graphicname="B137218" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026RU000X_01_0015" proc-id="RM0250U___0000AI200000">
<ptxt>REMOVE REAR BUMPER REINFORCEMENT SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 6 nuts and rear bumper reinforcement sub-assembly.</ptxt>
<figure>
<graphic graphicname="B137217" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>