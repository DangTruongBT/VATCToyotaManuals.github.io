<section id="1001I_S001E" variety="S001E">
<name>DOOR LOCK</name>
<ttl id="1001I_S001E_72XW5_T0086" variety="T0086">
<name>REAR DOOR LOCK</name>
<para id="RM000001P83004X" category="G" type-id="3001K" name-id="DL0VM-02" from="200601">
<name>INSPECTION</name>
<subpara id="RM000001P83004X_01" type-id="01" category="01">
<s-1 id="RM000001P83004X_01_0001" proc-id="RM0250U___000032K00000">
<ptxt>INSPECT REAR DOOR LOCK LH ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the rear door lock assembly LH.</ptxt>
</s2>
<s2>
<ptxt>Check operation of the door lock motor.</ptxt>
<figure>
<graphic graphicname="E123890E03" width="2.775699831in" height="3.779676365in"/>
</figure>
<s3>
<ptxt>Apply battery voltage and check operation of the door lock motor.</ptxt>
<spec>
<title>OK</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Measurement Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>Battery positive (+) → Terminal 4</ptxt>
<ptxt>Battery negative (-) → Terminal 1</ptxt>
</entry>
<entry valign="middle">
<ptxt>Lock</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Battery positive (+) → Terminal 1</ptxt>
<ptxt>Battery negative (-) → Terminal 4</ptxt>
</entry>
<entry valign="middle">
<ptxt>Unlock</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</s3>
</s2>
<s2>
<ptxt>Check operation of the unlock detection switch.</ptxt>
<figure>
<graphic graphicname="E123890E02" width="2.775699831in" height="3.779676365in"/>
</figure>
<s3>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="4" align="center">
<colspec colname="COLSPEC0" colwidth="1.03in"/>
<colspec colname="COL1" colwidth="1.03in"/>
<colspec colname="COL2" colwidth="1.03in"/>
<colspec colname="COL3" colwidth="1.04in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Measurement Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Door Lock Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>(Specified Condition)</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>6 - 9</ptxt>
</entry>
<entry valign="middle">
<ptxt>Battery positive (+) → Terminal 4</ptxt>
<ptxt>Battery negative (-) → Terminal 1</ptxt>
</entry>
<entry valign="middle">
<ptxt>Lock</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>6 - 9</ptxt>
</entry>
<entry valign="middle">
<ptxt>Battery positive (+) → Terminal 1</ptxt>
<ptxt>Battery negative (-) → Terminal 4</ptxt>
</entry>
<entry valign="middle">
<ptxt>Unlock</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</s3>
</s2>
</content1>
</s-1>
