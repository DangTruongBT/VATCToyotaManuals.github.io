<testgrp id="RM000000U5B01FX_09_0011">
<testtitle>CHECK ECM POWER SOURCE CIRCUIT</testtitle>
</testgrp>
<testgrp id="RM000000U5B01FX_09_0012" proc-id="RM0250U___00007BD00000">
<testtitle>CHECK HARNESS AND CONNECTOR (SENSOR GROUND)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the C2 MAF meter connector.</ptxt>
<figure>
<graphic graphicname="A127724E06" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.89in"/>
<colspec colname="COL2" colwidth="1.24in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>C2-4 (E2G) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
<test1>
