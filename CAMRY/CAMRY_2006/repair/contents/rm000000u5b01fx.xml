</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>C2-3 (+B) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>9 to 14 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
<test1>
<ptxt>Reconnect the MAF meter connector.</ptxt>
</test1>
