<subpara id="RM00000282Q000X_01" type-id="01" category="01">
<s-1 id="RM00000282Q000X_01_0001" proc-id="RM0250U___0000BNO00000">
<ptxt>INSTALL SHIFT SOLENOID VALVE SL4</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Coat the shift solenoid valve SL4 and bolt with ATF.</ptxt>
<figure>
<graphic graphicname="C138527E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the shift solenoid valve SL4 and lock plate to the valve body assembly with the bolt.</ptxt>
<torque>
<torqueitem>
<t-value1>11</t-value1>
<t-value2>112</t-value2>
<t-value4>8</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
