<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10007_S000G" variety="S000G">
<name>2GR-FE FUEL</name>
<ttl id="10007_S000G_7305V_T00DS" variety="T00DS">
<name>FUEL PUMP</name>
<para id="RM000001IRB001X" category="A" type-id="80002" name-id="FU0SW-02" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM000001IRB001X_01" type-id="01" category="01">
<s-1 id="RM000001IRB001X_01_0001" proc-id="RM0250U___00008U000000">
<ptxt>REMOVE NO. 2 FUEL SUCTION SUPPORT</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a screwdriver with its tip wrapped with tape, disengage the 5 snap claws from the claw holes, and remove the No. 2 fuel suction support.</ptxt>
<figure>
<graphic graphicname="A077832E05" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Do not damage the fuel suction support.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IRB001X_01_0002" proc-id="RM0250U___00008U100000">
<ptxt>REMOVE FUEL PUMP CUSHION RUBBER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the fuel pump cushion rubber from the fuel pump.</ptxt>
<figure>
<graphic graphicname="A079492E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IRB001X_01_0003" proc-id="RM0250U___00008U200000">
<ptxt>REMOVE FUEL SENDER GAUGE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the fuel sender gauge connector (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A129482E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Unlock the fuel sender gauge, and slide it to remove (<sup>*</sup>2).</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IRB001X_01_0004" proc-id="RM0250U___00008U300000">
<ptxt>REMOVE FUEL SUCTION PLATE SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the fuel pump connector (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A129483E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using a screwdriver with its tip wrapped with tape, disengage the 4 snap claws from the claw holes, and pull out the fuel suction plate.</ptxt>
<atten3>
<ptxt>Do not damage the fuel suction support.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IRB001X_01_0005" proc-id="RM0250U___00008U400000">
<ptxt>REMOVE FUEL PUMP HARNESS</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the connector (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A079495E05" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using a screwdriver, pry out the fuel pump harness (<sup>*</sup>2).</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IRB001X_01_0006" proc-id="RM0250U___00008U500000">
<ptxt>REMOVE FUEL PUMP</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Pull out the fuel pump from the fuel filter.</ptxt>
<figure>
<graphic graphicname="A079496E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IRB001X_01_0008" proc-id="RM0250U___00008U700000">
<ptxt>REMOVE FUEL PRESSURE REGULATOR ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Pull out the fuel pressure regulator from the fuel filter.</ptxt>
<figure>
<graphic graphicname="A133536E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the O-ring from the fuel pressure regulator.</ptxt>
<figure>
<graphic graphicname="A133534E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>