</entry>
</row>
<row>
<entry valign="middle">
<ptxt>A2A+ (C35-3) - A2A+ (C55-120)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>A2A- (C35-4) - A2A- (C55-119)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<spec>
<title>Standard resistance (Check for short)</title>
