</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
<test1>
<ptxt>Reconnect the A/F sensor connector.</ptxt>
</test1>
</content6>
<res>
<down ref="RM000000WC2015X_09_0015" fin="false">OK</down>
<right ref="RM000000WC2015X_09_0033" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000WC2015X_09_0015" proc-id="RM0250U___00002UL00000">
<testtitle>CHECK HARNESS AND CONNECTOR (A/F SENSOR - ECM)</testtitle>
<content6 releasenbr="1">
