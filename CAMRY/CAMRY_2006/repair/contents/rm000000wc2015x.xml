<graphic graphicname="A126269E12" width="2.775699831in" height="3.779676365in"/>
</figure>
<test1>
<ptxt>Disconnect the C15 or C35 A/F sensor connector.</ptxt>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance (Bank 1 sensor 1)</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COLSPEC0" colwidth="1.37in"/>
<colspec colname="COL2" colwidth="1.38in"/>
