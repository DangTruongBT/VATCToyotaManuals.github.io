<para id="RM0000013H8009X" category="C" type-id="302L5" name-id="ES3Y2-01" from="200601">
<dtccode>P2A00</dtccode>
<dtcname>A/F Sensor Circuit Slow Response (Bank 1 Sensor 1)</dtcname>
<subpara id="RM0000013H8009X_02" type-id="11" category="10" proc-id="RM0250U___00007OQ00000">
<name>CAUTION / NOTICE / HINT</name>
<content5 releasenbr="1">
<atten4>
<ptxt>Sensor 1 refers to the sensor mounted in front of the Three-Way Catalytic Converter (TWC) and located near the engine assembly.</ptxt>
</atten4>
</content5>
</subpara>
<subpara id="RM0000013H8009X_03" type-id="60" category="03" proc-id="RM0250U___00007OR00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
