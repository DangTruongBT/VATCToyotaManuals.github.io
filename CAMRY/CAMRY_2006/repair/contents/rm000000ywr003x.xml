<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000S" variety="S000S">
<name>U250E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000S_72XOZ_T007B" variety="T007B">
<name>PARK / NEUTRAL POSITION SWITCH</name>
<para id="RM000000YWR003X" category="A" type-id="80001" name-id="AX03H-02" from="200601">
<name>REMOVAL</name>
<subpara id="RM000000YWR003X_01" type-id="01" category="01">
<s-1 id="RM000000YWR003X_01_0013">
<ptxt>DISCONNECT CABLE FROM NEGATIVE BATTERY TERMINAL</ptxt>
</s-1>
<s-1 id="RM000000YWR003X_01_0012" proc-id="RM0250U___0000A7W00000">
<ptxt>REMOVE BATTERY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Loosen the bolt and nut, and remove the battery clamp.</ptxt>
<figure>
<graphic graphicname="A134906" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the battery and battery tray.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000YWR003X_01_0009" proc-id="RM0250U___00006LH00000">
<ptxt>SEPARATE TRANSMISSION CONTROL CABLE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the nut from the control shaft lever.</ptxt>
<figure>
<graphic graphicname="C135109" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the transmission control cable assembly from the control shaft lever.</ptxt>
</s2>
<s2>
<ptxt>Remove the clip and disconnect the transmission control cable assembly from the No. 1 control cable bracket.</ptxt>
<figure>
<graphic graphicname="C135705" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Do not hold the resin guide pipe.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YWR003X_01_0010" proc-id="RM0250U___00006LI00000">
<ptxt>REMOVE PARK/NEUTRAL POSITION SWITCH ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the park/neutral position switch connector.</ptxt>
<figure>
<graphic graphicname="C135706" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the nut, washer and control shaft lever.</ptxt>
<figure>
<graphic graphicname="C135707" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using a screwdriver, pry up the lock plate.</ptxt>
<figure>
<graphic graphicname="C135708" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the lock nut and the lock plate.</ptxt>
<figure>
<graphic graphicname="C135709" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts and pull out the park/neutral position switch.</ptxt>
<figure>
<graphic graphicname="C135710" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>