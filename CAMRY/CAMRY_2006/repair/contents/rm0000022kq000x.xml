<tmc-service-inc>
<pub id="RM0251U">
<servcat id="36">
<name>BRAKE</name>
<section id="1000O_S0012" variety="S0012">
<name>PARKING BRAKE</name>
<ttl id="1000O_S0012_72V97_T0044" variety="T0044">
<name>PARKING BRAKE LEVER</name>
<para id="RM0000022KQ000X" category="A" type-id="8000E" name-id="PB09K-01" from="200601">
<name>REASSEMBLY</name>
<subpara id="RM0000022KQ000X_01" type-id="01" category="01">
<s-1 id="RM0000022KQ000X_01_0001" proc-id="RM0250U___00001ID00000">
<ptxt>INSTALL PARKING BRAKE SWITCH ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the parking brake switch assembly with the screw.</ptxt>
<figure>
<graphic graphicname="C132654" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022KQ000X_01_0002" proc-id="RM0250U___00003PE00000">
<ptxt>INSTALL NO. 1 PARKING BRAKE CABLE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Pass the No. 1 parking brake cable assembly through the parking brake lever sub-assembly.</ptxt>
</s2>
<s2>
<ptxt>Temporarily tighten the lock nut and the No. 1 wire adjusting nut.</ptxt>
<figure>
<graphic graphicname="C132670E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Fully tighten the lock nut when adjusting the parking brake lever travel.</ptxt>
</atten3>
<torque>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Bend the parking brake lever claw.</ptxt>
<figure>
<graphic graphicname="C132671" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>