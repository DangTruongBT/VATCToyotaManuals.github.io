<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000T" variety="S000T">
<name>U660E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000T_737D4_T00GS" variety="T00GS">
<name>TCM</name>
<para id="RM000002DAI000X" category="A" type-id="30014" name-id="AX12Z-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000002DAI000X_01" type-id="01" category="01">
<s-1 id="RM000002DAI000X_01_0001" proc-id="RM0250U___0000CAX00000">
<ptxt>INSTALL TCM</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the TCM to the transaxle.</ptxt>
</s2>
<s2>
<ptxt>Install and tighten the 2 bolts in the order shown in the illustration.</ptxt>
<figure>
<graphic graphicname="C139840E02" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>11</t-value1>
<t-value2>112</t-value2>
<t-value4>8</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the connector to the TCM.</ptxt>
<figure>
<graphic graphicname="C139242" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Turn the lock lever and secure the connector with the lock lever.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000002DAI000X_01_0010" proc-id="RM0250U___00006RB00000">
<ptxt>INSTALL INTAKE AIR RESONATOR SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the intake air resonator with the bolt and clip.</ptxt>
<figure>
<graphic graphicname="A133928" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM000002DAI000X_01_0011" proc-id="RM0250U___00006RC00000">
<ptxt>INSTALL NO. 1 AIR CLEANER INLET
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the No. 1 air cleaner inlet with the bolt.</ptxt>
<figure>
<graphic graphicname="A132970" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM000002DAI000X_01_0012" proc-id="RM0250U___00006RE00000">
<ptxt>INSTALL AIR CLEANER INLET ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air cleaner inlet with the clamp and 2 bolts.</ptxt>
<figure>
<graphic graphicname="A132969" width="2.775699831in" height="2.775699831in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM000002DAI000X_01_0013" proc-id="RM0250U___0000A4J00000">
<ptxt>INSTALL BATTERY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the battery and battery tray.</ptxt>
<figure>
<graphic graphicname="A132972" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the battery clamp with the bolt and nut.</ptxt>
<torque>
<subtitle>Bolt</subtitle>
<torqueitem>
<t-value1>9.0</t-value1>
<t-value2>92</t-value2>
<t-value3>80</t-value3>
</torqueitem>
<subtitle>Nut</subtitle>
<torqueitem>
<t-value1>3.5</t-value1>
<t-value2>36</t-value2>
<t-value3>31</t-value3>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM000002DAI000X_01_0014" proc-id="RM0250U___0000A5U00000">
<ptxt>INSTALL COOL AIR INTAKE DUCT SEAL
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the intake duct seal with the 7 clips.</ptxt>
<figure>
<graphic graphicname="A132967" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000002DAI000X_01_0007" proc-id="RM0250U___0000CO800000">
<ptxt>PERFORM TCM REGISTRATION</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>(See page <xref label="Seep01" href="RM000000TJ400BX"/>)</ptxt>
</atten4>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>