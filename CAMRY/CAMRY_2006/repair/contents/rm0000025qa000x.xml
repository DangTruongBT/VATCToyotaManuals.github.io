<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="43">
<name>BODY</name>
<section id="1001H_S001L" variety="S001L">
<name>SEAT</name>
<ttl id="1001H_S001L_72Y77_T008Y" variety="T008Y">
<name>LUMBAR SUPPORT ADJUSTER ASSEMBLY</name>
<para id="RM0000025QA000X" category="A" type-id="30014" name-id="SE0W2-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000025QA000X_01" type-id="01" category="01">
<s-1 id="RM0000025QA000X_01_0001" proc-id="RM0250U___0000A6100000">
<ptxt>INSTALL LUMBAR SUPPORT ADJUSTER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the lumbar support adjuster assembly with the 2 screws.</ptxt>
<figure>
<graphic graphicname="B134693" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the connector.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000025QA000X_01_0002">
<ptxt>INSTALL SEPARATE TYPE FRONT SEAT BACK ASSEMBLY</ptxt>
</s-1>
<s-1 id="RM0000025QA000X_01_0003">
<ptxt>INSTALL FRONT SEAT HEADREST SUPPORT</ptxt>
</s-1>
<s-1 id="RM0000025QA000X_01_0004">
<ptxt>INSTALL FRONT SEAT HEADREST SUPPORT</ptxt>
</s-1>
<s-1 id="RM0000025QA000X_01_0005">
<ptxt>INSTALL FRONT SEAT BACK BOARD SUB-ASSEMBLY</ptxt>
</s-1>
<s-1 id="RM0000025QA000X_01_0006">
<ptxt>INSTALL FRONT SEAT CUSHION SHIELD INNER</ptxt>
</s-1>
<s-1 id="RM0000025QA000X_01_0014" proc-id="RM0250U___000045T00000">
<ptxt>INSTALL FRONT SEAT INNER BELT ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the front seat inner belt assembly with the nut.</ptxt>
<figure>
<graphic graphicname="B132035E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>42</t-value1>
<t-value2>428</t-value2>
<t-value4>31</t-value4>
</torqueitem>
</torque>
<atten3>
<ptxt>Do not allow the anchor part of the front seat inner belt assembly to overlap the protruding parts of the front seat adjuster.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>for Driver seat:</ptxt>
<figure>
<graphic graphicname="B132033E01" width="2.775699831in" height="3.779676365in"/>
</figure>
<s3>
<ptxt>Connect the connectors and engage the 4 clamps.</ptxt>
</s3>
</s2>
<s2>
<ptxt>for Passenger seat:</ptxt>
<s3>
<ptxt>Connect the connector and engage the 3 clamps.</ptxt>
</s3>
</s2>
</content1></s-1>
<s-1 id="RM0000025QA000X_01_0007">
<ptxt>INSTALL FRONT SEAT CUSHION SHIELD ASSEMBLY</ptxt>
</s-1>
<s-1 id="RM0000025QA000X_01_0008">
<ptxt>INSTALL SLIDE AND VERTICAL POWER SEAT SWITCH KNOB</ptxt>
</s-1>
<s-1 id="RM0000025QA000X_01_0009">
<ptxt>INSTALL RECLINING POWER SEAT SWITCH KNOB</ptxt>
</s-1>
<s-1 id="RM0000025QA000X_01_0010">
<ptxt>INSTALL FRONT SEAT ASSEMBLY</ptxt>
</s-1>
<s-1 id="RM0000025QA000X_01_0015" proc-id="RM0250U___0000C1H00000">
<ptxt>INSTALL INNER SEAT TRACK BRACKET COVER
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Slide the inner seat track bracket cover along the seat rail toward the front of the vehicle. Engage claw A to the seat rail.</ptxt>
<figure>
<graphic graphicname="B139100E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Push the inner  seat track bracket cover to engage claw B.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000025QA000X_01_0016" proc-id="RM0250U___0000C1I00000">
<ptxt>INSTALL SEAT TRACK COVER
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Slide the seat track cover along the seat rail toward the front of the vehicle. Engage claw A to the seat rail.</ptxt>
<figure>
<graphic graphicname="B139099E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Push the seat track cover to engage claw B.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000025QA000X_01_0013">
<ptxt>INSTALL FRONT SEAT HEADREST ASSEMBLY</ptxt>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>