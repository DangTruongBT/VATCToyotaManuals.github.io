<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="1000A_S0008" variety="S0008">
<name>2AZ-FE ENGINE MECHANICAL</name>
<ttl id="1000A_S0008_72ZKL_T00CH" variety="T00CH">
<name>ENGINE ASSEMBLY</name>
<para id="RM000000YIL001X" category="G" type-id="3001K" name-id="EM06G-02" from="200601">
<name>INSPECTION</name>
<subpara id="RM000000YIL001X_01" type-id="01" category="01">
<s-1 id="RM000000YIL001X_01_0001" proc-id="RM0250U___00006ZJ00000">
<ptxt>INSPECT INTAKE MANIFOLD</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a precision straight edge and feeler gauge, measure the surface contacting the cylinder head for warpage.</ptxt>
<figure>
<graphic graphicname="A085564" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Maximum warpage</title>
<specitem>
<ptxt> 0.20 mm (0.0079 in.)</ptxt>
</specitem>
</spec>
<ptxt>If the warpage is greater than maximum, replace the manifold.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YIL001X_01_0002" proc-id="RM0250U___00006ZK00000">
<ptxt>INSPECT EXHAUST MANIFOLD CONVERTER SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a precision straight edge and feeler gauge, measure the surface contacting the cylinder head for warpage.</ptxt>
<figure>
<graphic graphicname="A124780" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Maximum warpage</title>
<specitem>
<ptxt> 0.70 mm (0.0276 in.)</ptxt>
</specitem>
</spec>
<ptxt>If the warpage is greater than the maximum, replace the manifold.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
