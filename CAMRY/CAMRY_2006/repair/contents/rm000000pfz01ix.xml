</entry>
</row>
<row>
<entry valign="middle">
<ptxt>EPA (A17-5) or EPA (A55-59) - body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>VCPA (A17-4) or VCPA (A55-57) - body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>VPA2 (A17-3) or VPA2 (A55-56) - body ground</ptxt>
