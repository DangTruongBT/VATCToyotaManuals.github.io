</figure>
</test1>
<test1>
<ptxt>Turn the ignition switch to the ON position.</ptxt>
</test1>
<test1>
<ptxt>Measure the voltage between the terminal of the C22 HO2 sensor connector and body ground.</ptxt>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.89in"/>
<colspec colname="COL2" colwidth="1.24in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>C22-2 (+B) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>9 to 14 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
<test1>
<ptxt>Reconnect the HO2 sensor connector.</ptxt>
</test1>
</content6>
<res>
<down ref="RM000000PFA01CX_10_0015" fin="false">NG</down>
<right ref="RM000000PFA01CX_10_0007" fin="false">OK</right>
</res>
</testgrp>
<testgrp id="RM000000PFA01CX_10_0015" proc-id="RM0250U___00007AI00000">
<testtitle>INSPECT ENGINE ROOM J/B (EFI RELAY)
</testtitle>
