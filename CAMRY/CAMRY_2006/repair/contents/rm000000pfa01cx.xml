<entry valign="middle" align="center">
<ptxt>C22-2 (+B) or 1E-6 (Engine room J/B) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
