<s-1 id="RM0000012OM004X_01_0001" proc-id="RM0250U___0000B7X00000">
<ptxt>REMOVE HEATED OXYGEN SENSOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the heated oxygen sensor connector.</ptxt>
<figure>
<graphic graphicname="A135678E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using SST, remove the heated oxygen sensor from the exhaust pipe assembly front No. 3.</ptxt>
<figure>
<graphic graphicname="A135679E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09224-00010</s-number>
</sstitem>
</sst>
<atten3>
<ptxt>Do not damage the heated oxygen sensor.</ptxt>
</atten3>
</s2>
