<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>7 (SS1) - 5 (GND)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Not pushed</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>2 (SS2) - 5 (GND)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Not pushed</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000020S9004X_04_0012" fin="false">OK</down>
<right ref="RM0000020S9004X_04_0020" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000020S9004X_04_0012" proc-id="RM0250U___00009L700000">
