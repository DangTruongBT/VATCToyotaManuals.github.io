<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Switch Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>7 (SS1) - 5 (GND)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Pushed</ptxt>
</entry>
<entry valign="middle">
