<name>INSTALLATION</name>
<subpara id="RM000000MMQ003X_01" type-id="01" category="01">
<s-1 id="RM000000MMQ003X_01_0001" proc-id="RM0250U___00008LX00000">
<ptxt>INSTALL REAR BUMPER ASSEMBLY (w/o Rear Lower Spoiler)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage each claw.</ptxt>
<figure>
<graphic graphicname="B137214" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the rear bumper assembly with the 6 screws and 2 clips.</ptxt>
</s2>
<s2>
<ptxt>Install the 2 rear bumper plates.</ptxt>
<figure>
<graphic graphicname="B137213" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000MMQ003X_01_0009" proc-id="RM0250U___0000AGG00000">
<ptxt>INSTALL REAR BUMPER ASSEMBLY (w/ Rear Lower Spoiler)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage each claw.</ptxt>
<figure>
<graphic graphicname="B140154" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the rear bumper assembly with the 6 screws.</ptxt>
</s2>
<s2>
<ptxt>Install the 2 rear bumper plates.</ptxt>
<figure>
<graphic graphicname="B147905" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000MMQ003X_01_0008" proc-id="RM0250U___0000AGH00000">
<ptxt>INSTALL REAR FLOOR BOARD (w/ Rear Lower Spoiler)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the rear floor board with the 3 nuts, 2 clips and 4 screws.</ptxt>
<figure>
<graphic graphicname="B138885E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1>
</s-1>
