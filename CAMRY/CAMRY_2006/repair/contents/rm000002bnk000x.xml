<name>2GR-FE EMISSION CONTROL</name>
<ttl id="10008_S000H_7306P_T00EJ" variety="T00EJ">
<name>VACUUM SWITCHING VALVE (for EVAP)</name>
<para id="RM000002BNK000X" category="A" type-id="30014" name-id="EC0TG-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000002BNK000X_01" type-id="01" category="01">
<s-1 id="RM000002BNK000X_01_0001" proc-id="RM0250U___0000BSZ00000">
<ptxt>INSTALL NO. 1 VACUUM SWITCHING VALVE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the No. 1 vacuum switching valve with the bolt.</ptxt>
<figure>
<graphic graphicname="A132953" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Disconnect the 2 vacuum hoses and No. 1 vacuum switching valve connector.</ptxt>
<figure>
<graphic graphicname="A132952E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000002BNK000X_01_0003" proc-id="RM0250U___00006RL00000">
<ptxt>INSTALL V-BANK COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Fit the 3 retainers and install the V-bank cover.</ptxt>
<figure>
<graphic graphicname="A132968" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
</subpara>
</para>
