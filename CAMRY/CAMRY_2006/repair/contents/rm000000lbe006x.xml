<tmc-service-inc>
<pub id="RM0251U">
<servcat id="36">
<name>BRAKE</name>
<section id="1000N_S0011" variety="S0011">
<name>BRAKE</name>
<ttl id="1000N_S0011_72V90_T003X" variety="T003X">
<name>FRONT BRAKE</name>
<para id="RM000000LBE006X" category="A" type-id="80001" name-id="BR05N-03" from="200601">
<name>REMOVAL</name>
<subpara id="RM000000LBE006X_02" type-id="11" category="10" proc-id="RM0250U___00003VN00000">
<content3 releasenbr="1">
<atten4>
<list1 type="unordered">
<item>
<ptxt>Use the same procedures for the RH side and LH side.</ptxt>
</item>
<item>
<ptxt>The procedures listed below are for the LH side.</ptxt>
</item>
</list1>
</atten4>
</content3>
</subpara>
<subpara id="RM000000LBE006X_01" type-id="01" category="01">
<s-1 id="RM000000LBE006X_01_0001">
<ptxt>REMOVE FRONT WHEEL</ptxt>
</s-1>
<s-1 id="RM000000LBE006X_01_0002" proc-id="RM0250U___00003QA00000">
<ptxt>DRAIN BRAKE FLUID</ptxt>
<content1 releasenbr="1">
<atten3>
<ptxt>If brake fluid leaks onto any painted surface of the vehicle, wash or remove it completely.</ptxt>
</atten3>
</content1>
</s-1>
<s-1 id="RM000000LBE006X_01_0003" proc-id="RM0250U___00003QB00000">
<ptxt>REMOVE DISC BRAKE CYLINDER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the union bolt and gasket from the disc brake cylinder assembly, then disconnect the flexible hose. </ptxt>
<figure>
<graphic graphicname="C133332" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Hold the front disc brake cylinder slide pin and remove the 2 bolts and disc brake cylinder assembly.</ptxt>
<figure>
<graphic graphicname="C132794E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>