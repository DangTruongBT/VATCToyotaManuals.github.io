<thead>
<row>
<entry valign="middle">
<ptxt>Detection Item</ptxt>
</entry>
<entry valign="middle">
<ptxt>Symptom</ptxt>
</entry>
<entry valign="middle">
<ptxt>Trouble Area</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="left">
<ptxt>ECM Communication Stop Mode</ptxt>
</entry>
<entry valign="middle" align="left">
<list1 type="unordered">
<item>
