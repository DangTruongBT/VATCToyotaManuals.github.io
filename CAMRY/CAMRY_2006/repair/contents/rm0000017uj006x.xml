<name>2AZ-FE ENGINE CONTROL SYSTEM</name>
<ttl id="10006_S0004_731VU_T00G1" variety="T00G1">
<name>ACCELERATOR PEDAL ROD</name>
<para id="RM0000017UJ006X" category="A" type-id="30014" name-id="ES3J6-02" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000017UJ006X_01" type-id="01" category="01">
<s-1 id="RM0000017UJ006X_01_0001" proc-id="RM0250U___0000B6W00000">
<ptxt>INSTALL ACCELERATOR PEDAL ROD</ptxt>
<content1 releasenbr="1">
<atten3>
<list1 type="unordered">
<item>
<ptxt>Avoid physical shock to the accelerator pedal assembly.</ptxt>
</item>
<item>
<ptxt>Do not disassemble the accelerator pedal assembly.</ptxt>
</item>
</list1>
</atten3>
<s2>
<ptxt>Install the accelerator pedal rod with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="A135676" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.4</t-value1>
<t-value2>55</t-value2>
<t-value3>48</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the accelerator pedal position sensor connector.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
