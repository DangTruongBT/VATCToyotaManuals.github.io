<ttl id="1002T_S001K_72YEU_T009D" variety="T009D">
<name>CLOCK</name>
<para id="RM0000029CS000X" category="J" type-id="3029M" name-id="OT07C-01" from="200601">
<dtccode/>
<dtcname>Power Source Circuit</dtcname>
<subpara id="RM0000029CS000X_01" type-id="60" category="03" proc-id="RM0250U___0000AU400000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<list1 type="unordered">
<item>
<ptxt>This circuit is the power source for the clock assembly.</ptxt>
</item>
</list1>
<list1 type="unordered">
<item>
<ptxt>This circuit provides two types of power sources; one is a constant power source mainly used as a backup power source, and the other is a power source mainly used for signal transmission. The constant power source is mainly used as a backup power source of the clock assembly, however, it is also used for communication.</ptxt>
</item>
</list1>
<atten4>
<ptxt>If the clock assembly displays "1:00" when the ignition switch turned off, and turned on (IG) again, the B terminal has a malfunction.</ptxt>
</atten4>
</content5>
</subpara>
<subpara id="RM0000029CS000X_02" type-id="32" category="03" proc-id="RM0250U___0000AXE00000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="E132651E02" width="7.106578999in" height="3.779676365in"/>
</figure>
</content5>
</subpara>
<subpara id="RM0000029CS000X_03" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM0000029CS000X_04" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM0000029CS000X_04_0001" proc-id="RM0250U___0000AU600000">
<testtitle>INSPECT CLOCK ASSEMBLY</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the F3 connector.</ptxt>
<figure>
<graphic graphicname="E128063E05" width="2.775699831in" height="2.775699831in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the voltage according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry>
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>F3-1 (B) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 to 14 V</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>F3-2 (ACC) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Ignition switch on (IG)</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 to 14 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry align="center">
<ptxt>Condition</ptxt>
</entry>
<entry align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>F3-19 (GND1) - Body ground</ptxt>
</entry>
<entry>
<ptxt>Always</ptxt>
</entry>
<entry>
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000029CS000X_04_0003" fin="true">OK</down>
<right ref="RM0000029CS000X_04_0002" fin="true">NG</right>
</res>
</testgrp>
