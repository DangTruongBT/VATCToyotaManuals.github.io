<testgrp id="RM000000XH301BX_10_0002" proc-id="RM0250U___00002LZ00000">
<testtitle>READ VALUE OF INTELLIGENT TESTER (MISFIRE RPM AND MISFIRE LOAD)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Connect the intelligent tester to the DLC3.</ptxt>
</test1>
<test1>
