<row>
<entry valign="middle">
<ptxt>DENSO</ptxt>
</entry>
<entry valign="middle">
<ptxt>FK20HBR11</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<atten3>
<ptxt>If the electrode gap is larger than standard, replace the spark plug. Do not adjust the electrode gap.</ptxt>
</atten3>
</test1>
</content6>
<res>
