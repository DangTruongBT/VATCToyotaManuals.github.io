<graphic graphicname="A107715E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<test1>
<ptxt>Remove the ignition coil and the spark plug of the misfiring cylinder.</ptxt>
</test1>
<test1>
<ptxt>Measure the spark plug electrode gap.</ptxt>
<spec>
<title>Standard</title>
<specitem>
<ptxt>Between 1.0 mm and 1.4 mm (0.039 in. and 0.055 in.)</ptxt>
</specitem>
</spec>
