<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10008_S0006" variety="S0006">
<name>2AZ-FE EMISSION CONTROL</name>
<ttl id="10008_S0006_731VZ_T00G6" variety="T00G6">
<name>AIR FUEL RATIO SENSOR</name>
<para id="RM0000012OF004X" category="A" type-id="30014" name-id="EC04H-04" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000012OF004X_01" type-id="01" category="01">
<s-1 id="RM0000012OF004X_01_0001" proc-id="RM0250U___0000B7M00000">
<ptxt>INSTALL AIR FUEL RATIO SENSOR (for PZEV)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Temporarily tighten the air fuel ratio sensor.</ptxt>
<figure>
<graphic graphicname="A135687E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Do not damage the air fuel ratio sensor.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Using SST, fully tighten the air fuel ratio sensor.</ptxt>
<sst>
<sstitem>
<s-number>09224-00010</s-number>
</sstitem>
</sst>
<torque>
<torqueitem>
<t-value1>44</t-value1>
<t-value2>449</t-value2>
<t-value4>32</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the air fuel ratio sensor connector and clamp.</ptxt>
<figure>
<graphic graphicname="A135685E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000012OF004X_01_0002" proc-id="RM0250U___0000B7N00000">
<ptxt>INSTALL AIR FUEL RATIO SENSOR (except PZEV)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Temporarily tighten the air fuel ratio sensor.</ptxt>
<atten3>
<ptxt>Do not damage the air fuel ratio sensor.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Using SST, fully tighten the air fuel ratio sensor.</ptxt>
<figure>
<graphic graphicname="A135684E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09224-00010</s-number>
</sstitem>
</sst>
<torque>
<torqueitem>
<t-value1>44</t-value1>
<t-value2>449</t-value2>
<t-value4>32</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the air fuel ratio sensor connector and clamp.</ptxt>
<figure>
<graphic graphicname="A135681E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000012OF004X_01_0003" proc-id="RM0250U___0000BSR00000">
<ptxt>INSTALL NO. 1 EXHAUST MANIFOLD HEAT INSULATOR (except PZEV)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the exhaust manifold heat insulator with the 4 bolts.</ptxt>
<figure>
<graphic graphicname="A135682" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>12</t-value1>
<t-value2>122</t-value2>
<t-value4>9</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>