<res>
<down ref="RM0000027E4000X_05_0007" fin="false">OK</down>
<right ref="RM0000027E4000X_05_0022" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000027E4000X_05_0007" proc-id="RM0250U___0000AS600000">
