<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="43">
<name>BODY</name>
<section id="1001H_S001L" variety="S001L">
<name>SEAT</name>
<ttl id="1001H_S001L_72ZD6_T00C1" variety="T00C1">
<name>SEAT HEATER SWITCH</name>
<para id="RM0000028JW000X" category="A" type-id="80001" name-id="SE0W4-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000028JW000X_01" type-id="01" category="01">
<s-1 id="RM0000028JW000X_01_0001" proc-id="RM0250U___00005C400000">
<ptxt>REMOVE SHIFT LEVER KNOB SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Turn the shift lever knob counterclockwise and remove the shift lever knob sub-assembly.</ptxt>
<figure>
<graphic graphicname="B133990" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000028JW000X_01_0002" proc-id="RM0250U___00005C500000">
<ptxt>REMOVE NO. 1 INSTRUMENT CLUSTER FINISH PANEL GARNISH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 2 clips and remove the No. 1 instrument cluster finish panel garnish.</ptxt>
<figure>
<graphic graphicname="B133993" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000028JW000X_01_0003" proc-id="RM0250U___00005C600000">
<ptxt>REMOVE NO. 2 INSTRUMENT CLUSTER FINISH PANEL GARNISH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 2 clips and remove the No. 2 instrument cluster finish panel garnish.</ptxt>
<figure>
<graphic graphicname="B133994" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000028JW000X_01_0004" proc-id="RM0250U___00005C700000">
<ptxt>REMOVE FLOOR SHIFT POSITION INDICATOR HOUSING SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 6 claws and the 3 clips, and then remove the floor shift position indicator housing sub-assembly.</ptxt>
<figure>
<graphic graphicname="B133995" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>with Seat Heater System:</ptxt>
<s3>
<ptxt>Disconnect each connector.</ptxt>
</s3>
</s2>
</content1></s-1>
<s-1 id="RM0000028JW000X_01_0005" proc-id="RM0250U___0000A7000000">
<ptxt>REMOVE SEAT HEATER SWITCH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 2 claws and remove the seat heater switch.</ptxt>
<figure>
<graphic graphicname="B140583E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>