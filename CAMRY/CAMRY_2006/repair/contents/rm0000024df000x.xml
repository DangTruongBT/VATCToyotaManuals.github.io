<para id="RM0000024DF000X" category="A" type-id="8000E" name-id="IP08V-03" from="200601">
<name>REASSEMBLY</name>
<subpara id="RM0000024DF000X_01" type-id="01" category="01">
<s-1 id="RM0000024DF000X_01_0001" proc-id="RM0250U___00006B300000">
<ptxt>INSTALL NO. 1 INSTRUMENT PANEL PIN (for TMMK Made)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the 2 No. 1 instrument panel pins with the 2 screws &lt;X&gt;.</ptxt>
<figure>
<graphic graphicname="B137271E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000024DF000X_01_0018" proc-id="RM0250U___0000CB800000">
<ptxt>INSTALL PLASMACLUSTER (w/ Plasmacluster)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the "Plasmacluster" with the 2 screws.</ptxt>
<figure>
<graphic graphicname="E128542" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.4</t-value1>
<t-value2>55</t-value2>
<t-value3>48</t-value3>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM0000024DF000X_01_0003" proc-id="RM0250U___00006B400000">
<ptxt>INSTALL GLOVE BOX LIGHT ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 2 claws and install the glove box light.</ptxt>
<figure>
<graphic graphicname="B134023" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000024DF000X_01_0021" proc-id="RM0250U___000001T00000">
<ptxt>INSTALL FRONT PASSENGER AIRBAG ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 10 hooks and install the front passenger airbag assembly on the instrument panel.</ptxt>
<figure>
<graphic graphicname="C132566" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 2 screws.</ptxt>
<figure>
<graphic graphicname="C132565" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000024DF000X_01_0019" proc-id="RM0250U___0000C1K00000">
<ptxt>INSTALL NAVIGATION ANTENNA ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the navigation antenna assembly with the 2 screws.</ptxt>
<figure>
<graphic graphicname="E129192E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Engage the 3 clamps.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000024DF000X_01_0020" proc-id="RM0250U___0000C1K00001">
<ptxt>INSTALL NO. 2 ANTENNA CORD SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 6 clamps and clip and install the No. 2 antenna cord sub-assembly.</ptxt>
<figure>
<graphic graphicname="E129184E01" width="7.106578999in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000024DF000X_01_0006" proc-id="RM0250U___00006HY00000">
<ptxt>INSTALL NO. 2 HEATER TO REGISTER DUCT (for TMC Made)</ptxt>
<content1 releasenbr="1">
