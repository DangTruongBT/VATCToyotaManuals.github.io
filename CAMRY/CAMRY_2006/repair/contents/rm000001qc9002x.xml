<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1001A_S001B" variety="S001B">
<name>LIGHTING</name>
<ttl id="1001A_S001B_72Y3K_T008D" variety="T008D">
<name>REAR COMBINATION LIGHT ASSEMBLY</name>
<para id="RM000001QC9002X" category="A" type-id="30014" name-id="LI1S9-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000001QC9002X_01" type-id="01" category="01">
<s-1 id="RM000001QC9002X_01_0014" proc-id="RM0250U___00003E800000">
<ptxt>INSTALL REAR LIGHT ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the pin and install the rear light assembly.</ptxt>
<figure>
<graphic graphicname="E128227E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 3 nuts.</ptxt>
<torque>
<torqueitem>
<t-value1>3.6</t-value1>
<t-value2>37</t-value2>
<t-value3>32</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the connector and clamp.</ptxt>
<figure>
<graphic graphicname="E128231E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001QC9002X_01_0027" proc-id="RM0250U___00005T600000">
<ptxt>INSTALL LUGGAGE COMPARTMENT DOOR COVER
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the luggage compartment door cover with the 13 clips.</ptxt>
<figure>
<graphic graphicname="B135458" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001QC9002X_01_0001" proc-id="RM0250U___00003E700000">
<ptxt>INSTALL REAR COMBINATION LIGHT ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the clip and install the rear combination light assembly.</ptxt>
<figure>
<graphic graphicname="E128229" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 3 nuts.</ptxt>
<torque>
<torqueitem>
<t-value1>3.6</t-value1>
<t-value2>37</t-value2>
<t-value3>32</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the 2 connectors and clamp.</ptxt>
<figure>
<graphic graphicname="E128226E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001QC9002X_01_0029" proc-id="RM0250U___00006B900000">
<ptxt>INSTALL REAR FLOOR FINISH PLATE
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 7 clips and install the rear floor finish plate.</ptxt>
<figure>
<graphic graphicname="B136852" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001QC9002X_01_0030" proc-id="RM0250U___00006BA00000">
<ptxt>INSTALL NO. 1 LUGGAGE COMPARTMENT TRIM HOOK
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the 2 No. 1 luggage compartment trim hooks with the 2 screws.</ptxt>
<figure>
<graphic graphicname="B136879" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001QC9002X_01_0031" proc-id="RM0250U___00006BB00000">
<ptxt>INSTALL LUGGAGE COMPARTMENT SIDE TRAY ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the clip and install the luggage compartment side tray assembly.</ptxt>
<figure>
<graphic graphicname="B136853" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the bolt.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001QC9002X_01_0024">
<ptxt>INSTALL SPARE WHEEL COVER ASSEMBLY</ptxt>
</s-1>
<s-1 id="RM000001QC9002X_01_0025">
<ptxt>INSTALL SPARE WHEEL COVER CLAMP</ptxt>
</s-1>
<s-1 id="RM000001QC9002X_01_0026">
<ptxt>INSTALL LUGGAGE COMPARTMENT FLOOR MAT</ptxt>
</s-1>
<s-1 id="RM000001QC9002X_01_0032" proc-id="RM0250U___00008LX00000">
<ptxt>INSTALL REAR BUMPER ASSEMBLY (w/o Rear Lower Spoiler)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage each claw.</ptxt>
<figure>
<graphic graphicname="B137214" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the rear bumper assembly with the 6 screws and 2 clips.</ptxt>
</s2>
<s2>
<ptxt>Install the 2 rear bumper plates.</ptxt>
<figure>
<graphic graphicname="B137213" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001QC9002X_01_0033" proc-id="RM0250U___0000AGG00000">
<ptxt>INSTALL REAR BUMPER ASSEMBLY (w/ Rear Lower Spoiler)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage each claw.</ptxt>
<figure>
<graphic graphicname="B140154" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the rear bumper assembly with the 6 screws.</ptxt>
</s2>
<s2>
<ptxt>Install the 2 rear bumper plates.</ptxt>
<figure>
<graphic graphicname="B147905" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001QC9002X_01_0034" proc-id="RM0250U___0000AGH00000">
<ptxt>INSTALL REAR FLOOR BOARD (w/ Rear Lower Spoiler)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the rear floor board with the 3 nuts, 2 clips and 4 screws.</ptxt>
<figure>
<graphic graphicname="B138885E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>