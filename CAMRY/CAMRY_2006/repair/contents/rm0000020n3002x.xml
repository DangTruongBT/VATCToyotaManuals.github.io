<name>BODY ELECTRICAL</name>
<section id="1002Q_S001I" variety="S001I">
<name>NAVIGATION</name>
<ttl id="1002Q_S001I_72YIF_T00A4" variety="T00A4">
<name>NAVIGATION SYSTEM</name>
<para id="RM0000020N3002X" category="J" type-id="300CY" name-id="NS0NT-03" from="200601">
<dtccode/>
<dtcname>CD Sound Skips</dtcname>
<subpara id="RM0000020N3002X_01" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM0000020N3002X_02" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM0000020N3002X_02_0001" proc-id="RM0250U___00004VG00000">
<testtitle>CHECK CD</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check the CD.</ptxt>
<figure>
<graphic graphicname="I100151" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>OK</title>
<specitem>
<ptxt>The CD is clean.</ptxt>
</specitem>
</spec>
<atten4>
<ptxt>If dirt is on the CD surface, wipe it clean with a soft cloth from the inside to the outside in a radial direction.</ptxt>
</atten4>
<atten3>
<ptxt>Do not use a conventional record cleaner or anti-static preservative.</ptxt>
</atten3>
</test1>
</content6>
<res>
<down ref="RM0000020N3002X_02_0002" fin="false">OK</down>
<right ref="RM0000020N3002X_02_0005" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000020N3002X_02_0002" proc-id="RM0250U___00004VH00000">
<testtitle>CHECK CD</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check that the CD is not deformed or cracked.</ptxt>
<figure>
<graphic graphicname="I100152" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>OK</title>
<specitem>
<ptxt>No deformation or cracks on the CD.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000020N3002X_02_0003" fin="false">OK</down>
<right ref="RM0000020N3002X_02_0006" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000020N3002X_02_0003" proc-id="RM0250U___00004VI00000">
<testtitle>CHECK OPERATION OF ANOTHER CD</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check using another CD.</ptxt>
<test2>
<ptxt>Check if the problem recurs using another CD.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The problem does not occur.</ptxt>
</specitem>
</spec>
</test2>
</test1>
</content6>
<res>
<down ref="RM0000020N3002X_02_0004" fin="false">NG</down>
<right ref="RM0000020N3002X_02_0006" fin="true">OK</right>
</res>
</testgrp>
<testgrp id="RM0000020N3002X_02_0004" proc-id="RM0250U___00004VJ00000">
<testtitle>CHECK RADIO AND NAVIGATION ASSEMBLY</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check the radio and navigation assembly installation condition.</ptxt>
<test2>
<ptxt>Check that the radio and navigation assembly is properly installed.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Radio and navigation assembly is properly installed.</ptxt>
</specitem>
</spec>
</test2>
</test1>
</content6>
<res>
<down ref="RM0000020N3002X_02_0007" fin="true">OK</down>
<right ref="RM0000020N3002X_02_0008" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000020N3002X_02_0005">
<testtitle>CLEAN CD</testtitle>
</testgrp>
<testgrp id="RM0000020N3002X_02_0006">
<testtitle>CD IS FAULTY</testtitle>
</testgrp>
<testgrp id="RM0000020N3002X_02_0007">
<testtitle>REPLACE RADIO AND NAVIGATION ASSEMBLY</testtitle>
</testgrp>
<testgrp id="RM0000020N3002X_02_0008">
<testtitle>REINSTALL RADIO AND NAVIGATION ASSEMBLY</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
