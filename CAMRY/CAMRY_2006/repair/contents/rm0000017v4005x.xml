<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10006_S0004" variety="S0004">
<name>2AZ-FE ENGINE CONTROL SYSTEM</name>
<ttl id="10006_S0004_731VR_T00FY" variety="T00FY">
<name>CAMSHAFT POSITION SENSOR</name>
<para id="RM0000017V4005X" category="A" type-id="30014" name-id="ES49H-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000017V4005X_01" type-id="01" category="01">
<s-1 id="RM0000017V4005X_01_0001" proc-id="RM0250U___0000B6B00000">
<ptxt>INSTALL CAMSHAFT POSITION SENSOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply a light coat of engine oil to the O-ring of the sensor.</ptxt>
<figure>
<graphic graphicname="A095434E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Make sure that the O-ring is not cracked or jammed when installing it.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Install the camshaft position sensor with the bolt.</ptxt>
<figure>
<graphic graphicname="A124557" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>9.0</t-value1>
<t-value2>90</t-value2>
<t-value3>80</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the camshaft position sensor connector.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000017V4005X_01_0006" proc-id="RM0250U___0000B9500000">
<ptxt>INSTALL AIR CLEANER CAP SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the mass air flow meter connector (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A135666E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the purge VSV connector (<sup>*</sup>2).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the 2 purge VSV vacuum hoses (<sup>*</sup>3).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the purge line hose from the clamp (<sup>*</sup>4).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the No. 2 ventilation hose from the air cleaner hose.</ptxt>
<figure>
<graphic graphicname="A135667E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Lock the No. 1 air cleaner hose clamp, and then disconnect the No. 1 air cleaner hose from the throttle body.</ptxt>
<figure>
<graphic graphicname="A135668" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts and air cleaner cap.</ptxt>
<figure>
<graphic graphicname="A135669" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the air cleaner filter element from the air cleaner case.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000017V4005X_01_0003">
<ptxt>CHECK FOR ENGINE OIL LEAKS</ptxt>
</s-1>
<s-1 id="RM0000017V4005X_01_0007" proc-id="RM0250U___0000AMD00000">
<ptxt>INSTALL NO. 1 ENGINE COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the engine cover with the 2 nuts.</ptxt>
<figure>
<graphic graphicname="A134904" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>9.0</t-value1>
<t-value2>92</t-value2>
<t-value3>80</t-value3>
</torqueitem>
</torque>
</s2>
</content1></s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>