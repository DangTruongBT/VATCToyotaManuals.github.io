<subpara id="RM00000221E003X_08" type-id="67" category="03" proc-id="RM0250U___0000CIK00000">
<name>TYPICAL MALFUNCTION THRESHOLDS</name>
<content5 releasenbr="1">
<table pgwide="1">
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.83in"/>
<colspec colname="COL2" colwidth="4.25in"/>
<tbody>
<row>
<entry valign="middle">
<ptxt>One of following conditions met</ptxt>
</entry>
<entry valign="middle">
<ptxt>-</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>EVAP pressure just after reference pressure measurement start</ptxt>
</entry>
<entry valign="middle">
<ptxt>More than -1 kPa (-7.5 mmHg)</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
