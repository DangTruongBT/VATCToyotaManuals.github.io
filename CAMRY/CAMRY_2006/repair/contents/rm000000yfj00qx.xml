<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="1000C_S000M" variety="S000M">
<name>2GR-FE COOLING</name>
<ttl id="1000C_S000M_72Z7J_T00B7" variety="T00B7">
<name>COOLING FAN MOTOR</name>
<para id="RM000000YFJ00QX" category="G" type-id="8000T" name-id="CO01R-19" from="200601">
<name>ON-VEHICLE INSPECTION</name>
<subpara id="RM000000YFJ00QX_01" type-id="01" category="01">
<s-1 id="RM000000YFJ00QX_01_0001" proc-id="RM0250U___000064900000">
<ptxt>COOLING FAN MOTOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Check that the motor turns smoothly when the battery is connected to the fan motor connector.</ptxt>
<figure>
<graphic graphicname="A110241E04" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Measure the current while the motor is turning.</ptxt>
<spec>
<title>Standard current</title>
<subtitle>With trailer hitch</subtitle>
<specitem>
<ptxt>11.8 to 14.8 A at 20°C (68°F)</ptxt>
</specitem>
<subtitle>Without trailer hitch</subtitle>
<specitem>
<ptxt>6.8 to 9.8 A at 20°C (68°F)</ptxt>
</specitem>
</spec>
<ptxt>If the result is not as specified, replace the cooling fan motor.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YFJ00QX_01_0002" proc-id="RM0250U___000064A00000">
<ptxt>NO. 2 COOLING FAN MOTOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Check that the motor turns smoothly when the battery is connected to the fan motor connector.</ptxt>
<figure>
<graphic graphicname="A110242E04" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Measure the current while the motor is turning.</ptxt>
<spec>
<title>Standard current</title>
<subtitle>With trailer hitch</subtitle>
<specitem>
<ptxt>6.8 to 9.8 A at 20°C (68°F)</ptxt>
</specitem>
<subtitle>Without trailer hitch</subtitle>
<specitem>
<ptxt>6.8 to 9.8 A at 20°C (68°F)</ptxt>
</specitem>
</spec>
<ptxt>If the result is not as specified, replace the cooling fan motor No. 2.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>