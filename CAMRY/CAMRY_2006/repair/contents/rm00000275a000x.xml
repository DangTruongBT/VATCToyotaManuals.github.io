<subpara id="RM00000275A000X_01" type-id="01" category="01">
<s-1 id="RM00000275A000X_01_0001" proc-id="RM0250U___000071G00000">
<ptxt>INSPECT WINDSHIELD WIPER SWITCH ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Check the continuity of the windshield wiper switch assembly.</ptxt>
<figure>
<graphic graphicname="E069286E04" width="2.775699831in" height="1.771723296in"/>
</figure>
<s3>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<subtitle>Front Wiper Switch</subtitle>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Switch Position</ptxt>
</entry>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Resistance</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>MIST</ptxt>
</entry>
<entry valign="middle">
<ptxt>E20-2 (+B) - E20-3 (+1)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>OFF</ptxt>
</entry>
<entry valign="middle">
<ptxt>E20-1 (+S) - E20-3 (+1)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>INT</ptxt>
</entry>
<entry valign="middle">
<ptxt>E20-1 (+S) - E20-3 (+1)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>LO</ptxt>
</entry>
<entry valign="middle">
<ptxt>E20-2 (+B) - E20-3 (+1)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>HI</ptxt>
</entry>
<entry valign="middle">
<ptxt>E20-2 (+B) - E20-4 (+2)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<subtitle>Front Washer Switch</subtitle>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Switch Position</ptxt>
</entry>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Resistance</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>OFF</ptxt>
</entry>
<entry valign="middle">
<ptxt>E19-3 (WF) - E19-2 (EW)</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>ON</ptxt>
</entry>
<entry valign="middle">
<ptxt>E19-3 (WF) - E19-2 (EW)</ptxt>
