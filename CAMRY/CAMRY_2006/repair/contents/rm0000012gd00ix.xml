<testgrp id="RM0000012GD00IX_05_0016" proc-id="RM0250U___0000BUH00000">
<testtitle>REPLACE SKID CONTROL ECU</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Replace the skid control ECU to a new or a normal one.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The operation of the speedometer returns to normal.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000012GD00IX_05_0020" fin="true">OK</down>
<right ref="RM0000012GD00IX_05_0018" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000012GD00IX_05_0017">
<testtitle>GO TO CAN COMMUNICATION SYSTEM</testtitle>
</testgrp>
<testgrp id="RM0000012GD00IX_05_0018">
<testtitle>REPLACE COMBINATION METER ASSEMBLY</testtitle>
</testgrp>
<testgrp id="RM0000012GD00IX_05_0019">
