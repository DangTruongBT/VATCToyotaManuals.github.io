<down ref="RM000000WZ3011X_05_0025" fin="false">NG</down>
<right ref="RM000000WZ3011X_05_0030" fin="false">OK</right>
</res>
</testgrp>
<testgrp id="RM000000WZ3011X_05_0025" proc-id="RM0250U___0000AZQ00000">
