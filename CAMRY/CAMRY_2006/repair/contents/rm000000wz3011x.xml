</test1>
<test1>
<ptxt>Select the following menu items: DIAGNOSIS / ENHANCED OBD II / DATA LIST / ALL / STARTER SIG. Read the values.</ptxt>
</test1>
<test1>
<ptxt>Check the result when the ignition switch is turned on (IG) and when the engine is started.</ptxt>
<spec>
<title>Standard</title>
<table pgwide="1">
<tgroup cols="2">
<colspec colname="COL1" align="center" colwidth="3.55in"/>
<colspec colname="COL2" align="center" colwidth="3.53in"/>
<thead>
<row>
<entry>
<ptxt>Display (STARTER SIG)</ptxt>
</entry>
<entry>
<ptxt>Ignition Switch Position</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>OFF</ptxt>
</entry>
<entry>
<ptxt>ON</ptxt>
</entry>
</row>
<row>
<entry>
<ptxt>ON</ptxt>
</entry>
<entry>
<ptxt>START</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
