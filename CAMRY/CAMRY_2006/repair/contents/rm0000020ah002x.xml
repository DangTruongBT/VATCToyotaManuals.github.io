<tbody>
<row>
<entry morerows="1" valign="middle">
<ptxt>RC0 (E58-29) - E (E58-17)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Engine switch off, all doors closed and transmitter switch not pressed</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 V</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Engine switch off, all doors closed and transmitter switch pressed</ptxt>
</entry>
<entry valign="middle">
<ptxt>4.6 to 5.4 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000020AH002X_04_0010" fin="false">NG</down>
<right ref="RM0000020AH002X_04_0001" fin="false">OK</right>
</res>
