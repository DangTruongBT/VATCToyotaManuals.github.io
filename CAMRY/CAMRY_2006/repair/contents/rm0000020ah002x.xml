<testgrp id="RM0000020AH002X_04_0002" proc-id="RM0250U___00004KE00000">
<testtitle>INSPECT CERTIFICATION ECU (+B TERMINAL)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Measure the voltage according to value(s) in the table below.</ptxt>
<figure>
<graphic graphicname="B139430E02" width="2.775699831in" height="2.775699831in"/>
</figure>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Symbol</ptxt>
<ptxt>(Tester Connection)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>+B (E58-1) - E (E58-17)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 to 14 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000020AH002X_04_0009" fin="false">OK</down>
<right ref="RM0000020AH002X_04_0005" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000020AH002X_04_0009" proc-id="RM0250U___0000B1T00000">
<testtitle>INSPECT CERTIFICATION ECU (RC0 TERMINAL)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Measure the voltage according to value(s) in the table below.</ptxt>
<figure>
<graphic graphicname="B139430E03" width="2.775699831in" height="2.775699831in"/>
</figure>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Symbol</ptxt>
<ptxt>(Tester Connection)</ptxt>
