<name>AUDIO / VISUAL</name>
<ttl id="1001C_S001D_72YQ0_T00AC" variety="T00AC">
<name>STEREO COMPONENT AMPLIFIER</name>
<para id="RM0000026JN000X" category="A" type-id="30014" name-id="AV1R6-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000026JN000X_01" type-id="01" category="01">
<s-1 id="RM0000026JN000X_01_0001" proc-id="RM0250U___00005A100000">
<ptxt>INSTALL STEREO COMPONENT AMPLIFIER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the stereo component amplifier assembly as shown in the illustration.</ptxt>
<figure>
<graphic graphicname="E129200" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Install the bolt and connect each connector.</ptxt>
<figure>
<graphic graphicname="E129198" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Engage the clip.</ptxt>
</s2>
<s2>
<ptxt>Install the bolt.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026JN000X_01_0002" proc-id="RM0250U___00005A200000">
<ptxt>INSTALL AUDIO AMPLIFIER COVER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the audio amplifier cover with the 2 clips.</ptxt>
<figure>
<graphic graphicname="E129197" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026JN000X_01_0003" proc-id="RM0250U___0000BKI00000">
<ptxt>INSTALL FRONT SEAT ASSEMBLY RH (for Manual Seat)</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedures for the RH side and the LH side (see page <xref label="Seep01" href="RM000001OH3003X_01_0001"/>).</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000026JN000X_01_0004" proc-id="RM0250U___0000BKJ00000">
<ptxt>INSTALL INNER SEAT TRACK BRACKET COVER RH (for Manual Seat)</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedures for the RH side and the LH side (see page <xref label="Seep01" href="RM000001OH3003X_01_0002"/>).</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000026JN000X_01_0005" proc-id="RM0250U___0000BKK00000">
<ptxt>INSTALL SEAT TRACK COVER RH (for Manual Seat)</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedures for the RH side and the LH side (see page <xref label="Seep01" href="RM000001OH3003X_01_0003"/>).</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000026JN000X_01_0006" proc-id="RM0250U___0000C8500000">
<ptxt>INSTALL FRONT SEAT ASSEMBLY RH (for Power Seat)</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedures for the RH side and the LH side (see page <xref label="Seep01" href="RM000000VBE006X_02_0001"/>).</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000026JN000X_01_0007" proc-id="RM0250U___0000C8600000">
<ptxt>INSTALL INNER SEAT TRACK BRACKET COVER RH (for Power Seat)</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedures for the RH side and the LH side (see page <xref label="Seep01" href="RM000000VBE006X_02_0012"/>).</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000026JN000X_01_0008" proc-id="RM0250U___0000C8700000">
<ptxt>INSTALL SEAT TRACK COVER RH (for Power Seat)</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedures for the RH side and the LH side (see page <xref label="Seep01" href="RM000000VBE006X_02_0011"/>).</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000026JN000X_01_0009">
<ptxt>CONNECT CABLE TO NEGATIVE BATTERY TERMINAL (for Manual Seat)</ptxt>
</s-1>
<s-1 id="RM0000026JN000X_01_0014">
<ptxt>INSPECT SLIDE ADJUSTER LOCK (for Manual Seat)</ptxt>
</s-1>
<s-1 id="RM0000026JN000X_01_0012">
<ptxt>INSPECT FRONT SEAT ASSEMBLY (for Power Seat)</ptxt>
</s-1>
<s-1 id="RM0000026JN000X_01_0011" proc-id="RM0250U___0000CXP00000">
<ptxt>PERFORM ZERO POINT CALIBRATION AND SENSITIVITY CHECK</ptxt>
<content1 releasenbr="1">
<ptxt>(See page <xref label="Seep01" href="RM0000010VN00QX"/>)</ptxt>
</content1>
</s-1>
<s-1 id="RM0000026JN000X_01_0013" proc-id="RM0250U___0000D0I00000">
<ptxt>INSPECT SRS WARNING LIGHT</ptxt>
<content1 releasenbr="1">
<ptxt>(See page <xref label="Seep01" href="RM000000XFD00ZX"/>)</ptxt>
</content1>
</s-1>
</subpara>
</para>
