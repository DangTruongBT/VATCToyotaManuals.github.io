<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10025_S001V" variety="S001V">
<name>2AZ-FE CHARGING</name>
<ttl id="10025_S001V_72ZCO_T00BW" variety="T00BW">
<name>GENERATOR</name>
<para id="RM0000017VK005X" category="A" type-id="80002" name-id="CH040-04" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM0000017VK005X_01" type-id="01" category="01">
<s-1 id="RM0000017VK005X_01_0001" proc-id="RM0250U___00006K300000">
<ptxt>REMOVE GENERATOR CLUTCH PULLEY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a screwdriver, puncture the center of the generator pulley cap and pry it off.</ptxt>
<figure>
<graphic graphicname="A126771" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Do not reuse the generator pulley cap.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Set SST (A) and (B).</ptxt>
<figure>
<graphic graphicname="A124115E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09820-63020</s-number>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Clamp SST (A) in a vise.</ptxt>
</s2>
<s2>
<ptxt>Place the rotor shaft end into SST (A).</ptxt>
<figure>
<graphic graphicname="A128605E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Fit SST (B) to the clutch pulley.</ptxt>
<figure>
<graphic graphicname="A128606E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Loosen the pulley by turning SST (B) in the direction shown in the illustration.</ptxt>
<figure>
<graphic graphicname="A128607E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the generator assembly from the SST.</ptxt>
</s2>
<s2>
<ptxt>Remove the clutch pulley from the rotor shaft.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000017VK005X_01_0002" proc-id="RM0250U___00006K400000">
<ptxt>REMOVE GENERATOR BRUSH HOLDER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Place the generator assembly on the clutch pulley.</ptxt>
<figure>
<graphic graphicname="A128608" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 3 nuts and generator rear end cover.</ptxt>
<figure>
<graphic graphicname="A128610" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000017VK005X_01_0004" proc-id="RM0250U___00006LE00000">
<ptxt>REMOVE GENERATOR TERMINAL INSULATOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the terminal insulator.</ptxt>
<figure>
<graphic graphicname="A128609" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000017VK005X_01_0005" proc-id="RM0250U___00006LF00000">
<ptxt>REMOVE GENERATOR BRUSH HOLDER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 screws and generator brush holder.</ptxt>
<figure>
<graphic graphicname="A128611" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000017VK005X_01_0003" proc-id="RM0250U___00006K500000">
<ptxt>REMOVE GENERATOR ROTOR ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 4 bolts.</ptxt>
<figure>
<graphic graphicname="A128612" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the bolt and cord clip.</ptxt>
<figure>
<graphic graphicname="A128613" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using SST, remove the coil.</ptxt>
<figure>
<graphic graphicname="A128614E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-40011</s-number>
<s-subnumber>09951-04020</s-subnumber>
<s-subnumber>09952-04010</s-subnumber>
<s-subnumber>09953-04020</s-subnumber>
<s-subnumber>09954-04010</s-subnumber>
<s-subnumber>09955-04071</s-subnumber>
<s-subnumber>09957-04010</s-subnumber>
<s-subnumber>09958-04011</s-subnumber>
</sstitem>
</sst>
</s2>
</content1>
</s-1>
<s-1 id="RM0000017VK005X_01_0006" proc-id="RM0250U___00006LG00000">
<ptxt>REMOVE GENERATOR ROTOR ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the washer.</ptxt>
<figure>
<graphic graphicname="A118365E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the generator rotor.</ptxt>
<figure>
<graphic graphicname="A128615" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000017VK005X_01_0007" proc-id="RM0250U___00006LJ00000">
<ptxt>REMOVE GENERATOR DRIVE END FRAME BEARING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 4 screws and bearing retainer.</ptxt>
<figure>
<graphic graphicname="A128617" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using SST and a hammer, tap out the bearing.</ptxt>
<figure>
<graphic graphicname="A128618E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-60010</s-number>
<s-subnumber>09951-00250</s-subnumber>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07100</s-subnumber>
</sstitem>
</sst>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>