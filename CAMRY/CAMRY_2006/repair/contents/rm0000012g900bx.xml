<entry valign="middle" align="center">
<ptxt>Recovery</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>Shift position data is interrupted for 3.1 seconds.</ptxt>
</entry>
<entry valign="middle">
<ptxt>All indicator light go off.</ptxt>
</entry>
<entry valign="middle">
<ptxt>Normal data is received.</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Gear position data is interrupted for 3 seconds.</ptxt>
</entry>
<entry valign="middle">
<ptxt>The gear position indicator light goes off.</ptxt>
</entry>
<entry valign="middle">
<ptxt>Normal data is received.</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
