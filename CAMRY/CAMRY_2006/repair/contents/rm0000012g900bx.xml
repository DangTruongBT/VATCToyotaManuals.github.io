<content5 releasenbr="1">
<table pgwide="1">
<title>ENGINE COOLANT TEMPERATURE GAUGE:</title>
<tgroup cols="3">
<colspec colname="COL1" colwidth="2.36in"/>
<colspec colname="COL2" colwidth="2.36in"/>
<colspec colname="COL3" colwidth="2.36in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Response</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Recovery</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>Engine coolant temperature data is interrupted for 3.1 seconds.</ptxt>
</entry>
<entry valign="middle">
<ptxt>The gauge needle indicates between / and C.</ptxt>
</entry>
<entry valign="middle">
<ptxt>Engine coolant temperature data is received.</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<table pgwide="1">
