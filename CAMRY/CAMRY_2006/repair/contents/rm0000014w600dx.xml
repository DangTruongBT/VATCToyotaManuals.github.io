<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1002P_S001H" variety="S001H">
<name>METER</name>
<ttl id="1002P_S001H_73535_T00GH" variety="T00GH">
<name>FUEL SENDER GAUGE ASSEMBLY (for 2AZ-FE)</name>
<para id="RM0000014W600DX" category="G" type-id="3001K" name-id="ME04O-11" from="200601">
<name>INSPECTION</name>
<subpara id="RM0000014W600DX_01" type-id="01" category="01">
<s-1 id="RM0000014W600DX_01_0001" proc-id="RM0250U___0000B3500001">
<ptxt>INSPECT FUEL SENDER GAUGE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the fuel sender gauge assembly.</ptxt>
<figure>
<graphic graphicname="E132666E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Check that the float moves smoothly between F and E.</ptxt>
</s2>
<s2>
<ptxt>Measure the resistance between the terminals 2 (S) and 3 (FE) of connector according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="1.45in"/>
<colspec colname="COL2" colwidth="2.68in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Float Level</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Resistance (Ω)</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>F</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>13.5 to 16.5</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>Between E and F</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>13.5 to 414.5 (Gradually changes)</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>E</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>405.5 to 414.5</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<atten4>
<ptxt>If the value is not as specified, replace the fuel sender gauge assembly.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>