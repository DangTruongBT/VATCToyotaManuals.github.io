<testgrp id="RM000002769000X_06_0033">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
<testgrp id="RM000002769000X_06_0034">
<testtitle>REPLACE FUSE (IGN FUSE)</testtitle>
</testgrp>
<testgrp id="RM000002769000X_06_0035">
<testtitle>REPLACE IGNITION SWITCH ASSEMBLY</testtitle>
</testgrp>
<testgrp id="RM000002769000X_06_0036" proc-id="RM0250U___0000BC600000">
<testtitle>CHECK HARNESS AND CONNECTOR (EFI RELAY - ECM, EFI RELAY - BODY GROUND)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the A24 ECM connector.</ptxt>
<figure>
