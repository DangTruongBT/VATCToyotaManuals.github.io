<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10008_S000H" variety="S000H">
<name>2GR-FE EMISSION CONTROL</name>
<ttl id="10008_S000H_73426_T00GF" variety="T00GF">
<name>VENTILATION VALVE</name>
<para id="RM000000Q4K00HX" category="A" type-id="30014" name-id="EC0TH-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000000Q4K00HX_01" type-id="01" category="01">
<s-1 id="RM000000Q4K00HX_01_0001" proc-id="RM0250U___0000BT500000">
<ptxt>INSTALL VENTILATION VALVE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the ventilation valve.</ptxt>
<figure>
<graphic graphicname="A105280E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<s3>
<ptxt>Apply adhesive to 2 or 3 threads.</ptxt>
<spec>
<title>Adhesive</title>
<specitem>
<ptxt>Part No. 08833-00070, THREE BOND 1324 or equivalent.</ptxt>
</specitem>
</spec>
</s3>
<s3>
<ptxt>Install the ventilation valve.</ptxt>
<figure>
<graphic graphicname="A138519E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>27</t-value1>
<t-value2>275</t-value2>
<t-value4>20</t-value4>
</torqueitem>
</torque>
</s3>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Q4K00HX_01_0003" proc-id="RM0250U___0000BT700000">
<ptxt>CONNECT VENTILATION HOSE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Connect the ventilation hose to the ventilation valve.</ptxt>
<figure>
<graphic graphicname="A135715E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Q4K00HX_01_0002" proc-id="RM0250U___00006RL00000">
<ptxt>INSTALL V-BANK COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Fit the 3 retainers and install the V-bank cover.</ptxt>
<figure>
<graphic graphicname="A132968" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>