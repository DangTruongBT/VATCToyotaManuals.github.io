<section id="1002K_S0015" variety="S0015">
<name>AIR CONDITIONING</name>
<ttl id="1002K_S0015_72YGE_T009K" variety="T009K">
<name>AIR CONDITIONING SYSTEM</name>
<para id="RM000001O7Y002X" category="D" type-id="303F3" name-id="AC1A3-06" from="200601">
<name>DIAGNOSIS SYSTEM</name>
<subpara id="RM000001O7Y002X_z0" proc-id="RM0250U___00004FJ00000">
<content5 releasenbr="1">
<step1>
<ptxt>CHECK DLC3</ptxt>
<step2>
<ptxt>The vehicle's ECU uses the ISO 15765-4 for communication. The terminal arrangement of the DLC3 complies with SAE J1962 and matches the ISO 15765-4 format.</ptxt>
<figure>
<graphic graphicname="H100769E16" width="2.775699831in" height="1.771723296in"/>
</figure>
<table pgwide="1">
<tgroup cols="4" align="center">
<colspec colname="COL1" colwidth="1.78in"/>
<colspec colname="COL3" colwidth="1.78in"/>
<colspec colname="COL5" colwidth="1.78in"/>
<colspec colname="COL6" colwidth="1.74in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Symbol (Terminal No.)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Terminal Description</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>SIL (7) - SG (5)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Bus "+" line</ptxt>
</entry>
<entry valign="middle">
