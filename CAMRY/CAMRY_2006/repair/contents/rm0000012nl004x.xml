<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10006_S0004" variety="S0004">
<name>2AZ-FE ENGINE CONTROL SYSTEM</name>
<ttl id="10006_S0004_731VK_T00FR" variety="T00FR">
<name>CAMSHAFT TIMING OIL CONTROL VALVE ASSEMBLY</name>
<para id="RM0000012NL004X" category="A" type-id="30014" name-id="ES109-04" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000012NL004X_01" type-id="01" category="01">
<s-1 id="RM0000012NL004X_01_0001" proc-id="RM0250U___0000B3Z00000">
<ptxt>INSTALL CAMSHAFT TIMING OIL CONTROL VALVE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply a light coat of engine oil to an O-ring of the camshaft timing oil control valve assembly sensor.</ptxt>
<figure>
<graphic graphicname="A093611E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the camshaft timing oil control valve assembly with the bolt.</ptxt>
<figure>
<graphic graphicname="A124556" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>9.0</t-value1>
<t-value2>92</t-value2>
<t-value3>80</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the camshaft timing oil control valve assembly connector.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000012NL004X_01_0013" proc-id="RM0250U___0000B8P00000">
<ptxt>INSTALL CLIP NUT</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the clip nut.</ptxt>
<figure>
<graphic graphicname="A135665E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000012NL004X_01_0014" proc-id="RM0250U___0000B8Q00000">
<ptxt>INSTALL VACUUM HOSE CLAMP</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the vacuum hose clamp with the bolt.</ptxt>
<figure>
<graphic graphicname="A135664" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM0000012NL004X_01_0011" proc-id="RM0250U___0000A7T00000">
<ptxt>INSTALL NO. 1 ENGINE COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 nuts and cover.</ptxt>
<figure>
<graphic graphicname="A134904" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>