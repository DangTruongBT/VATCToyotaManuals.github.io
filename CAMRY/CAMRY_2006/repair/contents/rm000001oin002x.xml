<tmc-service-inc>
<pub id="RM0251U">
<servcat id="43">
<name>BODY</name>
<section id="1001K_S001M" variety="S001M">
<name>ENGINE HOOD / DOOR</name>
<ttl id="1001K_S001M_72XLM_T006X" variety="T006X">
<name>LUGGAGE COMPARTMENT DOOR</name>
<para id="RM000001OIN002X" category="A" type-id="8000E" name-id="ED0N1-01" from="200601">
<name>REASSEMBLY</name>
<subpara id="RM000001OIN002X_01" type-id="01" category="01">
<s-1 id="RM000001OIN002X_01_0029" proc-id="RM0250U___00003F700000">
<ptxt>INSTALL LICENSE PLATE LIGHT ASSEMBLY LH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 2 claws to install the license plate light assembly.</ptxt>
<figure>
<graphic graphicname="E128223" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the connector.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001OIN002X_01_0013">
<ptxt>INSTALL LICENSE PLATE LIGHT ASSEMBLY RH</ptxt>
</s-1>
<s-1 id="RM000001OIN002X_01_0030" proc-id="RM0250U___00003E800000">
<ptxt>INSTALL REAR LIGHT ASSEMBLY LH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the pin and install the rear light assembly.</ptxt>
<figure>
<graphic graphicname="E128227E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 3 nuts.</ptxt>
<torque>
<torqueitem>
<t-value1>3.6</t-value1>
<t-value2>37</t-value2>
<t-value3>32</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the connector and clamp.</ptxt>
<figure>
<graphic graphicname="E128231E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001OIN002X_01_0016">
<ptxt>INSTALL REAR LIGHT ASSEMBLY RH</ptxt>
</s-1>
<s-1 id="RM000001OIN002X_01_0037" proc-id="RM0250U___00005T300000">
<ptxt>INSTALL LUGGAGE COMPARTMENT OUTSIDE DOOR GARNISH SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 2 clips and install the luggage compartment door outside garnish.</ptxt>
<figure>
<graphic graphicname="B135462" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 3 nuts.</ptxt>
<figure>
<graphic graphicname="B135460" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001OIN002X_01_0038" proc-id="RM0250U___000033200000">
<ptxt>INSTALL LUGGAGE DOOR OPENING SWITCH ASSEMBLY (w/ Smart Key System)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the luggage door opening switch assembly with the 2 screws.</ptxt>
</s2>
<s2>
<ptxt>Connect the connector.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001OIN002X_01_0035" proc-id="RM0250U___00001S300000">
<ptxt>INSTALL REAR SPOILER (for SE Grade)
</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>When installing the spoiler, heat the vehicle body and spoiler using a heat light.</ptxt>
</atten4>
<spec>
<title>Heating temperature</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry align="center">
<ptxt>Item </ptxt>
</entry>
<entry align="center">
<ptxt>Temperature</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>Vehicle Body</ptxt>
</entry>
<entry align="center">
<ptxt>40 to 60°C (104 to 140°F)</ptxt>
</entry>
</row>
<row>
<entry>
<ptxt>Spoiler</ptxt>
</entry>
<entry align="center">
<ptxt>20 to 30°C (68 to 86°F)</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<atten3>
<ptxt>Do not heat the vehicle body and rear spoiler excessively.</ptxt>
</atten3>
<s2>
<ptxt>Clean the vehicle body surface.</ptxt>
<s3>
<ptxt>Using a heat light, heat the vehicle body surface.</ptxt>
</s3>
<s3>
<ptxt>Remove the double-sided tape from the vehicle body.</ptxt>
</s3>
<s3>
<ptxt>Wipe off any tape adhesive residue with cleaner.</ptxt>
</s3>
</s2>
<s2>
<ptxt>Clean the rear spoiler. (If reusing the rear spoiler)</ptxt>
<s3>
<ptxt>Using a heat light, heat the rear spoiler.</ptxt>
</s3>
<s3>
<ptxt>Remove the double-sided tape from the rear spoiler.</ptxt>
</s3>
<s3>
<ptxt>Wipe off any tape adhesive residue with cleaner.</ptxt>
</s3>
<s3>
<ptxt>Apply new double-sided tape to the rear spoiler.</ptxt>
<figure>
<graphic graphicname="B137017E01" width="7.106578999in" height="2.775699831in"/>
</figure>
</s3>
</s2>
<s2>
<ptxt>Install the rear spoiler.</ptxt>
<figure>
<graphic graphicname="B137018" width="2.775699831in" height="1.771723296in"/>
</figure>
<s3>
<ptxt>Using a heat light, heat the vehicle body and rear spoiler.</ptxt>
</s3>
<s3>
<ptxt>Remove the release paper from the rear spoiler.</ptxt>
<atten4>
<ptxt>After removing the release paper, keep the exposed adhesive free from foreign matter.</ptxt>
</atten4>
</s3>
<s3>
<ptxt>Engage the 4 clips and install the rear spoiler with the 2 nuts.</ptxt>
</s3>
</s2>
</content1></s-1>
<s-1 id="RM000001OIN002X_01_0025" proc-id="RM0250U___00001OP00000">
<ptxt>INSTALL LUGGAGE COMPARTMENT DOOR LOCK CYLINDER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the luggage compartment door lock cylinder with the 2 nuts.</ptxt>
<figure>
<graphic graphicname="B136497" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.5</t-value1>
<t-value2>56</t-value2>
<t-value3>49</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the cable and connector.</ptxt>
<figure>
<graphic graphicname="B136496" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001OIN002X_01_0032" proc-id="RM0250U___00001P300000">
<ptxt>INSTALL LUGGAGE COMPARTMENT DOOR LOCK ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the luggage compartment door lock assembly with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="B136880" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.5</t-value1>
<t-value2>56</t-value2>
<t-value3>49</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the connector.</ptxt>
</s2>
<s2>
<ptxt>Connect the rod.</ptxt>
<figure>
<graphic graphicname="B136492" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001OIN002X_01_0036" proc-id="RM0250U___00005T600000">
<ptxt>INSTALL LUGGAGE COMPARTMENT DOOR COVER
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the luggage compartment door cover with the 13 clips.</ptxt>
<figure>
<graphic graphicname="B135458" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
