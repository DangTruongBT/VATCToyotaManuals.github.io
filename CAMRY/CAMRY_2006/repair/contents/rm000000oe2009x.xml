<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000S" variety="S000S">
<name>U250E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000S_72XQS_T007P" variety="T007P">
<name>SPEED SENSOR</name>
<para id="RM000000OE2009X" category="A" type-id="30014" name-id="AX0M7-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000000OE2009X_03" type-id="01" category="01">
<s-1 id="RM000000OE2009X_03_0006" proc-id="RM0250U___00006L900000">
<ptxt>INSTALL SPEED SENSOR (NC SENSOR)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Coat a new O-ring with ATF WS and install it to the speed sensor.</ptxt>
</s2>
<s2>
<ptxt>Install the speed sensor with the bolt.</ptxt>
<figure>
<graphic graphicname="C135107" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>8.8</t-value1>
<t-value2>90</t-value2>
<t-value3>78</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the speed sensor connector.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000000OE2009X_03_0007" proc-id="RM0250U___00006LA00000">
<ptxt>INSTALL SPEED SENSOR (NT SENSOR)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Coat a new O-ring with ATF WS and install it to the speed sensor.</ptxt>
</s2>
<s2>
<ptxt>Install the speed sensor with the bolt.</ptxt>
<figure>
<graphic graphicname="C135106" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>8.8</t-value1>
<t-value2>90</t-value2>
<t-value3>78</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the speed sensor connector.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000000OE2009X_03_0015" proc-id="RM0250U___00006Z400000">
<ptxt>INSTALL AIR CLEANER CASE SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air cleaner case with the 3 bolts.</ptxt>
<figure>
<graphic graphicname="A134905" width="2.775699831in" height="2.775699831in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the hose clamp.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000OE2009X_03_0016" proc-id="RM0250U___0000B9900000">
<ptxt>INSTALL AIR CLEANER CAP SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air cleaner filter element onto the air cleaner case.</ptxt>
</s2>
<s2>
<ptxt>Insert the hinges. Install the air cleaner cap sub-assembly with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="A135670" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Align the matchmarks of the No. 1 air cleaner hose and throttle body, and then connect the air cleaner hose No. 1 to the throttle body and unfasten the No. 1 air cleaner hose clamp.</ptxt>
<figure>
<graphic graphicname="A135671E01" width="2.775699831in" height="2.775699831in"/>
</figure>
<atten3>
<ptxt>Make sure that the hose clamp is at the correct angle.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Connect the No. 2 ventilation hose to the air cleaner hose.</ptxt>
<figure>
<graphic graphicname="A135667E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the purge line hose to the clamp (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A135666E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the 2 purge VSV vacuum hoses (<sup>*</sup>2).</ptxt>
</s2>
<s2>
<ptxt>Connect the purge VSV connector (<sup>*</sup>3).</ptxt>
</s2>
<s2>
<ptxt>Connect the mass air flow meter connector (<sup>*</sup>4).</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000OE2009X_03_0017" proc-id="RM0250U___0000ALT00000">
<ptxt>INSTALL AIR CLEANER INLET ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air cleaner inlet with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="A134903" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM000000OE2009X_03_0014" proc-id="RM0250U___0000ALE00000">
<ptxt>INSTALL BATTERY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the battery and battery tray.</ptxt>
</s2>
<s2>
<ptxt>Install the battery clamp with the bolt and nut.</ptxt>
<figure>
<graphic graphicname="A134906" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<subtitle>Bolt</subtitle>
<torqueitem>
<t-value1>9.0</t-value1>
<t-value2>92</t-value2>
<t-value3>80</t-value3>
</torqueitem>
<subtitle>Nut</subtitle>
<torqueitem>
<t-value1>3.5</t-value1>
<t-value2>36</t-value2>
<t-value3>31</t-value3>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM000000OE2009X_03_0012" proc-id="RM0250U___0000BD400000">
<ptxt>CONNECT CABLE TO NEGATIVE BATTERY TERMINAL</ptxt>
<content1 releasenbr="1">
<torque>
<torqueitem>
<t-value1>6.9</t-value1>
<t-value2>70</t-value2>
<t-value3>61</t-value3>
</torqueitem>
</torque>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>