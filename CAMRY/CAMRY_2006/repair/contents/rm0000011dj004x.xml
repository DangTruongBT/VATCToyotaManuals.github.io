<tmc-service-inc>
<pub id="RM0251U">
<servcat id="35">
<name>SUSPENSION &amp; AXLE</name>
<section id="1002I_S000Z" variety="S000Z">
<name>SUSPENSION</name>
<ttl id="1002I_S000Z_72VB6_T0058" variety="T0058">
<name>FRONT SUSPENSION LOWER NO. 1 ARM</name>
<para id="RM0000011DJ004X" category="A" type-id="80001" name-id="SP0ZC-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000011DJ004X_02" type-id="11" category="10" proc-id="RM0250U___0000A9300000">
<content3 releasenbr="1">
<atten4>
<list1 type="unordered">
<item>
<ptxt>Use the same procedures for the RH side and the LH side.</ptxt>
</item>
<item>
<ptxt>The procedures listed below are for the LH side.</ptxt>
</item>
</list1>
</atten4>
</content3>
</subpara>
<subpara id="RM0000011DJ004X_01" type-id="01" category="01">
<s-1 id="RM0000011DJ004X_01_0001" proc-id="RM0250U___00000G600000">
<ptxt>REMOVE ENGINE ASSEMBLY WITH TRANSAXLE</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Refer to the instructions for installation of the engine assembly (See page <xref label="Seep01" href="RM000000YIN001X"/> for 2AZ-FE, <xref label="Seep02" href="RM0000021ZT001X"/> for 2GR-FE).</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000011DJ004X_01_0002" proc-id="RM0250U___00000G700000">
<ptxt>REMOVE ENGINE MOUNTING INSULATOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 3 nuts and the engine mounting insulator.</ptxt>
<figure>
<graphic graphicname="C138032E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011DJ004X_01_0003" proc-id="RM0250U___00000G800000">
<ptxt>REMOVE FRONT SUSPENSION LOWER NO. 1 ARM</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 3 bolts and the nut on the front suspension lower No. 1 arm and remove it from the front frame assembly.</ptxt>
<figure>
<graphic graphicname="C111327" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the front lower arm bushing stopper.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>