<para id="RM0000020N7002X" category="J" type-id="80024" name-id="NS0NV-03" from="200601">
<dtccode/>
<dtcname>Display Panel does not Open, Tilt or Tilts Improperly</dtcname>
<subpara id="RM0000020N7002X_01" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM0000020N7002X_02" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM0000020N7002X_02_0001" proc-id="RM0250U___00004YV00000">
<testtitle>CHECK RADIO AND NAVIGATION ASSEMBLY</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check for foreign matter or obstructions caught in the moving parts of the panel.</ptxt>
<figure>
<graphic graphicname="E120094" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>OK</title>
<specitem>
<ptxt>No obstruction or foreign matter found.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000020N7002X_02_0002" fin="false">OK</down>
<right ref="RM0000020N7002X_02_0004" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000020N7002X_02_0002" proc-id="RM0250U___00004YW00000">
<testtitle>CHECK OPERATION</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check if the navigation and audio systems function properly.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Navigation and audio systems function properly.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000020N7002X_02_0003" fin="true">NG</down>
<right ref="RM0000020N7002X_02_0005" fin="true">OK</right>
</res>
</testgrp>
<testgrp id="RM0000020N7002X_02_0003">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM0000020N7002X_02_0004">
<testtitle>REMOVE ANY OBSTRUCTION OR FOREIGN MATTER FOUND</testtitle>
</testgrp>
<testgrp id="RM0000020N7002X_02_0005">
<testtitle>REPLACE RADIO AND NAVIGATION ASSEMBLY</testtitle>
</testgrp>
</subpara>
</para>
