<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="1000D_S000C" variety="S000C">
<name>2AZ-FE LUBRICATION</name>
<ttl id="1000D_S000C_7303O_T00DE" variety="T00DE">
<name>OIL PUMP</name>
<para id="RM000001R0O004X" category="A" type-id="8000E" name-id="LU0A2-05" from="200601">
<name>REASSEMBLY</name>
<subpara id="RM000001R0O004X_01" type-id="01" category="01">
<s-1 id="RM000001R0O004X_01_0002" proc-id="RM0250U___00008MW00000">
<ptxt>INSTALL OIL PUMP COVER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the oil pump cover with the 5 bolts.</ptxt>
<figure>
<graphic graphicname="B011431E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>8.8</t-value1>
<t-value2>90</t-value2>
<t-value3>78</t-value3>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000001R0O004X_01_0003" proc-id="RM0250U___00008MX00000">
<ptxt>INSTALL OIL PUMP RELIEF VALVE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Coat the relief valve with engine oil.</ptxt>
</s2>
<s2>
<ptxt>Insert the relief valve and spring into the pump body hole.</ptxt>
<figure>
<graphic graphicname="A052074E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using a 27 mm socket wrench, install the plug.</ptxt>
<torque>
<torqueitem>
<t-value1>49</t-value1>
<t-value2>500</t-value2>
<t-value4>36</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000001R0O004X_01_0004" proc-id="RM0250U___00008MY00000">
<ptxt>INSTALL OIL PUMP STRAINER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install a new gasket and the oil strainer with the 2 nuts.</ptxt>
<figure>
<graphic graphicname="B011430E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>8.8</t-value1>
<t-value2>90</t-value2>
<t-value3>78</t-value3>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>