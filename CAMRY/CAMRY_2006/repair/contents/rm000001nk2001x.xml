<tmc-service-inc>
<pub id="RM0251U">
<servcat id="36">
<name>BRAKE</name>
<section id="1002J_S0010" variety="S0010">
<name>BRAKE CONTROL</name>
<ttl id="1002J_S0010_72W30_T005W" variety="T005W">
<name>VEHICLE STABILITY CONTROL SYSTEM (for BOSCH Made)</name>
<para id="RM000001NK2001X" category="J" type-id="3037F" name-id="BC12C-02" from="200601">
<dtccode/>
<dtcname>TS and CG Terminal Circuit</dtcname>
<subpara id="RM000001NK2001X_05" type-id="60" category="03" proc-id="RM0250U___00003W100000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>In the Test Mode (signal check), a malfunction of the speed sensor that cannot be detected when the vehicle is stopped can be detected while driving.</ptxt>
<ptxt>Transition to the sensor check mode can be performed by connecting terminals TS and CG of the DLC3 and turning the ignition switch from off to on (IG).</ptxt>
</content5>
</subpara>
<subpara id="RM000001NK2001X_06" type-id="32" category="03" proc-id="RM0250U___00003W200000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="C136515E03" width="7.106578999in" height="3.779676365in"/>
</figure>
</content5>
</subpara>
<subpara id="RM000001NK2001X_07" type-id="51" category="05" proc-id="RM0250U___00003W300000">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten4>
<ptxt>Check the condition of each related circuit connector before troubleshooting (See page <xref label="Seep01" href="RM000000UZ301TX"/>).</ptxt>
</atten4>
</content5>
</subpara>
<subpara id="RM000001NK2001X_08" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000001NK2001X_08_0006" proc-id="RM0250U___00003W400000">
<testtitle>CHECK HARNESS AND CONNECTOR (SKID CONTROL ECU TO DLC3)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the skid control ECU connector.</ptxt>
<figure>
<graphic graphicname="C139177E03" width="2.775699831in" height="3.779676365in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.36in"/>
<colspec colname="COLSPEC0" colwidth="1.36in"/>
<colspec colname="COL2" colwidth="1.41in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>A60-39 (TS) - E10-12 (TS)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
<test1>
<ptxt>Connect the connector.</ptxt>
</test1>
</content6>
<res>
<down ref="RM000001NK2001X_08_0007" fin="false">OK</down>
<right ref="RM000001NK2001X_08_0009" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000001NK2001X_08_0007" proc-id="RM0250U___00003W500000">
<testtitle>CHECK HARNESS AND CONNECTOR (DLC3 TO BODY GROUND)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<figure>
<graphic graphicname="G022987E25" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.36in"/>
<colspec colname="COLSPEC1" colwidth="1.36in"/>
<colspec colname="COL2" colwidth="1.41in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>E10-4 (CG) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000001NK2001X_08_0008" fin="false">OK</down>
<right ref="RM000001NK2001X_08_0010" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000001NK2001X_08_0008" proc-id="RM0250U___00003W600000">
<testtitle>CHECK HARNESS AND CONNECTOR (TS TERMINAL CIRCUIT)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<figure>
<graphic graphicname="G022987E26" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.36in"/>
<colspec colname="COLSPEC2" colwidth="1.36in"/>
<colspec colname="COL2" colwidth="1.41in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>E10-12 (TS) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000001NK2001X_08_0012" fin="true">OK</down>
<right ref="RM000001NK2001X_08_0011" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000001NK2001X_08_0009">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR (SKID CONTROL ECU TO DLC3)</testtitle>
</testgrp>
<testgrp id="RM000001NK2001X_08_0010">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR (DLC3 TO BODY GROUND)</testtitle>
</testgrp>
<testgrp id="RM000001NK2001X_08_0011">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR (TS TERMINAL CIRCUIT)</testtitle>
</testgrp>
<testgrp id="RM000001NK2001X_08_0012">
<testtitle>REPLACE BRAKE ACTUATOR ASSEMBLY<xref label="Seep01" href="RM0000013P6004X"/>
</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
