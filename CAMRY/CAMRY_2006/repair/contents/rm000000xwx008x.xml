<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>E51-1 (GND) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000XWX008X_04_0004" fin="false">OK</down>
<right ref="RM000000XWX008X_04_0015" fin="true">NG</right>
