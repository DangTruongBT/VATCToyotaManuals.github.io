<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002C_S000U" variety="S000U">
<name>E351 MANUAL TRANSAXLE</name>
<ttl id="1002C_S000U_73085_T00EX" variety="T00EX">
<name>TRANSMISSION CONTROL CABLE</name>
<para id="RM0000015P8004X" category="A" type-id="80001" name-id="MX0DD-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000015P8004X_02" type-id="01" category="01">
<s-1 id="RM0000015P8004X_02_0045">
<ptxt>DISCONNECT CABLE FROM NEGATIVE BATTERY TERMINAL</ptxt>
</s-1>
<s-1 id="RM0000015P8004X_02_0057" proc-id="RM0250U___00005C500000">
<ptxt>REMOVE NO. 1 INSTRUMENT CLUSTER FINISH PANEL GARNISH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 2 clips and remove the No. 1 instrument cluster finish panel garnish.</ptxt>
<figure>
<graphic graphicname="B133993" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000015P8004X_02_0058" proc-id="RM0250U___00005C600000">
<ptxt>REMOVE NO. 2 INSTRUMENT CLUSTER FINISH PANEL GARNISH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 2 clips and remove the No. 2 instrument cluster finish panel garnish.</ptxt>
<figure>
<graphic graphicname="B133994" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000015P8004X_02_0059" proc-id="RM0250U___00005D300000">
<ptxt>REMOVE SHIFT LEVER KNOB SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Turn the shift lever knob counterclockwise and remove the shift lever knob sub-assembly.</ptxt>
<figure>
<graphic graphicname="B137272" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000015P8004X_02_0060" proc-id="RM0250U___00005D400000">
<ptxt>REMOVE UPPER CONSOLE PANEL
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Open the lid of the upper console panel.</ptxt>
<figure>
<graphic graphicname="B137274E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Apply protective tape to the area shown in the illustration.</ptxt>
</s2>
<s2>
<ptxt>Using a moulding remover, disengage the 2 claws and the 5 clips, and then remove the upper console panel as shown in the illustration.</ptxt>
<figure>
<graphic graphicname="B137275E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000015P8004X_02_0061" proc-id="RM0250U___00007X100000">
<ptxt>REMOVE UPPER CONSOLE REAR PANEL SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 3 claws and 5 clips to install the upper console rear panel sub-assembly.</ptxt>
<figure>
<graphic graphicname="B137277" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000015P8004X_02_0035" proc-id="RM0250U___00009S100000">
<ptxt>SEPARATE TRANSMISSION CONTROL CABLE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 clips and disconnect the end of the transmission control cable.</ptxt>
<figure>
<graphic graphicname="C132951" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Pull out the control cable assembly locks.</ptxt>
<figure>
<graphic graphicname="C135402E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Turn the adjust nut 180° clockwise. While holding the adjust nut, separate the control cable assembly.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000015P8004X_02_0051" proc-id="RM0250U___0000CVJ00000">
<ptxt>REMOVE INSTRUMENT PANEL SAFETY PAD SUB-ASSEMBLY</ptxt>
<content1 releasenbr="2">
<ptxt>See page <xref label="Seep01" href="RM0000024DD000X"/>.</ptxt>
</content1>
</s-1>
<s-1 id="RM0000015P8004X_02_0052" proc-id="RM0250U___0000CVK00000">
<ptxt>REMOVE AIR CONDITIONER UNIT ASSEMBLY</ptxt>
<content1 releasenbr="2">
<ptxt>See page <xref label="Seep01" href="RM000001HLW001X"/>.</ptxt>
</content1>
</s-1>
<s-1 id="RM0000015P8004X_02_0062" proc-id="RM0250U___000003M00000">
<ptxt>REMOVE CENTER AIRBAG SENSOR ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Turn back the carpet.</ptxt>
</s2>
<s2>
<ptxt>Disconnect the holder (with connectors).</ptxt>
<figure>
<graphic graphicname="C133884" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 3 bolts and center airbag sensor assembly.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000015P8004X_02_0063" proc-id="RM0250U___0000A7T00000">
<ptxt>REMOVE NO. 1 ENGINE COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 nuts and cover.</ptxt>
<figure>
<graphic graphicname="A134904" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000015P8004X_02_0064" proc-id="RM0250U___0000A7U00000">
<ptxt>REMOVE AIR CLEANER INLET ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts, clamp and air cleaner inlet.</ptxt>
<figure>
<graphic graphicname="A134903" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000015P8004X_02_0065" proc-id="RM0250U___0000B9500000">
<ptxt>REMOVE AIR CLEANER CAP SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the mass air flow meter connector (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A135666E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the purge VSV connector (<sup>*</sup>2).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the 2 purge VSV vacuum hoses (<sup>*</sup>3).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the purge line hose from the clamp (<sup>*</sup>4).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the No. 2 ventilation hose from the air cleaner hose.</ptxt>
<figure>
<graphic graphicname="A135667E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Lock the No. 1 air cleaner hose clamp, and then disconnect the No. 1 air cleaner hose from the throttle body.</ptxt>
<figure>
<graphic graphicname="A135668" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts and air cleaner cap.</ptxt>
<figure>
<graphic graphicname="A135669" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the air cleaner filter element from the air cleaner case.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000015P8004X_02_0066" proc-id="RM0250U___0000A7V00000">
<ptxt>REMOVE AIR CLEANER CASE SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the hose clamp.</ptxt>
<figure>
<graphic graphicname="A134905" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 3 bolts and air cleaner case.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000015P8004X_02_0067" proc-id="RM0250U___0000A7W00000">
<ptxt>REMOVE BATTERY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Loosen the bolt and nut, and remove the battery clamp.</ptxt>
<figure>
<graphic graphicname="A134906" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the battery and battery tray.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000015P8004X_02_0017" proc-id="RM0250U___00009RT00000">
<ptxt>REMOVE TRANSMISSION CONTROL CABLE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 clips and 2 washers and disconnect the 2 cables from the transaxle.</ptxt>
<figure>
<graphic graphicname="C132952" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 clips and disconnect the 2 cables from the control cable bracket.</ptxt>
</s2>
<s2>
<ptxt>Remove the 2 bolts and control cable assembly.</ptxt>
<figure>
<graphic graphicname="C135401" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the No. 2 shift cable grommet retainer from the control cable assembly.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>