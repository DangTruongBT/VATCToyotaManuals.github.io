<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="35">
<name>SUSPENSION &amp; AXLE</name>
<section id="1000J_S000X" variety="S000X">
<name>TIRE AND WHEEL</name>
<ttl id="1000J_S000X_72XOD_T0076" variety="T0076">
<name>TIRE PRESSURE WARNING RESET SWITCH</name>
<para id="RM0000024XP000X" category="A" type-id="30014" name-id="TW0D4-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000024XP000X_01" type-id="01" category="01">
<s-1 id="RM0000024XP000X_01_0001" proc-id="RM0250U___00001RX00000">
<ptxt>INSTALL TIRE PRESSURE WARNING RESET SWITCH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 2 claws to install the tire pressure warning reset switch.</ptxt>
<figure>
<graphic graphicname="C132529" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000024XP000X_01_0010" proc-id="RM0250U___00007X800000">
<ptxt>INSTALL LOWER INSTRUMENT PANEL SUB-ASSEMBLY (for TMC Made)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Connect the connector.</ptxt>
</s2>
<s2>
<ptxt>Engage the 3 claws and 3 clips.</ptxt>
<figure>
<graphic graphicname="B133992E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 4 screws &lt;B&gt;.</ptxt>
</s2>
<s2>
<ptxt>Install the lower instrument panel sub-assembly with the bolt &lt;A&gt;.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000024XP000X_01_0011" proc-id="RM0250U___00007X900000">
<ptxt>INSTALL LOWER INSTRUMENT PANEL SUB-ASSEMBLY (for TMMK Made)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 3 claws and 3 clips.</ptxt>
<figure>
<graphic graphicname="B133992E02" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Install the screw &lt;O&gt; or &lt;P&gt; and 3 screws &lt;O&gt;.</ptxt>
</s2>
<s2>
<ptxt>Install the lower instrument panel sub-assembly with the bolt &lt;N&gt;.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000024XP000X_01_0012" proc-id="RM0250U___00007XA00000">
<ptxt>INSTALL NO. 2 INSTRUMENT PANEL UNDER COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 4 claws and 2 guides and install the instrument panel No. 2 under cover.</ptxt>
<figure>
<graphic graphicname="B133989E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000024XP000X_01_0013" proc-id="RM0250U___00006N000000">
<ptxt>INSTALL COWL SIDE TRIM SUB-ASSEMBLY RH
</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedure for the RH side and the LH side.</ptxt>
</atten4>
</content1></s-1>
<s-1 id="RM0000024XP000X_01_0014" proc-id="RM0250U___00006N100000">
<ptxt>INSTALL FRONT DOOR SCUFF PLATE RH
</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedure for the RH side and the LH side.</ptxt>
</atten4>
</content1></s-1>
<s-1 id="RM0000024XP000X_01_0006">
<ptxt>CONNECT CABLE TO NEGATIVE BATTERY TERMINAL</ptxt>
</s-1>
<s-1 id="RM0000024XP000X_01_0016" proc-id="RM0250U___0000BEB00000">
<ptxt>INITIALIZE SYSTEM</ptxt>
<content1 releasenbr="1">
<atten3>
<ptxt>Be sure to inflate all tires including the grand spare tire to the proper inflation pressure before initialization.</ptxt>
</atten3>
<atten4>
<ptxt>(See page <xref label="Seep01" href="RM000000XMZ008X"/>)</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000024XP000X_01_0015" proc-id="RM0250U___0000BEA00000">
<ptxt>INSPECT TIRE PRESSURE WARNING SYSTEM</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>(See page <xref label="Seep01" href="RM000000XN0008X"/>)</ptxt>
</atten4>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>