<tmc-service-inc>
<pub id="RM0251U">
<servcat id="36">
<name>BRAKE</name>
<section id="1000N_S0011" variety="S0011">
<name>BRAKE</name>
<ttl id="1000N_S0011_72V91_T003Y" variety="T003Y">
<name>FRONT BRAKE FLEXIBLE HOSE</name>
<para id="RM000000QC0006X" category="A" type-id="80001" name-id="BR0QS-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM000000QC0006X_02" type-id="11" category="10" proc-id="RM0250U___0000CZN00000">
<content3 releasenbr="1">
<atten4>
<list1 type="unordered">
<item>
<ptxt>Use the same procedures for the LH side and RH side.</ptxt>
</item>
<item>
<ptxt>The procedures listed below are for the LH side.</ptxt>
</item>
</list1>
</atten4>
</content3>
</subpara>
<subpara id="RM000000QC0006X_01" type-id="01" category="01">
<s-1 id="RM000000QC0006X_01_0002">
<ptxt>REMOVE FRONT WHEEL</ptxt>
</s-1>
<s-1 id="RM000000QC0006X_01_0003">
<ptxt>DRAIN BRAKE FLUID</ptxt>
</s-1>
<s-1 id="RM000000QC0006X_01_0004" proc-id="RM0250U___00003SG00000">
<ptxt>REMOVE FRONT BRAKE FLEXIBLE HOSE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the clip.</ptxt>
<figure>
<graphic graphicname="C145054E10" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the brake tube with SST while holding the front brake flexible hose with a wrench.</ptxt>
<sst>
<sstitem>
<s-number>09023-00101</s-number>
</sstitem>
</sst>
<atten3>
<list1 type="unordered">
<item>
<ptxt>Do not bend or damage the brake tube.</ptxt>
</item>
<item>
<ptxt>Do not allow any foreign matter such as dirt and dust to enter the brake tube from the connecting points.</ptxt>
</item>
</list1>
</atten3>
</s2>
<s2>
<ptxt>Remove the bolt, and separate the front brake flexible hose and the speed sensor from the shock absorber.</ptxt>
</s2>
<s2>
<ptxt>Remove the union bolt, the front brake flexible hose and gasket.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>