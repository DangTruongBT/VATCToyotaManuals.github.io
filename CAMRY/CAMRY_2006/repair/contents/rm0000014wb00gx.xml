<ptxt>20 km/h</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>(17.5 to 21.5 km/h)</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>40 km/h</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>38.0 to 42.0 km/h</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>60 km/h</ptxt>
</entry>
