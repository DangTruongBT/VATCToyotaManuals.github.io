<ptxt>20 mph</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>20.0 to 23.0 mph</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>40 mph</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>40.0 to 43.5 mph</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>60 mph</ptxt>
</entry>
