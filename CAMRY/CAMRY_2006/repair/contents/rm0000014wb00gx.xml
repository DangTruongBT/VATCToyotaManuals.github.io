<ptxt>60.0 to 64.0 mph</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>80 mph</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>80.0 to 84.5 mph</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>100 mph</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>100.0 to 105.0 mph</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>120 mph</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>120.0 to 125.5 mph</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>140 mph</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>140.0 to 146.0 mph</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>160 mph</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>160.0 to 166.5 mph</ptxt>
</entry>
</row>
