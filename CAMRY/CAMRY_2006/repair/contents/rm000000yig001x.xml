<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="1000A_S0008" variety="S0008">
<name>2AZ-FE ENGINE MECHANICAL</name>
<ttl id="1000A_S0008_72ZKJ_T00CG" variety="T00CG">
<name>ENGINE REAR OIL SEAL</name>
<para id="RM000000YIG001X" category="A" type-id="30014" name-id="EM06D-02" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000000YIG001X_01" type-id="01" category="01">
<s-1 id="RM000000YIG001X_01_0001" proc-id="RM0250U___00006XO00000">
<ptxt>INSTALL ENGINE REAR OIL SEAL</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply MP grease to a new oil seal lip.</ptxt>
<atten3>
<ptxt>Keep the lip free from foreign matter.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Using SST and a hammer, tap in the oil seal until its surface is flush with the rear oil seal retainer edge.</ptxt>
<figure>
<graphic graphicname="A128874E01" width="2.775699831in" height="2.775699831in"/>
</figure>
<sst>
<sstitem>
<s-number>09223-15030</s-number>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07100</s-subnumber>
</sstitem>
</sst>
<atten3>
<ptxt>Wipe off extra grease from the crankshaft.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YIG001X_01_0003" proc-id="RM0250U___00006XQ00000">
<ptxt>INSTALL FLYWHEEL SUB-ASSEMBLY (for Manual Transaxle)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>TMMK made:</ptxt>
<s3>
<ptxt>Using SST, hold the crankshaft.</ptxt>
<figure>
<graphic graphicname="A062061E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09960-10010</s-number>
<s-subnumber>09962-01000</s-subnumber>
<s-subnumber>09963-01000</s-subnumber>
</sstitem>
</sst>
</s3>
</s2>
<s2>
<ptxt>TMC made:</ptxt>
<s3>
<ptxt>Using SST, hold the crankshaft.</ptxt>
<figure>
<graphic graphicname="A126932E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09213-54015</s-number>
<s-subnumber>91651-60855</s-subnumber>
</sstitem>
<sstitem>
<s-number>09330-00021</s-number>
</sstitem>
</sst>
</s3>
</s2>
<s2>
<ptxt>Clean the bolt and the bolt hole.</ptxt>
</s2>
<s2>
<ptxt>Apply adhesive to 2 or 3 threads of the bolt end.</ptxt>
<spec>
<title>Adhesive</title>
<specitem>
<ptxt>Part No. 08833-00070, THREE BOND or equivalent</ptxt>
</specitem>
</spec>
</s2>
<s2>
<ptxt>Install the flywheel with the 8 bolts. Uniformly tighten the 8 bolts in the sequence shown in the illustration.</ptxt>
<figure>
<graphic graphicname="A060816" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>130</t-value1>
<t-value2>1,330</t-value2>
<t-value4>96</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YIG001X_01_0008" proc-id="RM0250U___00008ZC00000">
<ptxt>INSTALL CLUTCH DISC ASSEMBLY (for Manual Transaxle)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Insert SST into the clutch disc assembly, then insert them into the flywheel sub-assembly.</ptxt>
<figure>
<graphic graphicname="C127508E01" width="2.775699831in" height="3.779676365in"/>
</figure>
<sst>
<sstitem>
<s-number>09301-00220</s-number>
</sstitem>
</sst>
<atten3>
<ptxt>Take care not to insert the clutch disc assembly in the wrong direction.</ptxt>
</atten3>
</s2>
</content1></s-1>
<s-1 id="RM000000YIG001X_01_0009" proc-id="RM0250U___00008ZD00000">
<ptxt>INSTALL CLUTCH COVER ASSEMBLY (for Manual Transaxle)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Align the matchmarks on the clutch cover assembly with the one on the flywheel sub-assembly.</ptxt>
<figure>
<graphic graphicname="C127509E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Following the procedures shown in the illustration, tighten the 6 bolts in order, starting with the bolt located near the knock pin on the top.</ptxt>
<torque>
<torqueitem>
<t-value1>19</t-value1>
<t-value2>195</t-value2>
<t-value4>14</t-value4>
</torqueitem>
</torque>
<atten4>
<list1 type="unordered">
<item>
<ptxt>Following the order in the illustration, evenly tighten the bolts one turn at a time.</ptxt>
</item>
<item>
<ptxt>Lightly move SST up and down, and right and left after checking that the disc is in the center to tighten the bolts.</ptxt>
</item>
</list1>
</atten4>
<sst>
<sstitem>
<s-number>09301-00210</s-number>
</sstitem>
</sst>
</s2>
</content1></s-1>
<s-1 id="RM000000YIG001X_01_0002" proc-id="RM0250U___00006XP00000">
<ptxt>INSTALL DRIVE PLATE &amp; RING GEAR SUB-ASSEMBLY (for Automatic Transaxle)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>TMMK made:</ptxt>
<s3>
<ptxt>Using SST, hold the crankshaft.</ptxt>
<figure>
<graphic graphicname="A062061E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09960-10010</s-number>
<s-subnumber>09962-01000</s-subnumber>
<s-subnumber>09963-01000</s-subnumber>
</sstitem>
</sst>
</s3>
</s2>
<s2>
<ptxt>TMC made:</ptxt>
<s3>
<ptxt>Using SST, hold the crankshaft.</ptxt>
<figure>
<graphic graphicname="A126932E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09213-54015</s-number>
<s-subnumber>91651-60855</s-subnumber>
</sstitem>
<sstitem>
<s-number>09330-00021</s-number>
</sstitem>
</sst>
</s3>
</s2>
<s2>
<ptxt>Clean the bolt and the bolt hole.</ptxt>
</s2>
<s2>
<ptxt>Apply adhesive to 2 or 3 threads of the bolt end.</ptxt>
<spec>
<title>Adhesive</title>
<specitem>
<ptxt>Part No. 08833-00070, THREE BOND or equivalent</ptxt>
</specitem>
</spec>
</s2>
<s2>
<ptxt>Install the front spacer, drive plate and rear spacer with the 8 bolts. Uniformly tighten the 8 bolts in the sequence shown in the illustration.</ptxt>
<figure>
<graphic graphicname="A112224E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>98</t-value1>
<t-value2>1,000</t-value2>
<t-value4>72</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YIG001X_01_0007" proc-id="RM0250U___00006XS00000">
<ptxt>INSTALL MANUAL TRANSAXLE ASSEMBLY (for Manual Transaxle)</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>See page <xref label="Seep01" href="RM0000017UY002X"/>.</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM000000YIG001X_01_0006" proc-id="RM0250U___00006XR00000">
<ptxt>INSTALL AUTOMATIC TRANSAXLE ASSEMBLY (for Automatic Transaxle)</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>See page <xref label="Seep01" href="RM000000YWS00EX"/>.</ptxt>
</atten4>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
