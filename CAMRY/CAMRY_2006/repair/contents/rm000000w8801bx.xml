</content5>
</subpara>
<subpara id="RM000000W8801BX_08" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000000W8801BX_08_0003" proc-id="RM0250U___00007L700000">
<testtitle>INSPECT STOP LIGHT SWITCH</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Remove the stop light switch.</ptxt>
<figure>
<graphic graphicname="A115657E05" width="2.775699831in" height="2.775699831in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance between the terminals.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COLSPEC0" colwidth="1.37in"/>
<colspec colname="COL1" colwidth="1.37in"/>
<colspec colname="COL3" colwidth="1.39in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Switch Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry morerows="1" valign="middle">
<ptxt>1 - 2</ptxt>
</entry>
<entry valign="middle">
<ptxt>Switch pin released</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Switch pin pushed in</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry morerows="1" valign="middle">
<ptxt>3 - 4</ptxt>
</entry>
<entry valign="middle">
<ptxt>Switch pin released</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Switch pin pushed in</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
<test1>
<ptxt>Reinstall the stop light switch.</ptxt>
</test1>
</content6>
<res>
<down ref="RM000000W8801BX_08_0004" fin="false">OK</down>
<right ref="RM000000W8801BX_08_0007" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000W8801BX_08_0004" proc-id="RM0250U___00007L800000">
<testtitle>CHECK WIRE HARNESS (ECM - BATTERY)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Measure the voltage of the wire harness side connector.</ptxt>
<figure>
<graphic graphicname="A115671E21" width="2.775699831in" height="2.775699831in"/>
</figure>
<test2>
<ptxt>Disconnect the A24 ECM connector.</ptxt>
</test2>
<test2>
<ptxt>Measure the voltage.</ptxt>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>A24-36 (STP) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Brake pedal is depressed</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 to 14 V</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>A24-36 (STP) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Brake pedal is released</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test2>
<test2>
<ptxt>Reconnect the ECM connector.</ptxt>
</test2>
</test1>
</content6>
<res>
<down ref="RM000000W8801BX_08_0005" fin="true">OK</down>
<right ref="RM000000W8801BX_08_0008" fin="true">NG</right>
</res>
</testgrp>
