<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="35">
<name>SUSPENSION &amp; AXLE</name>
<section id="1002I_S000Z" variety="S000Z">
<name>SUSPENSION</name>
<ttl id="1002I_S000Z_72VBA_T005C" variety="T005C">
<name>REAR STRUT ROD</name>
<para id="RM0000011DY004X" category="A" type-id="30014" name-id="SP0ZO-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000011DY004X_01" type-id="01" category="01">
<s-1 id="RM0000011DY004X_01_0001" proc-id="RM0250U___00000IS00000">
<ptxt>TEMPORARILY TIGHTEN REAR STRUT ROD</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the rear strut rod (rear side), bolt and nut, and temporarily tighten the bolt.</ptxt>
<figure>
<graphic graphicname="C132496" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>When temporarily tightening the bolt, keep the nut from rotating.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Support the rear axle carrier.</ptxt>
<figure>
<graphic graphicname="C132459E01" width="2.775699831in" height="4.7836529in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the rear strut rod (inner side) with the bolt and nut.</ptxt>
<figure>
<graphic graphicname="C132476" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>When temporarily tightening the bolt, keep the nut from rotating.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011DY004X_01_0002" proc-id="RM0250U___00000IT00000">
<ptxt>STABILIZE SUSPENSION</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Jack up the rear axle carrier, placing a wooden block to avoid damage. Apply load to the suspension so that the installed bolt of the rear suspension No. 1 arm (inner side of vehicle) is horizontally aligned with the center of the rear axle hub.</ptxt>
<figure>
<graphic graphicname="C108450E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011DY004X_01_0003" proc-id="RM0250U___00000IU00000">
<ptxt>FULLY TIGHTEN REAR STRUT ROD</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Fully tighten the bolt.</ptxt>
<figure>
<graphic graphicname="C132476" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>113</t-value1>
<t-value2>1,152</t-value2>
<t-value4>83</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Fully tighten the bolt.</ptxt>
<figure>
<graphic graphicname="C132475" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>113</t-value1>
<t-value2>1,152</t-value2>
<t-value4>83</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011DY004X_01_0005" proc-id="RM0250U___00000IW00000">
<ptxt>CONNECT PARKING BRAKE NO. 3 CABLE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the parking brake No. 3 cable assembly with the bolt.</ptxt>
<figure>
<graphic graphicname="C132474" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>6.0</t-value1>
<t-value2>61</t-value2>
<t-value3>53</t-value3>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011DY004X_01_0004" proc-id="RM0250U___00000IV00000">
<ptxt>INSTALL REAR WHEEL</ptxt>
<content1 releasenbr="1">
<torque>
<torqueitem>
<t-value1>103</t-value1>
<t-value2>1,050</t-value2>
<t-value4>76</t-value4>
</torqueitem>
</torque>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>