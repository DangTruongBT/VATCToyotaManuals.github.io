<s-1 id="RM000001AQT008X_02_0010" proc-id="RM0250U___0000AQE00000">
<ptxt>INSPECT AIR CLEANER FILTER</ptxt>
<content1 releasenbr="1">
<figure>
<graphic graphicname="A054323" width="2.775699831in" height="1.771723296in"/>
</figure>
<s2>
<ptxt>Remove the air filter.</ptxt>
</s2>
<s2>
<ptxt>Visually check that the air filter is not excessively damaged or oily. If necessary, replace the air filter.</ptxt>
</s2>
<s2>
<ptxt>Reinstall the air filter.</ptxt>
</s2>
</content1>
</s-1>
