<ptxt>Temperature Displayed</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Malfunctions</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>-40°C (-40°F)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Open circuit</ptxt>
</entry>
</row>
<row>
