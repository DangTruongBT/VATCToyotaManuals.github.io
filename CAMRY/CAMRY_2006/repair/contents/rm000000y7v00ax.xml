<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="40">
<name>SECURITIES</name>
<section id="1002O_S0019" variety="S0019">
<name>ENGINE IMMOBILISER</name>
<ttl id="1002O_S0019_7301M_T00D1" variety="T00D1">
<name>ENGINE IMMOBILISER SYSTEM (w/ Smart Key System)</name>
<para id="RM000000Y7V00AX" category="C" type-id="800LD" name-id="EI0EC-01" from="200601">
<dtccode>B2789</dtccode>
<dtcname>No Response from ID BOX</dtcname>
<subpara id="RM000000Y7V00AX_01" type-id="60" category="03" proc-id="RM0250U___00008DW00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>This DTC is output when the certification ECU does not receive LIN communication from the ID code box for 10 seconds.</ptxt>
<table pgwide="1">
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.42in"/>
<colspec colname="COL2" colwidth="2.83in"/>
<colspec colname="COL3" colwidth="2.83in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>DTC No.</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>DTC Detection Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Trouble Area</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>B2789</ptxt>
</entry>
<entry valign="middle">
<ptxt>Certification ECU does not receive LIN communication from ID code box</ptxt>
<list1 type="unordered">
<item>
<ptxt>Open or short in wire harness between ECUs</ptxt>
</item>
</list1>
</entry>
<entry>
<list1 type="unordered">
<item>
<ptxt>Wire harness</ptxt>
</item>
<item>
<ptxt>Certification ECU</ptxt>
</item>
<item>
<ptxt>ID code box</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</content5>
</subpara>
<subpara id="RM000000Y7V00AX_02" type-id="32" category="03" proc-id="RM0250U___00008DX00000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="B128333E02" width="7.106578999in" height="3.779676365in"/>
</figure>
</content5>
</subpara>
<subpara id="RM000000Y7V00AX_03" type-id="51" category="05" proc-id="RM0250U___00009VF00000">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten3>
<ptxt>If the certification ECU or ID code box is replaced, register the key and ECU communication ID (See page <xref label="Seep01" href="RM000000QYF004X"/>).</ptxt>
</atten3>
</content5>
</subpara>
<subpara id="RM000000Y7V00AX_04" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000000Y7V00AX_04_0001" proc-id="RM0250U___00008DY00000">
<testtitle>CHECK DTC OUTPUT</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Delete the DTCs (See page <xref label="Seep01" href="RM000000QYC00BX"/>).</ptxt>
</test1>
<test1>
<ptxt>Recheck for DTCs (See page <xref label="Seep02" href="RM000000QYC00BX"/>).</ptxt>
<spec>
<title>Result</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Result</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>B2789 output reoccurs</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>B2789 output does not reoccur</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000Y7V00AX_04_0002" fin="false">A</down>
<right ref="RM000000Y7V00AX_04_0005" fin="true">B</right>
</res>
</testgrp>
<testgrp id="RM000000Y7V00AX_04_0002" proc-id="RM0250U___00008DZ00000">
<testtitle>CHECK HARNESS AND CONNECTOR (CERTIFICATION ECU - ID CODE BOX)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the E58 ECU and E50 ID code box connectors. </ptxt>
<figure>
<graphic graphicname="B113404E02" width="2.775699831in" height="3.779676365in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>E58-10 (LIN) - E50-3 (LIN1)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>E58-10 (LIN) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000Y7V00AX_04_0003" fin="false">OK</down>
<right ref="RM000000Y7V00AX_04_0006" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000Y7V00AX_04_0003" proc-id="RM0250U___00008E000000">
<testtitle>CHECK CERTIFICATION ECU</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>After replacing the certification ECU with a normal one, check for DTCs (See page <xref label="Seep01" href="RM000000QYC00BX"/>).</ptxt>
<spec>
<title>Result</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Result</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>B2789 output reoccurs</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>B2789 output does not reoccur</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000Y7V00AX_04_0007" fin="true">A</down>
<right ref="RM000000Y7V00AX_04_0005" fin="true">B</right>
</res>
</testgrp>
<testgrp id="RM000000Y7V00AX_04_0005">
<testtitle>END</testtitle>
</testgrp>
<testgrp id="RM000000Y7V00AX_04_0006">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
<testgrp id="RM000000Y7V00AX_04_0007">
<testtitle>REPLACE ID CODE BOX</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
