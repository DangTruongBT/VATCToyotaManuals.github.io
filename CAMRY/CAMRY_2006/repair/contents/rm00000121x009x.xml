<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>J5-6 (LSSR) - IL-5 (*1)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
