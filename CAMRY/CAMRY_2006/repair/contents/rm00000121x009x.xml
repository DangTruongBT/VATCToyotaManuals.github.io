<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.65in"/>
<colspec colname="COL2" colwidth="1.24in"/>
<colspec colname="COL3" colwidth="1.24in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection (Symbols)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
