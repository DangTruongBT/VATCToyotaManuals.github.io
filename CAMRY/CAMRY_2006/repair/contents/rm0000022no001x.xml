<subpara id="RM0000022NO001X_01" type-id="01" category="01">
<s-1 id="RM0000022NO001X_01_0001" proc-id="RM0250U___000092Z00000">
<ptxt>INSPECT KNOCK CONTROL SENSOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using an ohmmeter, measure the resistance between the terminals.</ptxt>
<figure>
<graphic graphicname="A065174" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Standard resistance</title>
<specitem>
<ptxt>120 to 280 kΩ at 20°C (68°F)</ptxt>
</specitem>
</spec>
<ptxt>If the result is not as specified, replace the sensor.</ptxt>
</s2>
</content1>
