<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="36">
<name>BRAKE</name>
<section id="1002J_S0010" variety="S0010">
<name>BRAKE CONTROL</name>
<ttl id="1002J_S0010_72Z6O_T00AN" variety="T00AN">
<name>VEHICLE STABILITY CONTROL SYSTEM (for ADVICS Made)</name>
<para id="RM000000XIH00AX" category="J" type-id="300E0" name-id="BC1MZ-01" from="200601">
<dtccode/>
<dtcname>ABS Warning Light Remains ON</dtcname>
<subpara id="RM000000XIH00AX_01" type-id="60" category="03" proc-id="RM0250U___00005NZ00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>The skid control ECU is connected to the combination meter via CAN communication.</ptxt>
<ptxt>If any of the following is detected, the ABS warning light remains on.</ptxt>
<list1 type="unordered">
<item>
<ptxt>The skid control ECU connectors are disconnected from the skid control ECU.</ptxt>
</item>
<item>
<ptxt>There is a malfunction in the skid control ECU internal circuit.</ptxt>
</item>
<item>
<ptxt>There is an open in the harness between the combination meter and the skid control ECU.</ptxt>
</item>
</list1>
<atten4>
<ptxt>In some cases, the intelligent tester cannot be used when the skid control ECU is abnormal.</ptxt>
</atten4>
</content5>
</subpara>
<subpara id="RM000000XIH00AX_02" type-id="32" category="03" proc-id="RM0250U___00005O000000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="C109474E03" width="7.106578999in" height="8.799559038in"/>
</figure>
</content5>
</subpara>
<subpara id="RM000000XIH00AX_03" type-id="51" category="05" proc-id="RM0250U___00005O100000">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten3>
<ptxt>When replacing the brake actuator assembly, perform zero point calibration (See page <xref label="Seep01" href="RM000000XHR009X"/>).</ptxt>
</atten3>
</content5>
</subpara>
<subpara id="RM000000XIH00AX_04" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000000XIH00AX_04_0001" proc-id="RM0250U___00005O200000">
<testtitle>CHECK CAN COMMUNICATION SYSTEM</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check if the CAN communication system DTC is output (See page <xref label="Seep01" href="RM000000WIB00RX"/>).</ptxt>
<spec>
<title>Result</title>
<table pgwide="1">
<tgroup cols="2">
<colspec colname="COL1" colwidth="4.54in"/>
<colspec colname="COL2" colwidth="2.54in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>DTC is not output</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>DTC is output</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000XIH00AX_04_0003" fin="false">A</down>
<right ref="RM000000XIH00AX_04_0009" fin="true">B</right>
</res>
</testgrp>
<testgrp id="RM000000XIH00AX_04_0003" proc-id="RM0250U___00005O400000">
<testtitle>CHECK IF SKID CONTROL ECU CONNECTOR IS SECURELY CONNECTED</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check if the skid control ECU connector is securely connected.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The connector should be securely connected.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000XIH00AX_04_0004" fin="false">OK</down>
<right ref="RM000000XIH00AX_04_0011" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000XIH00AX_04_0004" proc-id="RM0250U___00005O500000">
<testtitle>CHECK BATTERY</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check the battery voltage.</ptxt>
<spec>
<title>Standard voltage</title>
<specitem>
<ptxt>11 to 14 V</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000XIH00AX_04_0005" fin="false">OK</down>
<right ref="RM000000XIH00AX_04_0012" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000XIH00AX_04_0005" proc-id="RM0250U___00005O600000">
<testtitle>INSPECT SKID CONTROL ECU (IG1 TERMINAL)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the skid control ECU connector.</ptxt>
<figure>
<graphic graphicname="F049362E98" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>Turn the ignition switch on (IG).</ptxt>
</test1>
<test1>
<ptxt>Measure the voltage according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>A26-46 (IG1) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Ignition switch on (IG)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 to 14 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000XIH00AX_04_0006" fin="false">OK</down>
<right ref="RM000000XIH00AX_04_0013" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000XIH00AX_04_0006" proc-id="RM0250U___00005O700000">
<testtitle>INSPECT SKID CONTROL ECU (GND TERMINAL)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Turn the ignition switch off.</ptxt>
<figure>
<graphic graphicname="F049362E97" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.86in"/>
<colspec colname="COLSPEC0" colwidth="1.03in"/>
<colspec colname="COL3" colwidth="1.24in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>A26-32 (GND1) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>A26-1 (GND2) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000XIH00AX_04_0007" fin="false">OK</down>
<right ref="RM000000XIH00AX_04_0014" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000XIH00AX_04_0007" proc-id="RM0250U___00005O800000">
<testtitle>INSPECT COMBINATION METER ASSEMBLY</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Reconnect the skid control ECU connector.</ptxt>
</test1>
<test1>
<ptxt>Perform Active Test of the combination meter (meter CPU) using the intelligent tester (See page <xref label="Seep01" href="RM0000012G700DX"/>).</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The ABS warning light turns on or off in accordance with the intelligent tester.</ptxt>
</specitem>
</spec>
<atten4>
<ptxt>If troubleshooting has been carried out according to the Problem Symptoms Table, refer back to the table and proceed to the next step before replacing the part (See page <xref label="Seep02" href="RM000000XHN009X"/>).</ptxt>
</atten4>
</test1>
</content6>
<res>
<down ref="RM000000XIH00AX_04_0008" fin="true">OK</down>
<right ref="RM000000XIH00AX_04_0015" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000XIH00AX_04_0008">
<testtitle>REPLACE BRAKE ACTUATOR ASSEMBLY</testtitle>
</testgrp>
<testgrp id="RM000000XIH00AX_04_0009">
<testtitle>INSPECT CAN COMMUNICATION SYSTEM</testtitle>
</testgrp>
<testgrp id="RM000000XIH00AX_04_0011">
<testtitle>CONNECT CONNECTOR TO ECU CORRECTLY</testtitle>
</testgrp>
<testgrp id="RM000000XIH00AX_04_0012">
<testtitle>CHECK AND REPLACE CHARGING SYSTEM OR BATTERY</testtitle>
</testgrp>
<testgrp id="RM000000XIH00AX_04_0013">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR (IG1 CIRCUIT)</testtitle>
</testgrp>
<testgrp id="RM000000XIH00AX_04_0014">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR (GND CIRCUIT)</testtitle>
</testgrp>
<testgrp id="RM000000XIH00AX_04_0015">
<testtitle>REPLACE COMBINATION METER ASSEMBLY</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>