<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="36">
<name>BRAKE</name>
<section id="1002J_S0010" variety="S0010">
<name>BRAKE CONTROL</name>
<ttl id="1002J_S0010_72W31_T005X" variety="T005X">
<name>ANTI-LOCK BRAKE SYSTEM</name>
<para id="RM000001JD4002X" category="J" type-id="300NF" name-id="BC1GJ-01" from="200601">
<dtccode/>
<dtcname>ABS Warning Light does not Come ON</dtcname>
<subpara id="RM000001JD4002X_01" type-id="32" category="03" proc-id="RM0250U___000011O00000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="C136510E01" width="7.106578999in" height="8.799559038in"/>
</figure>
</content5>
</subpara>
<subpara id="RM000001JD4002X_02" type-id="51" category="05" proc-id="RM0250U___000021T00000">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten4>
<ptxt>Check the condition of each related circuit connector before troubleshooting (See page <xref label="Seep01" href="RM000000UZ301TX"/>).</ptxt>
</atten4>
</content5>
</subpara>
<subpara id="RM000001JD4002X_04" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000001JD4002X_04_0008" proc-id="RM0250U___000021U00000">
<testtitle>INSPECT CAN COMMUNICATION SYSTEM</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check if a CAN communication system DTC is output (See page <xref label="Seep01" href="RM000001JB8002X"/>).</ptxt>
<spec>
<title>Result</title>
<table pgwide="1">
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="3.54in"/>
<colspec colname="COL2" colwidth="3.54in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>CAN communication system DTC is not output</ptxt>
</entry>
<entry valign="middle">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>CAN communication system DTC is output</ptxt>
</entry>
<entry valign="middle">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000001JD4002X_04_0010" fin="false">A</down>
<right ref="RM000001JD4002X_04_0012" fin="true">B</right>
</res>
</testgrp>
<testgrp id="RM000001JD4002X_04_0010" proc-id="RM0250U___000021W00000">
<testtitle>INSPECT ABS WARNING LIGHT</testtitle>
<content6 releasenbr="1">
<atten4>
<ptxt>When disconnecting the skid control ECU connector, the ABS warning light comes on.</ptxt>
</atten4>
<test1>
<ptxt>Turn the ignition switch off.</ptxt>
</test1>
<test1>
<ptxt>Disconnect the skid control ECU connector.</ptxt>
</test1>
<test1>
<ptxt>Turn the ignition switch on (IG).</ptxt>
</test1>
<test1>
<ptxt>Check that the ABS warning light comes on.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The ABS warning light comes on.</ptxt>
</specitem>
</spec>
</test1>
<test1>
<ptxt>Connect the connector.</ptxt>
</test1>
</content6>
<res>
<down ref="RM000001JD4002X_04_0017" fin="true">OK</down>
<right ref="RM000001JD4002X_04_0011" fin="false">NG</right>
</res>
</testgrp>
<testgrp id="RM000001JD4002X_04_0011" proc-id="RM0250U___000022R00000">
<testtitle>INSPECT COMBINATION METER ASSEMBLY</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Connect the intelligent tester to the DLC3.</ptxt>
</test1>
<test1>
<ptxt>Select the "ACTIVE TEST" on the tester (See page <xref label="Seep01" href="RM000001JBA002X"/>).</ptxt>
<table pgwide="1">
<title>ACTIVE TEST: ABS</title>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="2.36in"/>
<colspec colname="COL2" colwidth="2.36in"/>
<colspec colname="COL3" colwidth="2.36in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Item</ptxt>
</entry>
<entry valign="middle">
<ptxt>Vehicle Condition / Test Details</ptxt>
</entry>
<entry valign="middle">
<ptxt>Diagnostic Note</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>ABS WRN LIGHT</ptxt>
</entry>
<entry valign="middle">
<ptxt>Turn ABS warning light ON / OFF</ptxt>
</entry>
<entry valign="middle">
<ptxt>Observe combination meter</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</test1>
<test1>
<ptxt>Check the ABS warning light operation.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The ABS warning light turns on or off in accordance with the intelligent tester.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000001JD4002X_04_0017" fin="true">OK</down>
<right ref="RM000001JD4002X_04_0014" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000001JD4002X_04_0012">
<testtitle>REPAIR CAN COMMUNICATION SYSTEM<xref label="Seep01" href="RM000000WI600QX"/>
</testtitle>
</testgrp>
<testgrp id="RM000001JD4002X_04_0014">
<testtitle>REPLACE COMBINATION METER ASSEMBLY<xref label="Seep01" href="RM0000024D7000X"/>
</testtitle>
</testgrp>
<testgrp id="RM000001JD4002X_04_0017">
<testtitle>REPLACE BRAKE ACTUATOR ASSEMBLY<xref label="Seep01" href="RM0000013P6004X"/>
</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>