<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000S" variety="S000S">
<name>U250E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000S_72XP0_T007C" variety="T007C">
<name>TRANSMISSION WIRE</name>
<para id="RM000000YWZ003X" category="A" type-id="80001" name-id="AX03L-02" from="200601">
<name>REMOVAL</name>
<subpara id="RM000000YWZ003X_01" type-id="01" category="01">
<s-1 id="RM000000YWZ003X_01_0006" proc-id="RM0250U___0000A8100000">
<ptxt>REMOVE AUTOMATIC TRANSAXLE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>See page <xref label="Seep01" href="RM000000YWV00EX"/>.</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM000000YWZ003X_01_0003" proc-id="RM0250U___00001WA00000">
<ptxt>REMOVE AUTOMATIC TRANSAXLE OIL PAN SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 18 bolts, oil pan and gasket.</ptxt>
<figure>
<graphic graphicname="C091925" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Some fluid will remain in the oil pan. Remove all the pan bolts, and carefully remove the oil pan assembly.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Remove the 2 magnets from the oil pan.</ptxt>
<figure>
<graphic graphicname="D030865E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Examine particles in the pan.</ptxt>
<s3>
<ptxt>Collect any steel chips with the removed magnets. Look carefully at the chips and particles in the pan and on the magnets to see the type of wear which might be found in the transaxle.</ptxt>
<ptxt>Steel (magnetic): bearing, gear and plate wear</ptxt>
<ptxt>Brass (non-magnetic): bearing wear</ptxt>
<spec>
<title>Result</title>
<subtitle>Steel (magnetic)</subtitle>
<specitem>
<ptxt>bearing, gear and plate wear</ptxt>
</specitem>
<subtitle>Brass (non-magnetic)</subtitle>
<specitem>
<ptxt>bearing wear</ptxt>
</specitem>
</spec>
<figure>
<graphic graphicname="AT00103" width="2.775699831in" height="1.771723296in"/>
</figure>
</s3>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YWZ003X_01_0004" proc-id="RM0250U___00001WB00000">
<ptxt>DISCONNECT TRANSMISSION WIRE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the 7 shift solenoid valve connectors.</ptxt>
<figure>
<graphic graphicname="C135717" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the bolt and lock plate, and disconnect the ATF temperature sensor.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YWZ003X_01_0005" proc-id="RM0250U___00001WC00000">
<ptxt>REMOVE TRANSMISSION WIRE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the transmission wire connector.</ptxt>
<figure>
<graphic graphicname="D030866" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the bolt and transmission wire.</ptxt>
</s2>
<s2>
<ptxt>Remove the O-ring from the transmission wire.</ptxt>
<figure>
<graphic graphicname="D030867" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>