<name>AUDIO / VISUAL</name>
<ttl id="1001C_S001D_72YIE_T00A3" variety="T00A3">
<name>AUDIO AND VISUAL SYSTEM</name>
<para id="RM000000NL700NX" category="J" type-id="300HB" name-id="AV05F-16" from="200601">
<dtccode/>
<dtcname>CD cannot be Ejected</dtcname>
<subpara id="RM000000NL700NX_01" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM000000NL700NX_02" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000000NL700NX_02_0001" proc-id="RM0250U___00004P300000">
<testtitle>PRESS "EJECT" AND CHECK OPERATION</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Press the CD EJECT switch of the radio receiver for 2 seconds or more and check that the CD is ejected.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>CD is ejected.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000NL700NX_02_0002" fin="false">OK</down>
<right ref="RM000000NL700NX_02_0003" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000NL700NX_02_0002" proc-id="RM0250U___00004P400000">
<testtitle>REPLACE CD WITH ANOTHER AND RECHECK</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Insert another CD and check if it is ejected.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>CD is ejected.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000NL700NX_02_0004" fin="true">OK</down>
<right ref="RM000000NL700NX_02_0003" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000NL700NX_02_0003">
<testtitle>REPLACE RADIO RECEIVER</testtitle>
</testgrp>
<testgrp id="RM000000NL700NX_02_0004">
<testtitle>END</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
