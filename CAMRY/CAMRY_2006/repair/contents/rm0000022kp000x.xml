<tmc-service-inc>
<pub id="RM0251U">
<servcat id="36">
<name>BRAKE</name>
<section id="1000O_S0012" variety="S0012">
<name>PARKING BRAKE</name>
<ttl id="1000O_S0012_72V97_T0044" variety="T0044">
<name>PARKING BRAKE LEVER</name>
<para id="RM0000022KP000X" category="A" type-id="80002" name-id="PB09J-01" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM0000022KP000X_01" type-id="01" category="01">
<s-1 id="RM0000022KP000X_01_0002" proc-id="RM0250U___00003PD00000">
<ptxt>REMOVE NO. 1 PARKING BRAKE CABLE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a screwdriver, pull up the parking brake lever claw.</ptxt>
<figure>
<graphic graphicname="C131912" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the lock nut, the No. 1 wire adjusting nut, and the No. 1 parking brake cable assembly from the parking brake lever sub-assembly.</ptxt>
<figure>
<graphic graphicname="C132670E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022KP000X_01_0001" proc-id="RM0250U___00001IC00000">
<ptxt>REMOVE PARKING BRAKE SWITCH ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the screw and the parking brake switch assembly.</ptxt>
<figure>
<graphic graphicname="C132654" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>