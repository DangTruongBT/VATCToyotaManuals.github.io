<ptxt>OPEN</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>OPEN</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Engine coolant temp. is between -10°C (14°F) and 60°C (140°F). Intake air temp. is -10°C (14°F) or more.</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>CLOSED</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>OPEN</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>OPEN</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
