<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="35">
<name>SUSPENSION &amp; AXLE</name>
<section id="1000J_S000X" variety="S000X">
<name>TIRE AND WHEEL</name>
<ttl id="1000J_S000X_738JZ_T00GU" variety="T00GU">
<name>TIRE PRESSURE WARNING SYSTEM</name>
<para id="RM0000026PN002X" category="C" type-id="304MO" name-id="TW0J9-01" from="200601">
<dtccode>C2176/76</dtccode>
<dtcname>Receiver Error</dtcname>
<subpara id="RM0000026PN002X_01" type-id="60" category="03" proc-id="RM0250U___00005SR00001">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>The signals are transmitted to the tire pressure warning antenna and receiver on the body as radio waves and then sent to the tire pressure warning ECU.</ptxt>
<table pgwide="1">
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.27in"/>
<colspec colname="COL2" colwidth="2.90in"/>
<colspec colname="COL3" colwidth="2.91in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>DTC No.</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>DTC Detection Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Trouble Area</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>C2176/76</ptxt>
</entry>
<entry valign="middle">
<ptxt>DTC is stored when any of the following is detected:</ptxt>
<list1 type="unordered">
<item>
<ptxt>Malfunction in the tire pressure warning ECU internal circuit.</ptxt>
</item>
<item>
<ptxt>Terminal RF5V is shorted to ground.</ptxt>
</item>
<item>
<ptxt>Malfunction in the tire pressure warning antenna and receiver internal circuit.</ptxt>
</item>
</list1>
</entry>
<entry valign="middle">
<list1 type="unordered">
<item>
<ptxt>Tire pressure warning antenna and receiver</ptxt>
</item>
<item>
<ptxt>Wire harness or connector</ptxt>
</item>
<item>
<ptxt>Tire pressure warning ECU</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</content5>
</subpara>
<subpara id="RM0000026PN002X_02" type-id="32" category="03" proc-id="RM0250U___00005SS00001">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="E131610E01" width="7.106578999in" height="3.779676365in"/>
</figure>
</content5>
</subpara>
<subpara id="RM0000026PN002X_03" type-id="51" category="05" proc-id="RM0250U___00005ST00001">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten3>
<list1 type="unordered">
<item>
<ptxt>When replacing the tire pressure warning ECU, read the IDs stored in the ECU using the intelligent tester and write them down before removal.</ptxt>
</item>
<item>
<ptxt>It is necessary to perform initialization (See page <xref label="Seep01" href="RM000000XMZ008X"/>) after registration (See page <xref label="Seep02" href="RM000000XN1008X"/>) of the transmitter IDs into the tire pressure warning ECU after the ECU have been replaced.</ptxt>
</item>
</list1>
</atten3>
</content5>
</subpara>
<subpara id="RM0000026PN002X_04" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM0000026PN002X_04_0001" proc-id="RM0250U___00005SU00001">
<testtitle>CHECK TIRE PRESSURE WARNING ECU</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Measure the voltage according to the value(s) in the table below.</ptxt>
<figure>
<graphic graphicname="E133090E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COLSPEC0" colwidth="1.37in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<thead>
<row>
<entry align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry align="center">
<ptxt>Switch Condition</ptxt>
</entry>
<entry align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>E60-6 (RF5V) - E60-11 (GND2)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Ignition switch ON (IG)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>4.5 to 5.5 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000026PN002X_04_0002" fin="false">OK</down>
<right ref="RM0000026PN002X_04_0005" fin="false">NG</right>
</res>
</testgrp>
<testgrp id="RM0000026PN002X_04_0002" proc-id="RM0250U___00005SV00001">
<testtitle>CHECK WIRE HARNESS (ECU - RECEIVER)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the E60 ECU connector.</ptxt>
<figure>
<graphic graphicname="E129461E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</test1>
<test1>
<ptxt>Disconnect the N20 receiver connector.<sup>*1</sup>
</ptxt>
</test1>
<test1>
<ptxt>Disconnect the N34 receiver connector.<sup>*2</sup>
</ptxt>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>E60-12 (RDA) - N20-1 (RDA)<sup>*1</sup>
</ptxt>
<ptxt>E60-12 (RDA) - N34-1 (RDA)<sup>*2</sup>
</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
<atten4>
<list1 type="unordered">
<item>
<ptxt>*1: TMC Made</ptxt>
</item>
<item>
<ptxt>*2: TMMK Made</ptxt>
</item>
</list1>
</atten4>
</content6>
<res>
<down ref="RM0000026PN002X_04_0003" fin="false">OK</down>
<right ref="RM0000026PN002X_04_0006" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000026PN002X_04_0003">
<testtitle>REPLACE TIRE PRESSURE WARNING ANTENNA AND RECEIVER</testtitle>
<res>
<down ref="RM0000026PN002X_04_0004" fin="false">NEXT</down>
</res>
</testgrp>
<testgrp id="RM0000026PN002X_04_0004" proc-id="RM0250U___00005SW00001">
<testtitle>CHECK DTC</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check for DTC (See page <xref label="Seep01" href="RM000000XMX008X"/>).</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>DTC is not output.</ptxt>
</specitem>
</spec>
<atten4>
<list1 type="unordered">
<item>
<ptxt>It is necessary to register IDs when replacing the tire pressure warning ECU (See page <xref label="Seep02" href="RM000000XN1008X"/>).</ptxt>
</item>
<item>
<ptxt>Read the IDs on the DATA LIST before removing the tire pressure warning ECU. Register the ID in the new tire pressure warning ECU.</ptxt>
</item>
</list1>
</atten4>
</test1>
</content6>
<res>
<down ref="RM0000026PN002X_04_0008" fin="true">OK</down>
<right ref="RM0000026PN002X_04_0007" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000026PN002X_04_0005" proc-id="RM0250U___00005SX00001">
<testtitle>CHECK HARNESS AND CONNECTOR (ECU - RECEIVER)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the E60 ECU connector.</ptxt>
<figure>
<graphic graphicname="E129461E02" width="2.775699831in" height="3.779676365in"/>
</figure>
</test1>
<test1>
<ptxt>Disconnect the N20 receiver connector.<sup>*1</sup>
</ptxt>
</test1>
<test1>
<ptxt>Disconnect the N34 receiver connector.<sup>*2</sup>
</ptxt>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>E60-11 (GND2) - N20-4 (GND)<sup>*1</sup>
</ptxt>
<ptxt>E60-11 (GND2) - N34-4 (GND)<sup>*2</sup>
</ptxt>
</entry>
<entry morerows="1" valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>E60-6 (RF5V) - N20-5 (+5V)<sup>*1</sup>
</ptxt>
<ptxt>E60-6 (RF5V) - N34-5 (+5V)<sup>*2</sup>
</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
<atten4>
<list1 type="unordered">
<item>
<ptxt>*1: TMC Made</ptxt>
</item>
<item>
<ptxt>*2: TMMK Made</ptxt>
</item>
</list1>
</atten4>
<spec>
<title>Result</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Result</ptxt>
</entry>
<entry valign="middle">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>OK</ptxt>
</entry>
<entry valign="middle">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>OK (When troubleshooting accordance with PROBLEM SYMPTOMS TABLE)</ptxt>
</entry>
<entry valign="middle">
<ptxt>B</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>NG</ptxt>
</entry>
<entry valign="middle">
<ptxt>C</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</content6>
<res>
<down ref="RM0000026PN002X_04_0012" fin="true">B</down>
<right ref="RM0000026PN002X_04_0010" fin="true">A</right>
<right ref="RM0000026PN002X_04_0009" fin="true">C</right>
</res>
</testgrp>
<testgrp id="RM0000026PN002X_04_0006">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
<testgrp id="RM0000026PN002X_04_0007">
<testtitle>REPLACE TIRE PRESSRUE WARNING ECU</testtitle>
</testgrp>
<testgrp id="RM0000026PN002X_04_0008">
<testtitle>END</testtitle>
</testgrp>
<testgrp id="RM0000026PN002X_04_0009">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR AND REPLACE TIRE PRESSURE WARNING ECU</testtitle>
</testgrp>
<testgrp id="RM0000026PN002X_04_0010">
<testtitle>REPLACE TIRE PRESSURE WARNING ECU</testtitle>
</testgrp>
<testgrp id="RM0000026PN002X_04_0012">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
