<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10008_S0006" variety="S0006">
<name>2AZ-FE EMISSION CONTROL</name>
<ttl id="10008_S0006_731VX_T00G4" variety="T00G4">
<name>VENTILATION VALVE</name>
<para id="RM000002A46000X" category="A" type-id="30014" name-id="EC0T0-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000002A46000X_01" type-id="01" category="01">
<s-1 id="RM000002A46000X_01_0001" proc-id="RM0250U___0000BSL00000">
<ptxt>INSTALL VENTILATION VALVE SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply adhesive to 2 or 3 threads of the ventilation valve.</ptxt>
<figure>
<graphic graphicname="A092670E03" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Adhesive</title>
<specitem>
<ptxt>Toyota genuine adhesive 1324, three bond 1324 or equivalent </ptxt>
</specitem>
</spec>
</s2>
<s2>
<ptxt>Using a 22 mm deep socket wrench, install the ventilation valve. </ptxt>
<figure>
<graphic graphicname="A098067E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>19</t-value1>
<t-value2>194</t-value2>
<t-value4>14</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the ventilation hose.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000002A46000X_01_0002">
<ptxt>INSTALL ENGINE COVER SUB-ASSEMBLY</ptxt>
</s-1>
<s-1 id="RM000002A46000X_01_0003">
<ptxt>CHECK FOR ENGINE OIL LEAKS</ptxt>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>