<dtccode>P0441</dtccode>
<dtcname>Evaporative Emission Control System Incorrect Purge Flow</dtcname>
<subpara id="RM000000SWF015X_01" type-id="76" category="03" proc-id="RM0250U___00007HX00000">
<name>DTC SUMMARY</name>
<content5 releasenbr="1">
<table pgwide="1">
