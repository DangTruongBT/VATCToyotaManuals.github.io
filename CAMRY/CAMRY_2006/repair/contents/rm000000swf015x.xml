<thead>
<row>
<entry valign="middle" align="center">
<ptxt>DTC</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Monitoring Item</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Malfunction Detection Condition</ptxt>
</entry>
<entry valign="middle" align="center">
