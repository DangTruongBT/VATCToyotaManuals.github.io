<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000T" variety="S000T">
<name>U660E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000T_72XRI_T007S" variety="T007S">
<name>PARK / NEUTRAL POSITION SWITCH</name>
<para id="RM0000016E100FX" category="A" type-id="80001" name-id="AX08K-02" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000016E100FX_01" type-id="01" category="01">
<s-1 id="RM0000016E100FX_01_0004">
<ptxt>DISCONNECT CABLE FROM NEGATIVE BATTERY TERMINAL</ptxt>
</s-1>
<s-1 id="RM0000016E100FX_01_0010" proc-id="RM0250U___00009VS00000">
<ptxt>REMOVE COOL AIR INTAKE DUCT SEAL
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 7 clips and intake duct seal.</ptxt>
<figure>
<graphic graphicname="A132967" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000016E100FX_01_0005" proc-id="RM0250U___00006SM00000">
<ptxt>REMOVE AIR CLEANER INLET ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts, clamp and air cleaner inlet.</ptxt>
<figure>
<graphic graphicname="A132969" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000016E100FX_01_0011" proc-id="RM0250U___0000BRR00000">
<ptxt>REMOVE AIR CLEANER CAP SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the 3 vacuum hoses.</ptxt>
<figure>
<graphic graphicname="A135704" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the mass air flow meter connector (<sup>*</sup>1). </ptxt>
<figure>
<graphic graphicname="A135705E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the No. 2 ventilation hose (<sup>*</sup>2).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the hose band (<sup>*</sup>3).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the 3 bands, and remove the air cleaner cap sub-assembly.</ptxt>
<figure>
<graphic graphicname="A135706" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000016E100FX_01_0006" proc-id="RM0250U___00006SN00000">
<ptxt>REMOVE AIR CLEANER CASE SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the vacuum hose and hose clamp.</ptxt>
<figure>
<graphic graphicname="A132971" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 3 bolts and air cleaner case.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000016E100FX_01_0007" proc-id="RM0250U___00006SO00000">
<ptxt>REMOVE NO. 1 AIR CLEANER INLET
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt and No. 1 air cleaner inlet.</ptxt>
<figure>
<graphic graphicname="A132970" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000016E100FX_01_0008" proc-id="RM0250U___00009QV00000">
<ptxt>REMOVE AIR CLEANER BRACKET</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Separate the wire harness clamp.</ptxt>
<figure>
<graphic graphicname="C132235" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 3 bolts and air cleaner bracket.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000016E100FX_01_0009" proc-id="RM0250U___0000CBN00000">
<ptxt>REMOVE PARK/NEUTRAL POSITION SWITCH ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the clip from the transmission cable bracket.</ptxt>
<figure>
<graphic graphicname="C132237" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the nut and transmission control cable from the control shaft lever.</ptxt>
<figure>
<graphic graphicname="C132236" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the connector from the park/neutral position switch.</ptxt>
</s2>
<s2>
<ptxt>Remove the nut, washer and control shaft lever from the control shaft.</ptxt>
<figure>
<graphic graphicname="C136685" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts and park/neutral position switch from the control shaft.</ptxt>
<figure>
<graphic graphicname="C135732" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Before removing the park/neutral position switch, remove any dirt or rust on the installation portion of the control shaft. Be sure to remove the switch straight along the shaft while being careful not to deform the plate spring that supports the shaft. If the plate spring is deformed, the park/neutral switch cannot be reinstalled correctly.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>