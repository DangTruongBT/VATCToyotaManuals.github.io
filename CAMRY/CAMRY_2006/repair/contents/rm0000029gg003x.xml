</entry>
<entry valign="middle">
<ptxt>Below 100 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Q6-4 (DOWN) - Q6-3 (GND)</ptxt>
</entry>
<entry valign="middle">
<ptxt>DOWN</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 100 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Q6-5 (UP) - Q6-3 (GND)</ptxt>
</entry>
<entry valign="middle">
<ptxt>UP</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 100 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Q6-1 (CLS) - Q6-3 (GND)</ptxt>
</entry>
<entry valign="middle">
<ptxt>OPEN</ptxt>
</entry>
<entry valign="middle">
<ptxt>1 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Q6-2 (OPN) - Q6-3 (GND)</ptxt>
</entry>
<entry valign="middle">
<ptxt>CLOSE</ptxt>
</entry>
<entry valign="middle">
<ptxt>1 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Q6-4 (DOWN) - Q6-3 (GND)</ptxt>
</entry>
