<ttl id="1001K_S001M_72XLO_T006Z" variety="T006Z">
<name>LUGGAGE COMPARTMENT DOOR LOCK</name>
<para id="RM000001OIQ002X" category="A" type-id="80001" name-id="ED0N2-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM000001OIQ002X_01" type-id="01" category="01">
<s-1 id="RM000001OIQ002X_01_0014" proc-id="RM0250U___00005SY00000">
<ptxt>REMOVE LUGGAGE COMPARTMENT DOOR COVER
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a clip remover, remove the 13 clips and luggage compartment door cover.</ptxt>
<figure>
<graphic graphicname="B135458" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001OIQ002X_01_0001" proc-id="RM0250U___00001OW00000">
<ptxt>REMOVE LUGGAGE COMPARTMENT DOOR LOCK ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the rod.</ptxt>
<figure>
<graphic graphicname="B136491" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the connector.</ptxt>
<figure>
<graphic graphicname="B136880" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts and luggage compartment door lock assembly.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
