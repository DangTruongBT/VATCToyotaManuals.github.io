<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="38">
<name>HEATER &amp; AIR CONDITIONING SYSTEM</name>
<section id="1002K_S0015" variety="S0015">
<name>AIR CONDITIONING</name>
<ttl id="1002K_S0015_72YHP_T009Y" variety="T009Y">
<name>ROOM TEMPERATURE SENSOR</name>
<para id="RM0000027V7000X" category="A" type-id="30014" name-id="AC23I-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000027V7000X_01" type-id="01" category="01">
<s-1 id="RM0000027V7000X_01_0001" proc-id="RM0250U___00009E100000">
<ptxt>INSTALL ROOM TEMPERATURE SENSOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the claw to install the sensor.</ptxt>
<figure>
<graphic graphicname="E129986" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the connector and attach the air hose.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000027V7000X_01_0005" proc-id="RM0250U___00007XU00000">
<ptxt>INSTALL LOWER INSTRUMENT PANEL FINISH PANEL LH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air hose and connect the connector.</ptxt>
<figure>
<graphic graphicname="B133980E05" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Engage the claw and the 9 clips.</ptxt>
</s2>
<s2>
<ptxt>Instal the instrument panel finish panel LH with the screw &lt;B&gt; and bolt &lt;A&gt;.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000027V7000X_01_0006" proc-id="RM0250U___00006MR00000">
<ptxt>INSTALL COWL SIDE TRIM SUB-ASSEMBLY LH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 2 clips.</ptxt>
<figure>
<graphic graphicname="B132116E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the cowl side trim sub-assembly LH with the cowl side trim clip.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000027V7000X_01_0007" proc-id="RM0250U___00006MS00000">
<ptxt>INSTALL FRONT DOOR SCUFF PLATE LH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 7 claws and 3 clips, then install the front door scuff plate LH.</ptxt>
<figure>
<graphic graphicname="B132067" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>