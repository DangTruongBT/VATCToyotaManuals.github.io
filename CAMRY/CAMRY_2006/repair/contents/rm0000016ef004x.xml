<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000T" variety="S000T">
<name>U660E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000T_72XRN_T007X" variety="T007X">
<name>SHIFT LEVER</name>
<para id="RM0000016EF004X" category="A" type-id="80002" name-id="AX090-02" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM0000016EF004X_01" type-id="01" category="01">
<s-1 id="RM0000016EF004X_01_0001" proc-id="RM0250U___000028Q00000">
<ptxt>REMOVE INDICATOR LIGHT WIRE SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a screwdriver, release the stopper.</ptxt>
<figure>
<graphic graphicname="C092376E02" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Using a screwdriver, disengage the locking lug of terminals (4) and (8), and pull the terminals out from the rear of the connector.</ptxt>
</s2>
<s2>
<ptxt>Release the indicator light wire from the clamp on the shift lock control unit assembly.</ptxt>
<figure>
<graphic graphicname="C135019E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Turn the indicator light guide counterclockwise.</ptxt>
</s2>
<s2>
<ptxt>Align the indicator light guide key with the groove on the shift lock control unit to remove the indicator light wire.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000016EF004X_01_0006" proc-id="RM0250U___00009TT00000">
<ptxt>REMOVE SHIFT LOCK CONTROL ECU</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the shift lock control ECU from the shift lock control unit assembly.</ptxt>
<figure>
<graphic graphicname="C135730" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>