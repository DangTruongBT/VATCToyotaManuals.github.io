<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="1000B_S000K" variety="S000K">
<name>2GR-FE EXHAUST</name>
<ttl id="1000B_S000K_7306U_T00EO" variety="T00EO">
<name>EXHAUST PIPE</name>
<para id="RM000001IRK001X" category="A" type-id="80001" name-id="EX057-02" from="200601">
<name>REMOVAL</name>
<subpara id="RM000001IRK001X_02" type-id="01" category="01">
<s-1 id="RM000001IRK001X_02_0006" proc-id="RM0250U___000095A00000">
<ptxt>REMOVE EXHAUST TAIL PIPE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 4 nuts and 2 exhaust tail pipes.</ptxt>
<figure>
<graphic graphicname="A135718" width="7.106578999in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 gaskets from the exhaust center pipe assembly.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IRK001X_02_0005" proc-id="RM0250U___000095900000">
<ptxt>REMOVE EXHAUST CENTER PIPE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts, 2 nuts and exhaust center pipe assembly.</ptxt>
<figure>
<graphic graphicname="A135719" width="7.106578999in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the gasket from the exhaust pipe assembly.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IRK001X_02_0002" proc-id="RM0250U___000095600000">
<ptxt>REMOVE FRONT EXHAUST PIPE NO. 1 SUPPORT BRACKET</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 nuts and front support brackets.</ptxt>
<figure>
<graphic graphicname="A085549E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IRK001X_02_0004" proc-id="RM0250U___000095800000">
<ptxt>REMOVE EXHAUST FRONT PIPE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the 2 heated oxygen sensor (bank 1, 2 sensor 2) connectors.</ptxt>
</s2>
<s2>
<ptxt>Remove the 2 nuts from the exhaust  front pipe (left bank exhaust manifold side).</ptxt>
<figure>
<graphic graphicname="A135720" width="7.106578999in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 nuts from the exhaust front pipe (right bank exhaust pipe manifold side).</ptxt>
</s2>
<s2>
<ptxt>Remove the exhaust front pipe.</ptxt>
</s2>
<s2>
<ptxt>Remove the 2 gaskets from the exhaust front pipe.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IRK001X_02_0008" proc-id="RM0250U___000094N00000">
<ptxt>REMOVE HEATED OXYGEN SENSOR
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST, remove the oxygen sensor.</ptxt>
<figure>
<graphic graphicname="A135716E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09224-00010</s-number>
</sstitem>
</sst>
</s2>
</content1></s-1>
<s-1 id="RM000001IRK001X_02_0003" proc-id="RM0250U___000095700000">
<ptxt>REMOVE REAR EXHAUST PIPE NO. 1 SUPPORT BRACKET</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts and rear support bracket.</ptxt>
<figure>
<graphic graphicname="A132948E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>