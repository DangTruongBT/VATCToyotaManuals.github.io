</spec>
</test1>
</content6>
<res>
<down ref="RM0000028IX000X_04_0006" fin="false">OK</down>
<right ref="RM0000028IX000X_04_0008" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000028IX000X_04_0006" proc-id="RM0250U___0000A6T00000">
