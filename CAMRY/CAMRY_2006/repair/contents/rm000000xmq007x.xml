<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="35">
<name>SUSPENSION &amp; AXLE</name>
<section id="1000J_S000X" variety="S000X">
<name>TIRE AND WHEEL</name>
<ttl id="1000J_S000X_738JZ_T00GU" variety="T00GU">
<name>TIRE PRESSURE WARNING SYSTEM</name>
<para id="RM000000XMQ007X" category="D" type-id="3001B" name-id="TW008-08" from="200601">
<name>HOW TO PROCEED WITH TROUBLESHOOTING</name>
<subpara id="RM000000XMQ007X_z0" proc-id="RM0250U___00005GI00001">
<content5 releasenbr="1">
<ptxt>The intelligent tester can be used at steps 4, 8 and 10.</ptxt>
<descript-diag>
<descript-testgroup>
<testtitle>Vehicle Brought to Workshop</testtitle>
<results>
<result-ci-down>NEXT</result-ci-down>
</results>
</descript-testgroup>
<descript-testgroup>
<testtitle>Customer Problem Analysis</testtitle>
<results>
<result-ci-down>NEXT</result-ci-down>
</results>
</descript-testgroup>
<descript-testgroup>
<testtitle>Check Tire Pressure Warning Light and Indicator Condition</testtitle>
<test1>
<ptxt>Turn the ignition switch on (IG).</ptxt>
</test1>
<test1>
<ptxt>Record the condition of the tire pressure warning light on the combination meter assembly.</ptxt>
</test1>
<test1>
<ptxt>Refer to the "TIRE PRESSURE WARNING LIGHT AND INDICATOR CHART" section of the DIAGNOSIS SYSTEM for checking the condition of the tire pressure warning light (See page <xref label="Seep01" href="RM000000XMW008X"/>).</ptxt>
</test1>
<results>
<result-ci-down>NEXT</result-ci-down>
</results>
</descript-testgroup>
<descript-testgroup>
<testtitle>DTC Check and Clear </testtitle>
<results>
<result/>
<action-ci-right>DTC is output: Go to step 5</action-ci-right>
<result/>
<action-ci-right>DTC is not output: Go to step 6</action-ci-right>
</results>
</descript-testgroup>
<descript-testgroup>
<testtitle>DTC Chart </testtitle>
<results>
<result/>
<action-ci-right>Go to step 8</action-ci-right>
</results>
</descript-testgroup>
<descript-testgroup>
<testtitle>Problem Symptom Confirmation</testtitle>
<results>
<result/>
<action-ci-right>Symptom does not occur: Symptom simulation</action-ci-right>
<result/>
<action-ci-right>Symptom occurs: Go to step 7</action-ci-right>
</results>
</descript-testgroup>
<descript-testgroup>
<testtitle>Problem Symptoms Table</testtitle>
<results>
<result-ci-down>Next</result-ci-down>
</results>
</descript-testgroup>
<descript-testgroup>
<testtitle>Circuit Inspection</testtitle>
<test1>
<ptxt>Refer to PRECAUTION (See page <xref label="Seep02" href="RM000000XMK008X"/>).</ptxt>
</test1>
<test1>
<ptxt>Refer to SYSTEM DESCRIPTION (See page <xref label="Seep03" href="RM000000XMM008X"/>).</ptxt>
</test1>
<test1>
<ptxt>Set the tire pressures to the appropriate specified values.</ptxt>
</test1>
<test1>
<ptxt>Perform initialization (See page <xref label="Seep04" href="RM000000XMZ008X"/>).</ptxt>
</test1>
<test1>
<ptxt>Perform test mode procedure (See page <xref label="Seep05" href="RM000000XN0008X"/>).</ptxt>
<test2>
<ptxt>Check for a DTC (See page <xref label="Seep06" href="RM000000XMX008X"/>).</ptxt>
</test2>
<test2>
<ptxt>Clear the DTC.</ptxt>
</test2>
<test2>
<ptxt>Identify the transmitter corresponding to a DTC.</ptxt>
</test2>
</test1>
<test1>
<ptxt>Perform registration of the transmitter ID (See page <xref label="Seep08" href="RM000000XN1008X"/>).</ptxt>
</test1>
<test1>
<ptxt>Check the terminals of ECU (See page <xref label="Seep09" href="RM000000XMS007X"/>).</ptxt>
</test1>
<test1>
<ptxt>Refer to DATA LIST / ACTIVE TEST (See page <xref label="Seep10" href="RM000000XMY007X"/>).</ptxt>
</test1>
<results>
<result-ci-down>NEXT</result-ci-down>
</results>
</descript-testgroup>
<descript-testgroup>
<testtitle>Repair</testtitle>
<results>
<result-ci-down>NEXT</result-ci-down>
</results>
</descript-testgroup>
<descript-testgroup>
<testtitle>Confirmation Test</testtitle>
<test1>
<ptxt>Check for a DTC (See page <xref label="Seep07" href="RM000000XMX008X"/>).</ptxt>
</test1>
<test1>
<ptxt>Perform initialization (See page <xref label="Seep11" href="RM000000XMZ008X"/>).</ptxt>
</test1>
<test1>
<ptxt>Confirm that the initialization has been completed.</ptxt>
</test1>
<results>
<result-ci-down>NEXT</result-ci-down>
<action-ci-fin>End</action-ci-fin>
</results>
</descript-testgroup>
</descript-diag>
</content5>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>