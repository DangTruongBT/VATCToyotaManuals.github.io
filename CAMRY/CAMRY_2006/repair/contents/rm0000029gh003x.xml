<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Q13-8 (DWN) - Q6-4 (DOWN)</ptxt>
<ptxt>
<sup>(*1)</sup>
</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
