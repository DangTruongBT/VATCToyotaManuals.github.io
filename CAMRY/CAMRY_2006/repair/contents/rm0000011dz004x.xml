<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="35">
<name>SUSPENSION &amp; AXLE</name>
<section id="1002I_S000Z" variety="S000Z">
<name>SUSPENSION</name>
<ttl id="1002I_S000Z_72VBA_T005C" variety="T005C">
<name>REAR STRUT ROD</name>
<para id="RM0000011DZ004X" category="A" type-id="80001" name-id="SP0ZN-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000011DZ004X_01" type-id="01" category="01">
<s-1 id="RM0000011DZ004X_01_0001">
<ptxt>REMOVE REAR WHEEL</ptxt>
</s-1>
<s-1 id="RM0000011DZ004X_01_0003" proc-id="RM0250U___00000IZ00000">
<ptxt>SEPARATE PARKING BRAKE NO. 3 CABLE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt, and separate the parking brake No. 3 cable assembly.</ptxt>
<figure>
<graphic graphicname="C132474" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011DZ004X_01_0002" proc-id="RM0250U___00000IY00000">
<ptxt>REMOVE REAR STRUT ROD</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Support the rear axle carrier with a jack.</ptxt>
<figure>
<graphic graphicname="C132459E01" width="2.775699831in" height="4.7836529in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the bolt and nut, and disconnect the strut rod (front side).</ptxt>
<figure>
<graphic graphicname="C132475" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>When removing the bolt, keep the nut from rotating.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Remove the bolt, nut and strut rod from the rear axle carrier.</ptxt>
<figure>
<graphic graphicname="C132476" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>When removing the bolt, keep the nut from rotating.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>