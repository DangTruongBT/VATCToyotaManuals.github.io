<ttl id="1001C_S001D_72YIE_T00A3" variety="T00A3">
<name>AUDIO AND VISUAL SYSTEM</name>
<para id="RM0000014OW00FX" category="J" type-id="303T7" name-id="AV1EX-01" from="200601">
<dtccode/>
<dtcname>Mute Signal Circuit between Radio Receiver and Stereo Component Amplifier</dtcname>
<subpara id="RM0000014OW00FX_01" type-id="60" category="03" proc-id="RM0250U___00004QI00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>This circuit sends a signal to the stereo component amplifier to mute noise. Because of that, the noise produced by changing the sound source ceases.</ptxt>
<ptxt>If there is an open in the circuit, noise can be heard from the speakers when changing the sound source.</ptxt>
<ptxt>If there is a short in the circuit, even though the stereo component amplifier is normal, no sound, or only an extremely small sound, can be produced.</ptxt>
</content5>
</subpara>
<subpara id="RM0000014OW00FX_02" type-id="32" category="03" proc-id="RM0250U___00004QJ00000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="E110892E25" width="7.106578999in" height="2.775699831in"/>
</figure>
</content5>
</subpara>
<subpara id="RM0000014OW00FX_03" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM0000014OW00FX_04" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM0000014OW00FX_04_0001" proc-id="RM0250U___00004QK00000">
<testtitle>INSPECT STEREO COMPONENT AMPLIFIER</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Measure the voltage according to the value(s) in the table below.</ptxt>
<figure>
<graphic graphicname="E126155E02" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>MUTE - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Turn ignition switch on (ACC), Audio system is playing → Changing</ptxt>
</entry>
<entry valign="middle">
<ptxt>Above 3.5 V → Below 1 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000014OW00FX_04_0003" fin="false">NG</down>
<right ref="RM0000014OW00FX_04_0002" fin="true">OK</right>
</res>
</testgrp>
<testgrp id="RM0000014OW00FX_04_0003" proc-id="RM0250U___00004QL00000">
<testtitle>CHECK HARNESS AND CONNECTOR (RADIO RECEIVER - STEREO COMPONENT AMPLIFIER)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the radio receiver connector F26 and stereo component amplifier connector F19.</ptxt>
<figure>
<graphic graphicname="E129816E06" width="2.775699831in" height="5.787629434in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>MUTE - MUTE</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>MUTE - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000014OW00FX_04_0009" fin="false">OK</down>
<right ref="RM0000014OW00FX_04_0006" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000014OW00FX_04_0009" proc-id="RM0250U___00004QM00000">
<testtitle>INSPECT STEREO COMPONENT AMPLIFIER (OUTPUT SIGNAL)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Reconnect the stereo component amplifier connector F19.</ptxt>
<figure>
<graphic graphicname="E131994E04" width="2.775699831in" height="2.775699831in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the voltage according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>MUTE - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Turn ignition switch on (ACC), Audio system is playing.</ptxt>
</entry>
<entry valign="middle">
<ptxt>Above 3.5 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000014OW00FX_04_0005" fin="true">OK</down>
<right ref="RM0000014OW00FX_04_0010" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000014OW00FX_04_0005">
<testtitle>REPLACE RADIO RECEIVER</testtitle>
</testgrp>
<testgrp id="RM0000014OW00FX_04_0002">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM0000014OW00FX_04_0006">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
<testgrp id="RM0000014OW00FX_04_0010">
<testtitle>REPLACE STEREO COMPONENT AMPLIFIER</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
