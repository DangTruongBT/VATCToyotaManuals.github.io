<name>BODY</name>
<section id="1002X_S001Q" variety="S001Q">
<name>EXTERIOR</name>
<ttl id="1002X_S001Q_72Z71_T00AX" variety="T00AX">
<name>ROCKER PANEL MOULDING</name>
<para id="RM000000MN7003X" category="A" type-id="80001" name-id="ET0PF-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM000000MN7003X_01" type-id="01" category="01">
<s-1 id="RM000000MN7003X_01_0001" proc-id="RM0250U___00005UQ00000">
<ptxt>REMOVE ROCKER PANEL MOULDING PROTECTOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 screws and rocker panel moulding protector.</ptxt>
<figure>
<graphic graphicname="B135471" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000MN7003X_01_0002" proc-id="RM0250U___00005UR00000">
<ptxt>REMOVE ROCKER PANEL MOULDING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Put protective tape around the rocker panel moulding.</ptxt>
<figure>
<graphic graphicname="B135470E01" width="7.106578999in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 screws and grommet.</ptxt>
<figure>
<graphic graphicname="B135472" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the screw.</ptxt>
<figure>
<graphic graphicname="B135473" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 7 clips.</ptxt>
<figure>
<graphic graphicname="B135475" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 screws.</ptxt>
<figure>
<graphic graphicname="B135474" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disengage the 8 clips and remove the rocker panel moulding.</ptxt>
<figure>
<graphic graphicname="B135476" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
