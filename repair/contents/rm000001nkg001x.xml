<testgrp id="RM000001NKG001X_05_0020" proc-id="RM0250U___00003LS00000">
<testtitle>CHECK HARNESS AND CONNECTOR (SKID CONTROL SENSOR WIRE TO REAR SPEED SENSOR)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check harness and connector (skid control sensor wire).</ptxt>
<figure>
<graphic graphicname="C113396E05" width="2.775699831in" height="2.775699831in"/>
</figure>
<test2>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<subtitle>LH</subtitle>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.89in"/>
<colspec colname="COL2" colwidth="1.24in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>g1-1 - A-1</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
