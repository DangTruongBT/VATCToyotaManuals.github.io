</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<atten3>
<ptxt>Check the speed sensor signal after replacement (See page <xref label="Seep01" href="RM000001NKD001X"/>).</ptxt>
</atten3>
</test1>
</content6>
<res>
<down ref="RM000001NKG001X_05_0019" fin="false">OK</down>
<right ref="RM000001NKG001X_05_0029" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000001NKG001X_05_0019" proc-id="RM0250U___00003LR00000">
