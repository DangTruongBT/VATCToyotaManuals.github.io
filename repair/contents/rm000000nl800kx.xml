<name>AUDIO AND VISUAL SYSTEM</name>
<para id="RM000000NL800KX" category="J" type-id="301GR" name-id="AV03M-13" from="200601">
<dtccode/>
<dtcname>Pressing Power Switch does not Turn on System</dtcname>
<subpara id="RM000000NL800KX_01" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM000000NL800KX_02" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000000NL800KX_02_0001" proc-id="RM0250U___00004PF00000">
<testtitle>CHECK VEHICLE CONDITION</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check that conditions in the cabin are not likely to cause condensation.</ptxt>
<atten4>
<ptxt>This problem occurs when the cabin is humid and the temperature changes rapidly. This may produce condensation, resulting in a short circuit.</ptxt>
</atten4>
<spec>
<title>OK</title>
<specitem>
<ptxt>Condensation is not likely to be produced.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000NL800KX_02_0007" fin="true">OK</down>
<right ref="RM000000NL800KX_02_0005" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000NL800KX_02_0007">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM000000NL800KX_02_0005">
<testtitle>DRY OUT CABIN AND RECHECK CONDITION</testtitle>
</testgrp>
</subpara>
</para>
