<ptxt>Tester Connection (Symbols)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>E58-1 (+B) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 to 14 V</ptxt>
</entry>
</row>
<row>
<entry morerows="1" valign="middle" align="center">
<ptxt>E58-18 (IG) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Engine switch OFF</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 1 V </ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>Engine switch ON (IG)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 to 14 V</ptxt>
</entry>
</row>
<row>
<entry morerows="1" valign="middle" align="center">
<ptxt>E58-19 (ACC) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Engine switch OFF</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 1 V </ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>Engine switch ON (ACC)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 to 14 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
