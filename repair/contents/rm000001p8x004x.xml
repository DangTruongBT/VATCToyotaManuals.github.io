<para id="RM000001P8X004X" category="J" type-id="800MY" name-id="DL19L-01" from="200601">
<dtccode/>
<dtcname>Certification ECU Power Source Circuit</dtcname>
<subpara id="RM000001P8X004X_01" type-id="60" category="03" proc-id="RM0250U___00009OD00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>This is the power source circuit of the certification ECU.</ptxt>
<ptxt>The certification ECU controls the following:</ptxt>
<list1 type="unordered">
<item>
<ptxt>Electrical key verification confirmation</ptxt>
</item>
<item>
<ptxt>Cabin and door oscillator control</ptxt>
</item>
<item>
<ptxt>Entry door LOCK/UNLOCK request to the main body ECU</ptxt>
</item>
<item>
<ptxt>Steering LOCK/UNLOCK request</ptxt>
</item>
<item>
<ptxt>Immobiliser SET/UNSET request to the ID code box</ptxt>
</item>
</list1>
</content5>
</subpara>
<subpara id="RM000001P8X004X_02" type-id="32" category="03" proc-id="RM0250U___00009OE00000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="B112475E04" width="7.106578999in" height="8.799559038in"/>
</figure>
</content5>
</subpara>
<subpara id="RM000001P8X004X_03" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM000001P8X004X_04" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000001P8X004X_04_0001" proc-id="RM0250U___00009OF00000">
<testtitle>CHECK HARNESS AND CONNECTOR (POWER SOURCE CIRCUIT)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the E58 certification ECU connector.</ptxt>
<figure>
<graphic graphicname="B137963E07" width="2.775699831in" height="2.775699831in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the voltage according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.65in"/>
<colspec colname="COL2" colwidth="1.45in"/>
<colspec colname="COL3" colwidth="1.03in"/>
<thead>
<row>
