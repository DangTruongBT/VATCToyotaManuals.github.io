<subpara id="RM000000W8F016X_08" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000000W8F016X_08_0001" proc-id="RM0250U___000038V00000">
<testtitle>INSPECT TRANSMISSION WIRE (SL1)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Remove the TCM from the transaxle.</ptxt>
<figure>
<graphic graphicname="C133212E02" width="2.775699831in" height="2.775699831in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
<ptxt>20°C (68°F)</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>14 (SL1+) - 13 (SL1-)</ptxt>
</entry>
<entry valign="middle">
<ptxt>5.0 to 5.6 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<subtitle>Check for short</subtitle>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.89in"/>
<colspec colname="COL2" colwidth="1.24in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>14 (SL1+) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>13 (SL1-) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000W8F016X_08_0003" fin="false">NG</down>
<right ref="RM000000W8F016X_08_0005" fin="true">OK</right>
</res>
</testgrp>
<testgrp id="RM000000W8F016X_08_0003" proc-id="RM0250U___000038X00000">
<testtitle>INSPECT SHIFT SOLENOID VALVE SL1</testtitle>
<content6 releasenbr="1">
