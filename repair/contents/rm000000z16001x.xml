<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1000S_S000R" variety="S000R">
<name>CLUTCH</name>
<ttl id="1000S_S000R_73063_T00DY" variety="T00DY">
<name>CLUTCH ACCUMULATOR</name>
<para id="RM000000Z16001X" category="A" type-id="80001" name-id="CL0FK-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM000000Z16001X_01" type-id="01" category="01">
<s-1 id="RM000000Z16001X_01_0005">
<ptxt>DISCONNECT CABLE FROM NEGATIVE BATTERY TERMINAL</ptxt>
</s-1>
<s-1 id="RM000000Z16001X_01_0010" proc-id="RM0250U___0000A7U00000">
<ptxt>REMOVE AIR CLEANER INLET ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts, clamp and air cleaner inlet.</ptxt>
<figure>
<graphic graphicname="A134903" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000000Z16001X_01_0011" proc-id="RM0250U___0000B9500000">
<ptxt>REMOVE AIR CLEANER CAP SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the mass air flow meter connector (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A135666E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the purge VSV connector (<sup>*</sup>2).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the 2 purge VSV vacuum hoses (<sup>*</sup>3).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the purge line hose from the clamp (<sup>*</sup>4).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the No. 2 ventilation hose from the air cleaner hose.</ptxt>
<figure>
<graphic graphicname="A135667E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Lock the No. 1 air cleaner hose clamp, and then disconnect the No. 1 air cleaner hose from the throttle body.</ptxt>
<figure>
<graphic graphicname="A135668" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts and air cleaner cap.</ptxt>
<figure>
<graphic graphicname="A135669" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the air cleaner filter element from the air cleaner case.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000Z16001X_01_0012" proc-id="RM0250U___0000A7V00000">
<ptxt>REMOVE AIR CLEANER CASE SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the hose clamp.</ptxt>
<figure>
<graphic graphicname="A134905" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 3 bolts and air cleaner case.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000Z16001X_01_0003" proc-id="RM0250U___0000A9A00000">
<ptxt>REMOVE CLUTCH ACCUMULATOR BRACKET</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts and clutch accumulator bracket.</ptxt>
<figure>
<graphic graphicname="C132974" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z16001X_01_0004" proc-id="RM0250U___0000A9B00000">
<ptxt>REMOVE RELEASE CYLINDER HEAT INSULATOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts and release cylinder heat insulator.</ptxt>
<figure>
<graphic graphicname="C132975" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z16001X_01_0001" proc-id="RM0250U___00008YY00000">
<ptxt>DISCONNECT CLUTCH LINE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST, disconnect the clutch lines.</ptxt>
<figure>
<graphic graphicname="C132976E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09023-00101</s-number>
</sstitem>
</sst>
<atten4>
<ptxt>Use a container to catch the fluid.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z16001X_01_0002" proc-id="RM0250U___00008YZ00000">
<ptxt>REMOVE CLUTCH ACCUMULATOR ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 nuts and clutch accumulator assembly.</ptxt>
<figure>
<graphic graphicname="C132977" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>