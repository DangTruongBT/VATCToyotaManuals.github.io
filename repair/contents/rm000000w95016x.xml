</entry>
<entry valign="middle">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>P0604, P0606, P0607 or P0657 and other DTCs</ptxt>
</entry>
<entry valign="middle">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</content6>
<res>
<down ref="RM000000W95016X_06_0003" fin="true">A</down>
<right ref="RM000000W95016X_06_0002" fin="true">B</right>
</res>
</testgrp>
