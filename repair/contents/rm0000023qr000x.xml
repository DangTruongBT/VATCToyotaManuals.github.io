<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1001B_S001C" variety="S001C">
<name>WIPER AND WASHER</name>
<ttl id="1001B_S001C_72WDN_T0064" variety="T0064">
<name>WIPER SWITCH</name>
<para id="RM0000023QR000X" category="A" type-id="80001" name-id="WW0M9-03" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000023QR000X_01" type-id="01" category="01">
<s-1 id="RM0000023QR000X_01_0004" proc-id="RM0250U___00000CD00000">
<ptxt>REMOVE STEERING COLUMN COVER
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 screws.</ptxt>
<figure>
<graphic graphicname="C132544" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disengage the 2 claws to remove the lower steering column cover.</ptxt>
</s2>
<s2>
<ptxt>Disengage the claw to remove the upper steering column cover.</ptxt>
<figure>
<graphic graphicname="C132545" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000023QR000X_01_0003" proc-id="RM0250U___000046800000">
<ptxt>REMOVE WINDSHIELD WIPER SWITCH ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the 2 connectors.</ptxt>
<figure>
<graphic graphicname="E128824" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Disengage the claw and remove the windshield wiper switch assembly as shown in the illustration.</ptxt>
<atten3>
<ptxt>If the claw is pushed with excessive force, it may break.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>