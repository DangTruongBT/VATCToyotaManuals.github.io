</entry>
<entry valign="middle">
<ptxt>0 to 2</ptxt>
</entry>
<entry valign="middle">
<ptxt>3 to 5</ptxt>
</entry>
<entry valign="middle">
<ptxt>6 to 8</ptxt>
</entry>
<entry valign="middle">
<ptxt>9 to 11</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Bearing to be used</ptxt>
</entry>
<entry valign="middle">
<ptxt>"1"</ptxt>
</entry>
<entry valign="middle">
<ptxt>"2"</ptxt>
</entry>
<entry valign="middle">
<ptxt>"3"</ptxt>
</entry>
<entry valign="middle">
<ptxt>"4"</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</atten4>
