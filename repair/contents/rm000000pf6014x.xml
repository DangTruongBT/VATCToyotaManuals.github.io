</entry>
</row>
<row>
<entry valign="middle">
<ptxt>VTA2 (C5-4) or VTA2 (C55-99) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
