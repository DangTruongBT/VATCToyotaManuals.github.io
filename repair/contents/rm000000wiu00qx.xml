<entry valign="middle" align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Value</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>E10-6 (CANH) - E10-4 (CG)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Ignition switch off</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>200 Ω or higher</ptxt>
</entry>
</row>
<row>
<entry>
<ptxt>E10-14 (CANL) - E10-4 (CG)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Ignition switch off</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>200 Ω or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000WIU00QX_06_0096" fin="false">NG</down>
<right ref="RM000000WIU00QX_06_0103" fin="false">OK</right>
</res>
</testgrp>
<testgrp id="RM000000WIU00QX_06_0096" proc-id="RM0250U___0000BX900000">
<testtitle>CHECK FOR SHORT TO GND IN CAN BUS WIRE</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect connectors from the No. 1 CAN J/C one at a time.</ptxt>
<figure>
<graphic graphicname="C126231E13" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten4>
<ptxt>Disconnect the ECU and sensor connectors other than the DLC3 branch wires and CAN main bus wire between the No. 1 CAN J/C.</ptxt>
</atten4>
</test1>
<test1>
<ptxt>Measure the resistance between terminals 6 (CANH) and 4 (CG), and between terminals 14 (CANL) and 4 (CG) of the DLC3 each time a connector is disconnected.</ptxt>
<figure>
<graphic graphicname="C136707E02" width="7.106578999in" height="8.799559038in"/>
</figure>
<figure>
<graphic graphicname="C137761E02" width="7.106578999in" height="4.7836529in"/>
</figure>
<table pgwide="1">
<tgroup cols="4">
<colspec colname="COL1" colwidth="2.83in"/>
<colspec colname="COLSPEC0" colwidth="1.42in"/>
<colspec colname="COL3" colwidth="1.42in"/>
<colspec colname="COL4" colwidth="1.41in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>No. 1 CAN J/C connectors ("A" side, with earth terminal)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Connector Color</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Wire Color (CAN-H)</ptxt>
</entry>
<entry valign="middle" align="center">
