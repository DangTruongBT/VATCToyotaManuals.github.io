</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>Airbag Sensor Assembly Center (E45)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Black</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>W</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<table pgwide="1">
<tgroup cols="4">
<colspec colname="COL1" colwidth="2.83in"/>
<colspec colname="COLSPEC1" colwidth="1.41in"/>
<colspec colname="COL3" colwidth="1.41in"/>
<colspec colname="COL4" colwidth="1.43in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>No. 1 CAN J/C connectors ("A" side, with earth terminal)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Connector Color</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Wire Color (CAN-H)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Wire Color (CAN-L)</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>Yaw Rate Sensor* (E46)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Blue</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>W</ptxt>
</entry>
</row>
<row>
<entry>
<ptxt>Steering Angle Sensor* (E63)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Brown</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>W</ptxt>
</entry>
</row>
<row>
<entry>
<ptxt>Combination Meter (E43)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>White</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>W</ptxt>
