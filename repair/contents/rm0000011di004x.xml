<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="35">
<name>SUSPENSION &amp; AXLE</name>
<section id="1002I_S000Z" variety="S000Z">
<name>SUSPENSION</name>
<ttl id="1002I_S000Z_72VB6_T0058" variety="T0058">
<name>FRONT SUSPENSION LOWER NO. 1 ARM</name>
<para id="RM0000011DI004X" category="A" type-id="30014" name-id="SP0ZD-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000011DI004X_01" type-id="01" category="01">
<s-1 id="RM0000011DI004X_01_0001" proc-id="RM0250U___00000G200000">
<ptxt>INSTALL FRONT SUSPENSION LOWER NO. 1 ARM</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the front lower arm bushing stopper.</ptxt>
</s2>
<s2>
<ptxt>Install the front suspension lower No. 1 arm to the front frame assembly with the 3 bolts and the nut, but do not tighten them yet.</ptxt>
</s2>
<s2>
<ptxt>Tighten the 3 bolts in numerical order shown in the illustration.</ptxt>
<figure>
<graphic graphicname="C111327E03" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>200</t-value1>
<t-value2>2,040</t-value2>
<t-value4>148</t-value4>
<ptxt>(bolt A)</ptxt>
</torqueitem>
<torqueitem>
<t-value1>206</t-value1>
<t-value2>2,100</t-value2>
<t-value4>152</t-value4>
<ptxt>(bolt B)</ptxt>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011DI004X_01_0002" proc-id="RM0250U___00000G300000">
<ptxt>INSTALL ENGINE MOUNTING INSULATOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the engine mounting insulator with the 3 nuts.</ptxt>
<figure>
<graphic graphicname="C138032E01" width="2.775699831in" height="3.779676365in"/>
</figure>
<torque>
<torqueitem>
<t-value1>87</t-value1>
<t-value2>887</t-value2>
<t-value4>64</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011DI004X_01_0003" proc-id="RM0250U___00000G400000">
<ptxt>INSTALL ENGINE ASSEMBLY WITH TRANSAXLE</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Refer to the instructions for removal of the engine assembly (See page <xref label="Seep01" href="RM000000YIK001X"/> for 2AZ-FE, <xref label="Seep02" href="RM0000021ZR001X"/> for 2GR-FE).</ptxt>
</atten4>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>