<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="1000A_S0008" variety="S0008">
<name>2AZ-FE ENGINE MECHANICAL</name>
<ttl id="1000A_S0008_72ZJV_T00CA" variety="T00CA">
<name>CYLINDER HEAD</name>
<para id="RM000000YIE001X" category="A" type-id="80002" name-id="EM069-02" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM000000YIE001X_01" type-id="01" category="01">
<s-1 id="RM000000YIE001X_01_0001" proc-id="RM0250U___00006UM00000">
<ptxt>REMOVE VALVE LIFTER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the valve lifters.</ptxt>
<figure>
<graphic graphicname="A062842E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten4>
<ptxt>Arrange the valve lifters in the correct order.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YIE001X_01_0002" proc-id="RM0250U___00006UN00000">
<ptxt>REMOVE INTAKE VALVE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST and wooden blocks, compress and remove the valve retainer locks.</ptxt>
<figure>
<graphic graphicname="A128225E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09202-70020</s-number>
<s-subnumber>09202-00010</s-subnumber>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Remove the retainer, valve spring and valve.</ptxt>
<atten4>
<ptxt>Arrange the removed parts in the correct order.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YIE001X_01_0003" proc-id="RM0250U___00006UO00000">
<ptxt>REMOVE EXHAUST VALVE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST and wooden blocks, compress and remove the valve retainer locks.</ptxt>
<figure>
<graphic graphicname="A128226E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09202-70020</s-number>
<s-subnumber>09202-00010</s-subnumber>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Remove the retainer, valve spring and valve.</ptxt>
<atten4>
<ptxt>Arrange the removed parts in the correct order.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YIE001X_01_0004" proc-id="RM0250U___00006UP00000">
<ptxt>REMOVE VALVE STEM OIL SEAL</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using needle-nose pliers, remove the oil seals.</ptxt>
<figure>
<graphic graphicname="A013356E04" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YIE001X_01_0005" proc-id="RM0250U___0000A4C00000">
<ptxt>REMOVE VALVE SPRING SEAT</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using compressed air and a magnetic finger, remove the valve spring seats by blowing air onto them.</ptxt>
<figure>
<graphic graphicname="A062845E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YIE001X_01_0009" proc-id="RM0250U___0000A4F00000">
<ptxt>REMOVE NO. 1 STRAIGHT SCREW PLUG</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a 14 mm straight hexagon wrench, remove the 2 screw plugs and 2 gaskets.</ptxt>
<figure>
<graphic graphicname="A062841" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>If water leaks from the straight screw plug or the plug corrodes, replace it.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YIE001X_01_0006">
<ptxt>REMOVE STUD BOLT</ptxt>
</s-1>
<s-1 id="RM000000YIE001X_01_0010">
<ptxt>REMOVE RING PIN</ptxt>
</s-1>
<s-1 id="RM000000YIE001X_01_0007" proc-id="RM0250U___00006UQ00000">
<ptxt>REMOVE INTAKE VALVE GUIDE BUSH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Heat the cylinder head to 80 to 100°C (176 to 212°F).  </ptxt>
</s2>
<s2>
<ptxt>Place the cylinder head on wooden blocks.</ptxt>
</s2>
<s2>
<ptxt>Using SST and a hammer, tap out the guide bush.</ptxt>
<figure>
<graphic graphicname="A036632E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09201-10000</s-number>
<s-subnumber>09201-01050</s-subnumber>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07100</s-subnumber>
</sstitem>
</sst>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YIE001X_01_0008" proc-id="RM0250U___00006UR00000">
<ptxt>REMOVE EXHAUST VALVE GUIDE BUSH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Heat the cylinder head to 80 to 100°C (176 to 212°F).   </ptxt>
</s2>
<s2>
<ptxt>Place the cylinder head on wooden blocks.</ptxt>
</s2>
<s2>
<ptxt>Using SST and a hammer, tap out the guide bush.</ptxt>
<figure>
<graphic graphicname="A036633E03" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09201-10000</s-number>
<s-subnumber>09201-01050</s-subnumber>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07100</s-subnumber>
</sstitem>
</sst>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
