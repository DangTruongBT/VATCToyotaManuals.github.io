<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="1000D_S000N" variety="S000N">
<name>2GR-FE LUBRICATION</name>
<ttl id="1000D_S000N_72Z80_T00BL" variety="T00BL">
<name>OIL PUMP</name>
<para id="RM000001IQO001X" category="A" type-id="8000E" name-id="LU0DM-02" from="200601">
<name>REASSEMBLY</name>
<subpara id="RM000001IQO001X_01" type-id="01" category="01">
<s-1 id="RM000001IQO001X_01_0001" proc-id="RM0250U___000069L00000">
<ptxt>INSTALL OIL PUMP COVER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Coat the drive and driven rotors with engine oil and place them into the timing chain cover with the marks facing outward (oil pump cover side). Check that the rotors revolve smoothly.</ptxt>
<figure>
<graphic graphicname="A128010E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the oil pump cover with the 8 bolts.</ptxt>
<figure>
<graphic graphicname="A094627E02" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>9.1</t-value1>
<t-value2>93</t-value2>
<t-value3>81</t-value3>
</torqueitem>
</torque>
<table>
<title>Bolt length</title>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Item</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Length</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>Bolt A</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>22 mm (0.87 in.)</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>Bolt B</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>40 mm (1.58 in.)</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IQO001X_01_0002" proc-id="RM0250U___000069M00000">
<ptxt>INSTALL OIL PUMP RELIEF VALVE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Coat the oil pump relief valve with engine oil.</ptxt>
<figure>
<graphic graphicname="A128008" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Insert the relief valve and relief valve spring into the oil pump cover hole.</ptxt>
</s2>
<s2>
<ptxt>Using a 27 mm socket wrench, install the plug.</ptxt>
<torque>
<torqueitem>
<t-value1>49</t-value1>
<t-value2>500</t-value2>
<t-value4>37</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>