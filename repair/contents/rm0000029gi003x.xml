</tgroup>
</table>
</spec>
<atten4>
<list1 type="unordered">
<item>
<ptxt>*1: TMC made</ptxt>
</item>
<item>
<ptxt>*2: TMMK made</ptxt>
</item>
</list1>
</atten4>
</test1>
</content6>
<res>
<down ref="RM0000029GI003X_04_0004" fin="false">OK</down>
<right ref="RM0000029GI003X_04_0008" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000029GI003X_04_0004" proc-id="RM0250U___0000C5Q00000">
<testtitle>INSPECT ROOF CONSOLE BOX ASSEMBLY (SLIDING ROOF CONTROL SWITCH)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Remove the roof console box assembly.</ptxt>
<figure>
<graphic graphicname="B131165E02" width="2.775699831in" height="4.7836529in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Switch Position</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>Q6-1 (CLS) - Q6-3 (GND)</ptxt>
</entry>
<entry valign="middle">
<ptxt>CLOSE</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 100 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Q6-2 (OPN) - Q6-3 (GND)</ptxt>
</entry>
<entry valign="middle">
<ptxt>OPEN</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 100 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Q6-4 (DOWN) - Q6-3 (GND)</ptxt>
</entry>
<entry valign="middle">
<ptxt>DOWN</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 100 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Q6-5 (UP) - Q6-3 (GND)</ptxt>
</entry>
<entry valign="middle">
<ptxt>UP</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 100 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Q6-1 (CLS) - Q6-3 (GND)</ptxt>
</entry>
<entry valign="middle">
<ptxt>OPEN</ptxt>
</entry>
<entry valign="middle">
<ptxt>1 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Q6-2 (OPN) - Q6-3 (GND)</ptxt>
</entry>
<entry valign="middle">
<ptxt>CLOSE</ptxt>
</entry>
<entry valign="middle">
<ptxt>1 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Q6-4 (DOWN) - Q6-3 (GND)</ptxt>
</entry>
<entry valign="middle">
<ptxt>UP</ptxt>
</entry>
<entry valign="middle">
<ptxt>1 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Q6-5 (UP) - Q6-3 (GND)</ptxt>
</entry>
