</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000029GI003X_04_0005" fin="true">OK</down>
<right ref="RM0000029GI003X_04_0007" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000029GI003X_04_0005">
<testtitle>REPLACE SLIDING ROOF DRIVE GEAR SUB-ASSEMBLY (SLIDING ROOF CONTROL ECU)</testtitle>
</testgrp>
