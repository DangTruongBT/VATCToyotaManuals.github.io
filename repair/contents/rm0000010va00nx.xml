</content6>
<res>
<down ref="RM0000010VA00NX_04_0009" fin="false">NEXT</down>
</res>
</testgrp>
<testgrp id="RM0000010VA00NX_04_0009" proc-id="RM0250U___0000AC900000">
<testtitle>PERFORM ZERO POINT CALIBRATION</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Connect the negative (-) terminal cable to the battery.</ptxt>
</test1>
<test1>
<ptxt>Connect the intelligent tester to the DLC3.</ptxt>
</test1>
<test1>
<ptxt>Turn the ignition switch on (IG).</ptxt>
</test1>
<test1>
<ptxt>Using the intelligent tester, perform "zero point calibration" (See page <xref label="Seep01" href="RM0000010VN00QX"/>).</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>"COMPLETED" is displayed.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000010VA00NX_04_0010" fin="false">OK</down>
<right ref="RM0000010VA00NX_04_0012" fin="false">NG</right>
</res>
</testgrp>
<testgrp id="RM0000010VA00NX_04_0010" proc-id="RM0250U___0000ACA00000">
<testtitle>PERFORM SENSITIVITY CHECK</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Using the intelligent tester, perform "sensitivity check" (See page <xref label="Seep01" href="RM0000010VN00QX"/>).</ptxt>
<spec>
<title>Standard value</title>
<specitem>
<ptxt>27 to 33 kg (59.52 to 72.75 lb)</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000010VA00NX_04_0011" fin="false">OK</down>
<right ref="RM0000010VA00NX_04_0012" fin="false">NG</right>
</res>
</testgrp>
<testgrp id="RM0000010VA00NX_04_0011" proc-id="RM0250U___0000ACB00000">
<testtitle>CHECK DTC</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Turn the ignition switch on (IG).</ptxt>
</test1>
<test1>
<ptxt>Clear the DTCs stored in the occupant classification ECU (See page <xref label="Seep01" href="RM0000010VK00PX"/>).</ptxt>
</test1>
<test1>
<ptxt>Clear the DTCs stored in the center airbag sensor assembly (See page <xref label="Seep03" href="RM000000XFE00YX"/>).</ptxt>
</test1>
<test1>
<ptxt>Turn the ignition switch off.</ptxt>
</test1>
<test1>
<ptxt>Turn the ignition switch on (IG).</ptxt>
</test1>
<test1>
<ptxt>Check the DTCs (See page <xref label="Seep02" href="RM0000010VK00PX"/>).</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>DTC B1783 is not output.</ptxt>
</specitem>
</spec>
<atten4>
<ptxt>Codes other than DTC B1783 may be output at this time, but they are not related to this check.</ptxt>
</atten4>
</test1>
</content6>
<res>
<down ref="RM0000010VA00NX_04_0012" fin="false">NG</down>
<right ref="RM0000010VA00NX_04_0015" fin="true">OK</right>
</res>
</testgrp>
<testgrp id="RM0000010VA00NX_04_0012" proc-id="RM0250U___0000ACC00000">
<testtitle>REPLACE FRONT SEAT ASSEMBLY RH</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Turn the ignition switch off.</ptxt>
</test1>
<test1>
<ptxt>Disconnect the negative (-) terminal cable from the battery.</ptxt>
</test1>
<test1>
<ptxt>Replace the front seat assembly RH (See page <xref label="Seep01" href="RM000000VBG006X"/> for power seat or <xref label="Seep02" href="RM000001OH5003X"/> for manual seat).</ptxt>
</test1>
</content6>
<res>
<down ref="RM0000010VA00NX_04_0013" fin="false">NEXT</down>
</res>
</testgrp>
<testgrp id="RM0000010VA00NX_04_0013" proc-id="RM0250U___0000ACD00000">
<testtitle>PERFORM ZERO POINT CALIBRATION</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Connect the negative (-) terminal cable to the battery.</ptxt>
</test1>
<test1>
<ptxt>Connect the intelligent tester to the DLC3.</ptxt>
</test1>
<test1>
<ptxt>Turn the ignition switch on (IG).</ptxt>
</test1>
<test1>
<ptxt>Using the intelligent tester, perform "zero point calibration" (See page <xref label="Seep01" href="RM0000010VN00QX"/>).</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>"COMPLETED" is displayed.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000010VA00NX_04_0014" fin="false">NEXT</down>
</res>
</testgrp>
<testgrp id="RM0000010VA00NX_04_0014" proc-id="RM0250U___0000ACE00000">
<testtitle>PERFORM SENSITIVITY CHECK</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Using the intelligent tester, perform "sensitivity check" (See page <xref label="Seep01" href="RM0000010VN00QX"/>).</ptxt>
<spec>
<title>Standard value</title>
<specitem>
<ptxt>27 to 33 kg (59.52 to 72.75 lb)</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000010VA00NX_04_0015" fin="true">NEXT</down>
</res>
</testgrp>
<testgrp id="RM0000010VA00NX_04_0015">
<testtitle>END</testtitle>
</testgrp>
<testgrp id="RM0000010VA00NX_04_0016">
<testtitle>USE SIMULATION METHOD TO CHECK<xref label="Seep01" href="RM0000010VJ00PX"/>
</testtitle>
</testgrp>
<testgrp id="RM0000010VA00NX_04_0017">
<testtitle>CONNECT CONNECTORS PROPERLY, THEN GO TO STEP 1</testtitle>
</testgrp>
<testgrp id="RM0000010VA00NX_04_0018">
<testtitle>REPAIR OR REPLACE FRONT SEAT WIRE RH</testtitle>
</testgrp>
</subpara>
</para>
