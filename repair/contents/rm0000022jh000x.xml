<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="36">
<name>BRAKE</name>
<section id="1000N_S0011" variety="S0011">
<name>BRAKE</name>
<ttl id="1000N_S0011_72V8Z_T003W" variety="T003W">
<name>BRAKE BOOSTER</name>
<para id="RM0000022JH000X" category="A" type-id="30014" name-id="BR0XN-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000022JH000X_01" type-id="01" category="01">
<s-1 id="RM0000022JH000X_01_0001" proc-id="RM0250U___00003P000000">
<ptxt>INSTALL BRAKE MASTER CYLINDER PUSH ROD CLEVIS</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Temporarily install the lock nut and the brake master cylinder push rod clevis to the brake booster assembly.</ptxt>
<atten3>
<ptxt>Fully tighten the lock nut after adjusting the pedal height.</ptxt>
</atten3>
<torque>
<torqueitem>
<t-value1>26</t-value1>
<t-value2>265</t-value2>
<t-value4>19</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022JH000X_01_0006" proc-id="RM0250U___000071500000">
<ptxt>INSTALL BRAKE BOOSTER GASKET</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install a new brake booster gasket.</ptxt>
<figure>
<graphic graphicname="C132835E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022JH000X_01_0002" proc-id="RM0250U___00003P100000">
<ptxt>INSTALL BRAKE BOOSTER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the brake booster assembly with the 4 nuts.</ptxt>
<figure>
<graphic graphicname="C132719" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>13</t-value1>
<t-value2>133</t-value2>
<t-value4>10</t-value4>
</torqueitem>
</torque>
<atten3>
<ptxt>Do not damage the brake lines.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022JH000X_01_0003" proc-id="RM0250U___00003P200000">
<ptxt>CONNECT BRAKE MASTER CYLINDER PUSH ROD CLEVIS</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply lithium soap base glycol grease to the push rod pin.</ptxt>
<figure>
<graphic graphicname="C133452E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the brake master cylinder push rod clevis to the brake pedal with the push rod pin and a new clip as shown in the illustration.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022JH000X_01_0004" proc-id="RM0250U___000078M00000">
<ptxt>INSTALL BRAKE PEDAL RETURN SPRING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the brake pedal return spring.</ptxt>
<figure>
<graphic graphicname="C133454" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022JH000X_01_0018" proc-id="RM0250U___00003CI00000">
<ptxt>INSPECT AND ADJUST BRAKE PEDAL HEIGHT
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Inspect the brake pedal height.</ptxt>
<figure>
<graphic graphicname="C132713E01" width="2.775699831in" height="3.779676365in"/>
</figure>
<spec>
<title>Pedal height from dash panel</title>
<table>
<tgroup cols="2">
<colspec colname="COL2" colwidth="1.21in"/>
<colspec colname="COL3" colwidth="2.92in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Transaxle</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>Automatic</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>129.9 to 139.9 mm (5.114 to 5.508 in.)</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>Manual</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>131.9 to 141.9 mm (5.193 to 5.587 in.)</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</s2>
<s2>
<ptxt>Adjust the brake pedal height.</ptxt>
<s3>
<ptxt>Disconnect the connector from the stop light switch assembly.</ptxt>
</s3>
<s3>
<ptxt>Remove the stop light switch.</ptxt>
</s3>
<s3>
<ptxt>Loosen the push rod clevis lock nut.</ptxt>
</s3>
<s3>
<ptxt>Adjust the pedal height by turning the push rod.</ptxt>
</s3>
<s3>
<ptxt>Tighten the clevis lock nut.</ptxt>
<torque>
<torqueitem>
<t-value1>26</t-value1>
<t-value2>265</t-value2>
<t-value4>19</t-value4>
</torqueitem>
</torque>
</s3>
<s3>
<ptxt>Insert the switch into the adjuster until the switch body touches the pedal.</ptxt>
<figure>
<graphic graphicname="C111301E03" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Do not depress the pedal.</ptxt>
</atten3>
</s3>
<s3>
<ptxt>Rotate the switch a quarter turn clockwise.</ptxt>
<torque>
<torqueitem>
<t-value1>1.5</t-value1>
<t-value2>15</t-value2>
<t-value3>13</t-value3>
<ptxt>or less</ptxt>
</torqueitem>
</torque>
<atten3>
<ptxt>Do not depress the pedal.</ptxt>
</atten3>
</s3>
<s3>
<ptxt>Connect the connector.</ptxt>
</s3>
<s3>
<ptxt>Check the switch clearance.</ptxt>
<figure>
<graphic graphicname="F043108E08" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Standard stop light switch clearance</title>
<specitem>
<ptxt>1.5 to 2.5 mm (0.059 to 0.098 in.)</ptxt>
</specitem>
</spec>
</s3>
</s2>
</content1></s-1>
<s-1 id="RM0000022JH000X_01_0017" proc-id="RM0250U___0000C1D00000">
<ptxt>INSTALL BRAKE MASTER CYLINDER SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Refer to the procedures up to "INSTALL BRAKE MASTER CYLINDER". (See page <xref label="Seep01" href="RM0000022JD000X"/>)</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000022JH000X_01_0005" proc-id="RM0250U___00003WU00000">
<ptxt>CONNECT NO. 2 VACUUM HOSE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Connect the No. 2 vacuum hose and slide the clip.</ptxt>
<figure>
<graphic graphicname="C132715" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
