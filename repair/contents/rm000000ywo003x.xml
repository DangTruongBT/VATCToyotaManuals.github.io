<name>TRANSMISSION</name>
<section id="1002B_S000S" variety="S000S">
<name>U250E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000S_72XOZ_T007B" variety="T007B">
<name>PARK / NEUTRAL POSITION SWITCH</name>
<para id="RM000000YWO003X" category="N" type-id="3000G" name-id="AX03J-02" from="200601">
<name>ADJUSTMENT</name>
<subpara id="RM000000YWO003X_01" type-id="01" category="01">
<s-1 id="RM000000YWO003X_01_0001" proc-id="RM0250U___00001VL00000">
<ptxt>ADJUST PARK/NEUTRAL POSITION SWITCH ASSEMBLY</ptxt>
<content1 releasenbr="2">
<s2>
<ptxt>Loosen the 2 bolts of the park/neutral position switch and move the shift lever to the N position.</ptxt>
<figure>
<graphic graphicname="D025514E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Align the groove with the neutral basic line.</ptxt>
</s2>
<s2>
<ptxt>Hold the switch in position and tighten the 2 bolts.</ptxt>
<torque>
<torqueitem>
<t-value1>5.4</t-value1>
<t-value2>55</t-value2>
<t-value3>48</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>After adjustment, perform the inspection (See page <xref label="Seep01" href="RM000000YWQ003X"/>).</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>