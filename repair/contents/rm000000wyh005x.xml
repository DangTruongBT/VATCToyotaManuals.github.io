<name>DEFOGGER RELAY</name>
<para id="RM000000WYH005X" category="G" type-id="8000T" name-id="WS02H-06" from="200601">
<name>ON-VEHICLE INSPECTION</name>
<subpara id="RM000000WYH005X_01" type-id="01" category="01">
<s-1 id="RM000000WYH005X_01_0001" proc-id="RM0250U___000059500000">
<ptxt>INSPECT DEFOGGER RELAY (Marking: DEFOG)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<figure>
<graphic graphicname="B106753E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" align="center" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>3 - 4</ptxt>
</entry>
<entry>
<ptxt>Below 1 Ω</ptxt>
<ptxt>(when battery voltage is not applied between terminals)</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>3 - 5</ptxt>
</entry>
<entry>
<ptxt>10 kΩ or higher</ptxt>
<ptxt>(when battery voltage is not applied between terminals)</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>3 - 5 </ptxt>
</entry>
<entry>
<ptxt>Below 1 Ω</ptxt>
<ptxt>(when battery voltage is applied to terminals 1 and 2)</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<specitem>
<ptxt>If the result is not as specified, replace the relay.</ptxt>
</specitem>
</spec>
</s2>
</content1>
</s-1>
</subpara>
</para>
