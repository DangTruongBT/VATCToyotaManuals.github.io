<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000S" variety="S000S">
<name>U250E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000S_72VQE_T005L" variety="T005L">
<name>UNDERDRIVE PLANETARY GEAR</name>
<para id="RM000000YXJ00FX" category="A" type-id="8000E" name-id="AX04G-03" from="200601">
<name>REASSEMBLY</name>
<subpara id="RM000000YXJ00FX_01" type-id="01" category="01">
<s-1 id="RM000000YXJ00FX_01_0001" proc-id="RM0250U___00000TD00000">
<ptxt>INSTALL UNDERDRIVE PLANETARY RING GEAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install a new snap ring to the outer race of the tapered roller bearing.</ptxt>
<figure>
<graphic graphicname="D008112E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten4>
<ptxt>If replacing the bearing, also replace the counter driven gear with a new one.</ptxt>
</atten4>
</s2>
<s2>
<ptxt>Using a piston ring compressor, squeeze the snap ring.</ptxt>
<figure>
<graphic graphicname="D008113" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using SST and a press, press in the outer race of the angular ball bearing.</ptxt>
<figure>
<graphic graphicname="C134902E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-60020</s-number>
<s-subnumber>09951-00890</s-subnumber>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07100</s-subnumber>
</sstitem>
</sst>
<atten3>
<ptxt>Do not damage the snap ring during installation of the outer race.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Install the underdrive planetary ring gear to the counter driven gear.</ptxt>
<figure>
<graphic graphicname="C137499E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Using snap ring pliers, install the snap ring.</ptxt>
<figure>
<graphic graphicname="C134900E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YXJ00FX_01_0002" proc-id="RM0250U___00000TE00000">
<ptxt>INSTALL UNDERDRIVE PLANETARY GEAR ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a press, press the angular ball bearing inner race (rear side) into the underdrive planetary gear.</ptxt>
<figure>
<graphic graphicname="C134903E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-60010</s-number>
<s-subnumber>09951-00260</s-subnumber>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07100</s-subnumber>
</sstitem>
<sstitem>
<s-number>09726-40010</s-number>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Install the counter driven gear with planetary ring gear to the underdrive planetary gear.</ptxt>
<figure>
<graphic graphicname="C134904" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using SST and a press, press in the angular ball bearing inner race (front side).</ptxt>
<figure>
<graphic graphicname="C134905E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-60010</s-number>
<s-subnumber>09951-00260</s-subnumber>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07100</s-subnumber>
</sstitem>
<sstitem>
<s-number>09726-40010</s-number>
</sstitem>
</sst>
<atten3>
<ptxt>Press the counter driven gear while rotating it.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Using a press, press in the parking lock gear.</ptxt>
<figure>
<graphic graphicname="C134906E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-60010</s-number>
<s-subnumber>09951-00260</s-subnumber>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07100</s-subnumber>
</sstitem>
<sstitem>
<s-number>09316-20011</s-number>
</sstitem>
</sst>
<atten3>
<ptxt>Press the counter driven gear while rotating it.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YXJ00FX_01_0003" proc-id="RM0250U___00000TF00000">
<ptxt>INSTALL DIFFERENTIAL DRIVE PINION</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a press, press in the differential drive pinion.</ptxt>
<figure>
<graphic graphicname="D026434E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09726-40010</s-number>
</sstitem>
<sstitem>
<s-number>09950-60010</s-number>
<s-subnumber>09951-00260</s-subnumber>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07100</s-subnumber>
</sstitem>
</sst>
<atten3>
<ptxt>Press the counter driven gear while rotating it.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YXJ00FX_01_0004" proc-id="RM0250U___00000TG00000">
<ptxt>INSTALL CYLINDRICAL ROLLER BEARING RACE INNER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a press, press in the cylindrical roller bearing race inner.</ptxt>
<figure>
<graphic graphicname="C134907E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09515-21010</s-number>
</sstitem>
<sstitem>
<s-number>09950-60010</s-number>
<s-subnumber>09951-00260</s-subnumber>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07100</s-subnumber>
</sstitem>
</sst>
<atten3>
<ptxt>Press the counter driven gear while rotating it.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YXJ00FX_01_0005" proc-id="RM0250U___00000TH00000">
<ptxt>INSTALL FRONT PLANETARY GEAR NUT</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Clamp the underdrive planetary gear in a soft jaw vise.</ptxt>
<figure>
<graphic graphicname="C134897E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Be careful not to damage the differential drive pinion.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Using a socket wrench, install a new lock nut.</ptxt>
<torque>
<torqueitem>
<t-value1>280</t-value1>
<t-value2>2,855</t-value2>
<t-value4>207</t-value4>
</torqueitem>
</torque>
<atten4>
<ptxt>Use a torque wrench with a fulcrum length of 750 mm (29.53 in.).</ptxt>
</atten4>
</s2>
<s2>
<ptxt>Using a chisel and hammer, stake the lock nut.</ptxt>
<figure>
<graphic graphicname="C056809" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten2>
<ptxt>Be sure that there are no cracks on the nut.</ptxt>
</atten2>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>