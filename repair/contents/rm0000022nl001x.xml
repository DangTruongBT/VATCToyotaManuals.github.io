<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10006_S000F" variety="S000F">
<name>2GR-FE ENGINE CONTROL SYSTEM</name>
<ttl id="10006_S000F_7306G_T00EA" variety="T00EA">
<name>THROTTLE BODY</name>
<para id="RM0000022NL001X" category="A" type-id="80001" name-id="ES3PJ-02" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000022NL001X_01" type-id="01" category="01">
<s-1 id="RM0000022NL001X_01_0010">
<ptxt>REMOVE ENGINE UNDER COVER LH</ptxt>
</s-1>
<s-1 id="RM0000022NL001X_01_0011">
<ptxt>REMOVE ENGINE UNDER COVER RH</ptxt>
</s-1>
<s-1 id="RM0000022NL001X_01_0020" proc-id="RM0250U___000064400000">
<ptxt>DRAIN ENGINE COOLANT
</ptxt>
<content1 releasenbr="1">
<atten3>
<ptxt>Do not remove the radiator cap sub-assembly while the engine and radiator are still hot. Pressurized, hot engine coolant and steam may be released and cause serious burns.</ptxt>
</atten3>
<s2>
<ptxt>Remove the radiator cap sub-assembly from the radiator assembly.</ptxt>
</s2>
<s2>
<ptxt>Loosen the radiator drain cock plug and 2 cylinder block drain cock plugs, then drain the coolant.</ptxt>
<figure>
<graphic graphicname="A128117E02" width="7.106578999in" height="3.779676365in"/>
</figure>
<atten4>
<ptxt>Collect the coolant in a container and dispose of it according to the regulations in your area.</ptxt>
</atten4>
</s2>
</content1></s-1>
<s-1 id="RM0000022NL001X_01_0021" proc-id="RM0250U___00009VS00000">
<ptxt>REMOVE COOL AIR INTAKE DUCT SEAL
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 7 clips and intake duct seal.</ptxt>
<figure>
<graphic graphicname="A132967" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000022NL001X_01_0022" proc-id="RM0250U___00006SI00000">
<ptxt>REMOVE V-BANK COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Hold the front of the V-bank cover and raise it to disengage the 2 clips on the front of the cover. Continue to raise the cover to disengage the clip on the rear of the cover and remove the cover.</ptxt>
<figure>
<graphic graphicname="A132968" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Attempting to disengage both front and rear clips at the same time may cause the cover to break.</ptxt>
</atten3>
</s2>
</content1></s-1>
<s-1 id="RM0000022NL001X_01_0023" proc-id="RM0250U___00006SM00000">
<ptxt>REMOVE AIR CLEANER INLET ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts, clamp and air cleaner inlet.</ptxt>
<figure>
<graphic graphicname="A132969" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000022NL001X_01_0009" proc-id="RM0250U___0000BRR00000">
<ptxt>REMOVE AIR CLEANER CAP SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the 3 vacuum hoses.</ptxt>
<figure>
<graphic graphicname="A135704" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the mass air flow meter connector (<sup>*</sup>1). </ptxt>
<figure>
<graphic graphicname="A135705E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the No. 2 ventilation hose (<sup>*</sup>2).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the hose band (<sup>*</sup>3).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the 3 bands, and remove the air cleaner cap sub-assembly.</ptxt>
<figure>
<graphic graphicname="A135706" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022NL001X_01_0024" proc-id="RM0250U___00006SN00000">
<ptxt>REMOVE AIR CLEANER CASE SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the vacuum hose and hose clamp.</ptxt>
<figure>
<graphic graphicname="A132971" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 3 bolts and air cleaner case.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000022NL001X_01_0025" proc-id="RM0250U___00006SO00000">
<ptxt>REMOVE NO. 1 AIR CLEANER INLET
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt and No. 1 air cleaner inlet.</ptxt>
<figure>
<graphic graphicname="A132970" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000022NL001X_01_0006" proc-id="RM0250U___000092Q00000">
<ptxt>REMOVE THROTTLE BODY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the throttle body connector and clamp.</ptxt>
<figure>
<graphic graphicname="A135707" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the 2 water by-pass hoses from the throttle body.</ptxt>
<figure>
<graphic graphicname="A135708" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 4 bolts and throttle body.</ptxt>
<figure>
<graphic graphicname="A135709" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the throttle body gasket from the intake air surge tank.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
