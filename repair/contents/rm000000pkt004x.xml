<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1001A_S001B" variety="S001B">
<name>LIGHTING</name>
<ttl id="1001A_S001B_72YGG_T009M" variety="T009M">
<name>LIGHTING SYSTEM</name>
<para id="RM000000PKT004X" category="D" type-id="303F4" name-id="LI040-07" from="200601">
<name>DTC CHECK / CLEAR</name>
<subpara id="RM000000PKT004X_z0" proc-id="RM0250U___00004MG00000">
<content5 releasenbr="1">
<step1>
<ptxt>CHECK DTC</ptxt>
<step2>
<ptxt>Connect the intelligent tester to the DLC3.</ptxt>
<figure>
<graphic graphicname="C131977E10" width="2.775699831in" height="2.775699831in"/>
</figure>
</step2>
<step2>
<ptxt>Turn the ignition switch on (IG).</ptxt>
</step2>
<step2>
<ptxt>Read the DTCs by following the directions on the tester screen.</ptxt>
<atten4>
<ptxt>Please refer to the intelligent tester operator's manual for further details.</ptxt>
</atten4>
</step2>
</step1>
<step1>
<ptxt>CLEAR DTC</ptxt>
<step2>
<ptxt>Connect the intelligent tester to the DLC3.</ptxt>
</step2>
<step2>
<ptxt>Turn the ignition switch on (IG).</ptxt>
</step2>
<step2>
<ptxt>Erase the DTCs by following the directions on the tester screen.</ptxt>
<atten4>
<ptxt>Please refer to the intelligent tester operator's manual for further details.</ptxt>
</atten4>
</step2>
</step1>
</content5>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
