<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002C_S000U" variety="S000U">
<name>E351 MANUAL TRANSAXLE</name>
<ttl id="1002C_S000U_72YGA_T009G" variety="T009G">
<name>INPUT SHAFT</name>
<para id="RM000000Z1W001X" category="A" type-id="80002" name-id="MX03K-02" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM000000Z1W001X_01" type-id="01" category="01">
<s-1 id="RM000000Z1W001X_01_0001" proc-id="RM0250U___00004CG00000">
<ptxt>REMOVE 4TH GEAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Hold the input shaft assembly in a vise using aluminum plates.</ptxt>
<figure>
<graphic graphicname="C070515" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using 2 screwdrivers and a hammer, remove the input shaft rear bearing shaft snap ring from the input shaft.</ptxt>
<atten4>
<ptxt>Use a shop rag or a piece of cloth to keep the snap ring from flying.</ptxt>
</atten4>
</s2>
<s2>
<ptxt>Using SST and a press, remove the input shaft rear bearing and 4th gear.</ptxt>
<figure>
<graphic graphicname="C092867E02" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-00020</s-number>
</sstitem>
</sst>
<atten3>
<ptxt>Do not overtighten the SST.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z1W001X_01_0002" proc-id="RM0250U___00004CH00000">
<ptxt>REMOVE 4TH GEAR NEEDLE ROLLER BEARING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 4th gear needle roller bearing from the input shaft.</ptxt>
<figure>
<graphic graphicname="C069551" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z1W001X_01_0003" proc-id="RM0250U___00004CI00000">
<ptxt>REMOVE 2ND SYNCHRONIZER OUTER RING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2nd synchronizer outer ring (No. 4 synchronizer ring) from the No. 2 transmission clutch hub.</ptxt>
<figure>
<graphic graphicname="D031907" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z1W001X_01_0004" proc-id="RM0250U___00004CJ00000">
<ptxt>REMOVE 4TH GEAR BEARING SPACER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 4th gear bearing spacer from the No. 2 transmission clutch hub.</ptxt>
<figure>
<graphic graphicname="D031906" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z1W001X_01_0005" proc-id="RM0250U___00004CK00000">
<ptxt>REMOVE 3RD GEAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using 2 screwdrivers and a hammer, remove the No. 2 clutch hub setting shaft snap ring from the input shaft.</ptxt>
<figure>
<graphic graphicname="C069615" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten4>
<ptxt>Use a shop rag or a piece of cloth to keep the snap ring from flying.</ptxt>
</atten4>
</s2>
<s2>
<ptxt>Using SST and a press, remove the No. 2 transmission clutch hub and 3rd gear from the input shaft.</ptxt>
<figure>
<graphic graphicname="D031908E02" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-00020</s-number>
</sstitem>
</sst>
<atten3>
<ptxt>Do not overtighten the SST.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z1W001X_01_0006" proc-id="RM0250U___00004CL00000">
<ptxt>REMOVE 3RD GEAR NEEDLE ROLLER BEARING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 3rd gear needle roller bearing from the input shaft.</ptxt>
<figure>
<graphic graphicname="C069617" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z1W001X_01_0007" proc-id="RM0250U___00004CM00000">
<ptxt>REMOVE NO. 3 SYNCHRONIZER RING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the No. 3 synchronizer ring from the 3rd gear.</ptxt>
<figure>
<graphic graphicname="C069618" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z1W001X_01_0008" proc-id="RM0250U___00004CN00000">
<ptxt>REMOVE NO. 2 TRANSMISSION HUB SLEEVE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the No. 2 transmission hub sleeve, 3 No. 2 synchromesh shifting keys, and 3 No. 2 synchromesh shifting key springs from the No. 2 transmission clutch hub.</ptxt>
<figure>
<graphic graphicname="C069619" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten4>
<ptxt>Use a shop rag or a piece of cloth to keep the shifting keys and shifting key springs from flying.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z1W001X_01_0009" proc-id="RM0250U___00004CO00000">
<ptxt>REMOVE INPUT SHAFT FRONT BEARING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST and a press, remove the input shaft front bearing (inner race) from the input shaft.</ptxt>
<figure>
<graphic graphicname="C092869E02" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-00020</s-number>
</sstitem>
</sst>
<atten3>
<ptxt>Do not overtighten the SST.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>