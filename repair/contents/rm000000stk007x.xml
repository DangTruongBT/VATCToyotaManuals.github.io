<testgrp id="RM000000STK007X_04_0021" proc-id="RM0250U___00004IT00000">
<testtitle>INSPECT AMBIENT TEMPERATURE SENSOR</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Remove the ambient temperature sensor.</ptxt>
<figure>
<graphic graphicname="E118395E04" width="2.775699831in" height="5.787629434in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>A2-1 - A2-2</ptxt>
</entry>
<entry valign="middle">
<ptxt>10°C (50°F)</ptxt>
</entry>
<entry valign="middle">
<ptxt>3.00 to 3.73 kΩ</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>A2-1 - A2-2</ptxt>
</entry>
<entry valign="middle">
<ptxt>15°C (59°F)</ptxt>
</entry>
<entry valign="middle">
<ptxt>2.45 to 2.88 kΩ</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>A2-1 - A2-2</ptxt>
</entry>
<entry valign="middle">
<ptxt>20°C (68°F)</ptxt>
</entry>
<entry valign="middle">
<ptxt>1.95 to 2.30 kΩ</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>A2-1 - A2-2</ptxt>
</entry>
<entry valign="middle">
<ptxt>25°C (77°F)</ptxt>
</entry>
<entry valign="middle">
<ptxt>1.60 to 1.80 kΩ</ptxt>
