<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000STK007X_04_0006" fin="true">OK</down>
<right ref="RM000000STK007X_04_0008" fin="true">NG</right>
