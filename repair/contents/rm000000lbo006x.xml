<name>BRAKE</name>
<section id="1000N_S0011" variety="S0011">
<name>BRAKE</name>
<ttl id="1000N_S0011_72V92_T003Z" variety="T003Z">
<name>REAR BRAKE</name>
<para id="RM000000LBO006X" category="A" type-id="80001" name-id="BR0QO-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM000000LBO006X_02" type-id="11" category="10"/>
<subpara id="RM000000LBO006X_01" type-id="01" category="01">
<s-1 id="RM000000LBO006X_01_0001" proc-id="RM0250U___0000CZO00000">
<ptxt>REMOVE REAR WHEEL</ptxt>
<content1 releasenbr="1">
<atten4>
<list1 type="unordered">
<item>
<ptxt>Use the same procedures for the LH side and RH side.</ptxt>
</item>
<item>
<ptxt>The procedures listed below are for the LH side.</ptxt>
</item>
</list1>
</atten4>
</content1>
</s-1>
<s-1 id="RM000000LBO006X_01_0002" proc-id="RM0250U___00003UE00000">
<ptxt>DRAIN BRAKE FLUID</ptxt>
<content1 releasenbr="1">
<atten3>
<ptxt>If brake fluid leaks onto any painted surface, wash or remove it completely.</ptxt>
</atten3>
</content1>
</s-1>
<s-1 id="RM000000LBO006X_01_0003" proc-id="RM0250U___00003RB00000">
<ptxt>DISCONNECT REAR BRAKE FLEXIBLE HOSE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the union bolt and the gasket from the rear disc brake cylinder assembly, then disconnect the flexible hose.</ptxt>
<figure>
<graphic graphicname="C132824" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000LBO006X_01_0006" proc-id="RM0250U___00003RE00000">
<ptxt>REMOVE REAR DISC BRAKE CYLINDER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Hold the 2 front disc brake cylinder slide pins and remove the 2 bolts and rear disc brake cylinder assembly.</ptxt>
<figure>
<graphic graphicname="C132823E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>