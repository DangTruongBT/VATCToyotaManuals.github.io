<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="1000A_S0008" variety="S0008">
<name>2AZ-FE ENGINE MECHANICAL</name>
<ttl id="1000A_S0008_72ZKJ_T00CG" variety="T00CG">
<name>ENGINE REAR OIL SEAL</name>
<para id="RM000000YIH001X" category="A" type-id="80001" name-id="EM06C-02" from="200601">
<name>REMOVAL</name>
<subpara id="RM000000YIH001X_01" type-id="01" category="01">
<s-1 id="RM000000YIH001X_01_0001" proc-id="RM0250U___00006XY00000">
<ptxt>SEPARATE AUTOMATIC TRANSAXLE ASSEMBLY (for Automatic Transaxle)</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>See page <xref label="Seep01" href="RM000000YWV00EX"/>.</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM000000YIH001X_01_0002" proc-id="RM0250U___00006XZ00000">
<ptxt>SEPARATE MANUAL TRANSAXLE ASSEMBLY (for Manual Transaxle)</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>See page <xref label="Seep01" href="RM0000017UZ002X"/>.</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM000000YIH001X_01_0003" proc-id="RM0250U___00006Y000000">
<ptxt>REMOVE DRIVE PLATE &amp; RING GEAR SUB-ASSEMBLY (for Automatic Transaxle)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>TMMK made:</ptxt>
<s3>
<ptxt>Using SST, hold the crankshaft.</ptxt>
<figure>
<graphic graphicname="A062061E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09960-10010</s-number>
<s-subnumber>09962-01000</s-subnumber>
<s-subnumber>09963-01000</s-subnumber>
</sstitem>
</sst>
</s3>
</s2>
<s2>
<ptxt>TMC made:</ptxt>
<s3>
<ptxt>Using SST, hold the crankshaft.</ptxt>
<figure>
<graphic graphicname="A126932E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09213-54015</s-number>
<s-subnumber>91651-60855</s-subnumber>
</sstitem>
<sstitem>
<s-number>09330-00021</s-number>
</sstitem>
</sst>
</s3>
</s2>
<s2>
<ptxt>Remove the 8 bolts, rear spacer, drive plate and front spacer.</ptxt>
<figure>
<graphic graphicname="A091018" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YIH001X_01_0008" proc-id="RM0250U___00008ZA00000">
<ptxt>REMOVE CLUTCH COVER ASSEMBLY (for Manual Transaxle)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Put matchmarks on the clutch cover assembly and flywheel sub-assembly.</ptxt>
<figure>
<graphic graphicname="D008941E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Loosen the 6 bolts one turn at a time until spring tension is released.</ptxt>
</s2>
<s2>
<ptxt>Remove the 6 bolts and pull off the clutch cover assembly.</ptxt>
<atten3>
<ptxt>Do not drop the clutch disc assembly.</ptxt>
</atten3>
</s2>
</content1></s-1>
<s-1 id="RM000000YIH001X_01_0009" proc-id="RM0250U___00008ZB00000">
<ptxt>REMOVE CLUTCH DISC ASSEMBLY (for Manual Transaxle)
</ptxt>
<content1 releasenbr="1">
<atten3>
<ptxt>Keep the lining part of the clutch disc assembly, the pressure plate and surface of the flywheel sub-assembly away from oil and foreign matter.</ptxt>
</atten3>
</content1></s-1>
<s-1 id="RM000000YIH001X_01_0006" proc-id="RM0250U___00006Y100000">
<ptxt>REMOVE FLYWHEEL SUB-ASSEMBLY (for Manual Transaxle)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>TMMK made:</ptxt>
<s3>
<ptxt>Using SST, hold the crankshaft.</ptxt>
<figure>
<graphic graphicname="A062061E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09960-10010</s-number>
<s-subnumber>09962-01000</s-subnumber>
<s-subnumber>09963-01000</s-subnumber>
</sstitem>
</sst>
</s3>
</s2>
<s2>
<ptxt>TMC made:</ptxt>
<s3>
<ptxt>Using SST, hold the crankshaft.</ptxt>
<figure>
<graphic graphicname="A126932E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09213-54015</s-number>
<s-subnumber>91651-60855</s-subnumber>
</sstitem>
<sstitem>
<s-number>09330-00021</s-number>
</sstitem>
</sst>
</s3>
</s2>
<s2>
<ptxt>Remove the 8 bolts and flywheel.</ptxt>
<figure>
<graphic graphicname="A091020E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YIH001X_01_0007" proc-id="RM0250U___00006Y200000">
<ptxt>REMOVE ENGINE REAR OIL SEAL</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a knife, cut through the oil seal lip.</ptxt>
<figure>
<graphic graphicname="A128873E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using a screwdriver with its tip taped, pry out the oil seal.</ptxt>
<atten3>
<ptxt>After the removal, check the crankshaft for damage. If it is damaged, smooth the surface with 400-grit sandpaper.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>