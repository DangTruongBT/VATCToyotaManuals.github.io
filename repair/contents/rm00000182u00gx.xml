<subpara id="RM00000182U00GX_02" type-id="51" category="05" proc-id="RM0250U___000052700000">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten4>
<ptxt>After the inspection is completed, clear the DTCs.</ptxt>
</atten4>
</content5>
</subpara>
<subpara id="RM00000182U00GX_03" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM00000182U00GX_03_0001" proc-id="RM0250U___000052800000">
<testtitle>CHECK MAP DISC</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check that the map disc is not deformed or cracked.</ptxt>
<figure>
<graphic graphicname="I100152" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>OK</title>
<specitem>
<ptxt>No deformations or cracks on the map disc.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM00000182U00GX_03_0002" fin="false">OK</down>
<right ref="RM00000182U00GX_03_0004" fin="false">NG</right>
</res>
</testgrp>
<testgrp id="RM00000182U00GX_03_0002" proc-id="RM0250U___000052900000">
<testtitle>DISC CLEANING</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disc cleaning</ptxt>
<figure>
<graphic graphicname="I100201E04" width="2.775699831in" height="1.771723296in"/>
</figure>
<test2>
<ptxt>If dirt is on the disc surface, wipe it clean with a soft cloth from the inside to the outside in a radial direction.</ptxt>
<atten3>
<ptxt>Do not use a conventional record cleaner or anti-static preservative.</ptxt>
</atten3>
</test2>
</test1>
</content6>
<res>
<down ref="RM00000182U00GX_03_0003" fin="false">NEXT</down>
</res>
</testgrp>
<testgrp id="RM00000182U00GX_03_0003" proc-id="RM0250U___000052A00000">
<testtitle>DTC CLEAR AND RECHECK</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Clear the DTCs (See page <xref label="Seep01" href="RM0000011BU00FX"/>).</ptxt>
</test1>
<test1>
<ptxt>Recheck for DTCs and check if the same trouble occurs again.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Same problem does not occur.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM00000182U00GX_03_0004" fin="false">NG</down>
<right ref="RM00000182U00GX_03_0006" fin="true">OK</right>
</res>
</testgrp>
<testgrp id="RM00000182U00GX_03_0004" proc-id="RM0250U___000052B00000">
<testtitle>REPLACE MAP DISC</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Replace the map disc.</ptxt>
</test1>
<test1>
<ptxt>Clear the DTCs and recheck for DTCs.</ptxt>
</test1>
<test1>
<ptxt>Check if the same trouble occurs again.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Same problem does not occur.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM00000182U00GX_03_0005" fin="true">NG</down>
<right ref="RM00000182U00GX_03_0006" fin="true">OK</right>
</res>
</testgrp>
<testgrp id="RM00000182U00GX_03_0005">
<testtitle>REPLACE RADIO AND NAVIGATION ASSEMBLY</testtitle>
</testgrp>
<testgrp id="RM00000182U00GX_03_0006">
<testtitle>END</testtitle>
</testgrp>
</subpara>
</para>
