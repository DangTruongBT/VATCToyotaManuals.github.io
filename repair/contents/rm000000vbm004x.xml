<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="43">
<name>BODY</name>
<section id="1001H_S001L" variety="S001L">
<name>SEAT</name>
<ttl id="1001H_S001L_72WMY_T006K" variety="T006K">
<name>REAR SEAT ASSEMBLY (for Fixed Type)</name>
<para id="RM000000VBM004X" category="A" type-id="80002" name-id="SE0OK-01" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM000000VBM004X_01" type-id="01" category="01">
<s-1 id="RM000000VBM004X_01_0001" proc-id="RM0250U___000056F00000">
<ptxt>REMOVE REAR BENCH TYPE SEAT CUSHION COVER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 36 hog rings.</ptxt>
<figure>
<graphic graphicname="B136578E01" width="7.106578999in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 14 hog rings and rear bench type seat cushion cover from the seat cushion frame (with pad).</ptxt>
<figure>
<graphic graphicname="B136579E01" width="7.106578999in" height="2.775699831in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000VBM004X_01_0002" proc-id="RM0250U___000056G00000">
<ptxt>REMOVE ARMREST ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 nuts.</ptxt>
<figure>
<graphic graphicname="B136580" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Disengage the 2 claws and remove the armrest assembly.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000000VBM004X_01_0003" proc-id="RM0250U___000056H00000">
<ptxt>REMOVE CENTER SEAT ARMREST BRACKET SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts and bushes.</ptxt>
<figure>
<graphic graphicname="B136581" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the center seat armrest bracket sub-assembly.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000000VBM004X_01_0015" proc-id="RM0250U___000059C00000">
<ptxt>REMOVE CUP HOLDER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 mats.</ptxt>
<figure>
<graphic graphicname="B136582" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 screws and cup holder.</ptxt>
<figure>
<graphic graphicname="B136583" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000VBM004X_01_0006" proc-id="RM0250U___000056K00000">
<ptxt>REMOVE INNER CENTER SEAT ARMREST PLATE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 11 claws and remove the inner center seat armrest plate.</ptxt>
<figure>
<graphic graphicname="B136584" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000VBM004X_01_0009" proc-id="RM0250U___000056N00000">
<ptxt>REMOVE REAR SEAT HEADREST SUPPORT</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 6 claws and remove the 3 rear seat headrest supports.</ptxt>
<figure>
<graphic graphicname="B136585" width="7.106578999in" height="2.775699831in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000VBM004X_01_0010">
<ptxt>REMOVE REAR SEAT HEADREST SUPPORT</ptxt>
</s-1>
<s-1 id="RM000000VBM004X_01_0013" proc-id="RM0250U___000056P00000">
<ptxt>REMOVE REAR SEAT SHOULDER BELT GUIDE RH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 screws and rear seat shoulder belt guide RH.</ptxt>
<figure>
<graphic graphicname="B136586" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000VBM004X_01_0016" proc-id="RM0250U___00008I300000">
<ptxt>REMOVE REAR SEAT SHOULDER BELT GUIDE LH</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedures for the RH side and LH side.</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM000000VBM004X_01_0005" proc-id="RM0250U___000056J00000">
<ptxt>REMOVE REAR BENCH TYPE SEAT BACK COVER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 44 hog rings and strap guide.</ptxt>
<figure>
<graphic graphicname="B136587E02" width="7.106578999in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 rear seat belt hooks.</ptxt>
</s2>
<s2>
<ptxt>Remove the 20 hog rings and seat back cover from the seat back frame (with pad).</ptxt>
<figure>
<graphic graphicname="B136588E01" width="7.106578999in" height="2.775699831in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>