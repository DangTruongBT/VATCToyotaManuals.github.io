<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000S" variety="S000S">
<name>U250E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000S_72VQE_T005L" variety="T005L">
<name>UNDERDRIVE PLANETARY GEAR</name>
<para id="RM000000YXI00FX" category="A" type-id="80002" name-id="AX04E-03" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM000000YXI00FX_02" type-id="01" category="01">
<s-1 id="RM000000YXI00FX_02_0006" proc-id="RM0250U___00000T800000">
<ptxt>REMOVE FRONT PLANETARY GEAR NUT</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST and a hammer, loosen the staked part of the lock nut.</ptxt>
<figure>
<graphic graphicname="D003686E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09930-00010</s-number>
<s-subnumber>09931-00010</s-subnumber>
<s-subnumber>09931-00020</s-subnumber>
</sstitem>
<sstitem>
<s-number>09387-00050</s-number>
</sstitem>
<sstitem>
<s-number>09495-65040</s-number>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Clamp the underdrive planetary gear in a soft jaw vise.</ptxt>
<figure>
<graphic graphicname="C134896E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Be careful not to damage the differential drive pinion.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Using a socket wrench, remove the lock nut.</ptxt>
<figure>
<graphic graphicname="C134897E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YXI00FX_02_0007" proc-id="RM0250U___00000T900000">
<ptxt>REMOVE CYLINDRICAL ROLLER BEARING RACE INNER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST, remove the cylindrical roller bearing race inner.</ptxt>
<figure>
<graphic graphicname="D003689E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09950-00020</s-number>
</sstitem>
<sstitem>
<s-number>09950-00030</s-number>
</sstitem>
<sstitem>
<s-number>09950-40011</s-number>
<s-subnumber>09957-04010</s-subnumber>
</sstitem>
<sstitem>
<s-number>09950-60010</s-number>
<s-subnumber>09951-00320</s-subnumber>
</sstitem>
</sst>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YXI00FX_02_0008" proc-id="RM0250U___00000TA00000">
<ptxt>REMOVE UNDERDRIVE PLANETARY GEAR ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST and a press, remove the differential drive pinion, parking lock gear, counter driven gear with underdrive planetary ring gear, and angular ball bearing.</ptxt>
<figure>
<graphic graphicname="C134898E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09387-00050</s-number>
</sstitem>
<sstitem>
<s-number>09495-65040</s-number>
</sstitem>
<sstitem>
<s-number>09950-60010</s-number>
<s-subnumber>09951-00320</s-subnumber>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07100</s-subnumber>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Clamp the underdrive planetary gear in a soft jaw vise.</ptxt>
<figure>
<graphic graphicname="C134899E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using SST, remove the rear angular ball bearing from the underdrive planetary gear.</ptxt>
<sst>
<sstitem>
<s-number>09950-00020</s-number>
</sstitem>
<sstitem>
<s-number>09950-00030</s-number>
</sstitem>
<sstitem>
<s-number>09950-40011</s-number>
<s-subnumber>09957-04010</s-subnumber>
</sstitem>
<sstitem>
<s-number>09950-60010</s-number>
<s-subnumber>09951-00320</s-subnumber>
</sstitem>
</sst>
</s2>
</content1>
</s-1>
<s-1 id="RM000000YXI00FX_02_0009" proc-id="RM0250U___00000TB00000">
<ptxt>REMOVE UNDERDRIVE PLANETARY RING GEAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using snap ring pliers, remove the snap ring.</ptxt>
<figure>
<graphic graphicname="C134900E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the underdrive planetary ring gear from the counter driven gear.</ptxt>
<figure>
<graphic graphicname="C137499E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>