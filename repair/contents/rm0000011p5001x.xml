<tmc-service-inc>
<pub id="RM0251U">
<servcat id="36">
<name>BRAKE</name>
<section id="1002J_S0010" variety="S0010">
<name>BRAKE CONTROL</name>
<ttl id="1002J_S0010_72VA9_T004H" variety="T004H">
<name>FRONT SPEED SENSOR</name>
<para id="RM0000011P5001X" category="A" type-id="80001" name-id="BC0AF-02" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000011P5001X_03" type-id="11" category="10" proc-id="RM0250U___0000CZC00000">
<content3 releasenbr="1">
<atten4>
<list1 type="unordered">
<item>
<ptxt>Use the same procedures for the RH side and LH side.</ptxt>
</item>
<item>
<ptxt>The procedures listed below are for the LH side.</ptxt>
</item>
</list1>
</atten4>
</content3>
</subpara>
<subpara id="RM0000011P5001X_01" type-id="01" category="01">
<s-1 id="RM0000011P5001X_01_0001">
<ptxt>REMOVE FRONT WHEEL</ptxt>
</s-1>
<s-1 id="RM0000011P5001X_01_0005" proc-id="RM0250U___00008A900000">
<ptxt>REMOVE FRONT WHEEL OPENING EXTENSION PAD LH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 3 screws and the front wheel opening extension pad.</ptxt>
<figure>
<graphic graphicname="B138883" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000011P5001X_01_0006" proc-id="RM0250U___00008AA00000">
<ptxt>REMOVE FRONT FENDER LINER
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 5 clips and bolt.</ptxt>
<figure>
<graphic graphicname="B136871" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 4 screws, grommet, and the front fender liner.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000011P5001X_01_0003" proc-id="RM0250U___00000M400000">
<ptxt>REMOVE FRONT SPEED SENSOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the front speed sensor connector and clamp.</ptxt>
<figure>
<graphic graphicname="C132783E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts from the body and the shock absorber assembly.</ptxt>
<figure>
<graphic graphicname="C132781E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Disengage the 2 claws from the steering knuckle and body.</ptxt>
</s2>
<s2>
<ptxt>Remove the bolt and the front speed sensor.</ptxt>
<figure>
<graphic graphicname="C132782" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<list1 type="unordered">
<item>
<ptxt>Prevent foreign matter from attaching to the sensor tip.</ptxt>
</item>
<item>
<ptxt>Clean the installation hole and the surface for the speed sensor every time the speed sensor is removed.</ptxt>
</item>
</list1>
</atten3>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>