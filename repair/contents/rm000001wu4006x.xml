<para id="RM000001WU4006X" category="J" type-id="301GR" name-id="NS0ME-05" from="200601">
<dtccode/>
<dtcname>Pressing Power Switch does not Turn on System</dtcname>
<subpara id="RM000001WU4006X_01" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM000001WU4006X_02" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000001WU4006X_02_0001" proc-id="RM0250U___00004WB00000">
<testtitle>CHECK CABIN</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check that conditions in the cabin are not likely to cause condensation.</ptxt>
<atten4>
<ptxt>This problem occurs when the cabin is humid and the temperature rapidly changes. This condition may produce condensation, resulting in a short circuit.</ptxt>
</atten4>
<spec>
<title>OK</title>
<specitem>
<ptxt>Condensation is not likely to occur.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000001WU4006X_02_0002" fin="true">OK</down>
<right ref="RM000001WU4006X_02_0003" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000001WU4006X_02_0002">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM000001WU4006X_02_0003">
<testtitle>DRY CABIN AND RECHECK CONDITIONS</testtitle>
</testgrp>
