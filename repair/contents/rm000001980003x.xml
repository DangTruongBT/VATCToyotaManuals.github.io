<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1001A_S001B" variety="S001B">
<name>LIGHTING</name>
<ttl id="1001A_S001B_72Y3P_T008I" variety="T008I">
<name>GLOVE BOX LIGHT</name>
<para id="RM000001980003X" category="G" type-id="3001K" name-id="LI0IM-04" from="200601">
<name>INSPECTION</name>
<subpara id="RM000001980003X_01" type-id="01" category="01">
<s-1 id="RM000001980003X_01_0001" proc-id="RM0250U___00004JE00000">
<ptxt>INSPECT GLOVE BOX LIGHT ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply battery voltage to the glove box light assembly connector.</ptxt>
<figure>
<graphic graphicname="I044128" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Check that the glove box light comes on.</ptxt>
<spec>
<title>OK</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Measurement Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Switch Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>Battery positive (+) → Terminal 2</ptxt>
<ptxt>Battery negative (-) → Terminal 1</ptxt>
</entry>
<entry valign="middle">
<ptxt>Glove box light switch ON</ptxt>
</entry>
<entry valign="middle">
<ptxt>Glove box light comes on</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<ptxt>If the result is not as specified, replace the glove box light assembly.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
