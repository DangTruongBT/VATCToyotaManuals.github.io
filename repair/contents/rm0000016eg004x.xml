<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000T" variety="S000T">
<name>U660E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000T_72XRN_T007X" variety="T007X">
<name>SHIFT LEVER</name>
<para id="RM0000016EG004X" category="A" type-id="8000E" name-id="AX092-02" from="200601">
<name>REASSEMBLY</name>
<subpara id="RM0000016EG004X_02" type-id="01" category="01">
<s-1 id="RM0000016EG004X_02_0007" proc-id="RM0250U___0000CBY00000">
<ptxt>INSTALL SHIFT LOCK CONTROL ECU</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the shift lock control ECU to the shift lever.</ptxt>
<figure>
<graphic graphicname="C135730" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000016EG004X_02_0008" proc-id="RM0250U___0000CBZ00000">
<ptxt>INSTALL INDICATOR LIGHT WIRE SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Insert the indicator light wire into the shift lock control unit while aligning the groove on the unit with the indicator light guide key.</ptxt>
<figure>
<graphic graphicname="C135019E02" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Install the indicator light guide by turning it clockwise until it securely locks.  </ptxt>
</s2>
<s2>
<ptxt>Install the indicator light wire to the clamp on the shift lock control unit.</ptxt>
</s2>
<s2>
<ptxt>Connect terminals (4) and (8) of the indicator light wire.</ptxt>
<figure>
<graphic graphicname="G028933E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Push the stopper.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>