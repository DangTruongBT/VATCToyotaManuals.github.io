<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="37">
<name>STEERING</name>
<section id="1000V_S0014" variety="S0014">
<name>POWER STEERING</name>
<ttl id="1000V_S0014_72VA0_T0049" variety="T0049">
<name>VANE PUMP (for 2AZ-FE)</name>
<para id="RM000001A1S003X" category="A" type-id="80001" name-id="PS0HX-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM000001A1S003X_01" type-id="01" category="01">
<s-1 id="RM000001A1S003X_01_0004">
<ptxt>DRAIN POWER STEERING FLUID</ptxt>
</s-1>
<s-1 id="RM000001A1S003X_01_0019">
<ptxt>REMOVE FRONT WHEEL RH</ptxt>
</s-1>
<s-1 id="RM000001A1S003X_01_0021">
<ptxt>REMOVE ENGINE UNDER COVER RH</ptxt>
</s-1>
<s-1 id="RM000001A1S003X_01_0022">
<ptxt>REMOVE FRONT FENDER APRON SEAL RH</ptxt>
</s-1>
<s-1 id="RM000001A1S003X_01_0020" proc-id="RM0250U___00006VG00000">
<ptxt>REMOVE FAN AND GENERATOR V BELT
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST and 19 mm socket wrench, loosen the V-ribbed belt tensioner arm clockwise, then remove the V-ribbed belt.</ptxt>
<figure>
<graphic graphicname="A114351E03" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09216-42010</s-number>
</sstitem>
</sst>
<atten3>
<list1 type="unordered">
<item>
<ptxt>Be sure to connect SST and the tools so that they are in line during use.</ptxt>
</item>
<item>
<ptxt>When retracting the tensioner, turn it clockwise slowly for 3 seconds or more. Do not apply force rapidly.</ptxt>
</item>
<item>
<ptxt>After the tensioner is fully retracted, do not apply force any more than necessary.</ptxt>
</item>
</list1>
</atten3>
</s2>
</content1></s-1>
<s-1 id="RM000001A1S003X_01_0001" proc-id="RM0250U___000006E00000">
<ptxt>DISCONNECT NO. 1 FLUID RESERVOIR TO PUMP HOSE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Slide the clip and disconnect the No. 1 fluid reservoir to pump hose from the vane pump assembly.</ptxt>
<figure>
<graphic graphicname="C135224E02" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001A1S003X_01_0002" proc-id="RM0250U___000006F00000">
<ptxt>DISCONNECT PRESSURE FEED TUBE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the union bolt and disconnect the pressure feed tube assembly from the vane pump assembly.</ptxt>
<figure>
<graphic graphicname="C135226" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the gasket from the pressure feed tube assembly.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001A1S003X_01_0018" proc-id="RM0250U___00005EE00000">
<ptxt>DISCONNECT POWER STEERING FLUID PRESSURE SWITCH CONNECTOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the power steering fluid pressure switch connector.</ptxt>
<figure>
<graphic graphicname="C135234" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000001A1S003X_01_0003" proc-id="RM0250U___000006G00000">
<ptxt>REMOVE VANE PUMP ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST, loosen the 2 bolts and remove the vane pump assembly.</ptxt>
<figure>
<graphic graphicname="C135228E01" width="2.775699831in" height="3.779676365in"/>
</figure>
<sst>
<sstitem>
<s-number>09249-63010</s-number>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Remove the 2 bolts from the vane pump assembly.</ptxt>
<figure>
<graphic graphicname="C135233" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>