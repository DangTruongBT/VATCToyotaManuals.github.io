<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1001B_S001C" variety="S001C">
<name>WIPER AND WASHER</name>
<ttl id="1001B_S001C_72WDL_T0062" variety="T0062">
<name>FRONT WIPER RUBBER</name>
<para id="RM0000023QL000X" category="A" type-id="80001" name-id="WW0M7-03" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000023QL000X_01" type-id="01" category="01">
<s-1 id="RM0000023QL000X_01_0001" proc-id="RM0250U___000046600000">
<ptxt>REMOVE FRONT WIPER BLADE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the holder of the front wiper blade.</ptxt>
</s2>
<s2>
<ptxt>Remove the front wiper blade from the front wiper arm as shown in the illustration.</ptxt>
<atten3>
<ptxt>Do not bend the front wiper arm with the front wiper blade removed because the arm tip could damage the windshield surface.</ptxt>
</atten3>
<figure>
<graphic graphicname="E128822E01" width="7.106578999in" height="4.7836529in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000023QL000X_01_0002" proc-id="RM0250U___000046700000">
<ptxt>REMOVE WIPER RUBBER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the wiper rubber and the wiper rubber backing plates from the front wiper blade.</ptxt>
<figure>
<graphic graphicname="E125259" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 wiper rubber backing plates from the wiper rubber.</ptxt>
<figure>
<graphic graphicname="E125260E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>