<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>Battery positive (+) → Terminal 7</ptxt>
<ptxt>Battery negative (-) → Terminal 8</ptxt>
</entry>
<entry valign="middle">
<ptxt>Front RH personal light switch ON</ptxt>
</entry>
<entry valign="middle">
