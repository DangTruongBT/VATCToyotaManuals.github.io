<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="36">
<name>BRAKE</name>
<section id="1002J_S0010" variety="S0010">
<name>BRAKE CONTROL</name>
<ttl id="1002J_S0010_72VAI_T004Q" variety="T004Q">
<name>BRAKE ACTUATOR (for BOSCH Made)</name>
<para id="RM0000013P6004X" category="A" type-id="80001" name-id="BC1GO-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000013P6004X_01" type-id="01" category="01">
<s-1 id="RM0000013P6004X_01_0029">
<ptxt>DISCONNECT CABLE FROM NEGATIVE BATTERY TERMINAL</ptxt>
</s-1>
<s-1 id="RM0000013P6004X_01_0030" proc-id="RM0250U___0000CUD00000">
<ptxt>REMOVE RADIATOR RESERVE TANK ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Separate the radiator reserve tank hose.</ptxt>
<figure>
<graphic graphicname="C143552" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the radiator reserve tank assembly.</ptxt>
<figure>
<graphic graphicname="C144510E20" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000013P6004X_01_0014" proc-id="RM0250U___00000N300000">
<ptxt>DRAIN BRAKE FLUID</ptxt>
<content1 releasenbr="1">
<atten3>
<ptxt>If brake fluid leaks onto any painted surface, immediately clean it off completely.</ptxt>
</atten3>
</content1>
</s-1>
<s-1 id="RM0000013P6004X_01_0016" proc-id="RM0250U___00000N400000">
<ptxt>REMOVE BRAKE ACTUATOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Release the lock lever and disconnect the brake actuator connector.</ptxt>
<figure>
<graphic graphicname="C132775E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using SST, disconnect the 6 brake lines from the brake actuator with brake actuator bracket assembly.</ptxt>
<figure>
<graphic graphicname="C132776E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09023-00101</s-number>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Use tags or make a memo to identify the places to reconnect.</ptxt>
<atten4>
<list1 type="unordered">
<item>
<ptxt>*1: To Front Wheel Cylinder RH  </ptxt>
</item>
<item>
<ptxt>*2: To Front Wheel Cylinder LH </ptxt>
</item>
<item>
<ptxt>*3: To Rear Wheel Cylinder RH </ptxt>
</item>
<item>
<ptxt>*4: To Rear Wheel Cylinder LH  </ptxt>
</item>
<item>
<ptxt>*5: From 2nd Master Cylinder </ptxt>
</item>
<item>
<ptxt>*6: From 1st Master Cylinder  </ptxt>
</item>
</list1>
</atten4>
<figure>
<graphic graphicname="C132777E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 3 bolts and brake actuator from the body with bracket.</ptxt>
<atten3>
<ptxt>Do not damage the brake lines and wire harness.</ptxt>
</atten3>
<figure>
<graphic graphicname="C132778" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>