<name>AUDIO AND VISUAL SYSTEM</name>
<para id="RM0000014SV00EX" category="J" type-id="800YU" name-id="AV1L8-01" from="200601">
<dtccode/>
<dtcname>The Other Caller cannot Hear Your Voice, or Your Voice is too Quiet or Distorted</dtcname>
<subpara id="RM0000014SV00EX_01" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM0000014SV00EX_02" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM0000014SV00EX_02_0001" proc-id="RM0250U___0000ANM00000">
<testtitle>CHECK CELLULAR PHONE</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check if the other side can hear your voice properly.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Your voice can be heard correctly.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000014SV00EX_02_0002" fin="false">OK</down>
<right ref="RM0000014SV00EX_02_0005" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000014SV00EX_02_0002" proc-id="RM0250U___0000ANN00000">
<testtitle>CHECK SETTINGS</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check if the mute is set to ON.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Mute is not set to ON.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000014SV00EX_02_0009" fin="true">OK</down>
<right ref="RM0000014SV00EX_02_0006" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000014SV00EX_02_0005">
<testtitle>REPLACE CELLULAR PHONE</testtitle>
</testgrp>
<testgrp id="RM0000014SV00EX_02_0006">
<testtitle>TURN MUTE OFF</testtitle>
</testgrp>
<testgrp id="RM0000014SV00EX_02_0009">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
