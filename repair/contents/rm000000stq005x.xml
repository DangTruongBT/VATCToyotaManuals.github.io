<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM000000STQ005X_04_0008">
<testtitle>REPLACE AIR CONDITIONING AMPLIFIER</testtitle>
</testgrp>
<testgrp id="RM000000STQ005X_04_0009">
<testtitle>REPLACE MAIN BODY ECU</testtitle>
</testgrp>
<testgrp id="RM000000STQ005X_04_0010">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
<testgrp id="RM000000STQ005X_04_0012">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
<testgrp id="RM000000STQ005X_04_0011">
