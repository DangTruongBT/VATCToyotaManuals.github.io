<name>HEATER &amp; AIR CONDITIONING SYSTEM</name>
<section id="1002K_S0015" variety="S0015">
<name>AIR CONDITIONING</name>
<ttl id="1002K_S0015_72YGE_T009K" variety="T009K">
<name>AIR CONDITIONING SYSTEM</name>
<para id="RM0000026BV000X" category="C" type-id="300BA" name-id="AC1WC-01" from="200601">
<dtccode>B1422/22</dtccode>
<dtcname>Compressor Lock Sensor Circuit</dtcname>
<subpara id="RM0000026BV000X_01" type-id="61" category="03" proc-id="RM0250U___00008N600000">
<name>SYSTEM DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>The ECM sends a signal to the A/C amplifier via CAN communication.</ptxt>
<ptxt>The A/C amplifier reads the difference between compressor speed and engine speed. When the difference becomes too large, the A/C amplifier determines that the compressor locks, and turns the magnetic clutch off.</ptxt>
<table pgwide="1">
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.42in"/>
<colspec colname="COL2" colwidth="2.83in"/>
<colspec colname="COL3" colwidth="2.83in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>DTC No.</ptxt>
</entry>
<entry valign="middle">
<ptxt>DTC Detection Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Trouble Area</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>B1422/22</ptxt>
</entry>
<entry valign="middle" align="left">
<ptxt>Open or short in compressor lock sensor circuit</ptxt>
</entry>
<entry valign="middle" align="left">
<list1 type="unordered">
<item>
<ptxt>A/C compressor (A/C lock sensor)</ptxt>
</item>
<item>
<ptxt>Compressor drive belt</ptxt>
</item>
<item>
<ptxt>Harness or connector between compressor and magnetic clutch (A/C lock sensor)</ptxt>
</item>
<item>
<ptxt>A/C amplifier</ptxt>
</item>
<item>
<ptxt>CAN communication system</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</content5>
</subpara>
<subpara id="RM0000026BV000X_02" type-id="32" category="03" proc-id="RM0250U___00008N700000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
