<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>OK (When troubleshooting according to the PROBLEM SYMPTOMS TABLE)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>OK (When troubleshooting according to the DTC)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>C</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000026BV000X_04_0003" fin="false">A</down>
<right ref="RM0000026BV000X_04_0006" fin="true">B</right>
<right ref="RM0000026BV000X_04_0007" fin="true">C</right>
</res>
</testgrp>
<testgrp id="RM0000026BV000X_04_0003" proc-id="RM0250U___00008NQ00000">
<testtitle>INSPECT COMPRESSOR AND MAGNETIC CLUTCH (A/C LOCK SENSOR)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the connector from the A/C compressor.</ptxt>
<figure>
<graphic graphicname="E005280" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>C53-1 (SSR+) - C53-2 (SSR-)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always (at 20°C (68°F))</ptxt>
</entry>
<entry valign="middle">
<ptxt>165 to 205 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000026BV000X_04_0004" fin="false">OK</down>
<right ref="RM0000026BV000X_04_0008" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000026BV000X_04_0004" proc-id="RM0250U___00008NR00000">
<testtitle>CHECK HARNESS AND CONNECTOR (A/C AMPLIFIER - A/C LOCK SENSOR)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the connector from the A/C amplifier.</ptxt>
<figure>
