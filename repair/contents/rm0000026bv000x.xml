</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000026BV000X_04_0007" fin="true">OK</down>
<right ref="RM0000026BV000X_04_0009" fin="true">NG</right>
</res>
