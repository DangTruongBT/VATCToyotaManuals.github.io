<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1002Q_S001I" variety="S001I">
<name>NAVIGATION</name>
<ttl id="1002Q_S001I_72YIF_T00A4" variety="T00A4">
<name>NAVIGATION SYSTEM</name>
<para id="RM0000014SU00AX" category="J" type-id="800YT" name-id="NS0WI-01" from="200601">
<dtccode/>
<dtcname>The Other Caller's Voice cannot be Heard, is too Quiet, or Distorted</dtcname>
<subpara id="RM0000014SU00AX_01" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM0000014SU00AX_02" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM0000014SU00AX_02_0001" proc-id="RM0250U___000050A00000">
<testtitle>CHECK CELLULAR PHONE</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check if the voice on the other side can be heard using a cellular phone.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Voice can be heard.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000014SU00AX_02_0008" fin="false">OK</down>
<right ref="RM0000014SU00AX_02_0005" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000014SU00AX_02_0008" proc-id="RM0250U___000050D00000">
<testtitle>CHECK NAVIGATION SYSTEM</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check that navigation sound can be heard from the driver side speaker.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Audio sound can be heard.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000014SU00AX_02_0002" fin="false">OK</down>
<right ref="RM0000014SU00AX_02_0006" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000014SU00AX_02_0002" proc-id="RM0250U___000050B00000">
<testtitle>CHECK SETTINGS</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check if the volume level is set to low on the CALL screen.</ptxt>
<figure>
<graphic graphicname="E120109E02" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>OK</title>
<specitem>
<ptxt>The level is not set low.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000014SU00AX_02_0003" fin="false">OK</down>
<right ref="RM0000014SU00AX_02_0007" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000014SU00AX_02_0003" proc-id="RM0250U___000050C00000">
<testtitle>CHECK SETTINGS</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Enter the "Handsfree Voice Quality Set" mode (See page <xref label="Seep01" href="RM000001YZ5006X"/>).</ptxt>
<figure>
<graphic graphicname="E120069E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>Check if the Receive Voice Level is set to "0".</ptxt>
<atten4>
<ptxt>The Receive Voice Level can be set to 11 different levels, -5 to +5, with a 3 dB difference.</ptxt>
</atten4>
</test1>
<test1>
<ptxt>Check if the Receive Voice Level is set to the minimum or maximum level.</ptxt>
<atten4>
<ptxt>When the Receive Voice Level is set to the minimum or maximum level, the sound may be distorted.</ptxt>
</atten4>
<spec>
<title>OK</title>
<specitem>
<ptxt>The Receive Voice Level is set to "0".</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000014SU00AX_02_0004" fin="true">OK</down>
<right ref="RM0000014SU00AX_02_0009" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000014SU00AX_02_0004">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM0000014SU00AX_02_0005">
<testtitle>REPAIR OR REPLACE CELLULAR PHONE</testtitle>
</testgrp>
<testgrp id="RM0000014SU00AX_02_0006">
<testtitle>GO TO "VOICE GUIDANCE DOES NOT FUNCTION" IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM0000014SU00AX_02_0007">
<testtitle>SET VOLUME TO HIGH</testtitle>
</testgrp>
<testgrp id="RM0000014SU00AX_02_0009">
<testtitle>SET RECEIVE VOICE LEVEL TO "0"</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>