<testgrp id="RM000001P91004X_04_0002">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM000001P91004X_04_0003">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
<testgrp id="RM000001P91004X_04_0004" proc-id="RM0250U___00009NX00000">
<testtitle>CHECK AND REPLACE DOOR OUTSIDE HANDLE</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Replace the door outside handle.</ptxt>
</test1>
<test1>
<ptxt>Check that the entry LOCK/UNLOCK function operates normally.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Entry LOCK/UNLOCK function operates normally.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000001P91004X_04_0005" fin="true">OK</down>
<right ref="RM000001P91004X_04_0002" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000001P91004X_04_0005">
<testtitle>END (DOOR OUTSIDE HANDLE IS DEFECTIVE)</testtitle>
</testgrp>
</subpara>
