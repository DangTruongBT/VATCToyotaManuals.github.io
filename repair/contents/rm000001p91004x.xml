<para id="RM000001P91004X" category="J" type-id="304YT" name-id="DL19J-01" from="200601">
<dtccode/>
<dtcname>Antenna Circuit</dtcname>
<subpara id="RM000001P91004X_01" type-id="60" category="03" proc-id="RM0250U___00009NU00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>Terminals ANT1 and ANT2 of the antenna (door outside handle) detect if the electrical key is within the action area around the door outside handle.</ptxt>
</content5>
</subpara>
<subpara id="RM000001P91004X_02" type-id="32" category="03" proc-id="RM0250U___00009NV00000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="B112492E04" width="7.106578999in" height="5.787629434in"/>
</figure>
</content5>
</subpara>
<subpara id="RM000001P91004X_03" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM000001P91004X_04" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000001P91004X_04_0001" proc-id="RM0250U___00009NW00000">
<testtitle>CHECK HARNESS AND CONNECTOR (ELECTRICAL KEY OSCILLATOR - ANTENNA)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Remove the outside handle.</ptxt>
<figure>
<graphic graphicname="B112467E07" width="2.775699831in" height="4.7836529in"/>
</figure>
</test1>
<test1>
<ptxt>Disconnect the antenna and door oscillator connectors.</ptxt>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
</test1>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.86in"/>
<colspec colname="COL2" colwidth="1.03in"/>
<colspec colname="COL3" colwidth="1.24in"/>
