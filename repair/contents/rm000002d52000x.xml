<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10006_S000F" variety="S000F">
<name>2GR-FE ENGINE CONTROL SYSTEM</name>
<ttl id="10006_S000F_7306M_T00EG" variety="T00EG">
<name>ACCELERATOR PEDAL</name>
<para id="RM000002D52000X" category="G" type-id="8000T" name-id="ES4RA-01" from="200601">
<name>ON-VEHICLE INSPECTION</name>
<subpara id="RM000002D52000X_01" type-id="01" category="01">
<s-1 id="RM000002D52000X_01_0001" proc-id="RM0250U___0000C8900000">
<ptxt>CHECK ACCELERATOR PEDAL ROD</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Measure the voltage.</ptxt>
<figure>
<graphic graphicname="B127989E01" width="2.775699831in" height="2.775699831in"/>
</figure>
<s3>
<ptxt>Connect the intelligent tester to the DLC3.</ptxt>
</s3>
<s3>
<ptxt>Turn the ignition switch on (IG).</ptxt>
</s3>
<s3>
<ptxt>Turn the intelligent tester ON.</ptxt>
</s3>
<s3>
<ptxt>Select the menu items: DIAGNOSIS / ENHANCED OBD II / DATA LIST / ALL / ACCEL POS #1, ACCEL POS #2.</ptxt>
</s3>
<s3>
<ptxt>Operate the accelerator pedal, and then check that the ACCEL POS #1 and ACCEL POS #2 values are within the specifications.</ptxt>
<spec>
<title>Standard voltage (ACCEL POS #1)</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.11in"/>
<colspec colname="COL2" colwidth="2.02in"/>
<thead>
<row>
<entry align="center">
<ptxt>Accelerator Pedal Condition</ptxt>
</entry>
<entry align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>Released</ptxt>
</entry>
<entry>
<ptxt>0.5 to 1.1 V</ptxt>
</entry>
</row>
<row>
<entry>
<ptxt>Depressed</ptxt>
</entry>
<entry>
<ptxt>2.5 to 4.5 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<spec>
<title>Standard voltage (ACCEL POS #2)</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.11in"/>
<colspec colname="COL2" colwidth="2.02in"/>
<thead>
<row>
<entry align="center">
<ptxt>Accelerator Pedal Condition</ptxt>
</entry>
<entry align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>Released</ptxt>
</entry>
<entry>
<ptxt>1.2 to 2.0 V</ptxt>
</entry>
</row>
<row>
<entry>
<ptxt>Depressed</ptxt>
</entry>
<entry>
<ptxt>3.4 to 5.0 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<ptxt>If the result is not as specified, check the accelerator pedal rod, wire harness or ECM.</ptxt>
</s3>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>