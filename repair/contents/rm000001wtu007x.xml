<section id="1002Q_S001I" variety="S001I">
<name>NAVIGATION</name>
<ttl id="1002Q_S001I_72YIF_T00A4" variety="T00A4">
<name>NAVIGATION SYSTEM</name>
<para id="RM000001WTU007X" category="C" type-id="800HD" name-id="NS0M7-07" from="200601">
<dtccode>63-44</dtccode>
<dtcname>CD Abnormal</dtcname>
<dtccode>63-48</dtccode>
<dtcname>Excess Current</dtcname>
<dtccode>63-50</dtccode>
<dtcname>Tray Insertion / Ejection Error</dtcname>
<subpara id="RM000001WTU007X_01" type-id="60" category="03" proc-id="RM0250U___00004ZM00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<table pgwide="1">
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.42in"/>
<colspec colname="COL2" colwidth="2.83in"/>
<colspec colname="COL3" colwidth="2.83in"/>
<thead>
<row>
<entry align="center">
<ptxt>DTC No.</ptxt>
</entry>
<entry align="center">
<ptxt>DTC Detection Condition</ptxt>
</entry>
<entry align="center">
<ptxt>Trouble Area</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>63-44</ptxt>
</entry>
<entry valign="middle">
<ptxt>Operation error in the CD mechanism</ptxt>
</entry>
<entry morerows="2" valign="middle">
<ptxt>Radio and navigation assembly</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>63-48</ptxt>
</entry>
<entry valign="middle">
<ptxt>Excess current is present in the CD changer.</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>63-50</ptxt>
</entry>
<entry valign="middle">
<ptxt>Malfunction in insertion/ejection system</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</content5>
</subpara>
<subpara id="RM000001WTU007X_02" type-id="51" category="05" proc-id="RM0250U___00004ZN00000">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten4>
<ptxt>After the inspection is completed, clear the DTCs.</ptxt>
</atten4>
</content5>
</subpara>
<subpara id="RM000001WTU007X_03" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000001WTU007X_03_0001" proc-id="RM0250U___00004ZO00000">
<testtitle>CLEAR DTC</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Clear the DTCs (See page <xref label="Seep01" href="RM0000011BU00FX"/>).</ptxt>
</test1>
</content6>
<res>
<down ref="RM000001WTU007X_03_0002" fin="false">NEXT</down>
</res>
</testgrp>
<testgrp id="RM000001WTU007X_03_0002" proc-id="RM0250U___00004ZP00000">
<testtitle>RECHECK DTC</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Recheck for DTCs and check if the same trouble occurs again.</ptxt>
<atten4>
<ptxt>If DTCs are detected frequently, replace the radio and navigation assembly.</ptxt>
</atten4>
<spec>
<title>OK</title>
<specitem>
<ptxt>Malfunction disappears.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000001WTU007X_03_0003" fin="true">OK</down>
<right ref="RM000001WTU007X_03_0004" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000001WTU007X_03_0003">
<testtitle>END</testtitle>
</testgrp>
<testgrp id="RM000001WTU007X_03_0004">
<testtitle>REPLACE RADIO AND NAVIGATION ASSEMBLY</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
