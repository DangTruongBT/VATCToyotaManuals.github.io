<testgrp id="RM000001W28002X_05_0016" proc-id="RM0250U___000085U00000">
<testtitle>CHECK CENTER AIRBAG SENSOR ASSEMBLY</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Turn the ignition switch off.</ptxt>
<figure>
<graphic graphicname="C123656E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</test1>
<test1>
<ptxt>Disconnect the negative (-) terminal cable from the battery, and wait for at least 90 seconds.</ptxt>
</test1>
<test1>
<ptxt>Connect the connectors to the center airbag sensor assembly.</ptxt>
</test1>
<test1>
<ptxt>Connect the negative (-) terminal cable to the battery and wait for at least 2 seconds.</ptxt>
</test1>
<test1>
<ptxt>Turn the ignition switch on (IG), and wait for at least 60 seconds.</ptxt>
</test1>
<test1>
<ptxt>Clear the DTCs stored in the memory (See page <xref label="Seep01" href="RM000000XFE00YX"/>).</ptxt>
</test1>
<test1>
<ptxt>Turn the ignition switch off.</ptxt>
</test1>
<test1>
<ptxt>Turn the ignition switch on (IG), and wait for at least 60 seconds.</ptxt>
</test1>
<test1>
<ptxt>Check for DTCs (See page <xref label="Seep02" href="RM000000XFE00YX"/>).</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>DTC B1660/43 is not output.</ptxt>
</specitem>
</spec>
<atten4>
<ptxt>Codes other than DTC B1660/43 may be output at this time, but they are not related to this check.</ptxt>
</atten4>
</test1>
</content6>
<res>
<down ref="RM000001W28002X_05_0022" fin="true">OK</down>
<right ref="RM000001W28002X_05_0019" fin="true">NG</right>
</res>
