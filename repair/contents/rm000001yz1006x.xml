<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1002Q_S001I" variety="S001I">
<name>NAVIGATION</name>
<ttl id="1002Q_S001I_72YIF_T00A4" variety="T00A4">
<name>NAVIGATION SYSTEM</name>
<para id="RM000001YZ1006X" category="C" type-id="801O5" name-id="NS0MC-05" from="200601">
<dtccode>63-7D</dtccode>
<dtcname>Disc cannot be Played</dtcname>
<dtccode>63-7E</dtccode>
<dtcname>No Playable Files</dtcname>
<dtccode>63-7F</dtccode>
<dtcname>Copyright Protection Error</dtcname>
<subpara id="RM000001YZ1006X_01" type-id="60" category="03" proc-id="RM0250U___000053F00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<table pgwide="1">
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.42in"/>
<colspec colname="COL2" colwidth="2.83in"/>
<colspec colname="COL3" colwidth="2.83in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>DTC No.</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>DTC Detection Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Trouble Area</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>63-7D</ptxt>
</entry>
<entry valign="middle">
<list1 type="unordered">
<item>
<ptxt>An incompatible MP3/WMA file is used.</ptxt>
</item>
<item>
<ptxt>Although the file has an extension of ".mp3" or ".wma", the header information cannot be read.</ptxt>
</item>
</list1>
</entry>
<entry morerows="2" valign="middle">
<list1 type="unordered">
<item>
<ptxt>CD</ptxt>
</item>
<item>
<ptxt>Radio and navigation assembly</ptxt>
</item>
</list1>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>63-7E</ptxt>
</entry>
<entry valign="middle">
<list1 type="unordered">
<item>
<ptxt>A disc with no music data is used.</ptxt>
</item>
<item>
<ptxt>Playable files are not on the disc (MP3/WMA).</ptxt>
</item>
</list1>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>63-7F</ptxt>
</entry>
<entry valign="middle">
<ptxt>A copy-protected file, which cannot be played, is used.</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</content5>
</subpara>
<subpara id="RM000001YZ1006X_02" type-id="51" category="05" proc-id="RM0250U___000053G00000">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten4>
<ptxt>After the inspection is completed, clear the DTCs.</ptxt>
</atten4>
</content5>
</subpara>
<subpara id="RM000001YZ1006X_03" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000001YZ1006X_03_0001" proc-id="RM0250U___000053H00000">
<testtitle>CHANGE DISC</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Insert a disc with a playable file and check if the disc can be played correctly.</ptxt>
<atten4>
<ptxt>For details on playable files and discs, refer to the Owner's Manual.</ptxt>
</atten4>
<spec>
<title>OK</title>
<specitem>
<ptxt>The disc can be played correctly.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000001YZ1006X_03_0002" fin="true">OK</down>
<right ref="RM000001YZ1006X_03_0003" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000001YZ1006X_03_0002">
<testtitle>DISC IS FAULTY</testtitle>
</testgrp>
<testgrp id="RM000001YZ1006X_03_0003">
<testtitle>REPLACE RADIO AND NAVIGATION ASSEMBLY</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>