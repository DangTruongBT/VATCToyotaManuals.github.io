<subpara id="RM0000020F0003X_02" type-id="51" category="05" proc-id="RM0250U___00004SV00000">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten4>
<ptxt>After the inspection is completed, clear the DTCs.</ptxt>
</atten4>
</content5>
</subpara>
<subpara id="RM0000020F0003X_03" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM0000020F0003X_03_0001" proc-id="RM0250U___00004SW00000">
<testtitle>CLEAR DTC</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Clear the DTCs (See page <xref label="Seep01" href="RM0000014CZ00FX"/>).</ptxt>
</test1>
</content6>
<res>
<down ref="RM0000020F0003X_03_0002" fin="false">NEXT</down>
</res>
</testgrp>
<testgrp id="RM0000020F0003X_03_0002" proc-id="RM0250U___00004SX00000">
<testtitle>RECHECK DTC</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Recheck for DTCs and check if the same trouble occurs again.</ptxt>
<atten4>
<ptxt>If DTCs are detected frequently, replace the radio receiver.</ptxt>
</atten4>
<spec>
<title>OK</title>
<specitem>
<ptxt>Malfunction disappears.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000020F0003X_03_0003" fin="true">OK</down>
<right ref="RM0000020F0003X_03_0004" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000020F0003X_03_0003">
<testtitle>END</testtitle>
</testgrp>
<testgrp id="RM0000020F0003X_03_0004">
<testtitle>REPLACE RADIO RECEIVER</testtitle>
</testgrp>
