<ptxt>Symptom</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Trouble Area</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>Skid Control ECU Communication Stop Mode</ptxt>
</entry>
<entry valign="middle">
<list1 type="unordered">
<item>
<ptxt>"ABS/VSC/TRC" is not displayed on the "Communication Bus Check" screen of the intelligent tester </ptxt>
</item>
<item>
<ptxt>Applies to "Skid Control ECU Communication Stop Mode" in the "DTC COMBINATION TABLE"</ptxt>
</item>
</list1>
</entry>
<entry valign="middle">
<list1 type="unordered">
<item>
<ptxt>Power source circuit of skid control ECU</ptxt>
</item>
<item>
<ptxt>Skid control ECU branch wire or connector</ptxt>
</item>
<item>
<ptxt>Brake actuator assembly (Skid control ECU)</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
