<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10007_S0005" variety="S0005">
<name>2AZ-FE FUEL</name>
<ttl id="10007_S0005_731H3_T00FM" variety="T00FM">
<name>FUEL PRESSURE PULSATION DAMPER</name>
<para id="RM0000017RP005X" category="A" type-id="30014" name-id="FU0S1-02" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000017RP005X_01" type-id="01" category="01">
<s-1 id="RM0000017RP005X_01_0001" proc-id="RM0250U___0000AUM00000">
<ptxt>INSTALL FUEL PRESSURE PULSATION DAMPER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply a light coat of gasoline or spindle oil to the O-ring of the fuel pressure pulsation damper.</ptxt>
<figure>
<graphic graphicname="A125339E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the fuel pressure pulsation damper with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="A125338" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>9.0</t-value1>
<t-value2>90</t-value2>
<t-value3>80</t-value3>
</torqueitem>
</torque>
<atten3>
<ptxt>Make sure that the O-ring is not cracked or jammed before installing the damper.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM0000017RP005X_01_0006" proc-id="RM0250U___0000AZZ00000">
<ptxt>INSTALL FUEL TUBE SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Connect the metallic type connector (See page <xref label="Seep01" href="RM000000YCO003X"/>).</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000017RP005X_01_0007" proc-id="RM0250U___0000B9900000">
<ptxt>INSTALL AIR CLEANER CAP SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air cleaner filter element onto the air cleaner case.</ptxt>
</s2>
<s2>
<ptxt>Insert the hinges. Install the air cleaner cap sub-assembly with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="A135670" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Align the matchmarks of the No. 1 air cleaner hose and throttle body, and then connect the air cleaner hose No. 1 to the throttle body and unfasten the No. 1 air cleaner hose clamp.</ptxt>
<figure>
<graphic graphicname="A135671E01" width="2.775699831in" height="2.775699831in"/>
</figure>
<atten3>
<ptxt>Make sure that the hose clamp is at the correct angle.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Connect the No. 2 ventilation hose to the air cleaner hose.</ptxt>
<figure>
<graphic graphicname="A135667E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the purge line hose to the clamp (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A135666E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the 2 purge VSV vacuum hoses (<sup>*</sup>2).</ptxt>
</s2>
<s2>
<ptxt>Connect the purge VSV connector (<sup>*</sup>3).</ptxt>
</s2>
<s2>
<ptxt>Connect the mass air flow meter connector (<sup>*</sup>4).</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000017RP005X_01_0003">
<ptxt>CONNECT CABLE TO NEGATIVE BATTERY TERMINAL</ptxt>
</s-1>
<s-1 id="RM0000017RP005X_01_0011" proc-id="RM0250U___0000BBP00000">
<ptxt>CHECK FOR FUEL LEAKS</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>See page <xref label="Seep01" href="RM000000YCR002X_01_0001"/>.</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000017RP005X_01_0008" proc-id="RM0250U___0000AMD00000">
<ptxt>INSTALL NO. 1 ENGINE COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the engine cover with the 2 nuts.</ptxt>
<figure>
<graphic graphicname="A134904" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>9.0</t-value1>
<t-value2>92</t-value2>
<t-value3>80</t-value3>
</torqueitem>
</torque>
</s2>
</content1></s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>