<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10024_S000E" variety="S000E">
<name>2AZ-FE STARTING</name>
<ttl id="10024_S000E_72Y90_T0092" variety="T0092">
<name>STARTER</name>
<para id="RM0000025TY000X" category="A" type-id="30014" name-id="ST0WP-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000025TY000X_01" type-id="01" category="01">
<s-1 id="RM0000025TY000X_01_0001" proc-id="RM0250U___00006C400000">
<ptxt>INSTALL STARTER ASSEMBLY (for Manual Transaxle)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the starter assembly and clutch flexible hose bracket with the 3 bolts.</ptxt>
<figure>
<graphic graphicname="A133566E02" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<subtitle>Bolt A</subtitle>
<torqueitem>
<t-value1>37</t-value1>
<t-value2>380</t-value2>
<t-value4>28</t-value4>
</torqueitem>
<subtitle>Bolt B</subtitle>
<torqueitem>
<t-value1>12</t-value1>
<t-value2>120</t-value2>
<t-value4>9</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the wire harness to terminal 30 and install the nut. Then, attach the terminal cap.</ptxt>
<figure>
<graphic graphicname="A133565" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>9.8</t-value1>
<t-value2>100</t-value2>
<t-value3>87</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the terminal 50 connector to the starter assembly.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000025TY000X_01_0002" proc-id="RM0250U___00006C500000">
<ptxt>INSTALL STARTER ASSEMBLY (for Automatic Transaxle)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the starter assembly with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="A134877" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>37</t-value1>
<t-value2>380</t-value2>
<t-value4>28</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the wire harness to terminal 30 and install the nut. Then, attach the terminal cap.</ptxt>
<figure>
<graphic graphicname="A134876" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>9.8</t-value1>
<t-value2>100</t-value2>
<t-value3>87</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the terminal 50 connector to the starter assembly.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000025TY000X_01_0008" proc-id="RM0250U___00006Z400000">
<ptxt>INSTALL AIR CLEANER CASE SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air cleaner case with the 3 bolts.</ptxt>
<figure>
<graphic graphicname="A134905" width="2.775699831in" height="2.775699831in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the hose clamp.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000025TY000X_01_0009" proc-id="RM0250U___0000B9900000">
<ptxt>INSTALL AIR CLEANER CAP SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air cleaner filter element onto the air cleaner case.</ptxt>
</s2>
<s2>
<ptxt>Insert the hinges. Install the air cleaner cap sub-assembly with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="A135670" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Align the matchmarks of the No. 1 air cleaner hose and throttle body, and then connect the air cleaner hose No. 1 to the throttle body and unfasten the No. 1 air cleaner hose clamp.</ptxt>
<figure>
<graphic graphicname="A135671E01" width="2.775699831in" height="2.775699831in"/>
</figure>
<atten3>
<ptxt>Make sure that the hose clamp is at the correct angle.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Connect the No. 2 ventilation hose to the air cleaner hose.</ptxt>
<figure>
<graphic graphicname="A135667E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the purge line hose to the clamp (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A135666E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the 2 purge VSV vacuum hoses (<sup>*</sup>2).</ptxt>
</s2>
<s2>
<ptxt>Connect the purge VSV connector (<sup>*</sup>3).</ptxt>
</s2>
<s2>
<ptxt>Connect the mass air flow meter connector (<sup>*</sup>4).</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000025TY000X_01_0010" proc-id="RM0250U___0000ALT00000">
<ptxt>INSTALL AIR CLEANER INLET ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air cleaner inlet with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="A134903" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM0000025TY000X_01_0011" proc-id="RM0250U___0000ALW00000">
<ptxt>CONNECT CABLE TO NEGATIVE BATTERY TERMINAL
</ptxt>
<content1 releasenbr="1">
<torque>
<torqueitem>
<t-value1>6.9</t-value1>
<t-value2>70</t-value2>
<t-value3>61</t-value3>
</torqueitem>
</torque>
</content1></s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>