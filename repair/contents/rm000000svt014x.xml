<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>2 (KNK1) - 1 (EKNK)</ptxt>
</entry>
<entry valign="middle">
<ptxt>120 to 280 kΩ at 20°C (68°F)</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
<test1>
<ptxt>Reinstall the knock sensor.</ptxt>
</test1>
</content6>
<res>
<down ref="RM000000SVT014X_09_0004" fin="true">OK</down>
<right ref="RM000000SVT014X_09_0011" fin="true">NG</right>
</res>
</testgrp>
