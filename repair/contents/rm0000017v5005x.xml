<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10006_S0004" variety="S0004">
<name>2AZ-FE ENGINE CONTROL SYSTEM</name>
<ttl id="10006_S0004_731VR_T00FY" variety="T00FY">
<name>CAMSHAFT POSITION SENSOR</name>
<para id="RM0000017V5005X" category="G" type-id="3001K" name-id="ES1RL-05" from="200601">
<name>INSPECTION</name>
<subpara id="RM0000017V5005X_01" type-id="01" category="01">
<s-1 id="RM0000017V5005X_01_0001" proc-id="RM0250U___0000B6E00000">
<ptxt>INSPECT CAMSHAFT POSITION SENSOR</ptxt>
<content1 releasenbr="1">
<figure>
<graphic graphicname="A095265E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<s2>
<ptxt>Measure the resistance of the sensor.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry>
<ptxt>Tester Connection</ptxt>
</entry>
<entry>
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>1 (G+) - 2 (G-)</ptxt>
</entry>
<entry>
<ptxt>835 to 1,400 Ω at Cold</ptxt>
</entry>
</row>
<row>
<entry>
<ptxt>1 (G+) - 2 (G-)</ptxt>
</entry>
<entry>
<ptxt>1,060 to 1,645 Ω at Hot</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<atten3>
<ptxt>"Cold" and "Hot" mean the temperature of the coils themselves. "Cold" is from -10 to 50°C (14 to 122 °F) and "Hot" is from 50 to 100°C (122 to 212°F).</ptxt>
</atten3>
<ptxt>If the result is not as specified, replace the camshaft position sensor.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>