</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000ZBM003X_04_0018" fin="true">OK</down>
<right ref="RM000000ZBM003X_04_0022" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000ZBM003X_04_0013" proc-id="RM0250U___00006IO00000">
<testtitle>INSPECT ENGINE ROOM JUNCTION BLOCK ASSEMBLY</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Remove the H-LP (RL) fuse and H-LP (LL) fuse from the engine room J/B assembly.</ptxt>
<figure>
<graphic graphicname="E121533E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the voltage between the loading slot of each fuse and body ground.</ptxt>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>H-LP (RL) Terminal - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Light control switch in HEAD</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 to 14 V</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>H-LP (LL) Terminal - Body ground</ptxt>
</entry>
<entry valign="middle">
