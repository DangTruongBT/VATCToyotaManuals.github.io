</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000ZBM003X_04_0028" fin="true">OK</down>
<right ref="RM000000ZBM003X_04_0019" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000ZBM003X_04_0022">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
<testgrp id="RM000000ZBM003X_04_0018">
<testtitle>REPLACE INSTRUMENT PANEL JUNCTION BLOCK ASSEMBLY</testtitle>
</testgrp>
<testgrp id="RM000000ZBM003X_04_0019">
<testtitle>REPLACE ENGINE ROOM JUNCTION BLOCK ASSEMBLY (POWER DISTRIBUTOR)</testtitle>
</testgrp>
<testgrp id="RM000000ZBM003X_04_0024">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
