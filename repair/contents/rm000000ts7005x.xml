<name>HEATER &amp; AIR CONDITIONING SYSTEM</name>
<section id="1002K_S0015" variety="S0015">
<name>AIR CONDITIONING</name>
<ttl id="1002K_S0015_72YGE_T009K" variety="T009K">
<name>AIR CONDITIONING SYSTEM</name>
<para id="RM000000TS7005X" category="J" type-id="300CG" name-id="AC1WM-01" from="200601">
<dtccode/>
<dtcname>Back-up Power Source Circuit</dtcname>
<subpara id="RM000000TS7005X_01" type-id="60" category="03" proc-id="RM0250U___00004KQ00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>The back-up power source circuit for the A/C amplifier is shown below. Power is supplied even when turning the ignition switch off and is used for diagnostic trouble code memory, etc.</ptxt>
</content5>
</subpara>
<subpara id="RM000000TS7005X_02" type-id="32" category="03" proc-id="RM0250U___00004KR00000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="E116884E03" width="7.106578999in" height="2.775699831in"/>
</figure>
</content5>
</subpara>
<subpara id="RM000000TS7005X_03" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM000000TS7005X_04" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000000TS7005X_04_0001" proc-id="RM0250U___00004KS00000">
<testtitle>INSPECT FUSE (A/C)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Remove the A/C fuse from the instrument panel J/B.</ptxt>
<figure>
<graphic graphicname="E124481E03" width="2.775699831in" height="2.775699831in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Item</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>A/C fuse</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000TS7005X_04_0002" fin="false">OK</down>
<right ref="RM000000TS7005X_04_0004" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000TS7005X_04_0002" proc-id="RM0250U___00004KT00000">
<testtitle>INSPECT AIR CONDITIONING AMPLIFIER (AIR CONDITIONING AMPLIFIER - BODY GROUND)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the A/C amplifier connector.</ptxt>
<figure>
<graphic graphicname="E124470E16" width="2.775699831in" height="2.775699831in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the voltage according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>E38-21 (B) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 to 14 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000TS7005X_04_0003" fin="true">OK</down>
<right ref="RM000000TS7005X_04_0005" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000TS7005X_04_0003">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM000000TS7005X_04_0004">
<testtitle>REPLACE FUSE (A/C)</testtitle>
</testgrp>
<testgrp id="RM000000TS7005X_04_0005">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
