<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10025_S000Q" variety="S000Q">
<name>2GR-FE CHARGING</name>
<ttl id="10025_S000Q_72ZS5_T00CK" variety="T00CK">
<name>CHARGING SYSTEM</name>
<para id="RM000001J2K00GX" category="J" type-id="801ET" name-id="CH069-09" from="200601">
<dtccode/>
<dtcname>Noise Occurs from Generator while Engine is Running</dtcname>
<subpara id="RM000001J2K00GX_02" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM000001J2K00GX_01" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000001J2K00GX_01_0008" proc-id="RM0250U___00006JX00001">
<testtitle>CHECK LOOSENESS OF V-RIBBED BELT</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check the tension of the belt by pushing it down with a finger.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The tension of the belt is enough.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000001J2K00GX_01_0005" fin="false">OK</down>
<right ref="RM000001J2K00GX_01_0009" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000001J2K00GX_01_0005" proc-id="RM0250U___00006JV00001">
<testtitle>CHECK V-RIBBED BELT FOR WEAR</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check the V-ribbed belt for wear.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The V-ribbed belt is not worn.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000001J2K00GX_01_0006" fin="false">OK</down>
<right ref="RM000001J2K00GX_01_0007" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000001J2K00GX_01_0006" proc-id="RM0250U___00006JW00001">
<testtitle>CHECK CLUTCH PULLEY FOR WEAR</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check the clutch pulley groove for wear or other defects.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The clutch pulley groove is not damaged.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000001J2K00GX_01_0002" fin="false">OK</down>
<right ref="RM000001J2K00GX_01_0003" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000001J2K00GX_01_0002" proc-id="RM0250U___00006JU00001">
<testtitle>CHECK FOR NOISE WHILE CLUTCH PULLEY IS OPERATING</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Perform a driving test and check if noise occurs when decelerating.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Noise does not occur.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000001J2K00GX_01_0004" fin="true">OK</down>
<right ref="RM000001J2K00GX_01_0003" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000001J2K00GX_01_0009">
<testtitle>REPLACE V-RIBBED BELT TENSIONER ASSEMBLY</testtitle>
</testgrp>
<testgrp id="RM000001J2K00GX_01_0007">
<testtitle>REPLACE V-RIBBED BELT</testtitle>
</testgrp>
<testgrp id="RM000001J2K00GX_01_0003">
<testtitle>REPLACE CLUTCH PULLEY</testtitle>
</testgrp>
<testgrp id="RM000001J2K00GX_01_0004">
<testtitle>REPLACE GENERATOR ASSEMBLY</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>