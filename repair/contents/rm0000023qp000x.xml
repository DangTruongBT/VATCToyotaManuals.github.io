<name>WIPER AND WASHER</name>
<ttl id="1001B_S001C_72WDN_T0064" variety="T0064">
<name>WIPER SWITCH</name>
<para id="RM0000023QP000X" category="A" type-id="30014" name-id="WW0MA-03" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000023QP000X_01" type-id="01" category="01">
<s-1 id="RM0000023QP000X_01_0001" proc-id="RM0250U___000055R00000">
<ptxt>INSTALL WINDSHIELD WIPER SWITCH ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the claw and install the windshield wiper switch assembly as shown in the illustration.</ptxt>
<figure>
<graphic graphicname="E128825" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the 2 connectors.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000023QP000X_01_0002" proc-id="RM0250U___00000BU00000">
<ptxt>INSTALL STEERING COLUMN COVER
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the claw to install the upper steering column cover.</ptxt>
<figure>
<graphic graphicname="C132545" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Engage the 2 claws to install the lower steering column cover.</ptxt>
<figure>
<graphic graphicname="C132544" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 2 screws.</ptxt>
</s2>
</content1></s-1>
</subpara>
</para>
</ttl>
