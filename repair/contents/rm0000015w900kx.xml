<subpara id="RM0000015W900KX_09" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM0000015W900KX_09_0001" proc-id="RM0250U___000063100000">
<testtitle>INSPECT TRANSMISSION WIRE (DSL)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the transmission wire connector from the transaxle.</ptxt>
<figure>
<graphic graphicname="C113969E32" width="2.775699831in" height="2.775699831in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
<ptxt>20°C (68°F)</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>10 - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>11 to 13 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000015W900KX_09_0002" fin="false">OK</down>
<right ref="RM0000015W900KX_09_0003" fin="false">NG</right>
</res>
</testgrp>
<testgrp id="RM0000015W900KX_09_0002" proc-id="RM0250U___000063200000">
<testtitle>CHECK HARNESS AND CONNECTOR (TRANSMISSION WIRE - ECM)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Connect the transmission wire connector.</ptxt>
<figure>
<graphic graphicname="A136781E03" width="2.775699831in" height="2.775699831in"/>
</figure>
</test1>
<test1>
<ptxt>Disconnect the ECM connector.</ptxt>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
<ptxt>20°C (68°F)</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>C24-79 (DSL) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>11 to 13 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000015W900KX_09_0007" fin="true">OK</down>
<right ref="RM0000015W900KX_09_0005" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000015W900KX_09_0003" proc-id="RM0250U___000063300000">
