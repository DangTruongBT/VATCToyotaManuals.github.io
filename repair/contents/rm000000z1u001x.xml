<s-1 id="RM000000Z1U001X_01_0006" proc-id="RM0250U___00004C600000">
<ptxt>INSPECT 4TH GEAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a cylinder gauge, measure the inside diameter of the 4th gear.</ptxt>
<figure>
<graphic graphicname="C069622" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Inside diameter</title>
<subtitle>mm (in.)</subtitle>
<table frame="all" colsep="1" rowsep="1">
<tgroup cols="2">
<colspec colnum="1" colname="c1" colwidth="2.0929012in"/>
<colspec colnum="2" colname="c2" colwidth="2.0929004in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Standard inside diameter</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Maximum inside diameter</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>42.009 to 42.025</ptxt>
<ptxt>(1.6539 to 1.6545)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>42.025</ptxt>
<ptxt>(1.6545)</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<ptxt>If the inside diameter exceeds the maximum, replace the 4th gear.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z1U001X_01_0007" proc-id="RM0250U___00004C700000">
<ptxt>INSPECT 3RD GEAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a cylinder gauge, measure the inside diameter of the 3rd gear.</ptxt>
<figure>
<graphic graphicname="C069622" width="2.775699831in" height="1.771723296in"/>
