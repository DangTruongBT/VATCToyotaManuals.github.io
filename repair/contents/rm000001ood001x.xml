<name>CANISTER</name>
<para id="RM000001OOD001X" category="A" type-id="30014" name-id="EC0M0-02" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000001OOD001X_01" type-id="01" category="01">
<s-1 id="RM000001OOD001X_01_0001" proc-id="RM0250U___000093W00000">
<ptxt>INSTALL CHARCOAL CANISTER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the 2 bolts, clip and charcoal canister.</ptxt>
<figure>
<graphic graphicname="A128096" width="2.775699831in" height="2.775699831in"/>
</figure>
<torque>
<torqueitem>
<t-value1>39</t-value1>
<t-value2>398</t-value2>
<t-value4>29</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the purge line hose to the charcoal canister.</ptxt>
</s2>
<s2>
<ptxt>Connect the wire harness clamp.</ptxt>
</s2>
<s2>
<ptxt>Connect the vapor pressure sensor connector.</ptxt>
</s2>
<s2>
<ptxt>Connect the charcoal canister filter sub-assembly to the charcoal canister.</ptxt>
</s2>
<s2>
<ptxt>Connect the fuel tank vent hose to the charcoal canister.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001OOD001X_01_0014" proc-id="RM0250U___0000BSW00000">
<ptxt>INSTALL FUEL TANK ASSEMBLY</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>(See page <xref label="Seep01" href="RM000001IRD001X"/>)</ptxt>
</atten4>
</content1>
</s-1>
</subpara>
</para>
