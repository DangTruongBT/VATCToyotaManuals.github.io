<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1001C_S001D" variety="S001D">
<name>AUDIO / VISUAL</name>
<ttl id="1001C_S001D_72YIE_T00A3" variety="T00A3">
<name>AUDIO AND VISUAL SYSTEM</name>
<para id="RM0000014SU00EX" category="J" type-id="800YT" name-id="AV1X1-01" from="200601">
<dtccode/>
<dtcname>The Other Caller's Voice cannot be Heard, is too Quiet, or Distorted</dtcname>
<subpara id="RM0000014SU00EX_01" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM0000014SU00EX_02" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM0000014SU00EX_02_0001" proc-id="RM0250U___0000ANI00000">
<testtitle>CHECK CELLULAR PHONE</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check if the voice on the other side can be heard using a cellular phone.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Voice can be heard.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000014SU00EX_02_0008" fin="false">OK</down>
<right ref="RM0000014SU00EX_02_0005" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000014SU00EX_02_0008" proc-id="RM0250U___0000ANL00000">
<testtitle>CHECK AUDIO AND VISUAL SYSTEM</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check that audio sound can be heard from the driver side speaker.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Audio sound can be heard.</ptxt>
</specitem>
</spec>
<atten4>
<ptxt>If audio sound cannot be heard, proceed to "No sound can be heard from speakers. (Audio is mute.)" in the PROBLEM SYMPTOMS TABLE (See page <xref label="Seep01" href="RM0000012A800CX"/>).</ptxt>
</atten4>
</test1>
</content6>
<res>
<down ref="RM0000014SU00EX_02_0002" fin="false">OK</down>
<right ref="RM0000014SU00EX_02_0004" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000014SU00EX_02_0002" proc-id="RM0250U___0000ANJ00000">
<testtitle>CHECK SETTINGS</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check that the received voice level setting on the cellular phone is not too low.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The received voice level setting is not too low.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000014SU00EX_02_0004" fin="true">OK</down>
<right ref="RM0000014SU00EX_02_0007" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000014SU00EX_02_0004">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM0000014SU00EX_02_0005">
<testtitle>REPAIR OR REPLACE CELLULAR PHONE</testtitle>
</testgrp>
<testgrp id="RM0000014SU00EX_02_0007">
<testtitle>SET VOLUME TO HIGH</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>