<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="35">
<name>SUSPENSION &amp; AXLE</name>
<section id="1002I_S000Z" variety="S000Z">
<name>SUSPENSION</name>
<ttl id="1002I_S000Z_72VB8_T005A" variety="T005A">
<name>FRONT STABILIZER BAR</name>
<para id="RM0000011DN004X" category="A" type-id="30014" name-id="SP0ZI-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000011DN004X_01" type-id="01" category="01">
<s-1 id="RM0000011DN004X_01_0002" proc-id="RM0250U___00000H900000">
<ptxt>INSTALL FRONT NO. 1 STABILIZER BAR BUSHING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the 2 front stabilizer bar bushings No. 1 to the outside of the bushing stopper on the front stabilizer bar.</ptxt>
<figure>
<graphic graphicname="C140709E01" width="2.775699831in" height="3.779676365in"/>
</figure>
<atten3>
<ptxt>Make sure that the cutout of the front stabilizer bar bushing No. 1 faces the rear side as shown in the illustration.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011DN004X_01_0005" proc-id="RM0250U___00000HC00000">
<ptxt>INSTALL FRONT NO. 1 STABILIZER BRACKET LH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the front No. 1 stabilizer bracket LH.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011DN004X_01_0006" proc-id="RM0250U___00000HD00000">
<ptxt>INSTALL FRONT NO. 1 STABILIZER BRACKET RH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the front No. 1 stabilizer bracket RH.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011DN004X_01_0001" proc-id="RM0250U___00000H800000">
<ptxt>INSTALL FRONT STABILIZER BAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the front stabilizer bar with the 2 bolts. (LH Side)</ptxt>
<figure>
<graphic graphicname="C143302E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>27</t-value1>
<t-value2>275</t-value2>
<t-value4>20</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Install the front stabilizer bar with the 2 bolts. (RH Side)</ptxt>
<figure>
<graphic graphicname="C143303E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>27</t-value1>
<t-value2>275</t-value2>
<t-value4>20</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011DN004X_01_0027" proc-id="RM0250U___0000AY400000">
<ptxt>INSTALL ENGINE ASSEMBLY WITH TRANSAXLE</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Refer to the instructions for installation of the engine assembly (See page <xref label="Seep01" href="RM000000YIK001X"/> for 2AZ-FE, <xref label="Seep02" href="RM0000021ZR001X"/> for 2GR-FE)</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000011DN004X_01_0007" proc-id="RM0250U___00000HE00000">
<ptxt>INSTALL FRONT STABILIZER LINK ASSEMBLY LH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the front stabilizer link assembly LH with the 2 nuts.</ptxt>
<figure>
<graphic graphicname="C132425" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>74</t-value1>
<t-value2>755</t-value2>
<t-value4>55</t-value4>
</torqueitem>
</torque>
<atten4>
<ptxt>If the ball joint turns together with the nut, use a hexagon (6 mm) wrench to hold the stud.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011DN004X_01_0008" proc-id="RM0250U___00000HF00000">
<ptxt>INSTALL FRONT STABILIZER LINK ASSEMBLY RH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the front stabilizer link assembly RH with the 2 nuts.</ptxt>
<figure>
<graphic graphicname="C139012" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>74</t-value1>
<t-value2>755</t-value2>
<t-value4>55</t-value4>
</torqueitem>
</torque>
<atten4>
<ptxt>If the ball joint turns together with the nut, use a hexagon (6 mm) wrench to hold the stud.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011DN004X_01_0016" proc-id="RM0250U___000046Y00000">
<ptxt>CONNECT TIE ROD END SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Connect the tie rod assembly LH to the steering knuckle with the nut.</ptxt>
<torque>
<torqueitem>
<t-value1>49</t-value1>
<t-value2>500</t-value2>
<t-value4>36</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Install a new cotter pin.</ptxt>
<atten3>
<ptxt>Further tighten the nut up to 60° if the holes for the cotter pin are not aligned.</ptxt>
</atten3>
</s2>
</content1></s-1>
<s-1 id="RM0000011DN004X_01_0017" proc-id="RM0250U___00000BQ00000">
<ptxt>CONNECT STEERING INTERMEDIATE SHAFT ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Align the matchmarks on the steering intermediate shaft assembly and the steering column assembly.</ptxt>
</s2>
<s2>
<ptxt>Install the bolt.</ptxt>
<figure>
<graphic graphicname="C133503E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>35</t-value1>
<t-value2>360</t-value2>
<t-value4>26</t-value4>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM0000011DN004X_01_0018">
<ptxt>PLACE FRONT WHEELS FACING STRAIGHT</ptxt>
</s-1>
<s-1 id="RM0000011DN004X_01_0009" proc-id="RM0250U___00000HG00000">
<ptxt>INSTALL FRONT WHEELS</ptxt>
<content1 releasenbr="1">
<torque>
<torqueitem>
<t-value1>103</t-value1>
<t-value2>1,050</t-value2>
<t-value4>76</t-value4>
</torqueitem>
</torque>
</content1>
</s-1>
<s-1 id="RM0000011DN004X_01_0020">
<ptxt>CONNECT CABLE TO NEGATIVE BATTERY TERMINAL</ptxt>
</s-1>
<s-1 id="RM0000011DN004X_01_0023" proc-id="RM0250U___00000HN00000">
<ptxt>INSPECT AND ADJUST FRONT WHEEL ALIGNMENT</ptxt>
<content1 releasenbr="1">
<ptxt>(See page <xref label="Seep01" href="RM0000011DA004X"/>)</ptxt>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>