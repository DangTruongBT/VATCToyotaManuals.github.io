</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>E14-2 (LR) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Hazard warning switch OFF</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 V</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>E14-2 (LR) - Body ground</ptxt>
