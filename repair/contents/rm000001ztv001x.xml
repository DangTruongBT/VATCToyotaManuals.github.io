</entry>
<entry valign="middle">
<ptxt>Below 1 V</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>E14-3 (LL) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Ignition switch on (IG) and turn signal switch in LH position</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 to 14 V (60 to 120 times per minute)</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>E14-5 (EL) - Body ground</ptxt>
</entry>
