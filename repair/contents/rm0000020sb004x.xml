<testtitle>INSPECT FUSE (AM2)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Remove the AM2 fuse from the engine room J/B.</ptxt>
</test1>
<test1>
<ptxt>Measure the resistance of the fuse.</ptxt>
<spec>
<title>Standard resistance</title>
<specitem>
<ptxt>Below 1 Ω</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000020SB004X_04_0002" fin="false">OK</down>
<right ref="RM0000020SB004X_04_0011" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000020SB004X_04_0002" proc-id="RM0250U___00009LM00000">
