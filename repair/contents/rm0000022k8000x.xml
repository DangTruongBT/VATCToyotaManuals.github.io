<name>BRAKE</name>
<section id="1000N_S0011" variety="S0011">
<name>BRAKE</name>
<ttl id="1000N_S0011_72V94_T0041" variety="T0041">
<name>STOP LIGHT SWITCH</name>
<para id="RM0000022K8000X" category="A" type-id="30014" name-id="BR0XV-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000022K8000X_01" type-id="01" category="01">
<s-1 id="RM0000022K8000X_01_0002" proc-id="RM0250U___00003VI00000">
<ptxt>INSTALL STOP LIGHT SWITCH</ptxt>
<content1 releasenbr="2">
<s2>
<ptxt>Insert the stop light switch assembly until the body hits the cushion.</ptxt>
<figure>
<graphic graphicname="C133308" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>When inserting the stop light switch assembly, support the pedal from behind so that the pedal is not pushed in.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Make a quarter turn clockwise to install the stop light switch assembly.</ptxt>
<torque>
<torqueitem>
<t-value1>1.5</t-value1>
<t-value2>15</t-value2>
<t-value3>13</t-value3>
<ptxt> or less</ptxt>
</torqueitem>
</torque>
<figure>
<graphic graphicname="C131701E02" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>When inserting the stop light switch assembly, support the pedal from behind so that the pedal is not pushed in.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Connect the stop light switch connector to the stop light switch assembly.</ptxt>
<figure>
<graphic graphicname="C133309E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Check the protrusion of the rod (See page <xref label="Seep01" href="RM0000022K7000X_01_0001"/>).</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022K8000X_01_0013" proc-id="RM0250U___00007XM00000">
<ptxt>INSTALL COMBINATION METER
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Connect each connector.</ptxt>
<figure>
<graphic graphicname="B133987E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the combination meter assembly with the 4 screws &lt;E&gt;.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000022K8000X_01_0014" proc-id="RM0250U___00007XO00000">
<ptxt>INSTALL INSTRUMENT CLUSTER FINISH PANEL
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the guide and the 4 claws.</ptxt>
<figure>
<graphic graphicname="B133985E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Install the instrument cluster finish panel with the 2 clips.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000022K8000X_01_0015" proc-id="RM0250U___00007XQ00000">
<ptxt>INSTALL LOWER INSTRUMENT PANEL FINISH PANEL (w/ Smart Key System)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Connect the connector.</ptxt>
</s2>
<s2>
<ptxt>Engage the 2 claws and 2 clips to install the lower instrument panel finish panel.</ptxt>
<figure>
<graphic graphicname="B133984" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000022K8000X_01_0016" proc-id="RM0250U___00007XP00000">
<ptxt>INSTALL LOWER INSTRUMENT PANEL FINISH PANEL (w/o Smart Key System)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 2 claws and 2 clips to install the lower instrument panel finish panel.</ptxt>
<figure>
<graphic graphicname="B133983" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000022K8000X_01_0017" proc-id="RM0250U___00007XR00000">
<ptxt>INSTALL NO. 1 INSTRUMENT PANEL SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Connect the connector.</ptxt>
</s2>
<s2>
<ptxt>Engage the 3 claws and 2 clips to install the No. 1 instrument panel sub-assembly.</ptxt>
<figure>
<graphic graphicname="B133982" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000022K8000X_01_0018" proc-id="RM0250U___00007XU00000">
<ptxt>INSTALL LOWER INSTRUMENT PANEL FINISH PANEL LH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air hose and connect the connector.</ptxt>
<figure>
<graphic graphicname="B133980E05" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Engage the claw and the 9 clips.</ptxt>
</s2>
<s2>
<ptxt>Instal the instrument panel finish panel LH with the screw &lt;B&gt; and bolt &lt;A&gt;.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000022K8000X_01_0019" proc-id="RM0250U___00006MR00000">
<ptxt>INSTALL COWL SIDE TRIM SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 2 clips.</ptxt>
<figure>
<graphic graphicname="B132116E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the cowl side trim sub-assembly LH with the cowl side trim clip.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000022K8000X_01_0020" proc-id="RM0250U___00006MS00000">
<ptxt>INSTALL FRONT DOOR SCUFF PLATE
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 7 claws and 3 clips, then install the front door scuff plate LH.</ptxt>
<figure>
<graphic graphicname="B132067" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
