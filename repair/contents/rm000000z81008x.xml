<testgrp id="RM000000Z81008X_07_0050" proc-id="RM0250U___0000D0T00000">
<testtitle>READ VALUE OF DATA LIST</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Turn the ignition switch off, and then turn it on (IG).</ptxt>
</test1>
<test1>
<ptxt>Select "TIREPRESS" by following the prompts displayed on the intelligent tester.</ptxt>
<atten4>
<ptxt>It may take for 1 minute or display the tire pressure data.</ptxt>
</atten4>
<spec>
<title>Result</title>
<table pgwide="1">
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="3.54in"/>
<colspec colname="COL2" colwidth="3.54in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>All tire pressure readings are equal to specified values.</ptxt>
</entry>
<entry valign="middle">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Tire pressure values are not displayed.</ptxt>
</entry>
<entry valign="middle">
