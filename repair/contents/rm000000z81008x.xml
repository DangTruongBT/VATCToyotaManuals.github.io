</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>TIREPRESS3</ptxt>
</entry>
<entry valign="middle">
<ptxt>ID3 tire inflation pressure/ min.: 0 kPa (0 kgf/cm<sup>2</sup>, 0 psi), max.: 637.5 kPa (6.48 kgf/cm<sup>2</sup>, 92.2 psi)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Actual tire inflation pressure</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>-</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>TIREPRESS4</ptxt>
</entry>
<entry valign="middle">
<ptxt>ID4 tire inflation pressure/ min.: 0 kPa (0 kgf/cm<sup>2</sup>, 0 psi), max.: 637.5 kPa (6.48 kgf/cm<sup>2</sup>, 92.2 psi)</ptxt>
