</entry>
<entry valign="middle">
<ptxt>Front kPa (kgf/cm<sup>2</sup>, psi)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Rear kPa (kgf/cm<sup>2</sup>, psi)</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>P215/60R16 94V</ptxt>
</entry>
<entry valign="middle">
<ptxt>210 (2.1, 31)</ptxt>
</entry>
<entry valign="middle">
<ptxt>210 (2.1, 31)</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>P215/55R17 93V</ptxt>
</entry>
<entry valign="middle">
<ptxt>220 (2.2, 32)</ptxt>
</entry>
<entry valign="middle">
<ptxt>220 (2.2, 32)</ptxt>
</entry>
</row>
