<ptxt>TIREPRESS2</ptxt>
</entry>
<entry valign="middle">
<ptxt>ID2 tire inflation pressure/ min.: 0 kPa (0 kgf/cm<sup>2</sup>, 0 psi), max.: 637.5 kPa (6.48 kgf/cm<sup>2</sup>, 92.2 psi)</ptxt>
</entry>
