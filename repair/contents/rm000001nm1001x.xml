<tmc-service-inc>
<pub id="RM0251U">
<servcat id="37">
<name>STEERING</name>
<section id="1000U_S0013" variety="S0013">
<name>STEERING COLUMN</name>
<ttl id="1000U_S0013_72VA8_T004G" variety="T004G">
<name>STEERING COLUMN ASSEMBLY</name>
<para id="RM000001NM1001X" category="G" type-id="3001K" name-id="SR0C8-02" from="200601">
<name>INSPECTION</name>
<subpara id="RM000001NM1001X_01" type-id="01" category="01">
<s-1 id="RM000001NM1001X_01_0001" proc-id="RM0250U___00000C600000">
<ptxt>INSPECT STEERING LOCK OPERATION (w/o Smart Key System)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Check that the steering lock mechanism is activated when the key is removed.</ptxt>
<figure>
<graphic graphicname="C103934" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Check that the steering lock mechanism is deactivated when the key is inserted and turned to the ACC position.</ptxt>
<figure>
<graphic graphicname="C103935E02" width="2.775699831in" height="2.775699831in"/>
</figure>
<atten4>
<ptxt>If there is any abnormality, replace the ignition switch lock cylinder assembly.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
