<servcat id="43">
<name>BODY</name>
<section id="1002U_S001N" variety="S001N">
<name>WINDSHIELD / WINDOWGLASS</name>
<ttl id="1002U_S001N_72YM9_T00A5" variety="T00A5">
<name>POWER WINDOW CONTROL SYSTEM</name>
<para id="RM0000011V300BX" category="J" type-id="304Z1" name-id="WS0R5-01" from="200601">
<dtccode/>
<dtcname>Driver Side Power Window Motor Circuit</dtcname>
<subpara id="RM0000011V300BX_01" type-id="60" category="03" proc-id="RM0250U___000057I00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>This circuit transmits signals from the power window regulator master switch assembly to the power window regulator motor (Front LH).</ptxt>
</content5>
</subpara>
<subpara id="RM0000011V300BX_02" type-id="32" category="03" proc-id="RM0250U___000057J00000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="B137064E01" width="7.106578999in" height="3.779676365in"/>
</figure>
<figure>
<graphic graphicname="B137065E04" width="7.106578999in" height="3.779676365in"/>
</figure>
</content5>
</subpara>
<subpara id="RM0000011V300BX_03" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM0000011V300BX_04" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM0000011V300BX_04_0001" proc-id="RM0250U___000057K00000">
<testtitle>INSPECT POWER WINDOW REGULATOR MOTOR</testtitle>
<content6 releasenbr="1">
<ptxt>without Jam protection:</ptxt>
<test1>
<ptxt>Remove the power window motor.</ptxt>
<figure>
<graphic graphicname="B127535E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<test2>
<ptxt>Apply battery voltage to the motor connector according to the table below.</ptxt>
<atten3>
<ptxt>Do not apply battery voltage to any terminals except terminals 1 and 2.</ptxt>
</atten3>
<spec>
<title>Standard</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Measurement Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>Battery positive (+) → Terminal 2</ptxt>
<ptxt>Battery negative (-) → Terminal 1</ptxt>
</entry>
<entry valign="middle">
<ptxt>Motor gear rotates clockwise</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Battery positive (+) → Terminal 1</ptxt>
<ptxt>Battery negative (-) → Terminal 2</ptxt>
</entry>
<entry valign="middle">
<ptxt>Motor gear rotates counterclockwise</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test2>
</test1>
<test1>
<ptxt>with Jam protection:</ptxt>
<ptxt>Remove the power window motor.</ptxt>
<figure>
<graphic graphicname="B145500E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<test2>
<ptxt>Apply battery voltage to the motor connector according to the table below.</ptxt>
<atten3>
<ptxt>Do not apply battery voltage to any terminals except terminals 1, 2, 4, 7 and 10.</ptxt>
</atten3>
<spec>
<title>Standard</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Switch Condition</ptxt>
</entry>
<entry>
<ptxt>Measurement Condition</ptxt>
</entry>
<entry>
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry morerows="1" valign="middle" align="center">
<ptxt>Manual Operation</ptxt>
</entry>
<entry valign="middle">
<ptxt>Battery positive (+) → Terminal 2 (B)</ptxt>
<ptxt>Battery negative (-) → Terminal 1 (E), 7 (DWN1)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Motor gear rotates counterclockwise</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Battery positive (+) → Terminal 2 (B)</ptxt>
<ptxt>Battery negative (-) → Terminal 1 (E), 10 (UP1)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Motor gear rotates clockwise</ptxt>
</entry>
</row>
<row>
<entry morerows="1" valign="middle" align="center">
<ptxt>Auto Operation</ptxt>
</entry>
<entry valign="middle">
<ptxt>Battery positive (+) → Terminal 2 (B)</ptxt>
<ptxt>Battery negative (-) → Terminal 1 (E), 4 (AUTO), 7 (DWN1)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Motor gear rotates counterclockwise</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Battery positive (+) → Terminal 2 (B)</ptxt>
<ptxt>Battery negative (-) → Terminal 1 (E), 4 (AUTO), 10 (UP1)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Motor gear rotates clockwise</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test2>
</test1>
</content6>
<res>
<down ref="RM0000011V300BX_04_0002" fin="false">OK</down>
<right ref="RM0000011V300BX_04_0003" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000011V300BX_04_0002" proc-id="RM0250U___000057L00000">
<testtitle>CHECK WIRE HARNESS (WINDOW REGULATOR MOTOR - WINDOW REGULATOR MASTER SWITCH)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>without Jam protection:</ptxt>
<ptxt>Disconnect the M1 and I4 connectors.</ptxt>
<figure>
<graphic graphicname="B137061E01" width="2.775699831in" height="3.779676365in"/>
</figure>
<test2>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>M1-3 (UP) - I4-2</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>M1-4 (DN) - I4-1</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>M1-3 (UP) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>M1-4 (DN) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test2>
</test1>
<test1>
<ptxt>with Jam protection:</ptxt>
<ptxt>Disconnect the M1 and I5 connectors.</ptxt>
<figure>
<graphic graphicname="B137046E01" width="2.775699831in" height="3.779676365in"/>
</figure>
<test2>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
</test2>
</test1>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>M1-8 (UP) - I5-10</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>M1-5 (DN) - I5-7</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>M1-8 (UP) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>M1-5 (DN) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</content6>
<res>
<down ref="RM0000011V300BX_04_0005" fin="true">OK</down>
<right ref="RM0000011V300BX_04_0004" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000011V300BX_04_0003">
<testtitle>REPLACE POWER WINDOW REGULATOR MOTOR</testtitle>
</testgrp>
<testgrp id="RM0000011V300BX_04_0004">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
<testgrp id="RM0000011V300BX_04_0005">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
