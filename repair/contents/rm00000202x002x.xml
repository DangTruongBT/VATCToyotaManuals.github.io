<s-1 id="RM00000202X002X_01_0001" proc-id="RM0250U___0000CCZ00000">
<ptxt>INSPECT EVAPORATOR TEMPERATURE SENSOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<figure>
<graphic graphicname="E124474E02" width="2.775699831in" height="5.787629434in"/>
</figure>
<spec>
