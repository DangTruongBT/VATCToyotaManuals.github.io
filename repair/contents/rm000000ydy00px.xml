<subpara id="RM000000YDY00PX_03" type-id="51" category="05" proc-id="RM0250U___000072Q00000">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten4>
<list1 type="unordered">
<item>
<ptxt>Perform the simulation method by selecting "check mode" (signal check) with the intelligent tester (See page <xref label="Seep01" href="RM000000XFF00TX"/>).</ptxt>
</item>
<item>
<ptxt>After selecting "check mode" (signal check), perform the simulation method by wiggling each connector of the airbag system or driving the vehicle on a city or rough road (See page <xref label="Seep02" href="RM000000XFF00TX"/>).</ptxt>
</item>
</list1>
</atten4>
</content5>
</subpara>
<subpara id="RM000000YDY00PX_04" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000000YDY00PX_04_0001" proc-id="RM0250U___000072R00000">
<testtitle>CHECK STEERING PAD (DRIVER SIDE SQUIB 2ND STEP)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Turn the ignition switch off.</ptxt>
<figure>
<graphic graphicname="C114814E01" width="2.775699831in" height="4.7836529in"/>
</figure>
</test1>
<test1>
<ptxt>Disconnect the negative (-) terminal cable from the battery, and wait for at least 90 seconds.</ptxt>
</test1>
<test1>
<ptxt>Disconnect the connectors from the steering pad.</ptxt>
</test1>
<test1>
<ptxt>Connect the white wire side of SST (resistance 2.1 Ω) to connector E (black connector).</ptxt>
<atten2>
<ptxt>Never connect the tester to the steering pad (driver side squib 2nd step) for measurement, as this may lead to a serious injury due to airbag deployment.</ptxt>
</atten2>
<atten3>
<list1 type="unordered">
<item>
<ptxt>Do not forcibly insert the SST into the terminals of the connector when connecting.</ptxt>
</item>
<item>
<ptxt>Insert straight the SST into the terminals of the connector.</ptxt>
</item>
</list1>
</atten3>
</test1>
<sst>
<sstitem>
<s-number>09843-18060</s-number>
</sstitem>
</sst>
<test1>
<ptxt>Connect the negative (-) terminal cable to the battery, and wait for at least 2 seconds.</ptxt>
</test1>
<test1>
<ptxt>Turn the ignition switch on (IG), and wait for at least 60 seconds.</ptxt>
</test1>
<test1>
<ptxt>Clear the DTCs stored in the memory (See page <xref label="Seep01" href="RM000000XFE00YX"/>).</ptxt>
</test1>
<test1>
<ptxt>Turn the ignition switch off.</ptxt>
</test1>
<test1>
<ptxt>Turn the ignition switch on (IG), and wait for at least 60 seconds.</ptxt>
</test1>
<test1>
<ptxt>Check the DTCs (See page <xref label="Seep02" href="RM000000XFE00YX"/>).</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>DTC B1810, B1811, B1812, B1813, or 53 is not output.</ptxt>
</specitem>
</spec>
<atten4>
<ptxt>Codes other than DTC B1810, B1811, B1812, B1813, and 53 may be output at this time, but they are not related to this check.</ptxt>
</atten4>
</test1>
</content6>
<res>
<down ref="RM000000YDY00PX_04_0002" fin="false">NG</down>
<right ref="RM000000YDY00PX_04_0008" fin="true">OK</right>
</res>
</testgrp>
<testgrp id="RM000000YDY00PX_04_0002" proc-id="RM0250U___000072S00000">
<testtitle>CHECK CONNECTOR</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Turn the ignition switch off.</ptxt>
</test1>
<test1>
<ptxt>Disconnect the negative (-) terminal cable from the battery, and wait for at least 90 seconds.</ptxt>
</test1>
<test1>
<ptxt>Disconnect the SST from connector E.</ptxt>
</test1>
<test1>
<ptxt>Check that the spiral cable connectors (on the steering pad side) are not damaged.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The lock button is not disengaged, or the claw of the lock is not deformed or damaged.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000YDY00PX_04_0003" fin="false">OK</down>
<right ref="RM000000YDY00PX_04_0009" fin="true">NG</right>
</res>
</testgrp>
