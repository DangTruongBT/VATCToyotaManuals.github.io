<subpara id="RM0000011M3004X_01" type-id="60" category="03" proc-id="RM0250U___00004NG00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>This circuit detects the condition of the headlight dimmer switch assembly.</ptxt>
</content5>
</subpara>
<subpara id="RM0000011M3004X_02" type-id="32" category="03" proc-id="RM0250U___00004NH00000">
