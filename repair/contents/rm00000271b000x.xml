<s-1 id="RM00000271B000X_01_0006" proc-id="RM0250U___0000BMQ00000">
<ptxt>REMOVE FRONT OIL PUMP BODY O-RING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the O-ring from the oil pump body.</ptxt>
<figure>
<graphic graphicname="C138278" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM00000271B000X_01_0004" proc-id="RM0250U___0000BMR00000">
<ptxt>REMOVE FRONT OIL PUMP DRIVE GEAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the front oil pump drive gear from the oil pump body.</ptxt>
<figure>
<graphic graphicname="C138276" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM00000271B000X_01_0005" proc-id="RM0250U___0000BMS00000">
<ptxt>REMOVE FRONT OIL PUMP DRIVEN GEAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the front oil pump driven gear from the oil pump body.</ptxt>
<figure>
<graphic graphicname="C138277" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM00000271B000X_01_0007" proc-id="RM0250U___0000BMT00000">
<ptxt>REMOVE FRONT OIL PUMP OIL SEAL</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Mount the oil pump in a soft jaw vise.</ptxt>
<figure>
<graphic graphicname="C138508E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using SST, remove the oil seal from the oil pump body.</ptxt>
<sst>
<sstitem>
<s-number>09308-00010</s-number>
</sstitem>
</sst>
</s2>
</content1>
</s-1>
