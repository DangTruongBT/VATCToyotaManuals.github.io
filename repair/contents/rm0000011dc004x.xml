<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="35">
<name>SUSPENSION &amp; AXLE</name>
<section id="1002I_S000Z" variety="S000Z">
<name>SUSPENSION</name>
<ttl id="1002I_S000Z_72VB5_T0057" variety="T0057">
<name>FRONT SHOCK ABSORBER</name>
<para id="RM0000011DC004X" category="A" type-id="30014" name-id="SP0ZB-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000011DC004X_01" type-id="01" category="01">
<s-1 id="RM0000011DC004X_01_0001" proc-id="RM0250U___00000FR00000">
<ptxt>INSTALL FRONT SHOCK ABSORBER WITH COIL SPRING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the front shock absorber with coil spring to the front axle assembly and insert the 2 bolts from the front side of the vehicle.</ptxt>
</s2>
<s2>
<ptxt>Slowly jack up the vehicle using a wooden block and install the front shock absorber with coil spring (upper side) to the vehicle.</ptxt>
<figure>
<graphic graphicname="C132410E01" width="2.775699831in" height="4.7836529in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 3 nuts to the upper side of the front shock absorber with coil spring.</ptxt>
<figure>
<graphic graphicname="C132415" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>85</t-value1>
<t-value2>867</t-value2>
<t-value4>63</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Install the 2 nuts to the lower side of the front shock absorber with coil spring.</ptxt>
<figure>
<graphic graphicname="C132414" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>210</t-value1>
<t-value2>2,140</t-value2>
<t-value4>155</t-value4>
</torqueitem>
</torque>
<atten3>
<ptxt>When installing the nuts, keep the bolts from rotating.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Install the front flexible hose and front speed sensor wire harness with the bolt.</ptxt>
<figure>
<graphic graphicname="C132413" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>19</t-value1>
<t-value2>194</t-value2>
<t-value4>14</t-value4>
</torqueitem>
</torque>
<atten3>
<ptxt>Do not twist the front speed sensor wire harness when installing it.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Fully tighten the lock nut.</ptxt>
<figure>
<graphic graphicname="C132412" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>70</t-value1>
<t-value2>714</t-value2>
<t-value4>52</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011DC004X_01_0003" proc-id="RM0250U___00000FS00000">
<ptxt>INSTALL FRONT STABILIZER LINK ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the front stabilizer link assembly with the nut.</ptxt>
<figure>
<graphic graphicname="C132411" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>74</t-value1>
<t-value2>755</t-value2>
<t-value4>55</t-value4>
</torqueitem>
</torque>
<atten4>
<ptxt>If the ball joint turns together with the nut, use a hexagon wrench (6 mm) to hold the stud.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011DC004X_01_0004" proc-id="RM0250U___00000FT00000">
<ptxt>INSTALL FRONT WHEEL</ptxt>
<content1 releasenbr="1">
<torque>
<torqueitem>
<t-value1>103</t-value1>
<t-value2>1,050</t-value2>
<t-value4>76</t-value4>
</torqueitem>
</torque>
</content1>
</s-1>
<s-1 id="RM0000011DC004X_01_0005" proc-id="RM0250U___00000FU00000">
<ptxt>INSPECT AND ADJUST FRONT WHEEL ALIGNMENT</ptxt>
<content1 releasenbr="1">
<ptxt>(See page <xref label="Seep01" href="RM0000011DA004X"/>)</ptxt>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
