<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10007_S0005" variety="S0005">
<name>2AZ-FE FUEL</name>
<ttl id="10007_S0005_731H3_T00FM" variety="T00FM">
<name>FUEL PRESSURE PULSATION DAMPER</name>
<para id="RM0000017RR005X" category="A" type-id="80001" name-id="FU0V7-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000017RR005X_01" type-id="01" category="01">
<s-1 id="RM0000017RR005X_01_0011" proc-id="RM0250U___0000BBO00000">
<ptxt>DISCHARGE FUEL SYSTEM PRESSURE</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>See page <xref label="Seep01" href="RM000000YCO003X"/>.</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000017RR005X_01_0012">
<ptxt>DISCONNECT CABLE FROM NEGATIVE BATTERY TERMINAL</ptxt>
</s-1>
<s-1 id="RM0000017RR005X_01_0009" proc-id="RM0250U___0000A7T00000">
<ptxt>REMOVE NO. 1 ENGINE COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 nuts and cover.</ptxt>
<figure>
<graphic graphicname="A134904" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000017RR005X_01_0013" proc-id="RM0250U___0000B9500000">
<ptxt>REMOVE AIR CLEANER CAP SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the mass air flow meter connector (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A135666E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the purge VSV connector (<sup>*</sup>2).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the 2 purge VSV vacuum hoses (<sup>*</sup>3).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the purge line hose from the clamp (<sup>*</sup>4).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the No. 2 ventilation hose from the air cleaner hose.</ptxt>
<figure>
<graphic graphicname="A135667E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Lock the No. 1 air cleaner hose clamp, and then disconnect the No. 1 air cleaner hose from the throttle body.</ptxt>
<figure>
<graphic graphicname="A135668" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts and air cleaner cap.</ptxt>
<figure>
<graphic graphicname="A135669" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the air cleaner filter element from the air cleaner case.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000017RR005X_01_0007" proc-id="RM0250U___0000AZY00000">
<ptxt>DISCONNECT FUEL TUBE SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Disconnect the metallic type connector (See page <xref label="Seep01" href="RM000000YCO003X"/>).</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000017RR005X_01_0005" proc-id="RM0250U___0000AUH00000">
<ptxt>REMOVE FUEL PRESSURE PULSATION DAMPER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts and fuel pressure pulsation damper.</ptxt>
<figure>
<graphic graphicname="A125338" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>