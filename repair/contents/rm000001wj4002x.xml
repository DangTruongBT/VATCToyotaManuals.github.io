<name>HAZARD WARNING SWITCH</name>
<para id="RM000001WJ4002X" category="A" type-id="80001" name-id="LI1S6-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM000001WJ4002X_02" type-id="01" category="01">
<s-1 id="RM000001WJ4002X_02_0045" proc-id="RM0250U___00006AB00000">
<ptxt>REMOVE INSTRUMENT PANEL NO. 2 REGISTER ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply protective tape to the areas shown in the illustration.</ptxt>
<figure>
<graphic graphicname="B133998E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using a moulding remover, disengage the 3 clips.</ptxt>
<figure>
<graphic graphicname="B133999" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Using a moulding remover, disengage the 4 clips.</ptxt>
<figure>
<graphic graphicname="B134000" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the connector and remove the instrument panel No. 2 register assembly.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001WJ4002X_02_0044" proc-id="RM0250U___00003WJ00000">
<ptxt>REMOVE HAZARD WARNING SIGNAL SWITCH ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 4 claws and remove the hazard warning signal switch assembly.</ptxt>
<figure>
<graphic graphicname="E128236" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
