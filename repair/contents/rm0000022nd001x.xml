<subpara id="RM0000022ND001X_01" type-id="01" category="01">
<s-1 id="RM0000022ND001X_01_0001" proc-id="RM0250U___000092200000">
<ptxt>INSTALL CRANKSHAFT POSITION SENSOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply a light coat of engine oil to the O-ring of the crankshaft position sensor.</ptxt>
</s2>
<s2>
<ptxt>Install the crankshaft position sensor with the bolt.</ptxt>
<figure>
<graphic graphicname="A106634E02" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>10</t-value1>
<t-value2>102</t-value2>
<t-value4>7</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the crankshaft position sensor connector.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022ND001X_01_0007" proc-id="RM0250U___0000BR500000">
