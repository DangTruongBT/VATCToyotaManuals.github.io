<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="36">
<name>BRAKE</name>
<section id="1002J_S0010" variety="S0010">
<name>BRAKE CONTROL</name>
<ttl id="1002J_S0010_72Z6O_T00AN" variety="T00AN">
<name>VEHICLE STABILITY CONTROL SYSTEM (for ADVICS Made)</name>
<para id="RM000000YHG00BX" category="J" type-id="3025M" name-id="BC1MW-01" from="200601">
<dtccode/>
<dtcname>Brake Warning Light Remains ON</dtcname>
<subpara id="RM000000YHG00BX_01" type-id="60" category="03" proc-id="RM0250U___00005PW00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>The skid control ECU is connected to the combination meter via CAN communication.</ptxt>
<ptxt>If any of the following is detected, the BRAKE warning light remains on:</ptxt>
<list1 type="unordered">
<item>
<ptxt>The skid control ECU connector is disconnected from the skid control ECU.</ptxt>
</item>
<item>
<ptxt>The brake fluid level is insufficient.</ptxt>
</item>
<item>
<ptxt>The parking brake is applied.</ptxt>
</item>
<item>
<ptxt>EBD operation is not possible.</ptxt>
</item>
</list1>
</content5>
</subpara>
<subpara id="RM000000YHG00BX_02" type-id="32" category="03" proc-id="RM0250U___00005PX00000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="C135799E03" width="7.106578999in" height="8.799559038in"/>
</figure>
</content5>
</subpara>
<subpara id="RM000000YHG00BX_03" type-id="51" category="05" proc-id="RM0250U___00005PY00000">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten3>
<ptxt>When replacing the brake actuator assembly, perform zero point calibration (See page <xref label="Seep01" href="RM000000XHR009X"/>).</ptxt>
</atten3>
</content5>
</subpara>
<subpara id="RM000000YHG00BX_04" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000000YHG00BX_04_0002" proc-id="RM0250U___00005PZ00000">
<testtitle>CHECK CAN COMMUNICATION SYSTEM</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check if the CAN communication system DTC is output (See page <xref label="Seep01" href="RM000000WIB00RX"/>).</ptxt>
<spec>
<title>Result</title>
<table pgwide="1">
<tgroup cols="2">
<colspec colname="COL1" colwidth="4.54in"/>
<colspec colname="COL2" colwidth="2.54in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>DTC is not output</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>DTC is output</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000YHG00BX_04_0004" fin="false">A</down>
<right ref="RM000000YHG00BX_04_0015" fin="true">B</right>
</res>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0004" proc-id="RM0250U___00005Q100000">
<testtitle>CHECK IF SKID CONTROL ECU CONNECTOR IS SECURELY CONNECTED</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check if the skid control ECU connector is securely connected.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The connector should be securely connected.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000YHG00BX_04_0005" fin="false">OK</down>
<right ref="RM000000YHG00BX_04_0017" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0005" proc-id="RM0250U___00005Q200000">
<testtitle>CHECK BATTERY</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check the battery voltage.</ptxt>
<spec>
<title>Standard voltage</title>
<specitem>
<ptxt>11 to 14 V</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000YHG00BX_04_0006" fin="false">OK</down>
<right ref="RM000000YHG00BX_04_0018" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0006" proc-id="RM0250U___00005Q300000">
<testtitle>INSPECT SKID CONTROL ECU (IG1 TERMINAL)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the skid control ECU connector.</ptxt>
<figure>
<graphic graphicname="F049362E98" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>Turn the ignition switch on (IG).</ptxt>
</test1>
<test1>
<ptxt>Measure the voltage according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.86in"/>
<colspec colname="COL2" colwidth="1.24in"/>
<colspec colname="COL3" colwidth="1.03in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>A26-46 (IG1) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Ignition switch on (IG)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 to 14 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000YHG00BX_04_0007" fin="false">OK</down>
<right ref="RM000000YHG00BX_04_0019" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0007" proc-id="RM0250U___00005Q400000">
<testtitle>INSPECT SKID CONTROL ECU (GND TERMINAL)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Turn the ignition switch off.</ptxt>
<figure>
<graphic graphicname="F049362E97" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.86in"/>
<colspec colname="COLSPEC0" colwidth="1.03in"/>
<colspec colname="COL2" colwidth="1.24in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>A26-32 (GND1) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>A26-1 (GND2) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000YHG00BX_04_0008" fin="false">OK</down>
<right ref="RM000000YHG00BX_04_0020" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0008" proc-id="RM0250U___00005Q500000">
<testtitle>INSPECT PARKING BRAKE SWITCH</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the parking brake switch connector.</ptxt>
<figure>
<graphic graphicname="C109430E02" width="2.775699831in" height="3.779676365in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>1 - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Parking brake switch ON</ptxt>
<ptxt>(Switch pin free)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>1 - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Parking brake switch OFF</ptxt>
<ptxt>(Switch pin pushed in)</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000YHG00BX_04_0009" fin="false">OK</down>
<right ref="RM000000YHG00BX_04_0021" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0009" proc-id="RM0250U___00005Q600000">
<testtitle>CHECK HARNESS AND CONNECTOR (MAIN BODY ECU - PARKING BRAKE SWITCH)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the main body ECU connector.</ptxt>
<figure>
<graphic graphicname="C136418E01" width="2.775699831in" height="5.787629434in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<subtitle>A/T</subtitle>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.86in"/>
<colspec colname="COLSPEC1" colwidth="1.03in"/>
<colspec colname="COL2" colwidth="1.24in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>IC-14 (PKB) - A18-1</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>IC-14 (PKB) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
<subtitle>M/T</subtitle>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.86in"/>
<colspec colname="COLSPEC1" colwidth="1.03in"/>
<colspec colname="COL2" colwidth="1.24in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>IM-2 (PKB) - E33-1</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>IM-2 (PKB) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000YHG00BX_04_0010" fin="false">OK</down>
<right ref="RM000000YHG00BX_04_0022" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0010" proc-id="RM0250U___00005Q700000">
<testtitle>INSPECT BRAKE FLUID LEVEL WARNING SWITCH</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Remove the reservoir tank cap and strainer.</ptxt>
<figure>
<graphic graphicname="C140953E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</test1>
<test1>
<ptxt>Disconnect the brake fluid level warning switch connector.</ptxt>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<atten4>
<ptxt>A float is located inside the reservoir. Its position can be changed by increasing or decreasing the level of brake fluid.</ptxt>
</atten4>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>1 - 2</ptxt>
</entry>
<entry valign="middle">
<ptxt>Float up (Switch OFF)</ptxt>
</entry>
<entry valign="middle">
<ptxt>1.9 to 2.1 kΩ</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>1 - 2</ptxt>
</entry>
<entry valign="middle">
<ptxt>Float down (Switch ON)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<atten4>
<ptxt>If there is no problem after finishing the above check, adjust the brake fluid level to the MAX level.</ptxt>
</atten4>
</test1>
</content6>
<res>
<down ref="RM000000YHG00BX_04_0011" fin="false">OK</down>
<right ref="RM000000YHG00BX_04_0023" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0011" proc-id="RM0250U___00005Q800000">
<testtitle>CHECK HARNESS AND CONNECTOR (COMBINATION METER - BRAKE FLUID LEVEL WARNING SWITCH)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the combination meter connector.</ptxt>
<figure>
<graphic graphicname="C136033E01" width="2.775699831in" height="4.7836529in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.86in"/>
<colspec colname="COLSPEC0" colwidth="1.03in"/>
<colspec colname="COL2" colwidth="1.24in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>F2-6 (B/LE) - A16-1</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>F2-6 (B/LE) - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>A16-2 - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000YHG00BX_04_0012" fin="false">OK</down>
<right ref="RM000000YHG00BX_04_0024" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0012" proc-id="RM0250U___00005Q900000">
<testtitle>INSPECT COMBINATION METER ASSEMBLY</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Perform Active Test of the combination meter (meter CPU) using the intelligent tester (See page <xref label="Seep01" href="RM0000012G700DX"/>).</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The BRAKE warning light turns on or off in accordance with the intelligent tester.</ptxt>
</specitem>
</spec>
<atten4>
<list1 type="unordered">
<item>
<ptxt>Reinstall the connectors and restore the vehicle to its prior condition before checking the combination meter.</ptxt>
</item>
<item>
<ptxt>If troubleshooting has been carried out according to the Problem Symptoms Table, refer back to the table and proceed to the next step before replacing the part (See page <xref label="Seep02" href="RM000000XHN009X"/>).</ptxt>
</item>
</list1>
</atten4>
</test1>
</content6>
<res>
<down ref="RM000000YHG00BX_04_0013" fin="true">OK</down>
<right ref="RM000000YHG00BX_04_0025" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0013">
<testtitle>REPLACE BRAKE ACTUATOR ASSEMBLY</testtitle>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0015">
<testtitle>INSPECT CAN COMMUNICATION SYSTEM</testtitle>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0017">
<testtitle>CONNECT CONNECTOR TO ECU CORRECTLY</testtitle>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0018">
<testtitle>CHECK AND REPLACE CHARGING SYSTEM OR BATTERY</testtitle>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0019">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR (IG1 CIRCUIT)</testtitle>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0020">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR (GND CIRCUIT)</testtitle>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0021">
<testtitle>REPLACE PARKING BRAKE SWITCH</testtitle>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0022">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0023">
<testtitle>REPLACE BRAKE MASTER CYLINDER RESERVOIR SUB-ASSEMBLY (BRAKE FLUID LEVEL WARNING SWITCH)</testtitle>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0024">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
<testgrp id="RM000000YHG00BX_04_0025">
<testtitle>REPLACE COMBINATION METER ASSEMBLY</testtitle>
</testgrp>
</subpara>
</para>
