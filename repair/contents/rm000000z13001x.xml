<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1000S_S000R" variety="S000R">
<name>CLUTCH</name>
<ttl id="1000S_S000R_73062_T00DX" variety="T00DX">
<name>CLUTCH RELEASE CYLINDER</name>
<para id="RM000000Z13001X" category="A" type-id="8000E" name-id="CL0FH-01" from="200601">
<name>REASSEMBLY</name>
<subpara id="RM000000Z13001X_01" type-id="01" category="01">
<s-1 id="RM000000Z13001X_01_0001" proc-id="RM0250U___00008YO00000">
<ptxt>INSTALL RELEASE CYLINDER BLEEDER PLUG</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the bleeder plug to the cylinder body.</ptxt>
<torque>
<torqueitem>
<t-value1>8.3</t-value1>
<t-value2>85</t-value2>
<t-value3>73</t-value3>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z13001X_01_0002" proc-id="RM0250U___00008YP00000">
<ptxt>INSTALL CLUTCH RELEASE CYLINDER KIT</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the bleeder plug cap to the bleeder plug.</ptxt>
</s2>
<s2>
<ptxt>Install a new spring to the cylinder body.</ptxt>
</s2>
<s2>
<ptxt>Coat the piston with lithium soap base glycol grease as shown in the illustration.</ptxt>
<figure>
<graphic graphicname="C128485" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the piston to the cylinder body.</ptxt>
<atten3>
<ptxt>Be careful not to damage the inside of the cylinder body.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Install the push rod to the cylinder body.</ptxt>
</s2>
<s2>
<ptxt>Install the boot to the cylinder body.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>