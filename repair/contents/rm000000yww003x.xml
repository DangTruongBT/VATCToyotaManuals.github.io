<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000S" variety="S000S">
<name>U250E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000S_736RH_T00GL" variety="T00GL">
<name>SHIFT SOLENOID VALVE</name>
<para id="RM000000YWW003X" category="A" type-id="30014" name-id="AX0Y7-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000000YWW003X_01" type-id="01" category="01">
<s-1 id="RM000000YWW003X_01_0014" proc-id="RM0250U___00001WD00000">
<ptxt>INSTALL TRANSMISSION VALVE BODY ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the spring and check ball body.</ptxt>
<figure>
<graphic graphicname="C050017" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Align the groove of the manual valve with the pin of the lever.</ptxt>
<figure>
<graphic graphicname="C091933E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the valve body with the 17 bolts.</ptxt>
<torque>
<torqueitem>
<t-value1>11</t-value1>
<t-value2>110</t-value2>
<t-value4>8</t-value4>
</torqueitem>
</torque>
<atten3>
<list1 type="unordered">
<item>
<ptxt>Push the valve body against the accumulator piston spring and the check ball body to install it.</ptxt>
</item>
<item>
<ptxt>First, temporarily tighten the bolts marked by (1) in the illustration because they are positioning bolts.</ptxt>
</item>
</list1>
</atten3>
<spec>
<title>Bolt length</title>
<specitem>
<ptxt>Bolt A: 25 mm (0.984 in.)</ptxt>
<ptxt>Bolt B: 57 mm (2.244 in.)</ptxt>
<ptxt>Bolt C: 41 mm (1.614 in.)</ptxt>
</specitem>
</spec>
</s2>
</content1></s-1>
<s-1 id="RM000000YWW003X_01_0015" proc-id="RM0250U___00001WE00000">
<ptxt>INSTALL VALVE BODY OIL STRAINER ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Coat a new O-ring with ATF WS.</ptxt>
<figure>
<graphic graphicname="C135716" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the O-ring to the oil strainer.</ptxt>
</s2>
<s2>
<ptxt>Install the oil strainer with the 3 bolts.</ptxt>
<figure>
<graphic graphicname="C135715" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>11</t-value1>
<t-value2>110</t-value2>
<t-value4>8</t-value4>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM000000YWW003X_01_0016" proc-id="RM0250U___00001WF00000">
<ptxt>INSTALL TRANSMISSION WIRE
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Coat the O-ring with ATF WS.</ptxt>
<figure>
<graphic graphicname="C135717" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the ATF temperature sensor with the lock plate and bolt.</ptxt>
<torque>
<torqueitem>
<t-value1>6.6</t-value1>
<t-value2>67</t-value2>
<t-value3>58</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the 7 shift solenoid valve connectors.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000YWW003X_01_0017" proc-id="RM0250U___00001WG00000">
<ptxt>INSTALL AUTOMATIC TRANSAXLE OIL PAN SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the 2 magnets in the oil pan.</ptxt>
<figure>
<graphic graphicname="D030865E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Apply adhesive or equivalent to new 18 bolts.</ptxt>
<spec>
<title>Adhesive</title>
<specitem>
<ptxt>Toyota Genuine Adhesive 1344, Three Bond 1344 or equivalent</ptxt>
</specitem>
</spec>
</s2>
<s2>
<ptxt>Using a new gasket, install the oil pan to the transaxle case with the 18 bolts.</ptxt>
<figure>
<graphic graphicname="C091925" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>7.8</t-value1>
<t-value2>80</t-value2>
<t-value3>69</t-value3>
</torqueitem>
</torque>
<atten3>
<ptxt>Since the bolts should be seal bolts, apply adhesive to the bolts and tighten them within 10 minutes of application.</ptxt>
</atten3>
</s2>
</content1></s-1>
<s-1 id="RM000000YWW003X_01_0018" proc-id="RM0250U___0000BD300000">
<ptxt>CONNECT CABLE TO NEGATIVE BATTERY TERMINAL
</ptxt>
<content1 releasenbr="1">
<torque>
<torqueitem>
<t-value1>6.9</t-value1>
<t-value2>70</t-value2>
<t-value3>61</t-value3>
</torqueitem>
</torque>
</content1></s-1>
<s-1 id="RM000000YWW003X_01_0012" proc-id="RM0250U___0000A8500001">
<ptxt>INSTALL AUTOMATIC TRANSAXLE ASSEMBLY</ptxt>
<content1 releasenbr="2">
<ptxt>(See page <xref label="Seep01" href="RM000000YWS00EX"/>)</ptxt>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>