<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="38">
<name>HEATER &amp; AIR CONDITIONING SYSTEM</name>
<section id="1002K_S0015" variety="S0015">
<name>AIR CONDITIONING</name>
<ttl id="1002K_S0015_72YHS_T00A1" variety="T00A1">
<name>AIR CONDITIONING AMPLIFIER</name>
<para id="RM0000026PS000X" category="A" type-id="30014" name-id="AC1ZH-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000026PS000X_01" type-id="01" category="01">
<s-1 id="RM0000026PS000X_01_0001" proc-id="RM0250U___00005JJ00000">
<ptxt>INSTALL AIR CONDITIONING AMPLIFIER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air conditioning amplifier assembly with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="E128518E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the connectors.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026PS000X_01_0006" proc-id="RM0250U___00007X800000">
<ptxt>INSTALL LOWER INSTRUMENT PANEL SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Connect the connector.</ptxt>
</s2>
<s2>
<ptxt>Engage the 3 claws and 3 clips.</ptxt>
<figure>
<graphic graphicname="B133992E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 4 screws &lt;B&gt;.</ptxt>
</s2>
<s2>
<ptxt>Install the lower instrument panel sub-assembly with the bolt &lt;A&gt;.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000026PS000X_01_0007" proc-id="RM0250U___00007XA00000">
<ptxt>INSTALL INSTRUMENT PANEL NO. 2 UNDER COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 4 claws and 2 guides and install the instrument panel No. 2 under cover.</ptxt>
<figure>
<graphic graphicname="B133989E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000026PS000X_01_0008" proc-id="RM0250U___00006N000000">
<ptxt>INSTALL COWL SIDE TRIM SUB-ASSEMBLY RH
</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedure for the RH side and the LH side.</ptxt>
</atten4>
</content1></s-1>
<s-1 id="RM0000026PS000X_01_0009" proc-id="RM0250U___00006N100000">
<ptxt>INSTALL FRONT DOOR SCUFF PLATE RH
</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedure for the RH side and the LH side.</ptxt>
</atten4>
</content1></s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
