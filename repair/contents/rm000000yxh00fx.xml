<ttl id="1002B_S000S_72VQE_T005L" variety="T005L">
<name>UNDERDRIVE PLANETARY GEAR</name>
<para id="RM000000YXH00FX" category="G" type-id="3001K" name-id="AX04F-06" from="200601">
<name>INSPECTION</name>
<subpara id="RM000000YXH00FX_01" type-id="01" category="01">
<s-1 id="RM000000YXH00FX_01_0001" proc-id="RM0250U___00000TC00000">
<ptxt>INSPECT UNDERDRIVE PLANETARY GEAR PRELOAD</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST, fix the underdrive planetary gear assembly.</ptxt>
<figure>
<graphic graphicname="C134894E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09387-00050</s-number>
</sstitem>
<sstitem>
<s-number>09495-65040</s-number>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Using SST and a torque wrench, measure the turning torque of the underdrive planetary gear assembly while turning the torque wrench at 60 rpm.</ptxt>
<figure>
<graphic graphicname="C134895E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09387-00050</s-number>
</sstitem>
<sstitem>
<s-number>09495-65040</s-number>
</sstitem>
</sst>
<spec>
<title>Turning torque at 60 rpm</title>
<specitem>
<ptxt>0.28 to 0.89 N*m (2.9 to 9.1 kgf*cm, 2.478 to 7.877 in.*lbf)</ptxt>
</specitem>
</spec>
<atten4>
<ptxt>Use a torque wrench with a fulcrum length of 160 mm (6.3 in.).</ptxt>
</atten4>
</s2>
</content1>
</s-1>
</subpara>
</para>
