<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="35">
<name>SUSPENSION &amp; AXLE</name>
<section id="1002I_S000Z" variety="S000Z">
<name>SUSPENSION</name>
<ttl id="1002I_S000Z_72VBF_T005H" variety="T005H">
<name>REAR STABILIZER BAR</name>
<para id="RM0000011E9005X" category="A" type-id="30014" name-id="SP0ZW-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000011E9005X_01" type-id="01" category="01">
<s-1 id="RM0000011E9005X_01_0006" proc-id="RM0250U___00000J500000">
<ptxt>INSTALL REAR STABILIZER BUSHING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the 2 rear stabilizer bushings to the outside of the stopper ring on the stabilizer bar.</ptxt>
<figure>
<graphic graphicname="C132495E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011E9005X_01_0002" proc-id="RM0250U___00000J600000">
<ptxt>INSTALL REAR STABILIZER BAR NO. 2 BRACKET</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the rear stabilizer bar No. 2 bracket.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011E9005X_01_0012" proc-id="RM0250U___0000BE300000">
<ptxt>INSTALL REAR STABILIZER BAR NO. 1 BRACKET</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the rear stabilizer bar No. 1 bracket.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011E9005X_01_0001" proc-id="RM0250U___00000J400000">
<ptxt>INSTALL REAR STABILIZER BAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the rear stabilizer bar with the 2 bolts. (LH Side)</ptxt>
<figure>
<graphic graphicname="C132494E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>31</t-value1>
<t-value2>316</t-value2>
<t-value4>23</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Install the rear stabilizer bar with the 2 bolts. (RH Side)</ptxt>
<figure>
<graphic graphicname="C138944E02" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>31</t-value1>
<t-value2>316</t-value2>
<t-value4>23</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011E9005X_01_0003" proc-id="RM0250U___00000J700000">
<ptxt>INSTALL REAR STABILIZER LINK ASSEMBLY LH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the rear stabilizer link assembly LH with the 2 nuts.</ptxt>
<figure>
<graphic graphicname="C132493" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>39</t-value1>
<t-value2>398</t-value2>
<t-value4>29</t-value4>
</torqueitem>
</torque>
<atten4>
<ptxt>If the ball joint turns together with the nut, use a hexagon wrench (5 mm) to hold the stud.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011E9005X_01_0004" proc-id="RM0250U___00000J800000">
<ptxt>INSTALL REAR STABILIZER LINK ASSEMBLY RH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the rear stabilizer link assembly RH with the 2 nuts.</ptxt>
<figure>
<graphic graphicname="C138761" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>39</t-value1>
<t-value2>398</t-value2>
<t-value4>29</t-value4>
</torqueitem>
</torque>
<atten4>
<ptxt>If the ball joint turns together with the nut, use a hexagon wrench (5 mm) to hold the stud.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011E9005X_01_0014" proc-id="RM0250U___0000AWV00000">
<ptxt>INSTALL CENTER EXHAUST PIPE ASSEMBLY (for 2AZ-FE)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install a new gasket onto the front exhaust pipe.</ptxt>
</s2>
<s2>
<ptxt>Install the center exhaust pipe assembly with the 2 bolts and 2 nuts.</ptxt>
<figure>
<graphic graphicname="A135690E01" width="7.106578999in" height="3.779676365in"/>
</figure>
<torque>
<torqueitem>
<t-value1>43</t-value1>
<t-value2>438</t-value2>
<t-value4>32</t-value4>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM0000011E9005X_01_0015" proc-id="RM0250U___000094X00000">
<ptxt>INSTALL CENTER EXHAUST PIPE ASSEMBLY (for 2GR-FE)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install a new gasket to the exhaust center pipe assembly.</ptxt>
</s2>
<s2>
<ptxt>Install the exhaust center pipe to the exhaust front pipe with the 2 nuts and 2 bolts.</ptxt>
<figure>
<graphic graphicname="A135719" width="7.106578999in" height="3.779676365in"/>
</figure>
<torque>
<torqueitem>
<t-value1>56</t-value1>
<t-value2>571</t-value2>
<t-value4>41</t-value4>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM0000011E9005X_01_0016" proc-id="RM0250U___000094W00000">
<ptxt>INSTALL TAIL EXHAUST PIPE ASSEMBLY (for 2GR-FE)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install 2 new gaskets to the exhaust tail pipes.</ptxt>
</s2>
<s2>
<ptxt>Install the 2 exhaust tail pipes with the 4 nuts.</ptxt>
<figure>
<graphic graphicname="A135718" width="7.106578999in" height="3.779676365in"/>
</figure>
<torque>
<torqueitem>
<t-value1>43</t-value1>
<t-value2>438</t-value2>
<t-value4>32</t-value4>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM0000011E9005X_01_0005" proc-id="RM0250U___00000JZ00000">
<ptxt>INSTALL REAR WHEELS</ptxt>
<content1 releasenbr="1">
<torque>
<torqueitem>
<t-value1>103</t-value1>
<t-value2>1,050</t-value2>
<t-value4>76</t-value4>
</torqueitem>
</torque>
</content1>
</s-1>
<s-1 id="RM0000011E9005X_01_0013" proc-id="RM0250U___0000AWY00000">
<ptxt>INSPECT EXHAUST GAS LEAK
</ptxt>
<content1 releasenbr="1">
<ptxt>If gas is leaking, tighten the areas necessary to stop the leak. Replace the damaged parts as necessary.</ptxt>
</content1></s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>