</spec>
</test1>
</content6>
<res>
<down ref="RM000000XI9009X_04_0004" fin="false">OK</down>
<right ref="RM000000XI9009X_04_0005" fin="false">NG</right>
</res>
</testgrp>
<testgrp id="RM000000XI9009X_04_0004" proc-id="RM0250U___00005LR00000">
<testtitle>RECONFIRM DTC</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Turn the ignition switch off.</ptxt>
</test1>
<test1>
<ptxt>Clear the DTC (See page <xref label="Seep01" href="RM000000XHV009X"/>).</ptxt>
</test1>
<test1>
<ptxt>Start the engine.</ptxt>
</test1>
<test1>
<ptxt>Drive the vehicle at the speed of 20 mph (32 km/h) or more for at least 60 seconds.</ptxt>
</test1>
<test1>
<ptxt>Check if the same DTC is recorded (See page <xref label="Seep02" href="RM000000XHV009X"/>).</ptxt>
<spec>
<title>Result</title>
<table pgwide="1">
<tgroup cols="2">
<colspec colname="COL1" colwidth="4.54in"/>
<colspec colname="COL2" colwidth="2.54in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>DTCs (C0200/31 and/or C0205/32) are not output</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>DTCs (C0200/31 and/or C0205/32) are output</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<atten4>
<ptxt>If troubleshooting has been carried out according to the Problem Symptoms Table, refer back to the table and proceed to the next step (See page <xref label="Seep03" href="RM000000XHN009X"/>).</ptxt>
</atten4>
</test1>
</content6>
<res>
<down ref="RM000000XI9009X_04_0023" fin="true">A</down>
<right ref="RM000000XI9009X_04_0025" fin="false">B</right>
</res>
</testgrp>
<testgrp id="RM000000XI9009X_04_0005" proc-id="RM0250U___00005LS00000">
<testtitle>CHECK FRONT SPEED SENSOR INSTALLATION</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Turn the ignition switch off.</ptxt>
<figure>
<graphic graphicname="BR03795E52" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>Check the speed sensor installation.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>There is no clearance between the sensor and the front steering knuckle.</ptxt>
</specitem>
<specitem>
<ptxt>The installation bolt is tightened properly.</ptxt>
</specitem>
<subtitle>Torque</subtitle>
<specitem>
<ptxt>8.0 N*m (82 kgf*cm, 71 in.*lbf)</ptxt>
</specitem>
</spec>
</test1>
</content6>
