</test1>
<test1>
<ptxt>Read the value displayed on the tester.</ptxt>
<spec>
<title>Standard</title>
<specitem>
<ptxt>Between 80°C and 97°C (176°F and 207°F) with warm engine.</ptxt>
</specitem>
</spec>
<spec>
<title>Result</title>
<table pgwide="1">
<tgroup cols="2" align="center">
