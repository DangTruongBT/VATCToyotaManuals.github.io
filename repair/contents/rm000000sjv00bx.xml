<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="40">
<name>SECURITIES</name>
<section id="1002O_S0019" variety="S0019">
<name>ENGINE IMMOBILISER</name>
<ttl id="1002O_S0019_7301M_T00D1" variety="T00D1">
<name>ENGINE IMMOBILISER SYSTEM (w/ Smart Key System)</name>
<para id="RM000000SJV00BX" category="C" type-id="3018W" name-id="EI0EF-01" from="200601">
<dtccode>B2799</dtccode>
<dtcname>Engine Immobiliser System Malfunction</dtcname>
<subpara id="RM000000SJV00BX_01" type-id="60" category="03" proc-id="RM0250U___00008ED00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>This DTC is output when one of the following occurs: 1) the ECM detects errors in its own communications with the ID code box; 2) the ECM detects errors in the communication lines; or 3) the ECU communication ID between the ID code box and ECM is different and an engine start is attempted. Before troubleshooting for this DTC, make sure no certification ECU DTCs are present. If present, troubleshoot the certification ECU DTCs first.</ptxt>
<table pgwide="1">
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.42in"/>
<colspec colname="COL2" colwidth="2.83in"/>
<colspec colname="COL3" colwidth="2.83in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>DTC No.</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>DTC Detection Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Trouble Area</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>B2799</ptxt>
</entry>
<entry valign="middle">
<ptxt>One of following conditions is met:</ptxt>
<list1 type="unordered">
<item>
<ptxt>Error in communication between ECM and ID code box</ptxt>
</item>
<item>
<ptxt>Error in communication lines</ptxt>
</item>
<item>
<ptxt>Communication ID is different with ID code box during communication </ptxt>
</item>
</list1>
</entry>
<entry valign="middle">
<list1 type="unordered">
<item>
<ptxt>Wire harness</ptxt>
</item>
<item>
<ptxt>ECM</ptxt>
</item>
<item>
<ptxt>ID code box</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</content5>
</subpara>
<subpara id="RM000000SJV00BX_02" type-id="32" category="03" proc-id="RM0250U___00008EE00000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="B128336E03" width="7.106578999in" height="3.779676365in"/>
</figure>
</content5>
</subpara>
<subpara id="RM000000SJV00BX_03" type-id="51" category="05" proc-id="RM0250U___00009VN00000">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten3>
<list1 type="unordered">
<item>
<ptxt>If the ID code box is replaced, register the key and ECU communication ID (See page <xref label="Seep01" href="RM000000QYF004X"/>).</ptxt>
</item>
</list1>
<list1 type="unordered">
<item>
<ptxt>If the ECM is replaced, register the ECU communication ID (See page <xref label="Seep02" href="RM000000QYF004X"/>).</ptxt>
</item>
</list1>
</atten3>
</content5>
</subpara>
<subpara id="RM000000SJV00BX_04" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000000SJV00BX_04_0001" proc-id="RM0250U___00008EF00000">
<testtitle>CHECK DTC OUTPUT</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Delete the DTCs (See page <xref label="Seep01" href="RM000000QYC00BX"/>).</ptxt>
</test1>
<test1>
<ptxt>Recheck for DTCs (See page <xref label="Seep02" href="RM000000QYC00BX"/>).</ptxt>
<spec>
<title>Result</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Result</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>B2799 output reoccurs</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry>
<ptxt>B2799 output does not reoccur</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000SJV00BX_04_0010" fin="false">A</down>
<right ref="RM000000SJV00BX_04_0005" fin="true">B</right>
</res>
</testgrp>
<testgrp id="RM000000SJV00BX_04_0010" proc-id="RM0250U___00008EI00000">
<testtitle>RE-REGISTER ECU COMMUNICATION ID</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Re-register the ECU communication ID (See page <xref label="Seep01" href="RM000000QYF004X"/>) between the ID code box and ECM.</ptxt>
</test1>
<test1>
<ptxt>Check that the engine starts.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Engine starts.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000SJV00BX_04_0002" fin="false">NG</down>
<right ref="RM000000SJV00BX_04_0005" fin="true">OK</right>
</res>
</testgrp>
<testgrp id="RM000000SJV00BX_04_0002" proc-id="RM0250U___00008EG00000">
<testtitle>CHECK HARNESS AND CONNECTOR (ID CODE BOX - ECM)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the E50 ID code box and A55 ECM connectors.</ptxt>
<figure>
<graphic graphicname="B128354E01" width="2.775699831in" height="4.7836529in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>E50-5 (EFII) - A55-10 (IMO)</ptxt>
</entry>
<entry morerows="1" valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>E50-6 (EFIO) - A55-11 (IMI)</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>E50-5 (EFII) - Body ground</ptxt>
</entry>
<entry morerows="1" valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>E50-6 (EFIO) - Body ground</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000SJV00BX_04_0004" fin="false">OK</down>
<right ref="RM000000SJV00BX_04_0006" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000SJV00BX_04_0004" proc-id="RM0250U___00008I200000">
<testtitle>CHECK ECM</testtitle>
<content6 releasenbr="2">
<test1>
<ptxt>After replacing the ECM (See page <xref label="Seep01" href="RM0000022NT001X"/>) with a normal one, check for DTCs (See page <xref label="Seep02" href="RM000000QYF004X"/>).</ptxt>
<spec>
<title>Result</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Result</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>B2799 output reoccurs</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry>
<ptxt>B2799 output does not reoccur</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000SJV00BX_04_0005" fin="true">B</down>
<right ref="RM000000SJV00BX_04_0007" fin="true">A</right>
</res>
</testgrp>
<testgrp id="RM000000SJV00BX_04_0005">
<testtitle>END</testtitle>
</testgrp>
<testgrp id="RM000000SJV00BX_04_0007">
<testtitle>REPLACE ID CODE BOX</testtitle>
</testgrp>
<testgrp id="RM000000SJV00BX_04_0006">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>