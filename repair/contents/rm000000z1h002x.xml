<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002C_S000U" variety="S000U">
<name>E351 MANUAL TRANSAXLE</name>
<ttl id="1002C_S000U_7306A_T00E5" variety="T00E5">
<name>DIFFERENTIAL OIL SEAL</name>
<para id="RM000000Z1H002X" category="A" type-id="30014" name-id="MX0FP-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000000Z1H002X_01" type-id="01" category="01">
<s-1 id="RM000000Z1H002X_01_0001" proc-id="RM0250U___000090S00000">
<ptxt>INSTALL FRONT TRANSAXLE CASE COVER OIL SEAL</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Coat a new oil seal lip with MP grease.</ptxt>
<figure>
<graphic graphicname="D025722E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using SST and a hammer, install the oil seal.</ptxt>
<sst>
<sstitem>
<s-number>09608-10010</s-number>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07200</s-subnumber>
</sstitem>
</sst>
<spec>
<title>Installation depth</title>
<specitem>
<ptxt>-0.5 to 0.5 mm (-0.020 to 0.020 in.)</ptxt>
</specitem>
</spec>
<atten3>
<ptxt>Be careful not to damage the oil seal lip.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z1H002X_01_0002" proc-id="RM0250U___000090T00000">
<ptxt>INSTALL TRANSAXLE CASE OIL SEAL</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Coat a new oil seal lip with MP grease.</ptxt>
<figure>
<graphic graphicname="D026133E04" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using SST and a hammer, install the oil seal.</ptxt>
<sst>
<sstitem>
<s-number>09608-32010</s-number>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07200</s-subnumber>
</sstitem>
</sst>
<spec>
<title>Installation depth</title>
<specitem>
<ptxt>3.0 to 4.0 mm (0.1181 to 0.1575 in.)</ptxt>
</specitem>
</spec>
<atten3>
<ptxt>Be careful not to damage the oil seal lip.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z1H002X_01_0010" proc-id="RM0250U___0000CV400000">
<ptxt>INSTALL FRONT DRIVE SHAFT ASSEMBLY LH</ptxt>
<content1 releasenbr="1">
<ptxt>TMC made: (See page <xref label="Seep01" href="RM000001IW6001X"/>).</ptxt>
<ptxt>TMMK made: (See page <xref label="Seep02" href="RM000001IW6002X"/>).</ptxt>
</content1>
</s-1>
<s-1 id="RM000000Z1H002X_01_0011" proc-id="RM0250U___0000CVA00000">
<ptxt>INSTALL FRONT DRIVE SHAFT ASSEMBLY RH</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedures described for the LH side.</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM000000Z1H002X_01_0005" proc-id="RM0250U___000090W00000">
<ptxt>INSTALL FRONT WHEELS</ptxt>
<content1 releasenbr="1">
<torque>
<torqueitem>
<t-value1>103</t-value1>
<t-value2>1,050</t-value2>
<t-value4>76</t-value4>
</torqueitem>
</torque>
</content1>
</s-1>
<s-1 id="RM000000Z1H002X_01_0006" proc-id="RM0250U___000090X00000">
<ptxt>ADD MANUAL TRANSAXLE OIL</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Park the vehicle on a level place.</ptxt>
<figure>
<graphic graphicname="D025304E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the filler plug and gasket.</ptxt>
</s2>
<s2>
<ptxt>Check that the oil surface is within 5 mm (0.20 in.) below the lowest point of the filler plug opening.</ptxt>
<spec>
<title>Oil grade</title>
<specitem>
<ptxt>API GL-4 or GL-5</ptxt>
</specitem>
</spec>
<spec>
<title>Viscosity</title>
<specitem>
<ptxt>SAE 75W-90</ptxt>
</specitem>
</spec>
<atten3>
<list1 type="unordered">
<item>
<ptxt>Problems may occur if the oil level is too high or too low.</ptxt>
</item>
<item>
<ptxt>After replacing the oil, drive the vehicle and check the oil level again.</ptxt>
</item>
</list1>
</atten3>
</s2>
<s2>
<ptxt>Check for oil leakage if the oil level is low.</ptxt>
</s2>
<s2>
<ptxt>Install the filler plug and a new gasket.</ptxt>
<torque>
<torqueitem>
<t-value1>49</t-value1>
<t-value2>500</t-value2>
<t-value4>36</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z1H002X_01_0015" proc-id="RM0250U___00008ZQ00000">
<ptxt>INSPECT MANUAL TRANSAXLE OIL
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Stop the vehicle on a level surface.</ptxt>
<figure>
<graphic graphicname="D025304E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the transmission filler plug and gasket.</ptxt>
</s2>
<s2>
<ptxt>Check that the oil surface is within 5 mm (0.20 in.) of the bottom of the transmission filler plug opening.</ptxt>
<atten3>
<list1 type="unordered">
<item>
<ptxt>Excessively large or small amounts of oil may cause trouble.</ptxt>
</item>
<item>
<ptxt>After replacing the oil, drive the vehicle and check the oil level again.</ptxt>
</item>
</list1>
</atten3>
<atten4>
<ptxt>Insert your finger into the filler plug hole. You should be able to just touch the surface of the oil if the oil is at the correct level.</ptxt>
</atten4>
</s2>
<s2>
<ptxt>Check for oil leakage if the oil level is low.</ptxt>
</s2>
<s2>
<ptxt>Install the transmission filler plug and a new gasket.</ptxt>
<torque>
<torqueitem>
<t-value1>49</t-value1>
<t-value2>500</t-value2>
<t-value4>36</t-value4>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM000000Z1H002X_01_0013" proc-id="RM0250U___0000CV500000">
<ptxt>INSPECT AND ADJUST FRONT WHEEL ALIGNMENT</ptxt>
<content1 releasenbr="1">
<ptxt>See page <xref label="Seep01" href="RM0000011DA004X"/>.</ptxt>
</content1>
</s-1>
<s-1 id="RM000000Z1H002X_01_0014" proc-id="RM0250U___0000CV600000">
<ptxt>CHECK ABS SPEED SENSOR SIGNAL</ptxt>
<content1 releasenbr="2">
<s2>
<ptxt>ABS: See page <xref label="Seep01" href="RM000001JBD002X"/>.</ptxt>
</s2>
<s2>
<ptxt>VSC (for BOSCH): See page <xref label="Seep02" href="RM000001NKD001X"/>.</ptxt>
</s2>
<s2>
<ptxt>VSC (for ADVICS): See page <xref label="Seep03" href="RM000000XHT00AX"/>.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
