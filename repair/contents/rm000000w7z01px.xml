<testgrp id="RM000000W7Z01PX_09_0008" proc-id="RM0250U___0000CL000000">
<testtitle>INSPECT TRANSMISSION WIRE (ATF TEMPERATURE SENSOR)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Remove the TCM from the transaxle.</ptxt>
