</item>
<list2 type="unordered">
<item>
<ptxt>Faulty pressure regulator</ptxt>
</item>
<item>
<ptxt>Defective ECT</ptxt>
</item>
<item>
<ptxt>Defective MAF meter</ptxt>
</item>
<item>
<ptxt>Faulty ECM</ptxt>
</item>
<item>
<ptxt>Faulty injectors</ptxt>
</item>
<item>
<ptxt>Faulty throttle position sensor</ptxt>
</item>
</list2>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</s3>
</s2>
</content1>
</s-1>
</subpara>
</para>
