</entry>
<entry valign="middle">
<ptxt>Depressed</ptxt>
</entry>
<entry valign="middle">
<ptxt>0 to 3 V</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>ST1- (A55-35) - Body ground</ptxt>
</entry>
