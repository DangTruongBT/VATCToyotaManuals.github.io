<ptxt>9 to 14 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000XCT00UX_04_0009" fin="true">OK</down>
<right ref="RM000000XCT00UX_04_0008" fin="true">NG</right>
</res>
</testgrp>
