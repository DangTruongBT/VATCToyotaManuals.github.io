<name>ENGINE</name>
<section id="10006_S0004" variety="S0004">
<name>2AZ-FE ENGINE CONTROL SYSTEM</name>
<ttl id="10006_S0004_731VK_T00FR" variety="T00FR">
<name>CAMSHAFT TIMING OIL CONTROL VALVE ASSEMBLY</name>
<para id="RM0000012NO004X" category="A" type-id="80001" name-id="ES107-04" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000012NO004X_01" type-id="01" category="01">
<s-1 id="RM0000012NO004X_01_0011" proc-id="RM0250U___0000A7T00000">
<ptxt>REMOVE NO. 1 ENGINE COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 nuts and cover.</ptxt>
<figure>
<graphic graphicname="A134904" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000012NO004X_01_0008" proc-id="RM0250U___0000B8N00000">
<ptxt>REMOVE VACUUM HOSE CLAMP</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt and disconnect the vacuum hose clamp.</ptxt>
<figure>
<graphic graphicname="A135664" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000012NO004X_01_0009" proc-id="RM0250U___0000B8O00000">
<ptxt>REMOVE CLIP NUT</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the clip nut.</ptxt>
<figure>
<graphic graphicname="A135665E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000012NO004X_01_0007" proc-id="RM0250U___0000B4900000">
<ptxt>REMOVE CAMSHAFT TIMING OIL CONTROL VALVE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the camshaft timing oil control valve assembly connector.</ptxt>
<figure>
<graphic graphicname="A124556" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the bolt and camshaft timing oil control valve assembly.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
