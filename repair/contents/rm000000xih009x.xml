<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="36">
<name>BRAKE</name>
<section id="1002J_S0010" variety="S0010">
<name>BRAKE CONTROL</name>
<ttl id="1002J_S0010_72W30_T005W" variety="T005W">
<name>VEHICLE STABILITY CONTROL SYSTEM (for BOSCH Made)</name>
<para id="RM000000XIH009X" category="J" type-id="300E0" name-id="BC1HD-01" from="200601">
<dtccode/>
<dtcname>ABS Warning Light Remains ON</dtcname>
<subpara id="RM000000XIH009X_01" type-id="60" category="03" proc-id="RM0250U___00003ML00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>The skid control ECU is connected to the combination meter assembly via CAN communication.</ptxt>
<ptxt>If any of the following is detected, the ABS warning light remains on.</ptxt>
<list1 type="unordered">
<item>
<ptxt>The skid control ECU connectors are disconnected from the skid control ECU.</ptxt>
</item>
<item>
<ptxt>There is a malfunction in the skid control ECU internal circuit.</ptxt>
</item>
<item>
<ptxt>There is an open in the wire harness between the combination meter assembly and the skid control ECU.</ptxt>
</item>
</list1>
<atten4>
<ptxt>In some cases, the intelligent tester cannot be used when the skid control ECU is abnormal.</ptxt>
</atten4>
</content5>
</subpara>
<subpara id="RM000000XIH009X_02" type-id="32" category="03" proc-id="RM0250U___00003MM00000">
<name>WIRING DIAGRAM</name>
<content5 releasenbr="1">
<figure>
<graphic graphicname="C136510E02" width="7.106578999in" height="8.799559038in"/>
</figure>
</content5>
</subpara>
<subpara id="RM000000XIH009X_03" type-id="51" category="05" proc-id="RM0250U___00003MN00000">
<name>INSPECTION PROCEDURE</name>
<content5 releasenbr="1">
<atten4>
<ptxt>Check the condition of each related circuit connector before troubleshooting (See page <xref label="Seep01" href="RM000000UZ301TX"/>).</ptxt>
</atten4>
</content5>
</subpara>
<subpara id="RM000000XIH009X_04" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000000XIH009X_04_0001" proc-id="RM0250U___00003MO00000">
<testtitle>CHECK CAN COMMUNICATION SYSTEM</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check if a CAN communication system DTC is output (See page <xref label="Seep01" href="RM000001NK5001X"/>).</ptxt>
<spec>
<title>Result</title>
<table pgwide="1">
<tgroup cols="2">
<colspec colname="COL1" colwidth="4.53in"/>
<colspec colname="COL2" colwidth="2.55in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>CAN communication system DTC is not output</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>A</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>CAN communication system DTC is output</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>B</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000XIH009X_04_0003" fin="false">A</down>
<right ref="RM000000XIH009X_04_0009" fin="true">B</right>
</res>
</testgrp>
<testgrp id="RM000000XIH009X_04_0003" proc-id="RM0250U___00003MQ00000">
<testtitle>CHECK IF SKID CONTROL ECU CONNECTOR IS SECURELY CONNECTED</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check if the skid control ECU connector is securely connected.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The connector is securely connected.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000XIH009X_04_0004" fin="false">OK</down>
<right ref="RM000000XIH009X_04_0011" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000XIH009X_04_0004" proc-id="RM0250U___00003MR00000">
<testtitle>CHECK BATTERY</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check the battery voltage.</ptxt>
<spec>
<title>Standard voltage</title>
<specitem>
<ptxt>11 to 14 V</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000XIH009X_04_0005" fin="false">OK</down>
<right ref="RM000000XIH009X_04_0012" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000XIH009X_04_0005" proc-id="RM0250U___00003MS00000">
<testtitle>INSPECT SKID CONTROL ECU (IG1 TERMINAL)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the skid control ECU connector.</ptxt>
<figure>
<graphic graphicname="C136493E05" width="2.775699831in" height="2.775699831in"/>
</figure>
</test1>
<test1>
<ptxt>Turn the ignition switch on (IG).</ptxt>
</test1>
<test1>
<ptxt>Measure the voltage according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>A60-28 (IG1) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Ignition switch on (IG)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 to 14 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000XIH009X_04_0006" fin="false">OK</down>
<right ref="RM000000XIH009X_04_0013" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000XIH009X_04_0006" proc-id="RM0250U___00003MT00000">
<testtitle>INSPECT SKID CONTROL ECU (GND TERMINAL)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Turn the ignition switch off.</ptxt>
<figure>
<graphic graphicname="C136493E02" width="2.775699831in" height="2.775699831in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3">
<colspec colname="COL1" colwidth="1.35in"/>
<colspec colname="COLSPEC0" colwidth="1.41in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>A60-4 (GND1) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>A60-1 (GND2) - Body ground</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
<test1>
<ptxt>Connect the connector.</ptxt>
</test1>
</content6>
<res>
<down ref="RM000000XIH009X_04_0007" fin="false">OK</down>
<right ref="RM000000XIH009X_04_0014" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000XIH009X_04_0007" proc-id="RM0250U___00003MU00000">
<testtitle>INSPECT COMBINATION METER ASSEMBLY</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Connect the intelligent tester to the DLC3.</ptxt>
</test1>
<test1>
<ptxt>Perform "ACTIVE TEST" of the combination meter assembly using the intelligent tester (See page <xref label="Seep01" href="RM0000012G700DX"/>).</ptxt>
</test1>
<test1>
<ptxt>Check the ABS warning light operation.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>The ABS warning light turns on or off in accordance with the intelligent tester.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000XIH009X_04_0008" fin="true">OK</down>
<right ref="RM000000XIH009X_04_0015" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000XIH009X_04_0008">
<testtitle>REPLACE BRAKE ACTUATOR ASSEMBLY<xref label="Seep01" href="RM0000013P6004X"/>
</testtitle>
</testgrp>
<testgrp id="RM000000XIH009X_04_0009">
<testtitle>INSPECT CAN COMMUNICATION SYSTEM<xref label="Seep01" href="RM000000WI600QX"/>
</testtitle>
</testgrp>
<testgrp id="RM000000XIH009X_04_0011">
<testtitle>CONNECT CONNECTOR TO ECU CORRECTLY</testtitle>
</testgrp>
<testgrp id="RM000000XIH009X_04_0012">
<testtitle>CHECK AND REPLACE CHARGING SYSTEM OR BATTERY</testtitle>
</testgrp>
<testgrp id="RM000000XIH009X_04_0013">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR (IG1 CIRCUIT)</testtitle>
</testgrp>
<testgrp id="RM000000XIH009X_04_0014">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR (GND CIRCUIT)</testtitle>
</testgrp>
<testgrp id="RM000000XIH009X_04_0015">
<testtitle>REPLACE COMBINATION METER ASSEMBLY<xref label="Seep01" href="RM0000024D7000X"/>
</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>