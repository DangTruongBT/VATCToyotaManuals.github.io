<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1001A_S001B" variety="S001B">
<name>LIGHTING</name>
<ttl id="1001A_S001B_72YGJ_T009P" variety="T009P">
<name>TAILLIGHT RELAY</name>
<para id="RM000001Y6R001X" category="G" type-id="8000T" name-id="LI1FQ-02" from="200601">
<name>ON-VEHICLE INSPECTION</name>
<subpara id="RM000001Y6R001X_01" type-id="01" category="01">
<s-1 id="RM000001Y6R001X_01_0001" proc-id="RM0250U___00007VY00000">
<ptxt>INSPECT TAILLIGHT RELAY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the taillight relay from the instrument panel J/B assembly.</ptxt>
<figure>
<graphic graphicname="A087121E11" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="1.32in"/>
<colspec colname="COL2" colwidth="2.81in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry morerows="1" valign="middle">
<ptxt>3 - 5</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Below 1 Ω (When battery voltage is applied to terminals 1 and 2)</ptxt>
</entry>
</row>
<row>
<entry morerows="1" valign="middle">
<ptxt>3 - 4</ptxt>
</entry>
<entry valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>10 kΩ or higher (When battery voltage is applied to terminals 1 and 2)</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<ptxt>If the result is not as specified, replace the taillight relay.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>