<s-1 id="RM0000026JY000X_01_0003" proc-id="RM0250U___000045200000">
<ptxt>REMOVE ROOF CONSOLE BOX ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a moulding remover, disengage the 2 clips and 2 claws.</ptxt>
<figure>
<graphic graphicname="B132064" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the connectors and remove the roof console box assembly.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000026JY000X_01_0002" proc-id="RM0250U___00005DE00000">
<ptxt>REMOVE TELEPHONE MICROPHONE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the connector.</ptxt>
</s2>
<s2>
<ptxt>Disengage the 2 claws and remove the telephone microphone assembly.</ptxt>
<figure>
<graphic graphicname="E129195" width="2.775699831in" height="1.771723296in"/>
