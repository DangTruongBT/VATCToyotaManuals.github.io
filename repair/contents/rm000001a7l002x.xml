<ptxt>1D-9 - Body ground</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 to 14 V</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</content6>
<res>
<down ref="RM000001A7L002X_04_0022" fin="false">OK</down>
<right ref="RM000001A7L002X_04_0014" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000001A7L002X_04_0022" proc-id="RM0250U___0000BAX00000">
<testtitle>CHECK HARNESS AND CONNECTOR (ENGINE ROOM J/B ASSEMBLY - INSTRUMENT PANEL J/B ASSEMBLY)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Reconnect the 1D engine room J/B assembly connector.</ptxt>
</test1>
<test1>
<ptxt>Disconnect the ID instrument panel J/B connector.</ptxt>
<figure>
<graphic graphicname="E121479E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the voltage according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard voltage</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
