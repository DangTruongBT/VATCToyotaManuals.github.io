<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000S" variety="S000S">
<name>U250E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000S_72XQS_T007P" variety="T007P">
<name>SPEED SENSOR</name>
<para id="RM000000OE4009X" category="A" type-id="80001" name-id="AX0M5-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM000000OE4009X_03" type-id="01" category="01">
<s-1 id="RM000000OE4009X_03_0012">
<ptxt>DISCONNECT CABLE FROM NEGATIVE BATTERY TERMINAL</ptxt>
</s-1>
<s-1 id="RM000000OE4009X_03_0007" proc-id="RM0250U___0000A7W00000">
<ptxt>REMOVE BATTERY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Loosen the bolt and nut, and remove the battery clamp.</ptxt>
<figure>
<graphic graphicname="A134906" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the battery and battery tray.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000OE4009X_03_0013" proc-id="RM0250U___0000A7U00000">
<ptxt>REMOVE AIR CLEANER INLET ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts, clamp and air cleaner inlet.</ptxt>
<figure>
<graphic graphicname="A134903" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000000OE4009X_03_0014" proc-id="RM0250U___0000B9500000">
<ptxt>REMOVE AIR CLEANER CAP SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the mass air flow meter connector (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A135666E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the purge VSV connector (<sup>*</sup>2).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the 2 purge VSV vacuum hoses (<sup>*</sup>3).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the purge line hose from the clamp (<sup>*</sup>4).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the No. 2 ventilation hose from the air cleaner hose.</ptxt>
<figure>
<graphic graphicname="A135667E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Lock the No. 1 air cleaner hose clamp, and then disconnect the No. 1 air cleaner hose from the throttle body.</ptxt>
<figure>
<graphic graphicname="A135668" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts and air cleaner cap.</ptxt>
<figure>
<graphic graphicname="A135669" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the air cleaner filter element from the air cleaner case.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000OE4009X_03_0015" proc-id="RM0250U___0000A7V00000">
<ptxt>REMOVE AIR CLEANER CASE SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the hose clamp.</ptxt>
<figure>
<graphic graphicname="A134905" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 3 bolts and air cleaner case.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000OE4009X_03_0005" proc-id="RM0250U___00006KL00000">
<ptxt>REMOVE SPEED SENSOR (NT SENSOR)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the speed sensor connector.</ptxt>
<figure>
<graphic graphicname="C135106" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the bolt and speed sensor.</ptxt>
</s2>
<s2>
<ptxt>Remove the O-ring from the speed sensor.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000000OE4009X_03_0006" proc-id="RM0250U___00006KM00000">
<ptxt>REMOVE SPEED SENSOR (NC SENSOR)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the speed sensor connector.</ptxt>
<figure>
<graphic graphicname="C135107" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the bolt and speed sensor.</ptxt>
</s2>
<s2>
<ptxt>Remove the O-ring from the speed sensor.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>