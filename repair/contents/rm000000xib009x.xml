</testgrp>
<testgrp id="RM000000XIB009X_04_0005" proc-id="RM0250U___00005MQ00000">
<testtitle>INSPECT ENGINE ROOM RELAY BLOCK</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<figure>
<graphic graphicname="C135809E02" width="2.775699831in" height="2.775699831in"/>
</figure>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COLSPEC2" colwidth="0.83in"/>
<colspec colname="COL2" colwidth="1.23in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>VSC NO. 1 (fail safe) relay terminal 3 - VSC NO. 2 relay terminal 5</ptxt>
</entry>
