<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COLSPEC3" colwidth="0.83in"/>
<colspec colname="COL2" colwidth="1.23in"/>
<thead>
