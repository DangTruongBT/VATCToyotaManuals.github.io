<right ref="RM000000XIB009X_04_0013" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000XIB009X_04_0006" proc-id="RM0250U___00005MR00000">
<testtitle>CHECK HARNESS AND CONNECTOR (SKID CONTROL ECU - ENGINE ROOM RELAY BLOCK)</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the skid control ECU connector.</ptxt>
<figure>
<graphic graphicname="C136023E03" width="2.775699831in" height="4.7836529in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
