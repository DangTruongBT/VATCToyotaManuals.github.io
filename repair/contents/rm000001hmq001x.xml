</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>F16-9 (ADI1) - F16-8 (SG)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>TEMP+ switch: ON</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Approx. 1,000 Ω</ptxt>
