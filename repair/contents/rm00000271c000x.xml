<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000T" variety="S000T">
<name>U660E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000T_72VR8_T005P" variety="T005P">
<name>OIL PUMP</name>
<para id="RM00000271C000X" category="A" type-id="8000E" name-id="AX13F-01" from="200601">
<name>REASSEMBLY</name>
<subpara id="RM00000271C000X_01" type-id="01" category="01">
<s-1 id="RM00000271C000X_01_0006" proc-id="RM0250U___0000BN200000">
<ptxt>INSTALL FRONT OIL PUMP OIL SEAL</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST and a hammer, install a new oil seal to the oil pump body.</ptxt>
<figure>
<graphic graphicname="C138515E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09350-32014</s-number>
<s-subnumber>09351-32140</s-subnumber>
</sstitem>
</sst>
<atten3>
<ptxt>The seal end should be level with the outer edge of the oil pump.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Coat the lip of the oil seal with MP grease.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM00000271C000X_01_0007" proc-id="RM0250U___0000BN300000">
<ptxt>INSTALL FRONT OIL PUMP BODY O-RING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Coat a new O-ring with ATF and install it to the oil pump body.</ptxt>
<figure>
<graphic graphicname="C138278" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Ensure that the O-ring is not twisted.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
<s-1 id="RM00000271C000X_01_0001" proc-id="RM0250U___0000BN400000">
<ptxt>INSTALL FRONT OIL PUMP DRIVEN GEAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Coat the front oil pump driven gear with ATF and install it to the oil pump body with the marked side up.</ptxt>
<figure>
<graphic graphicname="C138277" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM00000271C000X_01_0002" proc-id="RM0250U___0000BN500000">
<ptxt>INSTALL FRONT OIL PUMP DRIVE GEAR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Coat the front oil pump drive gear with ATF, and install it to the oil pump body with the marked side up.</ptxt>
<figure>
<graphic graphicname="C138276" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM00000271C000X_01_0003" proc-id="RM0250U___0000BN700000">
<ptxt>INSTALL STATOR SHAFT ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>	Align each knock pin of the stator shaft with the holes in the oil pump body and install the stator shaft to the oil pump body with the 16 bolts.</ptxt>
<figure>
<graphic graphicname="C138275E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Using a "TORX" socket (T30), install the 11 bolts.</ptxt>
<torque>
<torqueitem>
<t-value1>9.3</t-value1>
<t-value2>95</t-value2>
<t-value3>82</t-value3>
</torqueitem>
</torque>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle">
<title>-</title>
</entry>
<entry valign="middle">
<title>Bolt length:</title>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<title>Bolt A</title>
</entry>
<entry valign="middle">
<ptxt>14 mm (0.55 in)</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<title>Bolt B</title>
</entry>
<entry valign="middle">
<ptxt>26 mm (1.02 in)</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</s2>
</content1>
</s-1>
<s-1 id="RM00000271C000X_01_0009" proc-id="RM0250U___0000BMU00000">
<ptxt>INSPECT FRONT OIL PUMP AND GEAR BODY SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Turn the drive gear with 2 screwdrivers and make sure that it rotates smoothly.</ptxt>
<figure>
<graphic graphicname="C138512" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Be careful not to damage the oil seal lip.</ptxt>
</atten3>
</s2>
</content1></s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>