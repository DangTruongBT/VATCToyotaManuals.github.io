<ttl id="1000D_S000N_72Z80_T00BL" variety="T00BL">
<name>OIL PUMP</name>
<para id="RM000001IQN001X" category="A" type-id="80002" name-id="LU0DK-02" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM000001IQN001X_01" type-id="01" category="01">
<s-1 id="RM000001IQN001X_01_0001" proc-id="RM0250U___000069J00000">
<ptxt>REMOVE OIL PUMP RELIEF VALVE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a 27 mm socket wrench, remove the relief valve plug.</ptxt>
<figure>
<graphic graphicname="A128008" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the valve spring and oil pump relief valve.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IQN001X_01_0002" proc-id="RM0250U___000069K00000">
<ptxt>REMOVE OIL PUMP COVER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 8 bolts, oil pump cover and oil pump rotor set.</ptxt>
<figure>
<graphic graphicname="A128009" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
