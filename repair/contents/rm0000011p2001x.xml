<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="36">
<name>BRAKE</name>
<section id="1002J_S0010" variety="S0010">
<name>BRAKE CONTROL</name>
<ttl id="1002J_S0010_72VA9_T004H" variety="T004H">
<name>FRONT SPEED SENSOR</name>
<para id="RM0000011P2001X" category="A" type-id="30014" name-id="BC0AH-02" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000011P2001X_01" type-id="01" category="01">
<s-1 id="RM0000011P2001X_01_0001" proc-id="RM0250U___00000M600000">
<ptxt>INSTALL FRONT SPEED SENSOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the front speed sensor with the bolt.</ptxt>
<figure>
<graphic graphicname="C132782" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>8.0</t-value1>
<t-value2>82</t-value2>
<t-value3>71</t-value3>
</torqueitem>
</torque>
<atten3>
<ptxt>Prevent foreign matter from attaching to the sensor tip.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Install the front speed sensor with the 2 bolts and engage the 2 claws.</ptxt>
<figure>
<graphic graphicname="C132781E03" width="2.775699831in" height="3.779676365in"/>
</figure>
<torque>
<subtitle>Bolt A</subtitle>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
<subtitle>Bolt B</subtitle>
<torqueitem>
<t-value1>19</t-value1>
<t-value2>194</t-value2>
<t-value4>14</t-value4>
</torqueitem>
</torque>
<atten3>
<list1 type="unordered">
<item>
<ptxt>Do not twist the wire harness for the front speed sensor when installing the speed sensor.</ptxt>
</item>
<item>
<ptxt>The bolt B tightens the brake flexible hose and front speed sensor together. Make sure that the flexible hose is positioned over the front speed sensor.</ptxt>
</item>
<item>
<ptxt>Install the stopper firmly to the hole in the body.</ptxt>
</item>
</list1>
</atten3>
</s2>
<s2>
<ptxt>Connect the front speed sensor connector and clamp.</ptxt>
<figure>
<graphic graphicname="C132783E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000011P2001X_01_0006" proc-id="RM0250U___00008L000000">
<ptxt>INSTALL FRONT FENDER LINER
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the front fender liner with the grommet and 4 screws.</ptxt>
<figure>
<graphic graphicname="B136871" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Install the bolt and 5 clips.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000011P2001X_01_0007" proc-id="RM0250U___00009PC00000">
<ptxt>INSTALL FRONT WHEEL OPENING EXTENSION PAD LH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the front wheel opening extension pad with the 3 screws.</ptxt>
<figure>
<graphic graphicname="B138883" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000011P2001X_01_0003" proc-id="RM0250U___00000M800000">
<ptxt>INSTALL FRONT WHEEL</ptxt>
<content1 releasenbr="1">
<torque>
<torqueitem>
<t-value1>103</t-value1>
<t-value2>1,050</t-value2>
<t-value4>76</t-value4>
</torqueitem>
</torque>
</content1>
</s-1>
<s-1 id="RM0000011P2001X_01_0004" proc-id="RM0250U___00000M900000">
<ptxt>CHECK SPEED SENSOR SIGNAL</ptxt>
<content1 releasenbr="1">
<atten4>
<list1 type="unordered">
<item>
<ptxt>for BOSCH without VSC (See page <xref label="Seep01" href="RM000001JBD002X"/>)</ptxt>
</item>
<item>
<ptxt>for BOSCH with VSC (See page <xref label="Seep02" href="RM000001NKD001X"/>)</ptxt>
</item>
<item>
<ptxt>for ADVICS (See page <xref label="Seep03" href="RM000000XHT00AX"/>)</ptxt>
</item>
</list1>
</atten4>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>