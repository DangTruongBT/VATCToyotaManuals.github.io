<name>BODY</name>
<section id="1001H_S001L" variety="S001L">
<name>SEAT</name>
<ttl id="1001H_S001L_72WMX_T006J" variety="T006J">
<name>REAR SEAT ASSEMBLY (for Fold Down Seat Type)</name>
<para id="RM00000241V000X" category="A" type-id="30014" name-id="SE0VT-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM00000241V000X_01" type-id="01" category="01">
<s-1 id="RM00000241V000X_01_0002" proc-id="RM0250U___0000A3K00000">
<ptxt>INSTALL REAR SIDE SEAT BACK ASSEMBLY LH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the rear side seat back assembly with the bolt.</ptxt>
<torque>
<torqueitem>
<t-value1>18</t-value1>
<t-value2>184</t-value2>
<t-value4>13</t-value4>
</torqueitem>
</torque>
<figure>
<graphic graphicname="B136561" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM00000241V000X_01_0001">
<ptxt>INSTALL REAR SIDE SEAT BACK ASSEMBLY RH</ptxt>
</s-1>
<s-1 id="RM00000241V000X_01_0003" proc-id="RM0250U___0000A3L00000">
<ptxt>INSTALL SEPARATE TYPE REAR SEAT BACK ASSEMBLY LH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the separate type rear seat back assembly with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="B136539" width="2.775699831in" height="2.775699831in"/>
</figure>
<torque>
<torqueitem>
<t-value1>18</t-value1>
<t-value2>184</t-value2>
<t-value4>13</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM00000241V000X_01_0004" proc-id="RM0250U___0000A3M00000">
<ptxt>INSTALL SEPARATE TYPE REAR SEAT BACK ASSEMBLY RH</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the separate type rear seat back assembly with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="B134700" width="2.775699831in" height="2.775699831in"/>
</figure>
<torque>
<torqueitem>
<t-value1>18</t-value1>
<t-value2>184</t-value2>
<t-value4>13</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM00000241V000X_01_0006">
<ptxt>INSTALL REAR CENTER SEAT HEADREST ASSEMBLY</ptxt>
</s-1>
<s-1 id="RM00000241V000X_01_0007">
<ptxt>INSTALL REAR SEAT HEADREST ASSEMBLY</ptxt>
</s-1>
<s-1 id="RM00000241V000X_01_0005" proc-id="RM0250U___0000A3N00000">
<ptxt>INSTALL REAR SEAT CUSHION ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Attach the front hooks of the bench type rear seat cushion assembly to the vehicle body.</ptxt>
<figure>
<graphic graphicname="B140584E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Confirm that the seat cushion is firmly installed.</ptxt>
<atten3>
<ptxt>When installing the bench type rear seat cushion assembly, make sure that the seat belt buckle is not under the bench type rear seat cushion assembly.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
