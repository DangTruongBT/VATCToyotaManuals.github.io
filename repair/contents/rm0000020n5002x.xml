<name>BODY ELECTRICAL</name>
<section id="1002Q_S001I" variety="S001I">
<name>NAVIGATION</name>
<ttl id="1002Q_S001I_72YIF_T00A4" variety="T00A4">
<name>NAVIGATION SYSTEM</name>
<para id="RM0000020N5002X" category="J" type-id="300HB" name-id="NS0NR-03" from="200601">
<dtccode/>
<dtcname>CD cannot be Ejected</dtcname>
<subpara id="RM0000020N5002X_01" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM0000020N5002X_02" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM0000020N5002X_02_0001" proc-id="RM0250U___00004VU00000">
<testtitle>CHECK OPERATION</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Press the disc eject switch of the radio receiver for 5 seconds or more and check that the CD is ejected.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>CD is ejected.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000020N5002X_02_0002" fin="false">OK</down>
<right ref="RM0000020N5002X_02_0003" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000020N5002X_02_0002" proc-id="RM0250U___00004VV00000">
<testtitle>REPLACE CD WITH ANOTHER AND RECHECK</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Insert another CD and check if it is ejected.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>CD is ejected.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM0000020N5002X_02_0004" fin="true">OK</down>
<right ref="RM0000020N5002X_02_0003" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM0000020N5002X_02_0003">
<testtitle>REPLACE RADIO AND NAVIGATION ASSEMBLY</testtitle>
</testgrp>
<testgrp id="RM0000020N5002X_02_0004">
<testtitle>CD IS FAULTY</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
