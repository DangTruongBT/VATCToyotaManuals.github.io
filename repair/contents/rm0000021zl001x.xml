<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="1000A_S000J" variety="S000J">
<name>2GR-FE ENGINE MECHANICAL</name>
<ttl id="1000A_S000J_72ZHB_T00C8" variety="T00C8">
<name>ENGINE REAR OIL SEAL</name>
<para id="RM0000021ZL001X" category="A" type-id="30014" name-id="EM0XX-02" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000021ZL001X_01" type-id="01" category="01">
<s-1 id="RM0000021ZL001X_01_0001" proc-id="RM0250U___00006Q200000">
<ptxt>INSTALL ENGINE REAR OIL SEAL</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply MP grease to a new oil seal lip.</ptxt>
<figure>
<graphic graphicname="A132245E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Using SST and a hammer, tap in the oil seal.</ptxt>
<sst>
<sstitem>
<s-number>09223-15030</s-number>
</sstitem>
<sstitem>
<s-number>09950-70010</s-number>
<s-subnumber>09951-07150</s-subnumber>
</sstitem>
</sst>
<spec>
<title>Oil seal tap in depth</title>
<specitem>
<ptxt>-0.5 to 0.5 mm (-0.020 to 0.020 in.)</ptxt>
</specitem>
</spec>
</s2>
</content1>
</s-1>
<s-1 id="RM0000021ZL001X_01_0002" proc-id="RM0250U___00006Q300000">
<ptxt>INSTALL DRIVE PLATE AND RING GEAR SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST, hold the crankshaft.</ptxt>
<figure>
<graphic graphicname="A129631E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09213-70011</s-number>
<s-subnumber>09213-70020</s-subnumber>
</sstitem>
<sstitem>
<s-number>09330-00021</s-number>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Apply adhesive to 2 or 3 threads of the mounting bolt end.</ptxt>
<figure>
<graphic graphicname="P000601E04" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Adhesive</title>
<specitem>
<ptxt>Part No. 08833-00070, THREE BOND 1324 or equivalent</ptxt>
</specitem>
</spec>
<s3>
<ptxt>Install the front spacer, drive plate and rear spacer on the crankshaft.</ptxt>
<figure>
<graphic graphicname="A132243E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s3>
<s3>
<ptxt>Install and tighten the 8 mounting bolts uniformly in several steps.</ptxt>
<torque>
<torqueitem>
<t-value1>83</t-value1>
<t-value2>850</t-value2>
<t-value4>61</t-value4>
</torqueitem>
</torque>
</s3>
</s2>
</content1>
</s-1>
<s-1 id="RM0000021ZL001X_01_0004" proc-id="RM0250U___00009PP00000">
<ptxt>INSTALL AUTOMATIC TRANSAXLE ASSEMBLY</ptxt>
<content1 releasenbr="2">
<atten4>
<ptxt>See page <xref label="Seep01" href="RM0000016DT004X"/>.</ptxt>
</atten4>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>