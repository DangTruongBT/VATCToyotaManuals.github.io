<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10006_S000F" variety="S000F">
<name>2GR-FE ENGINE CONTROL SYSTEM</name>
<ttl id="10006_S000F_7306L_T00EF" variety="T00EF">
<name>ECM</name>
<para id="RM0000022NR001X" category="A" type-id="30014" name-id="ES3PV-02" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000022NR001X_01" type-id="01" category="01">
<s-1 id="RM0000022NR001X_01_0001" proc-id="RM0250U___000093900000">
<ptxt>INSTALL ECM</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the ECM bracket with the 4 screws.</ptxt>
<figure>
<graphic graphicname="A135713" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>3.0</t-value1>
<t-value2>31</t-value2>
<t-value3>27</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the 2 ECM connectors.</ptxt>
<atten3>
<ptxt>When connecting the connector, make sure that dirt, water and other foreign matter do not become stuck between the connector and other parts.</ptxt>
</atten3>
<s3>
<ptxt>Connect the 2 ECM connectors and lower the 2 levers.</ptxt>
<figure>
<graphic graphicname="A128949" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Make sure that the 2 levers are securely lowered.</ptxt>
</atten3>
</s3>
</s2>
<s2>
<ptxt>Install the ECM with the 3 nuts.</ptxt>
<figure>
<graphic graphicname="A135711" width="2.775699831in" height="2.775699831in"/>
</figure>
<torque>
<torqueitem>
<t-value1>8.0</t-value1>
<t-value2>82</t-value2>
<t-value3>71</t-value3>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022NR001X_01_0018" proc-id="RM0250U___0000CI500000">
<ptxt>INSTALL COWL TOP PANEL OUTER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the cowl top panel outer sub-assembly with the 4 bolts and 4 nuts.</ptxt>
<figure>
<graphic graphicname="A136272" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<subtitle>Bolt</subtitle>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
<subtitle>Nut</subtitle>
<torqueitem>
<t-value1>85</t-value1>
<t-value2>867</t-value2>
<t-value4>63</t-value4>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM0000022NR001X_01_0019" proc-id="RM0250U___000055H00000">
<ptxt>INSTALL WINDSHIELD WIPER MOTOR AND LINK
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the windshield wiper motor and link assembly with the 4 bolts.</ptxt>
<figure>
<graphic graphicname="E128813E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>7.5</t-value1>
<t-value2>77</t-value2>
<t-value3>66</t-value3>
</torqueitem>
</torque>
<atten3>
<ptxt>Tighten the bolts in the order shown in the illustration.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Connect the connector.</ptxt>
<figure>
<graphic graphicname="E128812" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000022NR001X_01_0020" proc-id="RM0250U___000055I00000">
<ptxt>INSTALL COWL TOP VENTILATOR LOUVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 4 claws and install the cowl top ventilator louver sub-assembly.</ptxt>
<figure>
<graphic graphicname="E128811" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 2 clips.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000022NR001X_01_0021" proc-id="RM0250U___000055J00000">
<ptxt>INSTALL FRONT FENDER TO COWL SIDE SEAL RH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the claw and install the front fender to cowl side seal RH.</ptxt>
<figure>
<graphic graphicname="E128810" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000022NR001X_01_0022" proc-id="RM0250U___000055K00000">
<ptxt>INSTALL FRONT FENDER TO COWL SIDE SEAL LH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the claw and install the front fender to cowl side seal LH.</ptxt>
<figure>
<graphic graphicname="E128809" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000022NR001X_01_0023" proc-id="RM0250U___000055L00000">
<ptxt>INSTALL WINDSHIELD WIPER ARM AND BLADE ASSEMBLY LH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Operate the wiper and stop the windshield wiper motor at the automatic stop position.</ptxt>
</s2>
<s2>
<ptxt>Clean the wiper arm serrations.</ptxt>
<figure>
<graphic graphicname="E112237E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>When reinstalling:</ptxt>
<s3>
<ptxt>Clean the wiper pivot serrations with a wire brush.</ptxt>
</s3>
</s2>
<s2>
<ptxt>Install the front wiper arm and blade assembly LH with the nut to the position shown in the illustration.</ptxt>
<figure>
<graphic graphicname="E128820E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>20</t-value1>
<t-value2>204</t-value2>
<t-value4>15</t-value4>
</torqueitem>
</torque>
<atten4>
<ptxt>Hold the arm hinge by hand to fasten the nut.</ptxt>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry>
<ptxt>Area</ptxt>
</entry>
<entry>
<ptxt>Measurement</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>A</ptxt>
</entry>
<entry>
<ptxt>37 to 52 mm (1.46 to 2.05 in.)</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</atten4>
</s2>
</content1></s-1>
<s-1 id="RM0000022NR001X_01_0024" proc-id="RM0250U___000055M00000">
<ptxt>INSTALL WINDSHIELD WIPER ARM AND BLADE ASSEMBLY RH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Operate the wiper and stop the windshield wiper motor at the automatic stop position.</ptxt>
</s2>
<s2>
<ptxt>Clean the wiper arm serrations.</ptxt>
<figure>
<graphic graphicname="E112237E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>When reinstalling:</ptxt>
<s3>
<ptxt>Clean the wiper pivot serrations with a wire brush.</ptxt>
</s3>
</s2>
<s2>
<ptxt>Install the front wiper arm and blade assembly RH with the nut to the position shown in the illustration.</ptxt>
<figure>
<graphic graphicname="E128821E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>20</t-value1>
<t-value2>204</t-value2>
<t-value4>15</t-value4>
</torqueitem>
</torque>
<atten4>
<ptxt>Hold the arm hinge by hand to fasten the nut.</ptxt>
<table frame="all">
<tgroup cols="2" align="center">
<colspec colname="col1" colwidth="2.07in"/>
<colspec colname="col2" colwidth="2.06in"/>
<thead>
<row>
<entry>
<ptxt>Area</ptxt>
</entry>
<entry>
<ptxt>Measurement</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry>
<ptxt>A</ptxt>
</entry>
<entry>
<ptxt>23 to 38 mm (0.90 to 1.49 in.)</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</atten4>
</s2>
<s2>
<ptxt>Operate the front wipers while spraying washer fluid on the windshield glass. Make sure that the front wipers function properly and the wipers do not come into contact with the vehicle body.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000022NR001X_01_0025" proc-id="RM0250U___0000A6600000">
<ptxt>CONNECT CABLE TO NEGATIVE BATTERY TERMINAL
</ptxt>
<content1 releasenbr="1">
<torque>
<torqueitem>
<t-value1>6.9</t-value1>
<t-value2>70</t-value2>
<t-value3>61</t-value3>
</torqueitem>
</torque>
</content1></s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>