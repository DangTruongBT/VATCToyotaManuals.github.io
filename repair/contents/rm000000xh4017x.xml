<entry valign="middle">
<ptxt>Terminals</ptxt>
</entry>
<entry valign="middle">
<ptxt>CH1: IGT1, IGT2, IGT3, IGT4, IGT5, IGT6 - E1</ptxt>
<ptxt>CH2: IGF1 - E1</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Equipment Settings</ptxt>
</entry>
<entry valign="middle">
<ptxt>2 V/DIV.</ptxt>
<ptxt>20 ms./DIV.</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Conditions</ptxt>
</entry>
<entry valign="middle">
<ptxt>Cranking or idling</ptxt>
</entry>
</row>
</tbody>
</tgroup>
