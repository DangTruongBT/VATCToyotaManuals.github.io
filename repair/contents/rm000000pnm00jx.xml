<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1002Q_S001I" variety="S001I">
<name>NAVIGATION</name>
<ttl id="1002Q_S001I_72YIF_T00A4" variety="T00A4">
<name>NAVIGATION SYSTEM</name>
<para id="RM000000PNM00JX" category="J" type-id="303V0" name-id="NS0WC-01" from="200601">
<dtccode/>
<dtcname>Voice Guidance does not Function</dtcname>
<subpara id="RM000000PNM00JX_01" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM000000PNM00JX_02" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM000000PNM00JX_02_0001" proc-id="RM0250U___00004XT00000">
<testtitle>CHECK NAVIGATION SETTING</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Enter the "Menu" screen by pressing the "MENU" switch.</ptxt>
<figure>
<graphic graphicname="E120104E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>Select "Volume".</ptxt>
</test1>
<test1>
<ptxt>Check that "OFF" is not selected.</ptxt>
<figure>
<graphic graphicname="E120106" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>OK</title>
<specitem>
<ptxt>"OFF" is not selected.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000PNM00JX_02_0011" fin="false">OK</down>
<right ref="RM000000PNM00JX_02_0013" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000PNM00JX_02_0011" proc-id="RM0250U___00004XW00000">
<testtitle>CHECK NAVIGATION SETTING</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Enter the "Menu" screen by pressing the "MENU" switch.</ptxt>
<figure>
<graphic graphicname="E120104E03" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>Select "Set up".</ptxt>
</test1>
<test1>
<ptxt>Check that "Voice Guidance in All Modes" is not OFF.</ptxt>
<figure>
<graphic graphicname="E120105E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>OK</title>
<specitem>
<ptxt>Voice guidance in all modes is not OFF.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000PNM00JX_02_0012" fin="false">OK</down>
<right ref="RM000000PNM00JX_02_0004" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000PNM00JX_02_0012" proc-id="RM0250U___00004XX00000">
<testtitle>CHECK NAVIGATION SETTING</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Enter the "Menu" screen by pressing the "MENU" switch.</ptxt>
<figure>
<graphic graphicname="E120104E03" width="2.775699831in" height="1.771723296in"/>
</figure>
</test1>
<test1>
<ptxt>Select "Setup".</ptxt>
</test1>
<test1>
<ptxt>Check that "Auto Voice Guidance" is not OFF.</ptxt>
<figure>
<graphic graphicname="E120107" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>OK</title>
<specitem>
<ptxt>Auto voice guidance is not OFF.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000PNM00JX_02_0005" fin="false">OK</down>
<right ref="RM000000PNM00JX_02_0010" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000PNM00JX_02_0004">
<testtitle>TURN VOICE GUIDANCE IN ALL MODES "ON"</testtitle>
</testgrp>
<testgrp id="RM000000PNM00JX_02_0005" proc-id="RM0250U___00004XU00000">
<testtitle>CHECK MAP DISC</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check that the map disc is not deformed or cracked.</ptxt>
<figure>
<graphic graphicname="I100152E12" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>OK</title>
<specitem>
<ptxt>No deformations or cracks on map disc.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000PNM00JX_02_0007" fin="false">OK</down>
<right ref="RM000000PNM00JX_02_0006" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000PNM00JX_02_0006">
<testtitle>REPLACE MAP DISC</testtitle>
</testgrp>
<testgrp id="RM000000PNM00JX_02_0007" proc-id="RM0250U___00004XV00000">
<testtitle>CHECK RADIO AND NAVIGATION ASSEMBLY</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Check that audio sound can be heard from the driver side speaker.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Audio sound can be heard.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM000000PNM00JX_02_0009" fin="true">OK</down>
<right ref="RM000000PNM00JX_02_0008" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM000000PNM00JX_02_0008">
<testtitle>PROCEED TO NEXT CIRCUIT INSPECTION SHOWN IN PROBLEM SYMPTOMS TABLE</testtitle>
</testgrp>
<testgrp id="RM000000PNM00JX_02_0009">
<testtitle>REPLACE RADIO AND NAVIGATION ASSEMBLY</testtitle>
</testgrp>
<testgrp id="RM000000PNM00JX_02_0010">
<testtitle>TURN AUTO VOICE GUIDANCE "ON"</testtitle>
</testgrp>
<testgrp id="RM000000PNM00JX_02_0013">
<testtitle>TURN VOICE GUIDANCE VOLUME UP TO 4 USING VOICE ADJUSTMENT SWITCHES</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>