<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10024_S000E" variety="S000E">
<name>2AZ-FE STARTING</name>
<ttl id="10024_S000E_72Y8U_T0090" variety="T0090">
<name>STARTER RELAY</name>
<para id="RM000001QNJ007X" category="G" type-id="8000T" name-id="ST0CL-04" from="200601">
<name>ON-VEHICLE INSPECTION</name>
<subpara id="RM000001QNJ007X_01" type-id="01" category="01">
<s-1 id="RM000001QNJ007X_01_0001" proc-id="RM0250U___00003V600000">
<ptxt>INSPECT STARTER RELAY ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using an ohmmeter, measure the resistance between each terminal.</ptxt>
<figure>
<graphic graphicname="E034090E03" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="2" align="center">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester Connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry morerows="1" valign="middle">
<ptxt>3 - 5</ptxt>
</entry>
<entry valign="middle">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Below 1 Ω (when battery voltage is applied to terminals 1 and 2)</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<ptxt>If the result is not as specified, replace the starter relay assembly.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>