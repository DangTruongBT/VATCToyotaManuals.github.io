<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="39">
<name>RESTRAINTS</name>
<section id="1000Y_S0016" variety="S0016">
<name>SUPPLEMENTAL RESTRAINT SYSTEM</name>
<ttl id="1000Y_S0016_72VA2_T004A" variety="T004A">
<name>SIDE AIRBAG SENSOR</name>
<para id="RM000000UWN00GX" category="A" type-id="80001" name-id="RS1QI-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM000000UWN00GX_02" type-id="11" category="10" proc-id="RM0250U___000007X00000">
<content3 releasenbr="1">
<atten4>
<list1 type="unordered">
<item>
<ptxt>Use the same procedures for the RH side and LH side.</ptxt>
</item>
<item>
<ptxt>The procedures listed below are for the LH side.</ptxt>
</item>
</list1>
</atten4>
</content3>
</subpara>
<subpara id="RM000000UWN00GX_01" type-id="01" category="01">
<s-1 id="RM000000UWN00GX_01_0014" proc-id="RM0250U___000007V00000">
<ptxt>PRECAUTION</ptxt>
<content1 releasenbr="1">
<atten2>
<ptxt>Be sure to read "PRECAUTION" thoroughly before servicing (See page <xref label="Seep01" href="RM000000KT1010X"/>).</ptxt>
</atten2>
</content1>
</s-1>
<s-1 id="RM000000UWN00GX_01_0001" proc-id="RM0250U___000007O00000">
<ptxt>DISCONNECT CABLE FROM NEGATIVE BATTERY TERMINAL</ptxt>
<content1 releasenbr="1">
<atten3>
<ptxt>Wait for 90 seconds after disconnecting the cable to prevent airbag deployment.</ptxt>
</atten3>
</content1>
</s-1>
<s-1 id="RM000000UWN00GX_01_0019" proc-id="RM0250U___000044K00000">
<ptxt>REMOVE FRONT DOOR SCUFF PLATE
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 7 claws and 3 clips, and remove the front door scuff plate LH.</ptxt>
<figure>
<graphic graphicname="B132067" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000000UWN00GX_01_0020" proc-id="RM0250U___000044M00000">
<ptxt>REMOVE REAR DOOR SCUFF PLATE
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 5 claws and 2 clips, and remove the rear door scuff plate LH.</ptxt>
<figure>
<graphic graphicname="B132068" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000000UWN00GX_01_0017">
<ptxt>REMOVE FRONT DOOR OPENING TRIM WEATHERSTRIP</ptxt>
</s-1>
<s-1 id="RM000000UWN00GX_01_0018">
<ptxt>REMOVE REAR DOOR OPENING TRIM WEATHERSTRIP</ptxt>
</s-1>
<s-1 id="RM000000UWN00GX_01_0021" proc-id="RM0250U___000044P00000">
<ptxt>REMOVE LOWER CENTER PILLAR GARNISH
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 2 claws and 2 clips, and remove the lower center pillar garnish LH.</ptxt>
<figure>
<graphic graphicname="B132057" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000000UWN00GX_01_0002" proc-id="RM0250U___000007P00000">
<ptxt>REMOVE SIDE AIRBAG SENSOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt and side airbag sensor from the body.</ptxt>
<figure>
<graphic graphicname="C133888" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the connector from the side airbag sensor.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>