<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1002B_S000T" variety="S000T">
<name>U660E AUTOMATIC TRANSAXLE</name>
<ttl id="1002B_S000T_737D4_T00GS" variety="T00GS">
<name>TCM</name>
<para id="RM000002DAK000X" category="A" type-id="80001" name-id="AX10Y-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM000002DAK000X_02" type-id="11" category="10" proc-id="RM0250U___0000CO700000">
<content3 releasenbr="1">
<atten3>
<ptxt>When the TCM is replaced, the existing transaxle compensation codes must be input into the new TCM (See page <xref label="Seep01" href="RM000000TJ400BX_01_0002"/>).</ptxt>
</atten3>
</content3>
</subpara>
<subpara id="RM000002DAK000X_01" type-id="01" category="01">
<s-1 id="RM000002DAK000X_01_0012" proc-id="RM0250U___00009VS00000">
<ptxt>REMOVE COOL AIR INTAKE DUCT SEAL
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 7 clips and intake duct seal.</ptxt>
<figure>
<graphic graphicname="A132967" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000002DAK000X_01_0008" proc-id="RM0250U___00009R300000">
<ptxt>REMOVE BATTERY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Loosen the bolt and nut, and remove the battery clamp.</ptxt>
<figure>
<graphic graphicname="A132972" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the battery and battery tray.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000002DAK000X_01_0009" proc-id="RM0250U___00006SM00000">
<ptxt>REMOVE AIR CLEANER INLET ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts, clamp and air cleaner inlet.</ptxt>
<figure>
<graphic graphicname="A132969" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000002DAK000X_01_0010" proc-id="RM0250U___00006SO00000">
<ptxt>REMOVE NO. 1 AIR CLEANER INLET
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt and No. 1 air cleaner inlet.</ptxt>
<figure>
<graphic graphicname="A132970" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000002DAK000X_01_0011" proc-id="RM0250U___00006SP00000">
<ptxt>REMOVE INTAKE AIR RESONATOR SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the clip, bolt and intake air resonator.</ptxt>
<figure>
<graphic graphicname="A133928" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000002DAK000X_01_0001" proc-id="RM0250U___0000CAV00000">
<ptxt>REMOVE TCM</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Turn the lock lever and disconnect the connector from the TCM.</ptxt>
<figure>
<graphic graphicname="C133604" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts and TCM from the transaxle.</ptxt>
<figure>
<graphic graphicname="C139840E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>