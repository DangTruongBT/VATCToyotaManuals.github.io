<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1000S_S000R" variety="S000R">
<name>CLUTCH</name>
<ttl id="1000S_S000R_73063_T00DY" variety="T00DY">
<name>CLUTCH ACCUMULATOR</name>
<para id="RM000000Z14001X" category="A" type-id="30014" name-id="CL0FL-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000000Z14001X_01" type-id="01" category="01">
<s-1 id="RM000000Z14001X_01_0001" proc-id="RM0250U___00008YU00000">
<ptxt>INSTALL CLUTCH ACCUMULATOR ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the clutch accumulator assembly with the 2 nuts.</ptxt>
<figure>
<graphic graphicname="C132977" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>12</t-value1>
<t-value2>120</t-value2>
<t-value4>9</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z14001X_01_0002" proc-id="RM0250U___00008YV00000">
<ptxt>CONNECT CLUTCH LINE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST, connect the clutch lines to the clutch accumulator assembly.</ptxt>
<figure>
<graphic graphicname="C132976E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09023-00101</s-number>
</sstitem>
</sst>
<torque>
<torqueitem>
<t-value1>15</t-value1>
<t-value2>155</t-value2>
<t-value4>11</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z14001X_01_0006" proc-id="RM0250U___0000A9K00000">
<ptxt>INSTALL RELEASE CYLINDER HEAT INSULATOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the release cylinder heat insulator with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="C132975" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>12</t-value1>
<t-value2>120</t-value2>
<t-value4>9</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z14001X_01_0007" proc-id="RM0250U___0000A9L00000">
<ptxt>INSTALL CLUTCH ACCUMULATOR BRACKET</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the clutch accumulator bracket with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="C132974E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<subtitle>Bolt A</subtitle>
<torqueitem>
<t-value1>12</t-value1>
<t-value2>120</t-value2>
<t-value4>9</t-value4>
</torqueitem>
<subtitle>Bolt B</subtitle>
<torqueitem>
<t-value1>37</t-value1>
<t-value2>380</t-value2>
<t-value4>28</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z14001X_01_0003" proc-id="RM0250U___00008YW00000">
<ptxt>BLEED CLUTCH PIPE LINE</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Fill the brake reservoir with brake fluid and bleed the clutch system.</ptxt>
<torque>
<torqueitem>
<t-value1>8.4</t-value1>
<t-value2>86</t-value2>
<t-value3>74</t-value3>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z14001X_01_0004" proc-id="RM0250U___0000A9M00000">
<ptxt>CHECK FOR BRAKE FLUID LEAKAGE</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Check for leakage in the clutch system.</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM000000Z14001X_01_0015" proc-id="RM0250U___00006Z400000">
<ptxt>INSTALL AIR CLEANER CASE SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air cleaner case with the 3 bolts.</ptxt>
<figure>
<graphic graphicname="A134905" width="2.775699831in" height="2.775699831in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the hose clamp.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000Z14001X_01_0016" proc-id="RM0250U___0000B9900000">
<ptxt>INSTALL AIR CLEANER CAP SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air cleaner filter element onto the air cleaner case.</ptxt>
</s2>
<s2>
<ptxt>Insert the hinges. Install the air cleaner cap sub-assembly with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="A135670" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Align the matchmarks of the No. 1 air cleaner hose and throttle body, and then connect the air cleaner hose No. 1 to the throttle body and unfasten the No. 1 air cleaner hose clamp.</ptxt>
<figure>
<graphic graphicname="A135671E01" width="2.775699831in" height="2.775699831in"/>
</figure>
<atten3>
<ptxt>Make sure that the hose clamp is at the correct angle.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Connect the No. 2 ventilation hose to the air cleaner hose.</ptxt>
<figure>
<graphic graphicname="A135667E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the purge line hose to the clamp (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A135666E02" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the 2 purge VSV vacuum hoses (<sup>*</sup>2).</ptxt>
</s2>
<s2>
<ptxt>Connect the purge VSV connector (<sup>*</sup>3).</ptxt>
</s2>
<s2>
<ptxt>Connect the mass air flow meter connector (<sup>*</sup>4).</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000000Z14001X_01_0017" proc-id="RM0250U___0000ALT00000">
<ptxt>INSTALL AIR CLEANER INLET ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air cleaner inlet with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="A134903" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM000000Z14001X_01_0014">
<ptxt>CHECK BRAKE FLUID LEVEL IN RESERVOIR</ptxt>
</s-1>
<s-1 id="RM000000Z14001X_01_0011">
<ptxt>CONNECT CABLE TO NEGATIVE BATTERY TERMINAL</ptxt>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>