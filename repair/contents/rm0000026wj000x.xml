<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10024_S000P" variety="S000P">
<name>2GR-FE STARTING</name>
<ttl id="10024_S000P_72ZB1_T00BS" variety="T00BS">
<name>STARTER</name>
<para id="RM0000026WJ000X" category="A" type-id="30014" name-id="ST0WU-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM0000026WJ000X_01" type-id="01" category="01">
<s-1 id="RM0000026WJ000X_01_0001" proc-id="RM0250U___00006J400000">
<ptxt>INSTALL STARTER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the starter assembly with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="A133864" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>37</t-value1>
<t-value2>380</t-value2>
<t-value4>28</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the wire harness to terminal 30 and install the nut. Then, attach the terminal cap.</ptxt>
<torque>
<torqueitem>
<t-value1>9.8</t-value1>
<t-value2>100</t-value2>
<t-value3>87</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the terminal 50 connector to the starter assembly.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000026WJ000X_01_0010" proc-id="RM0250U___00006RC00000">
<ptxt>INSTALL NO. 1 AIR CLEANER INLET
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the No. 1 air cleaner inlet with the bolt.</ptxt>
<figure>
<graphic graphicname="A132970" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM0000026WJ000X_01_0011" proc-id="RM0250U___00006RD00000">
<ptxt>INSTALL AIR CLEANER CASE SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air cleaner case with the 3 bolts.</ptxt>
<figure>
<graphic graphicname="A132971" width="2.775699831in" height="2.775699831in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the vacuum hose and hose clamp.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000026WJ000X_01_0016" proc-id="RM0250U___0000BRT00000">
<ptxt>INSTALL AIR CLEANER CAP SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air cleaner cap sub-assembly, and connect the 3 bands.</ptxt>
<figure>
<graphic graphicname="A135706" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the mass air flow meter connector (<sup>*</sup>1). </ptxt>
<figure>
<graphic graphicname="A135705E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Connect the No. 2 ventilation hose (<sup>*</sup>2).</ptxt>
</s2>
<s2>
<ptxt>Connect the hose band (<sup>*</sup>3).</ptxt>
</s2>
<s2>
<ptxt>Connect the 3 vacuum hoses.</ptxt>
<figure>
<graphic graphicname="A135704" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000026WJ000X_01_0012" proc-id="RM0250U___00006RE00000">
<ptxt>INSTALL AIR CLEANER INLET ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the air cleaner inlet with the clamp and 2 bolts.</ptxt>
<figure>
<graphic graphicname="A132969" width="2.775699831in" height="2.775699831in"/>
</figure>
<torque>
<torqueitem>
<t-value1>5.0</t-value1>
<t-value2>51</t-value2>
<t-value3>44</t-value3>
</torqueitem>
</torque>
</s2>
</content1></s-1>
<s-1 id="RM0000026WJ000X_01_0013" proc-id="RM0250U___00006RL00000">
<ptxt>INSTALL V-BANK COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Fit the 3 retainers and install the V-bank cover.</ptxt>
<figure>
<graphic graphicname="A132968" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000026WJ000X_01_0014" proc-id="RM0250U___0000A5U00000">
<ptxt>INSTALL COOL AIR INTAKE DUCT SEAL
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the intake duct seal with the 7 clips.</ptxt>
<figure>
<graphic graphicname="A132967" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000026WJ000X_01_0015" proc-id="RM0250U___0000A6600000">
<ptxt>CONNECT CABLE TO NEGATIVE BATTERY TERMINAL
</ptxt>
<content1 releasenbr="1">
<torque>
<torqueitem>
<t-value1>6.9</t-value1>
<t-value2>70</t-value2>
<t-value3>61</t-value3>
</torqueitem>
</torque>
</content1></s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>