<entry valign="middle" align="center">
<ptxt>A-1 (CCS) - A-3 (ECC)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>- (COAST)/SET</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>567 to 693 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>A-1 (CCS) - A-3 (ECC)</ptxt>
