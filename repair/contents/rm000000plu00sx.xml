</entry>
<entry valign="middle">
<ptxt>Center</ptxt>
</entry>
<entry morerows="2" valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>2.5 rotations to the left</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>2.5 rotations to the right</ptxt>
</entry>
</row>
<row>
<entry morerows="2" valign="middle">
<ptxt>b1-4 - E18-2 (ECC)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Center</ptxt>
</entry>
<entry morerows="2" valign="middle">
<ptxt>Below 1 Ω</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>2.5 rotations to the left</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>2.5 rotations to the right</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<atten4>
<ptxt>The spiral cable makes a maximum of approximately 5 rotations.</ptxt>
</atten4>
</content6>
<res>
<down ref="RM000000PLU00SX_04_0005" fin="false">OK</down>
<right ref="RM000000PLU00SX_04_0009" fin="true">NG</right>
</res>
