<test1>
<ptxt>Remove the spiral cable.</ptxt>
</test1>
<figure>
<graphic graphicname="E106780E15" width="2.775699831in" height="4.7836529in"/>
</figure>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
