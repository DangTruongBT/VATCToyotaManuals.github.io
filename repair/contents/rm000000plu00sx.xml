<ptxt>Remove the cruise control main switch (See page <xref label="Seep01" href="RM000000VQ3007X"/>).</ptxt>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<figure>
<graphic graphicname="E106137E06" width="7.106578999in" height="3.779676365in"/>
</figure>
</test1>
<spec>
<title>Standard resistance</title>
<table pgwide="1">
<tgroup cols="3">
<colspec colname="COL1" colwidth="2.36in"/>
<colspec colname="COL2" colwidth="2.36in"/>
<colspec colname="COL3" colwidth="2.36in"/>
<thead>
<row>
