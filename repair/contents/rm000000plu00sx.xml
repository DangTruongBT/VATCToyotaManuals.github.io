</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>A-1 (CCS) - A-3 (ECC)</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Neutral</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>10 kΩ or higher</ptxt>
</entry>
</row>
<row>
<entry valign="middle" align="center">
<ptxt>A-1 (CCS) - A-3 (ECC)</ptxt>
</entry>
<entry valign="middle" align="center">
