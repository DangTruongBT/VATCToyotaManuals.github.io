<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1001A_S001B" variety="S001B">
<name>LIGHTING</name>
<ttl id="1001A_S001B_72Y72_T008V" variety="T008V">
<name>IGNITION KEY CYLINDER LIGHT</name>
<para id="RM000001983005X" category="G" type-id="3001K" name-id="LI1FT-02" from="200601">
<name>INSPECTION</name>
<subpara id="RM000001983005X_01" type-id="01" category="01">
<s-1 id="RM000001983005X_01_0001" proc-id="RM0250U___00004J000000">
<ptxt>INSPECT TRANSPONDER KEY AMPLIFIER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply battery voltage to the transponder key amplifier connector.</ptxt>
<figure>
<graphic graphicname="E074066E03" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Check that the ignition key cylinder light comes on.</ptxt>
<spec>
<title>OK</title>
<table>
<tgroup cols="2">
<colspec colname="COL1" colwidth="2.07in"/>
<colspec colname="COL2" colwidth="2.06in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Measurement Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Specified Condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>Battery positive (+) → Terminal 2 (ILL+)</ptxt>
<ptxt>Battery negative (-) → Terminal 6 (ILL-)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Ignition key cylinder light comes on</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
<ptxt>If the result is not as specified, replace the transponder key amplifier.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>