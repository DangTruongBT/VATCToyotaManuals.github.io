<tmc-service-inc>
<pub id="RM0251U">
<servcat id="43">
<name>BODY</name>
<section id="1001H_S001L" variety="S001L">
<name>SEAT</name>
<ttl id="1001H_S001L_72WMY_T006K" variety="T006K">
<name>REAR SEAT ASSEMBLY (for Fixed Type)</name>
<para id="RM000000VBJ004X" category="A" type-id="30014" name-id="SE0OM-01" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000000VBJ004X_01" type-id="01" category="01">
<s-1 id="RM000000VBJ004X_01_0001" proc-id="RM0250U___000056U00000">
<ptxt>INSTALL REAR SEAT BACK ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Place the seat back in the cabin.</ptxt>
<figure>
<graphic graphicname="B136577" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten3>
<ptxt>Be careful not to damage the vehicle body.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Install the rear seat back assembly with the 4 bolts.</ptxt>
<torque>
<torqueitem>
<t-value1>18</t-value1>
<t-value2>184</t-value2>
<t-value4>13</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Pass the 3 seat belts through and close the cap of the 2 rear seat shoulder belt guides.</ptxt>
<figure>
<graphic graphicname="B136576" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the floor anchor part with the bolt.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000000VBJ004X_01_0002">
<ptxt>INSTALL REAR CENTER SEAT HEADREST ASSEMBLY</ptxt>
</s-1>
<s-1 id="RM000000VBJ004X_01_0003">
<ptxt>INSTALL REAR SEAT HEADREST ASSEMBLY</ptxt>
</s-1>
<s-1 id="RM000000VBJ004X_01_0004" proc-id="RM0250U___000056V00000">
<ptxt>INSTALL REAR SEAT CUSHION ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Attach the 2 front hooks of the seat cushion to the vehicle body.</ptxt>
<figure>
<graphic graphicname="B140589E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Confirm that the seat cushion is firmly installed.</ptxt>
<atten3>
<ptxt>When installing the seat cushion, make sure the seat belt buckle is not under the seat cushion.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>