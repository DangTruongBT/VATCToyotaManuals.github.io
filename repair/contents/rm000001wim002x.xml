<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1001A_S001B" variety="S001B">
<name>LIGHTING</name>
<ttl id="1001A_S001B_72Y3P_T008I" variety="T008I">
<name>GLOVE BOX LIGHT</name>
<para id="RM000001WIM002X" category="A" type-id="80001" name-id="LI23T-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM000001WIM002X_01" type-id="01" category="01">
<s-1 id="RM000001WIM002X_01_0011" proc-id="RM0250U___000044R00000">
<ptxt>REMOVE FRONT DOOR SCUFF PLATE RH
</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedure for the RH side and the LH side.</ptxt>
</atten4>
</content1></s-1>
<s-1 id="RM000001WIM002X_01_0012" proc-id="RM0250U___000044S00000">
<ptxt>REMOVE COWL SIDE TRIM SUB-ASSEMBLY RH
</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>Use the same procedure for the RH side and the LH side.</ptxt>
</atten4>
</content1></s-1>
<s-1 id="RM000001WIM002X_01_0013" proc-id="RM0250U___00005C100000">
<ptxt>REMOVE INSTRUMENT PANEL NO. 2 UNDER COVER SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disengage the 4 claws.</ptxt>
<figure>
<graphic graphicname="B133988E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Disengage the 2 guides and remove the No. 2 under cover sub-assembly.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001WIM002X_01_0014" proc-id="RM0250U___00005C200000">
<ptxt>REMOVE LOWER INSTRUMENT PANEL SUB-ASSEMBLY (for TMC Made)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt &lt;A&gt;.</ptxt>
<figure>
<graphic graphicname="B133992E01" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 4 screws &lt;B&gt;.</ptxt>
</s2>
<s2>
<ptxt>Disengage the 3 claws and the 3 clips.</ptxt>
</s2>
<s2>
<ptxt>Disconnect the connector and remove the lower instrument panel sub-assembly.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001WIM002X_01_0015" proc-id="RM0250U___00005C300000">
<ptxt>REMOVE LOWER INSTRUMENT PANEL SUB-ASSEMBLY (for TMMK Made)
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bolt &lt;N&gt;.</ptxt>
<figure>
<graphic graphicname="B133992E02" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the screw &lt;O&gt; or &lt;P&gt; and the 3 screws &lt;O&gt;.</ptxt>
</s2>
<s2>
<ptxt>Disengage the 3 claws and the 3 clips.</ptxt>
</s2>
<s2>
<ptxt>Disconnect the connector and remove the lower instrument panel sub-assembly.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001WIM002X_01_0008" proc-id="RM0250U___00003GG00000">
<ptxt>REMOVE GLOVE BOX LIGHT ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the connector.</ptxt>
<figure>
<graphic graphicname="E128205" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disengage the 2 claws and remove the glove box light assembly.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>