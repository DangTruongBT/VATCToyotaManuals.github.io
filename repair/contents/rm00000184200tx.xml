<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="42">
<name>BODY ELECTRICAL</name>
<section id="1001C_S001D" variety="S001D">
<name>AUDIO / VISUAL</name>
<ttl id="1001C_S001D_72YIE_T00A3" variety="T00A3">
<name>AUDIO AND VISUAL SYSTEM</name>
<para id="RM00000184200TX" category="J" type-id="80137" name-id="AV1F1-01" from="200601">
<dtccode/>
<dtcname>Stereo Component Amplifier Communication Error</dtcname>
<subpara id="RM00000184200TX_01" type-id="51" category="05">
<name>INSPECTION PROCEDURE</name>
</subpara>
<subpara id="RM00000184200TX_02" type-id="01" category="01">
<name>PROCEDURE</name>
<testgrp id="RM00000184200TX_02_0010" proc-id="RM0250U___00004TL00000">
<testtitle>IDENTIFY THE COMPONENT SHOWN BY SUB-CODE</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Enter the diagnostic mode.</ptxt>
<figure>
<graphic graphicname="E110917E05" width="7.106578999in" height="6.791605969in"/>
</figure>
</test1>
<test1>
<ptxt>Press the preset switch "3" to change to "Detailed Information Mode".</ptxt>
</test1>
<test1>
<ptxt>Identify the component shown by the sub-code.</ptxt>
</test1>
<atten4>
<list1 type="unordered">
<item>
<ptxt>"190 (radio receiver)" is the component shown by the sub-code in the example shown in the illustration.</ptxt>
</item>
</list1>
<list1 type="unordered">
<item>
<ptxt>For details of the DTC display, refer to "DTC CHECK/CLEAR" (See page <xref label="Seep01" href="RM0000014CZ00FX"/>).</ptxt>
</item>
</list1>
</atten4>
</content6>
<res>
<down ref="RM00000184200TX_02_0001" fin="false">NEXT</down>
</res>
</testgrp>
<testgrp id="RM00000184200TX_02_0001" proc-id="RM0250U___00004TH00000">
<testtitle>CHECK POWER SOURCE CIRCUIT OF COMPONENT SHOWN BY SUB-CODE</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Inspect the power source circuit of the component shown by the sub-code.</ptxt>
<ptxt>If the power source circuit is operating normally, proceed to the next step.</ptxt>
<atten4>
<ptxt>The "Bluetooth" handsfree module is built into the radio receiver.</ptxt>
</atten4>
<table pgwide="1">
<title>Component Table:</title>
<tgroup cols="2">
<colspec colname="COL1" colwidth="3.54in"/>
<colspec colname="COL2" colwidth="3.54in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>Component</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Proceed to</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>"Bluetooth" handsfree module (19D)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Radio receiver power source circuit (See page <xref label="Seep02" href="RM0000012CI00IX"/>)</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>Radio receiver (190)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Radio receiver power source circuit (See page <xref label="Seep03" href="RM0000012CI00IX"/>)</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</test1>
</content6>
<res>
<down ref="RM00000184200TX_02_0002" fin="false">NEXT</down>
</res>
</testgrp>
<testgrp id="RM00000184200TX_02_0002" proc-id="RM0250U___00004TI00000">
<testtitle>INSPECT RADIO RECEIVER</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Disconnect the radio receiver connector.</ptxt>
<figure>
<graphic graphicname="E129798E04" width="2.775699831in" height="2.775699831in"/>
</figure>
</test1>
<test1>
<ptxt>Measure the resistance according to the value(s) in the table below.</ptxt>
<spec>
<title>Standard resistance</title>
<table>
<tgroup cols="3" align="center">
<colspec colname="COL1" colwidth="1.38in"/>
<colspec colname="COL2" colwidth="1.38in"/>
<colspec colname="COL3" colwidth="1.37in"/>
<thead>
<row>
<entry valign="middle">
<ptxt>Tester connection</ptxt>
</entry>
<entry valign="middle">
<ptxt>Condition</ptxt>
</entry>
<entry valign="middle">
<ptxt>Specified condition</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>ATX+ (F26-5) - ATX- (F26-15)</ptxt>
</entry>
<entry valign="middle">
<ptxt>Always</ptxt>
</entry>
<entry valign="middle">
<ptxt>60 to 80 Ω</ptxt>
</entry>
</row>
</tbody>
</tgroup>
</table>
</spec>
</test1>
</content6>
<res>
<down ref="RM00000184200TX_02_0003" fin="false">OK</down>
<right ref="RM00000184200TX_02_0006" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM00000184200TX_02_0003" proc-id="RM0250U___00004TJ00000">
<testtitle>CHECK HARNESS AND CONNECTOR (STEREO COMPONENT AMPLIFIER - COMPONENT SHOWN BY SUB-CODE)</testtitle>
<content6 releasenbr="1">
<atten4>
<list1 type="unordered">
<item>
<ptxt>Start the check from the circuit that is near the component shown by the sub-code first.</ptxt>
</item>
</list1>
<list1 type="unordered">
<item>
<ptxt>For details of the connectors, refer to the "TERMINALS OF ECU" (See page <xref label="Seep01" href="RM0000012A700EX"/>).</ptxt>
</item>
</list1>
</atten4>
<test1>
<ptxt>Referring to the AVC-LAN wiring diagram below, check the AVC-LAN circuit between the stereo component amplifier and the component shown by the sub-code.</ptxt>
<test2>
<ptxt>Disconnect all connectors between the stereo component amplifier and the component shown by the sub-code.</ptxt>
</test2>
<test2>
<ptxt>Check for an open or short in the AVC-LAN circuit between the stereo component amplifier and the component shown by the sub-code.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>There is no open or short circuit.</ptxt>
</specitem>
</spec>
<figure>
<graphic graphicname="E111831E15" width="7.106578999in" height="3.779676365in"/>
</figure>
</test2>
</test1>
</content6>
<res>
<down ref="RM00000184200TX_02_0004" fin="false">OK</down>
<right ref="RM00000184200TX_02_0007" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM00000184200TX_02_0004" proc-id="RM0250U___00004TK00000">
<testtitle>REPLACE COMPONENT SHOWN BY SUB-CODE</testtitle>
<content6 releasenbr="1">
<test1>
<ptxt>Replace the component shown by the sub-code with a normal one and check if the same problem occurs again.</ptxt>
<spec>
<title>OK</title>
<specitem>
<ptxt>Same problem does not occur.</ptxt>
</specitem>
</spec>
</test1>
</content6>
<res>
<down ref="RM00000184200TX_02_0005" fin="true">OK</down>
<right ref="RM00000184200TX_02_0008" fin="true">NG</right>
</res>
</testgrp>
<testgrp id="RM00000184200TX_02_0005">
<testtitle>END</testtitle>
</testgrp>
<testgrp id="RM00000184200TX_02_0006">
<testtitle>REPLACE RADIO RECEIVER</testtitle>
</testgrp>
<testgrp id="RM00000184200TX_02_0007">
<testtitle>REPAIR OR REPLACE HARNESS OR CONNECTOR</testtitle>
</testgrp>
<testgrp id="RM00000184200TX_02_0008">
<testtitle>REPLACE STEREO COMPONENT AMPLIFIER</testtitle>
</testgrp>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>