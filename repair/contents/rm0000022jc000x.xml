<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="36">
<name>BRAKE</name>
<section id="1000N_S0011" variety="S0011">
<name>BRAKE</name>
<ttl id="1000N_S0011_72V8P_T003M" variety="T003M">
<name>BRAKE PEDAL</name>
<para id="RM0000022JC000X" category="A" type-id="8000E" name-id="BR0XI-01" from="200601">
<name>REASSEMBLY</name>
<subpara id="RM0000022JC000X_01" type-id="01" category="01">
<s-1 id="RM0000022JC000X_01_0001" proc-id="RM0250U___00003OT00000">
<ptxt>INSTALL BRAKE PEDAL PAD</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the brake pedal pad.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022JC000X_01_0002" proc-id="RM0250U___00003OU00000">
<ptxt>INSTALL BRAKE PEDAL SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Apply lithium soap base glycol grease to 2 new brake pedal bushings.</ptxt>
</s2>
<s2>
<ptxt>Install the brake pedal sub-assembly, the 2 brake pedal bushings, and the brake pedal shaft collar to the brake pedal support assembly with the bolt and the nut as shown in the illustration.</ptxt>
<figure>
<graphic graphicname="C132723" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>37</t-value1>
<t-value2>377</t-value2>
<t-value4>27</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022JC000X_01_0003" proc-id="RM0250U___00008KS00000">
<ptxt>INSTALL STOP LIGHT SWITCH MOUNTING ADJUSTER</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the stop light switch mounting adjuster.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM0000022JC000X_01_0004" proc-id="RM0250U___00005EL00000">
<ptxt>TEMPORARILY TIGHTEN STOP LIGHT SWITCH ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Temporarily tighten the stop light switch assembly as shown in the illustration.</ptxt>
<torque>
<torqueitem>
<t-value1>1.5</t-value1>
<t-value2>15</t-value2>
<t-value3>13</t-value3>
<ptxt>or less</ptxt>
</torqueitem>
</torque>
<figure>
<graphic graphicname="C132726" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten4>
<ptxt>Completely install the stop light switch assembly after adjusting the brake pedal height.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>