<name>ROCKER PANEL MOULDING</name>
<para id="RM000000MN5003X" category="A" type-id="30014" name-id="ET0LQ-02" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000000MN5003X_01" type-id="01" category="01">
<s-1 id="RM000000MN5003X_01_0001" proc-id="RM0250U___00005US00000">
<ptxt>INSTALL ROCKER PANEL MOULDING</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Engage the 8 clips and install the rocker panel moulding.</ptxt>
<figure>
<graphic graphicname="B135476" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 2 screws.</ptxt>
<figure>
<graphic graphicname="B135474" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the 7 clips.</ptxt>
<figure>
<graphic graphicname="B135475" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install the screw.</ptxt>
<figure>
<graphic graphicname="B135473" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Install a new grommet and 2 screws.</ptxt>
<figure>
<graphic graphicname="B135472" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM000000MN5003X_01_0002" proc-id="RM0250U___00005UT00000">
<ptxt>INSTALL ROCKER PANEL MOULDING PROTECTOR</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the rocker panel moulding protector with the 2 screws.</ptxt>
<figure>
<graphic graphicname="B135471" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
