<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="35">
<name>SUSPENSION &amp; AXLE</name>
<section id="1002H_S000Y" variety="S000Y">
<name>AXLE</name>
<ttl id="1002H_S000Y_72ZYN_T00CW" variety="T00CW">
<name>REAR AXLE CARRIER</name>
<para id="RM000001IXN001X" category="A" type-id="30014" name-id="AH0A6-02" from="200601">
<name>INSTALLATION</name>
<subpara id="RM000001IXN001X_01" type-id="01" category="01">
<s-1 id="RM000001IXN001X_01_0001" proc-id="RM0250U___000087I00000">
<ptxt>INSTALL REAR AXLE CARRIER SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the rear axle carrier sub-assembly to the shock absorber with the 2 bolts and 2 nuts.</ptxt>
<figure>
<graphic graphicname="C129156" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>180</t-value1>
<t-value2>1,836</t-value2>
<t-value4>133</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IXN001X_01_0002" proc-id="RM0250U___000087J00000">
<ptxt>TEMPORARILY TIGHTEN REAR NO. 1 SUSPENSION ARM</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Temporarily tighten the rear No. 1 suspension arm with the bolt and nut.</ptxt>
<figure>
<graphic graphicname="G025995" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten4>
<ptxt>Insert the bolt from the rear side of the vehicle and temporarily tighten the bolt.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IXN001X_01_0003" proc-id="RM0250U___000087K00000">
<ptxt>TEMPORARILY TIGHTEN REAR NO. 2 SUSPENSION ARM</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Temporarily tighten the rear No. 2 suspension arm with the bolt and nut.</ptxt>
<figure>
<graphic graphicname="G024053" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten4>
<ptxt>Insert the bolt from the rear side of the vehicle and temporarily tighten the bolt.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IXN001X_01_0004" proc-id="RM0250U___000087L00000">
<ptxt>TEMPORARILY TIGHTEN REAR STRUT ROD</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Temporarily tighten the rear strut rod with the bolt and nut.</ptxt>
<atten4>
<ptxt>Insert the bolt from the inside of the vehicle and temporarily tighten the bolt.</ptxt>
</atten4>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IXN001X_01_0025" proc-id="RM0250U___000087700000">
<ptxt>INSTALL REAR AXLE HUB AND BEARING ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the hub and bearing assembly with the 4 bolts.</ptxt>
<figure>
<graphic graphicname="C083035E02" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>80</t-value1>
<t-value2>816</t-value2>
<t-value4>59</t-value4>
</torqueitem>
</torque>
</s2>
<s2>
<ptxt>Connect the skid control sensor connector.</ptxt>
<atten3>
<ptxt>Do not twist the sensor wire when connecting it.</ptxt>
</atten3>
</s2>
</content1></s-1>
<s-1 id="RM000001IXN001X_01_0018" proc-id="RM0250U___000087B00000">
<ptxt>INSPECT REAR AXLE HUB BEARING LOOSENESS
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a dial indicator, check for looseness near the center of the axle hub.</ptxt>
<figure>
<graphic graphicname="C119285" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Maximum</title>
<specitem>
<ptxt>0.05 mm (0.0020 in.)</ptxt>
</specitem>
</spec>
<atten3>
<ptxt>Ensure that the dial indicator is set perpendicular to the measurement surface.</ptxt>
</atten3>
<ptxt>If looseness exceeds the maximum, replace the axle hub assembly.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001IXN001X_01_0019" proc-id="RM0250U___000087C00000">
<ptxt>INSPECT REAR AXLE HUB RUNOUT
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a dial indicator, check for runout on the surface of the axle hub outside the hub bolt.</ptxt>
<figure>
<graphic graphicname="C119286" width="2.775699831in" height="1.771723296in"/>
</figure>
<spec>
<title>Maximum</title>
<specitem>
<ptxt>0.07 mm (0.0027 in.)</ptxt>
</specitem>
</spec>
<atten3>
<ptxt>Ensure that the dial indicator is set perpendicular to the measurement surface.</ptxt>
</atten3>
<ptxt>If runout exceeds the maximum, replace the axle hub assembly.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM000001IXN001X_01_0026" proc-id="RM0250U___00003RR00000">
<ptxt>INSTALL REAR DISC
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Aligning the matchmarks, install the rear disc.</ptxt>
<figure>
<graphic graphicname="C132813E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<atten4>
<ptxt>When replacing the rear disc with a new one, select the installation position where the rear disc has the minimum runout.</ptxt>
</atten4>
</s2>
</content1></s-1>
<s-1 id="RM000001IXN001X_01_0010" proc-id="RM0250U___000087O00000">
<ptxt>INSTALL REAR DISC BRAKE CALIPER ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Install the rear disc brake caliper with the 2 bolts.</ptxt>
<figure>
<graphic graphicname="C083008E03" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>62</t-value1>
<t-value2>630</t-value2>
<t-value4>46</t-value4>
</torqueitem>
</torque>
<atten3>
<ptxt>Do not twist the brake hose when installing the rear disc brake caliper assembly LH.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Install the rear flexible hose with the bolt.</ptxt>
<figure>
<graphic graphicname="C083014E03" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>19</t-value1>
<t-value2>192</t-value2>
<t-value4>14</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IXN001X_01_0011" proc-id="RM0250U___000087P00000">
<ptxt>INSTALL REAR WHEEL</ptxt>
<content1 releasenbr="1">
<torque>
<torqueitem>
<t-value1>103</t-value1>
<t-value2>1,050</t-value2>
<t-value4>76</t-value4>
</torqueitem>
</torque>
</content1>
</s-1>
<s-1 id="RM000001IXN001X_01_0020" proc-id="RM0250U___00000IT00000">
<ptxt>STABILIZE SUSPENSION
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Jack up the rear axle carrier, placing a wooden block to avoid damage. Apply load to the suspension so that the installed bolt of the rear suspension No. 1 arm (inner side of vehicle) is horizontally aligned with the center of the rear axle hub.</ptxt>
<figure>
<graphic graphicname="C108450E01" width="2.775699831in" height="3.779676365in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001IXN001X_01_0021" proc-id="RM0250U___0000AW200000">
<ptxt>FULLY TIGHTEN REAR NO. 1 SUSPENSION ARM</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Fully tighten the bolt.</ptxt>
<figure>
<graphic graphicname="C132483" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>100</t-value1>
<t-value2>1,020</t-value2>
<t-value4>74</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IXN001X_01_0022" proc-id="RM0250U___0000AW300000">
<ptxt>FULLY TIGHTEN REAR NO. 2 SUSPENSION ARM</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Fully tighten the bolt.</ptxt>
<figure>
<graphic graphicname="C132492" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>100</t-value1>
<t-value2>1,020</t-value2>
<t-value4>74</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IXN001X_01_0023" proc-id="RM0250U___0000AW400000">
<ptxt>FULLY TIGHTEN REAR STRUT ROD</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Fully tighten the bolt.</ptxt>
<figure>
<graphic graphicname="C132476" width="2.775699831in" height="1.771723296in"/>
</figure>
<torque>
<torqueitem>
<t-value1>113</t-value1>
<t-value2>1,150</t-value2>
<t-value4>83</t-value4>
</torqueitem>
</torque>
</s2>
</content1>
</s-1>
<s-1 id="RM000001IXN001X_01_0027" proc-id="RM0250U___00000LW00000">
<ptxt>CONNECT SKID CONTROL SENSOR CONNECTOR
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Connect the connector to the skid control sensor.</ptxt>
<figure>
<graphic graphicname="C143907" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM000001IXN001X_01_0016" proc-id="RM0250U___000087Q00000">
<ptxt>ADJUST REAR WHEEL ALIGNMENT</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>See page <xref label="Seep01" href="RM0000011DQ004X"/>
</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM000001IXN001X_01_0024" proc-id="RM0250U___0000CE300000">
<ptxt>CHECK ABS SPEED SENSOR SIGNAL</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>ABS: See page <xref label="Seep01" href="RM000001JBD002X"/>
</ptxt>
</s2>
<s2>
<ptxt>VSC (for BOSCH): See page <xref label="Seep02" href="RM000001NKD001X"/>
</ptxt>
</s2>
<s2>
<ptxt>VSC (for ADVICS): See page <xref label="Seep03" href="RM000000XHT00AX"/>
</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
