<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="33">
<name>TRANSMISSION</name>
<section id="1000S_S000R" variety="S000R">
<name>CLUTCH</name>
<ttl id="1000S_S000R_73062_T00DX" variety="T00DX">
<name>CLUTCH RELEASE CYLINDER</name>
<para id="RM000000Z12001X" category="A" type-id="80002" name-id="CL0FG-01" from="200601">
<name>DISASSEMBLY</name>
<subpara id="RM000000Z12001X_01" type-id="01" category="01">
<s-1 id="RM000000Z12001X_01_0004" proc-id="RM0250U___00008YN00000">
<ptxt>REMOVE CLUTCH RELEASE CYLINDER KIT</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the boot from the cylinder body.</ptxt>
</s2>
<s2>
<ptxt>Remove the push rod from the cylinder body.</ptxt>
</s2>
<s2>
<ptxt>Remove the piston from the cylinder body.</ptxt>
<atten3>
<ptxt>Be careful not to damage the inside of the cylinder body.</ptxt>
</atten3>
</s2>
<s2>
<ptxt>Remove the spring from the cylinder body.</ptxt>
</s2>
<s2>
<ptxt>Remove the bleeder plug cap from the bleeder plug.</ptxt>
</s2>
</content1>
</s-1>
<s-1 id="RM000000Z12001X_01_0005" proc-id="RM0250U___0000BIR00000">
<ptxt>REMOVE RELEASE CYLINDER BLEEDER PLUG</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the bleeder plug from the cylinder body.</ptxt>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>