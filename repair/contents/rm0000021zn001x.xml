<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="1000A_S000J" variety="S000J">
<name>2GR-FE ENGINE MECHANICAL</name>
<ttl id="1000A_S000J_72ZHB_T00C8" variety="T00C8">
<name>ENGINE REAR OIL SEAL</name>
<para id="RM0000021ZN001X" category="A" type-id="80001" name-id="EM0XW-02" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000021ZN001X_01" type-id="01" category="01">
<s-1 id="RM0000021ZN001X_01_0004" proc-id="RM0250U___00009PO00000">
<ptxt>REMOVE AUTOMATIC TRANSAXLE ASSEMBLY</ptxt>
<content1 releasenbr="1">
<atten4>
<ptxt>See page <xref label="Seep01" href="RM0000016DV004X"/>.</ptxt>
</atten4>
</content1>
</s-1>
<s-1 id="RM0000021ZN001X_01_0002" proc-id="RM0250U___00006Q800000">
<ptxt>REMOVE DRIVE PLATE AND RING GEAR SUB-ASSEMBLY</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using SST, hold the crankshaft.</ptxt>
<figure>
<graphic graphicname="A129631E01" width="2.775699831in" height="1.771723296in"/>
</figure>
<sst>
<sstitem>
<s-number>09213-70011</s-number>
<s-subnumber>09213-70020</s-subnumber>
</sstitem>
<sstitem>
<s-number>09330-00021</s-number>
</sstitem>
</sst>
</s2>
<s2>
<ptxt>Remove the 8 bolts, front spacer, drive plate and rear spacer.</ptxt>
<figure>
<graphic graphicname="A132243" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000021ZN001X_01_0003" proc-id="RM0250U___00006Q900000">
<ptxt>REMOVE ENGINE REAR OIL SEAL</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Using a knife, cut off the oil seal lip.</ptxt>
<figure>
<graphic graphicname="A132244E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Using a screwdriver, pry out the oil seal.</ptxt>
<atten3>
<ptxt>Be careful not to damage the crankshaft. Tape the screwdriver tip before use.</ptxt>
</atten3>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>