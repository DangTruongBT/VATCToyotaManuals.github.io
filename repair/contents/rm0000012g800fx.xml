<step1>
<ptxt>COMBINATION METER ASSEMBLY</ptxt>
<atten3>
<list1 type="nonmark">
<item>
<ptxt>Be sure to record the current value before customizing.</ptxt>
</item>
</list1>
</atten3>
<atten4>
<ptxt>The following items can be customized using intelligent tester.</ptxt>
</atten4>
<table pgwide="1">
<title>METER:</title>
<tgroup cols="4">
<colspec colname="COL1" colwidth="1.75in"/>
<colspec colname="COL2" colwidth="1.78in"/>
