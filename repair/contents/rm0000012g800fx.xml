<ptxt>Tester Display</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Default</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Contents</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Setting</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle">
<ptxt>KEY REMND VOLUM</ptxt>
</entry>
<entry valign="middle">
<ptxt>LARGE</ptxt>
</entry>
<entry valign="middle">
<ptxt>Function to change the volume of the key remind warning buzzer</ptxt>
</entry>
<entry valign="middle">
<ptxt>LARGE, MEDIUM, SMALL</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>KEY REMND SOUND</ptxt>
</entry>
<entry valign="middle">
<ptxt>NORMAL</ptxt>
</entry>
<entry valign="middle">
<ptxt>Function to change the cycle of the key remind warning buzzer</ptxt>
</entry>
<entry valign="middle">
<ptxt>FAST, NORMAL, SLOW</ptxt>
</entry>
</row>
<row>
<entry valign="middle">
<ptxt>SEAT-BELT WARN</ptxt>
</entry>
<entry valign="middle">
<ptxt>D/P ON</ptxt>
</entry>
<entry valign="middle">
<ptxt>Function to change the setting of the seat belt buzzer.</ptxt>
</entry>
<entry valign="middle">
<ptxt>D/P on, D ON, P on, D/P off</ptxt>
</entry>
</row>
</tbody>
