<para id="RM0000011M1005X" category="C" type-id="300V0" name-id="LI20D-01" from="200601">
<dtccode>B1244</dtccode>
<dtcname>Light Sensor Circuit Malfunction</dtcname>
<subpara id="RM0000011M1005X_01" type-id="60" category="03" proc-id="RM0250U___00004MI00000">
<name>DESCRIPTION</name>
<content5 releasenbr="1">
<ptxt>The automatic light control sensor detects ambient light, converts it into an electrical signal, and outputs it to the main body ECU. The main body ECU turns on or off the headlights and taillights according to the signal.</ptxt>
<table pgwide="1">
<tgroup cols="3" align="left">
<colspec colname="COL1" colwidth="1.42in"/>
<colspec colname="COL2" colwidth="2.83in"/>
<colspec colname="COL3" colwidth="2.83in"/>
<thead>
<row>
<entry valign="middle" align="center">
<ptxt>DTC No.</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>DTC Detecting Condition</ptxt>
</entry>
<entry valign="middle" align="center">
<ptxt>Trouble Area</ptxt>
</entry>
</row>
</thead>
<tbody>
<row>
<entry valign="middle" align="center">
<ptxt>B1244</ptxt>
</entry>
<entry valign="middle">
<list1 type="unordered">
<item>
<ptxt>Malfunction in automatic light control sensor</ptxt>
</item>
<item>
<ptxt>Open or short in automatic light control sensor circuit</ptxt>
</item>
</list1>
</entry>
<entry valign="middle">
<list1 type="unordered">
<item>
<ptxt>Automatic light control sensor</ptxt>
</item>
<item>
<ptxt>Harness or connector</ptxt>
</item>
<item>
<ptxt>Main body ECU (Instrument panel J/B)</ptxt>
</item>
</list1>
</entry>
</row>
</tbody>
</tgroup>
</table>
</content5>
</subpara>
