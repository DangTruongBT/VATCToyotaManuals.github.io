<?xml version="1.0" encoding="UTF-8"?>
<tmc-service-inc>
<pub id="RM0251U">
<servcat id="30">
<name>ENGINE</name>
<section id="10024_S000E" variety="S000E">
<name>2AZ-FE STARTING</name>
<ttl id="10024_S000E_72Y90_T0092" variety="T0092">
<name>STARTER</name>
<para id="RM0000025U0000X" category="A" type-id="80001" name-id="ST0WO-01" from="200601">
<name>REMOVAL</name>
<subpara id="RM0000025U0000X_01" type-id="01" category="01">
<s-1 id="RM0000025U0000X_01_0001">
<ptxt>DISCONNECT CABLE FROM NEGATIVE BATTERY TERMINAL</ptxt>
</s-1>
<s-1 id="RM0000025U0000X_01_0008" proc-id="RM0250U___0000A7U00000">
<ptxt>REMOVE AIR CLEANER INLET ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Remove the 2 bolts, clamp and air cleaner inlet.</ptxt>
<figure>
<graphic graphicname="A134903" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1></s-1>
<s-1 id="RM0000025U0000X_01_0009" proc-id="RM0250U___0000B9500000">
<ptxt>REMOVE AIR CLEANER CAP SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the mass air flow meter connector (<sup>*</sup>1).</ptxt>
<figure>
<graphic graphicname="A135666E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Disconnect the purge VSV connector (<sup>*</sup>2).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the 2 purge VSV vacuum hoses (<sup>*</sup>3).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the purge line hose from the clamp (<sup>*</sup>4).</ptxt>
</s2>
<s2>
<ptxt>Disconnect the No. 2 ventilation hose from the air cleaner hose.</ptxt>
<figure>
<graphic graphicname="A135667E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Lock the No. 1 air cleaner hose clamp, and then disconnect the No. 1 air cleaner hose from the throttle body.</ptxt>
<figure>
<graphic graphicname="A135668" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 2 bolts and air cleaner cap.</ptxt>
<figure>
<graphic graphicname="A135669" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the air cleaner filter element from the air cleaner case.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000025U0000X_01_0010" proc-id="RM0250U___0000A7V00000">
<ptxt>REMOVE AIR CLEANER CASE SUB-ASSEMBLY
</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the hose clamp.</ptxt>
<figure>
<graphic graphicname="A134905" width="2.775699831in" height="2.775699831in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the 3 bolts and air cleaner case.</ptxt>
</s2>
</content1></s-1>
<s-1 id="RM0000025U0000X_01_0004" proc-id="RM0250U___000063I00000">
<ptxt>REMOVE STARTER ASSEMBLY (for Manual Transaxle)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the terminal 50 connector from the starter assembly.</ptxt>
<figure>
<graphic graphicname="A133565" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the nut and disconnect the wire harness from terminal 30.</ptxt>
</s2>
<s2>
<ptxt>Remove the 3 bolts, clutch flexible hose bracket and starter assembly.</ptxt>
<figure>
<graphic graphicname="A133566E01" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
<s-1 id="RM0000025U0000X_01_0005" proc-id="RM0250U___00006C100000">
<ptxt>REMOVE STARTER ASSEMBLY (for Automatic Transaxle)</ptxt>
<content1 releasenbr="1">
<s2>
<ptxt>Disconnect the terminal 50 connector from the starter assembly.</ptxt>
<figure>
<graphic graphicname="A134876" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
<s2>
<ptxt>Remove the nut and disconnect the wire harness from terminal 30.</ptxt>
</s2>
<s2>
<ptxt>Remove the 2 bolts and starter assembly.</ptxt>
<figure>
<graphic graphicname="A134877" width="2.775699831in" height="1.771723296in"/>
</figure>
</s2>
</content1>
</s-1>
</subpara>
</para>
</ttl>
</section>
</servcat>
</pub>
</tmc-service-inc>